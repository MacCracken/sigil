# ed25519_bug.tcyr — Ed25519 RFC 8032 test vector verification
#
# STATUS: ALL PASS
# - Keypair: correct pk from seed
# - Sign: byte-exact RFC 8032 test vector 1 signature
# - Verify: sign+verify roundtrip passes
#
# Bugs fixed during development:
# - u256_sub borrow propagation (bigint.cyr): limbs 1,2 of p = 0xFF..FF lost borrow
# - sc_reduce constant off-by-one: r256modL ended in 951c, should be 951d
# - sc_reduce truncated: only 2 levels of reduction, needed iterative (~64 iters)

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"

include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "lib/ct.cyr"
include "src/ct.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"

fn main() {
    alloc_init();
    ed25519_init();

    # RFC 8032 Test Vector 1
    test_group("keypair");
    var seed = hex_decode("9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60", 64);
    var sk = alloc(64);
    var pk = alloc(32);
    ed25519_keypair(seed, sk, pk);
    var pk_hex = hex_encode(pk, 32);
    assert_streq(pk_hex, "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a", "pk correct");

    test_group("sign");
    var sig = alloc(64);
    ed25519_sign(sk, "", 0, sig);
    var sig_hex = hex_encode(sig, 64);
    syscall(1, 1, "sig R: ", 7);
    syscall(1, 1, sig_hex, 64);
    syscall(1, 1, "\nsig S: ", 7);
    syscall(1, 1, sig_hex + 64, 64);
    syscall(1, 1, "\n", 1);

    test_group("verify own sig");
    var valid = ed25519_verify(pk, "", 0, sig);
    assert_eq(valid, 1, "self-verify passes");

    test_group("roundtrip");
    var rsk = alloc(64);
    var rpk = alloc(32);
    ed25519_generate_keypair(rsk, rpk);
    var rsig = alloc(64);
    ed25519_sign(rsk, "test", 4, rsig);
    var rvalid = ed25519_verify(rpk, "test", 4, rsig);
    assert_eq(rvalid, 1, "roundtrip valid");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
