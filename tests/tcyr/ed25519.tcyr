# ed25519.tcyr — Ed25519 tests with RFC 8032 test vectors

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"

include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/ct.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"

fn main() {
    alloc_init();

    # ============================================================
    # RFC 8032 Test Vector 1
    # ============================================================
    test_group("ed25519 keypair");
    var seed = hex_decode("9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60", 64);
    var sk = alloc(64);
    var pk = alloc(32);
    ed25519_keypair(seed, sk, pk);

    var pk_hex = hex_encode(pk, 32);
    assert_streq(pk_hex, "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a", "pk matches rfc8032");

    test_group("ed25519 sign empty");
    var sig = alloc(64);
    ed25519_sign(sk, "", 0, sig);

    var sig_hex = hex_encode(sig, 64);
    assert_streq(sig_hex, "e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b", "sig matches rfc8032 TEST 1");

    test_group("ed25519 verify");
    var valid = ed25519_verify(pk, "", 0, sig);
    assert_eq(valid, 1, "valid signature");

    # Tamper with signature
    test_group("ed25519 reject tampered");
    store8(sig, (load8(sig) & 0xFF) ^ 1);
    var invalid = ed25519_verify(pk, "", 0, sig);
    assert_eq(invalid, 0, "tampered sig rejected");

    # ============================================================
    # RFC 8032 §7.1 TEST 2 — 1-byte message
    # ============================================================
    test_group("rfc8032 TEST 2");
    var seed2 = hex_decode("4ccd089b28ff96da9db6c346ec114e0f5b8a319f35aba624da8cf6ed4fb8a6fb", 64);
    var sk2 = alloc(64);
    var pk2 = alloc(32);
    ed25519_keypair(seed2, sk2, pk2);
    var pk2_hex = hex_encode(pk2, 32);
    assert_streq(pk2_hex, "3d4017c3e843895a92b70aa74d1b7ebc9c982ccf2ec4968cc0cd55f12af4660c", "TEST 2 pk");

    var msg2 = hex_decode("72", 2);
    var sig2 = alloc(64);
    ed25519_sign(sk2, msg2, 1, sig2);
    var sig2_hex = hex_encode(sig2, 64);
    assert_streq(sig2_hex, "92a009a9f0d4cab8720e820b5f642540a2b27b5416503f8fb3762223ebdb69da085ac1e43e15996e458f3613d0f11d8c387b2eaeb4302aeeb00d291612bb0c00", "TEST 2 sig");

    var valid2 = ed25519_verify(pk2, msg2, 1, sig2);
    assert_eq(valid2, 1, "TEST 2 verify");

    # ============================================================
    # RFC 8032 §7.1 TEST 3 — 2-byte message
    # ============================================================
    test_group("rfc8032 TEST 3");
    var seed3 = hex_decode("c5aa8df43f9f837bedb7442f31dcb7b166d38535076f094b85ce3a2e0b4458f7", 64);
    var sk3 = alloc(64);
    var pk3 = alloc(32);
    ed25519_keypair(seed3, sk3, pk3);
    var pk3_hex = hex_encode(pk3, 32);
    assert_streq(pk3_hex, "fc51cd8e6218a1a38da47ed00230f0580816ed13ba3303ac5deb911548908025", "TEST 3 pk");

    var msg3 = hex_decode("af82", 4);
    var sig3 = alloc(64);
    ed25519_sign(sk3, msg3, 2, sig3);
    var sig3_hex = hex_encode(sig3, 64);
    assert_streq(sig3_hex, "6291d657deec24024827e69c3abe01a30ce548a284743a445e3680d7db5ac3ac18ff9b538d16f290ae67f760984dc6594a7c15e9716ed28dc027beceea1ec40a", "TEST 3 sig");

    var valid3 = ed25519_verify(pk3, msg3, 2, sig3);
    assert_eq(valid3, 1, "TEST 3 verify");

    # ============================================================
    # RFC 8032 §7.1 TEST 1024 — 1023-byte message
    # Message lives in tests/data/rfc8032/test_1024.hex (2046 hex
    # chars, no newline). Loaded at runtime because a 2046-char
    # string literal is impractical to keep inline.
    # ============================================================
    test_group("rfc8032 TEST 1024");
    var seed1024 = hex_decode("f5e5767cf153319517630f226876b86c8160cc583bc013744c6bf255f5cc0ee5", 64);
    var sk1024 = alloc(64);
    var pk1024 = alloc(32);
    ed25519_keypair(seed1024, sk1024, pk1024);
    var pk1024_hex = hex_encode(pk1024, 32);
    assert_streq(pk1024_hex, "278117fc144c72340f67d0f2316e8386ceffbf2b2428c9c51fef7c597f1d426e", "TEST 1024 pk");

    # Read the 2046-char hex message fixture.
    var msg_hex = alloc(2048);
    var n_read = file_read_all("tests/data/rfc8032/test_1024.hex", msg_hex, 2048);
    assert_eq(n_read, 2046, "TEST 1024 fixture loaded");
    var msg1024 = hex_decode(msg_hex, 2046);

    var sig1024 = alloc(64);
    ed25519_sign(sk1024, msg1024, 1023, sig1024);
    var sig1024_hex = hex_encode(sig1024, 64);
    assert_streq(sig1024_hex, "0aab4c900501b3e24d7cdf4663326a3a87df5e4843b2cbdb67cbf6e460fec350aa5371b1508f9f4528ecea23c436d94b5e8fcd4f681e30a6ac00a9704a188a03", "TEST 1024 sig");

    var valid1024 = ed25519_verify(pk1024, msg1024, 1023, sig1024);
    assert_eq(valid1024, 1, "TEST 1024 verify");

    # ============================================================
    # Random keypair sign/verify roundtrip
    # ============================================================
    test_group("ed25519 roundtrip");
    var rsk = alloc(64);
    var rpk = alloc(32);
    ed25519_generate_keypair(rsk, rpk);

    var rsig = alloc(64);
    ed25519_sign(rsk, "hello world", 11, rsig);
    var rvalid = ed25519_verify(rpk, "hello world", 11, rsig);
    assert_eq(rvalid, 1, "roundtrip valid");

    # Wrong message
    var rwrong = ed25519_verify(rpk, "hello worle", 11, rsig);
    assert_eq(rwrong, 0, "wrong msg rejected");

    # ============================================================
    # ge_cmov branchless select (2.2.1 CT scalarmult primitive)
    # dst and src are 128 bytes; cmov must flip every byte iff bit==1.
    # ============================================================
    test_group("ge_cmov bit=0");
    var cm_dst = alloc(128);
    var cm_src = alloc(128);
    var i = 0;
    while (i < 128) {
        store8(cm_dst + i, 0xAA);
        store8(cm_src + i, 0x55);
        i = i + 1;
    }
    ge_cmov(cm_dst, cm_src, 0);
    var ok0 = 1;
    i = 0;
    while (i < 128) {
        if ((load8(cm_dst + i) & 0xFF) != 0xAA) { ok0 = 0; }
        i = i + 1;
    }
    assert_eq(ok0, 1, "bit=0 leaves dst untouched");

    test_group("ge_cmov bit=1");
    ge_cmov(cm_dst, cm_src, 1);
    var ok1 = 1;
    i = 0;
    while (i < 128) {
        if ((load8(cm_dst + i) & 0xFF) != 0x55) { ok1 = 0; }
        i = i + 1;
    }
    assert_eq(ok1, 1, "bit=1 copies src to dst");

    test_group("ge_cmov bit=1 same-value");
    # When dst already equals src, any bit must leave dst equal.
    ge_cmov(cm_dst, cm_src, 1);
    var oks = 1;
    i = 0;
    while (i < 128) {
        if ((load8(cm_dst + i) & 0xFF) != 0x55) { oks = 0; }
        i = i + 1;
    }
    assert_eq(oks, 1, "bit=1 same-value stable");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
