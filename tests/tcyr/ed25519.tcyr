# ed25519.tcyr — Ed25519 tests with RFC 8032 test vectors

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"

include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/ct.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"

fn main() {
    alloc_init();

    # ============================================================
    # RFC 8032 Test Vector 1
    # ============================================================
    test_group("ed25519 keypair");
    var seed = hex_decode("9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60", 64);
    var sk = alloc(64);
    var pk = alloc(32);
    ed25519_keypair(seed, sk, pk);

    var pk_hex = hex_encode(pk, 32);
    assert_streq(pk_hex, "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a", "pk matches rfc8032");

    test_group("ed25519 sign empty");
    var sig = alloc(64);
    ed25519_sign(sk, "", 0, sig);

    var sig_hex = hex_encode(sig, 64);
    syscall(1, 1, "sig: ", 5);
    syscall(1, 1, sig_hex, 128);
    syscall(1, 1, "\n", 1);

    test_group("ed25519 verify");
    var valid = ed25519_verify(pk, "", 0, sig);
    assert_eq(valid, 1, "valid signature");

    # Tamper with signature
    test_group("ed25519 reject tampered");
    store8(sig, (load8(sig) & 0xFF) ^ 1);
    var invalid = ed25519_verify(pk, "", 0, sig);
    assert_eq(invalid, 0, "tampered sig rejected");

    # ============================================================
    # Random keypair sign/verify roundtrip
    # ============================================================
    test_group("ed25519 roundtrip");
    var rsk = alloc(64);
    var rpk = alloc(32);
    ed25519_generate_keypair(rsk, rpk);

    var rsig = alloc(64);
    ed25519_sign(rsk, "hello world", 11, rsig);
    var rvalid = ed25519_verify(rpk, "hello world", 11, rsig);
    assert_eq(rvalid, 1, "roundtrip valid");

    # Wrong message
    var rwrong = ed25519_verify(rpk, "hello worle", 11, rsig);
    assert_eq(rwrong, 0, "wrong msg rejected");

    # ============================================================
    # ge_cmov branchless select (2.2.1 CT scalarmult primitive)
    # dst and src are 128 bytes; cmov must flip every byte iff bit==1.
    # ============================================================
    test_group("ge_cmov bit=0");
    var cm_dst = alloc(128);
    var cm_src = alloc(128);
    var i = 0;
    while (i < 128) {
        store8(cm_dst + i, 0xAA);
        store8(cm_src + i, 0x55);
        i = i + 1;
    }
    ge_cmov(cm_dst, cm_src, 0);
    var ok0 = 1;
    i = 0;
    while (i < 128) {
        if ((load8(cm_dst + i) & 0xFF) != 0xAA) { ok0 = 0; }
        i = i + 1;
    }
    assert_eq(ok0, 1, "bit=0 leaves dst untouched");

    test_group("ge_cmov bit=1");
    ge_cmov(cm_dst, cm_src, 1);
    var ok1 = 1;
    i = 0;
    while (i < 128) {
        if ((load8(cm_dst + i) & 0xFF) != 0x55) { ok1 = 0; }
        i = i + 1;
    }
    assert_eq(ok1, 1, "bit=1 copies src to dst");

    test_group("ge_cmov bit=1 same-value");
    # When dst already equals src, any bit must leave dst equal.
    ge_cmov(cm_dst, cm_src, 1);
    var oks = 1;
    i = 0;
    while (i < 128) {
        if ((load8(cm_dst + i) & 0xFF) != 0x55) { oks = 0; }
        i = i + 1;
    }
    assert_eq(oks, 1, "bit=1 same-value stable");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
