# bignum_tls12_concurrent.tcyr — race-detector for the 3.9.7 banking of
# the RSA bignum engine (src/bignum.cyr Montgomery modexp) and the TLS 1.2
# PRF (src/tls12_prf.cyr). Both kept per-call scratch in module-static /
# `secret var` arrays (function-scope statics, quirk #1) shared across
# threads. Off the TLS 1.3 server path (RSA rejected by tls_native; 1.3
# does not use the 1.2 PRF), so this is the lowest-priority banking — done
# for completeness. Each worker recomputes its slot's modexp + PRF many
# times on a distinct bank; a lane overlap corrupts the result vs the
# serial (bank-0) reference.

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/ct.cyr"
include "lib/thread.cyr"
include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/hmac.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/hmac_sha384.cyr"
include "src/bignum.cyr"
include "src/tls12_prf.cyr"

var _bg_n = 0;   # modulus (bignum limb form, read-only)
var _bg_b = 0;   # base    (bignum limb form, read-only)
var _bg_e = 0;   # exponent 65537 (BE bytes, read-only)
var _bg_out = 0; # NA × 64  worker-written modexp results
var _pf_seed = 0;     # 16 B shared seed (read-only)
var _pf_secrets = 0;  # NA × 16  distinct per-worker PRF secrets
var _pf_out = 0;      # NA × 48  worker-written PRF outputs

fn _b4_worker(arg): i64 {
    var bank = load64(arg + 0);
    var idx  = load64(arg + 8);
    crypto_bank_set(bank);
    var rep = 0;
    while (rep < 6) {
        bn_mont_modexp(_bg_out + idx * 64, _bg_b, _bg_e, 3, _bg_n, 4);
        tls12_prf_sha256(_pf_secrets + idx * 16, 16, "test label", 10, _pf_seed, 16, _pf_out + idx * 48, 48);
        rep = rep + 1;
    }
    return 0;
}

fn main() {
    alloc_init();
    crypto_tls_main_init();

    var N = 8;                       # banks 1..8

    # 256-bit modexp inputs (from bignum.tcyr KAT) — read-only.
    var n256 = hex_decode("c0ffee1234567890abcdef00112233445566778899aabbccddeeff0102030405", 64);
    var b256 = hex_decode("0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef", 64);
    _bg_e = hex_decode("010001", 6);
    _bg_n = alloc(64); _bg_b = alloc(64);
    bn_from_be(_bg_n, 4, n256, 32);
    bn_from_be(_bg_b, 4, b256, 32);
    _bg_out = alloc(N * 64);
    var exp_modexp = alloc(64);
    bn_mont_modexp(exp_modexp, _bg_b, _bg_e, 3, _bg_n, 4);   # serial reference

    # PRF inputs — distinct per-worker secret, shared seed.
    _pf_seed = alloc(16); memset(_pf_seed, 0x5A, 16);
    _pf_secrets = alloc(N * 16);
    _pf_out = alloc(N * 48);
    var exp_prf = alloc(N * 48);
    var i = 0;
    while (i < N) {
        var k = 0;
        while (k < 16) { store8(_pf_secrets + i * 16 + k, (i * 31 + k * 3 + 1) & 0xFF); k = k + 1; }
        tls12_prf_sha256(_pf_secrets + i * 16, 16, "test label", 10, _pf_seed, 16, exp_prf + i * 48, 48);
        i = i + 1;
    }

    var args = alloc(N * 16);
    var ths  = alloc(N * 8);
    i = 0;
    while (i < N) {
        store64(args + i * 16 + 0, i + 1);
        store64(args + i * 16 + 8, i);
        store64(ths + i * 8, thread_create(&_b4_worker, args + i * 16));
        i = i + 1;
    }
    i = 0;
    while (i < N) { thread_join(load64(ths + i * 8)); i = i + 1; }

    test_group("bignum + tls12_prf banking — concurrent == serial");
    var mod_bad = 0;
    var prf_bad = 0;
    i = 0;
    while (i < N) {
        if (ct_eq_bytes(_bg_out + i * 64, exp_modexp, 32) == 0) { mod_bad = mod_bad + 1; }
        if (ct_eq_bytes(_pf_out + i * 48, exp_prf + i * 48, 48) == 0) { prf_bad = prf_bad + 1; }
        i = i + 1;
    }
    assert_eq(mod_bad, 0, "8 concurrent bn_mont_modexp workers (banks 1-8) match serial");
    assert_eq(prf_bad, 0, "8 concurrent tls12_prf workers (banks 1-8) match serial");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
