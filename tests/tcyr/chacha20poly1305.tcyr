# chacha20poly1305.tcyr — ChaCha20-Poly1305 AEAD (RFC 8439 §2.8)
#
# Vectors:
#   1. RFC 8439 §2.8.2 — the published AEAD vector. Key 80..9f,
#      nonce 07:00:00:00 || 40..47, AAD 50:51:52:53:c0..c7, the
#      114-byte sunscreen plaintext → published ciphertext + tag.
#      Anchors the whole composition: Poly1305 key-gen from the
#      ChaCha20 counter-0 block, encryption from counter 1, and the
#      aad||pad||ct||pad||le64||le64 mac-data layout.
#   2. Round-trip — decrypt returns ERR_NONE and recovers the
#      plaintext.
#   3. Tamper — a single flipped ciphertext byte must fail tag
#      verification (ERR_INTEGRITY_MISMATCH) and withhold plaintext.

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/crypto_scratch.cyr"
include "src/hex.cyr"
include "src/poly1305.cyr"
include "src/chacha20.cyr"
include "src/chacha20poly1305.cyr"

fn main() {
    alloc_init();

    var key[32];
    hex_decode_into("808182838485868788898a8b8c8d8e8f909192939495969798999a9b9c9d9e9f", 64, &key);
    var nonce[12];
    hex_decode_into("070000004041424344454647", 24, &nonce);
    var aad[12];
    hex_decode_into("50515253c0c1c2c3c4c5c6c7", 24, &aad);
    var pt = "Ladies and Gentlemen of the class of '99: If I could offer you only one tip for the future, sunscreen would be it.";

    # ============================================================
    # RFC 8439 §2.8.2 — encrypt
    # ============================================================
    test_group("ChaCha20-Poly1305 §2.8.2 encrypt");
    var ct[114];
    var tag[16];
    chacha20poly1305_encrypt(&key, &nonce, &aad, 12, pt, 114, &ct, &tag);
    assert_streq(hex_encode(&ct, 114),
        "d31a8d34648e60db7b86afbc53ef7ec2a4aded51296e08fea9e2b5a736ee62d63dbea45e8ca9671282fafb69da92728b1a71de0a9e060b2905d6a5b67ecd3b3692ddbd7f2d778b8c9803aee328091b58fab324e4fad675945585808b4831d7bc3ff4def08e4b7a9de576d26586cec64b6116",
        "rfc8439 2.8.2 ciphertext");
    assert_streq(hex_encode(&tag, 16), "1ae10b594f09e26a7e902ecbd0600691", "rfc8439 2.8.2 tag");

    # ============================================================
    # Round-trip decrypt
    # ============================================================
    test_group("ChaCha20-Poly1305 decrypt round-trip");
    var back[114];
    var r = chacha20poly1305_decrypt(&key, &nonce, &aad, 12, &ct, 114, &tag, &back);
    assert_eq(r, ERR_NONE, "decrypt returns ERR_NONE");
    assert_streq(hex_encode(&back, 114), hex_encode(pt, 114), "decrypt recovers plaintext");

    # ============================================================
    # Tamper — flip a ciphertext byte, expect tag rejection
    # ============================================================
    test_group("ChaCha20-Poly1305 tamper reject");
    store8(&ct, load8(&ct) ^ 0x01);
    var back2[114];
    var r2 = chacha20poly1305_decrypt(&key, &nonce, &aad, 12, &ct, 114, &tag, &back2);
    assert_eq(r2, ERR_INTEGRITY_MISMATCH, "tampered ciphertext rejected");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
