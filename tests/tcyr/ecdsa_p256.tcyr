# ecdsa_p256.tcyr — ECDSA P-256 verify, with field-arithmetic groundwork tests.
#
# Sigil 3.2.1 — first bite of the TEE attestation arc.
#
# Test groups (built up bottom-to-top, so a failure in field
# arithmetic surfaces before any signature-verify failure):
#   1. big-endian byte ⇄ u256 codec
#   2. p256_reduce — 512-bit → 256-bit mod p256
#   3. fp_p256_add / sub / neg / mul / sq
#   4. (later bites) Jacobian point ops, scalar mul, verify

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "lib/random.cyr"
include "src/random.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"

fn main() {
    alloc_init();
    _p256_init();

    # ============================================================
    # Group 1 — big-endian byte codec roundtrip
    # ============================================================
    test_group("u256 big-endian load/store roundtrip");

    # Known value: hex represents a 32-byte big-endian integer.
    # After load_be → store_be the bytes should match exactly.
    var be_bytes = hex_decode("6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296", 64);
    var dst_limbs = alloc(32);
    u256_load_be(dst_limbs, be_bytes);

    # The loaded value should compare equal to _p256_gx (initialised via
    # u256_from_hex which is big-endian by convention).
    assert_eq(u256_eq(dst_limbs, _p256_gx), 1, "load_be(gx_bytes) == gx");

    var roundtrip = alloc(32);
    u256_store_be(roundtrip, dst_limbs);
    var roundtrip_hex = hex_encode(roundtrip, 32);
    assert_streq(roundtrip_hex,
        "6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296",
        "store_be(load_be(gx)) == gx");

    # ============================================================
    # Group 2 — p256_reduce
    # ============================================================
    test_group("p256_reduce");

    # 2a: any value < p reduces to itself.
    # Pad a 256-bit value into the low half of a 512-bit buffer.
    var val512 = alloc(64);
    memset(val512, 0, 64);
    # Place the value 7 in the low limb.
    store64(val512, 7);
    var reduced = alloc(32);
    p256_reduce(reduced, val512);
    assert_eq(load64(reduced), 7,           "reduce(7) low limb");
    assert_eq(load64(reduced + 8), 0,       "reduce(7) limb 1");
    assert_eq(load64(reduced + 16), 0,      "reduce(7) limb 2");
    assert_eq(load64(reduced + 24), 0,      "reduce(7) limb 3");

    # 2b: p itself reduces to 0.
    memset(val512, 0, 64);
    store64(val512 + 0,  load64(_p256_p));
    store64(val512 + 8,  load64(_p256_p + 8));
    store64(val512 + 16, load64(_p256_p + 16));
    store64(val512 + 24, load64(_p256_p + 24));
    p256_reduce(reduced, val512);
    assert_eq(u256_is_zero(reduced), 1, "reduce(p) == 0");

    # 2c: p + 1 reduces to 1. Build p+1 properly (limb[0] of p is 0xFF..FF
    # so a naive `limb[0] + 1` drops the carry into limb[1] — use u256_add).
    memset(val512, 0, 64);
    var p_plus_one = u256_clone(_p256_p);
    u256_add(p_plus_one, p_plus_one, _p256_one);
    store64(val512 + 0,  load64(p_plus_one));
    store64(val512 + 8,  load64(p_plus_one + 8));
    store64(val512 + 16, load64(p_plus_one + 16));
    store64(val512 + 24, load64(p_plus_one + 24));
    p256_reduce(reduced, val512);
    assert_eq(load64(reduced), 1,     "reduce(p+1) low limb == 1");
    assert_eq(load64(reduced + 8), 0, "reduce(p+1) limb 1");
    assert_eq(load64(reduced + 16), 0, "reduce(p+1) limb 2");
    assert_eq(load64(reduced + 24), 0, "reduce(p+1) limb 3");

    # 2d: 2^256 ≡ 2^224 - 2^192 - 2^96 + 1  (mod p256)
    # i.e. the high half = 1, low half = 0. Expected reduction:
    #    (2^256 - p) = (2^224 - 2^192 - 2^96 + 1)
    # Big-endian hex (64 chars):
    #   limb[3] = 00000000fffffffe   high half of result
    #   limb[2] = ffffffffffffffff
    #   limb[1] = ffffffff00000000
    #   limb[0] = 0000000000000001   low half
    memset(val512, 0, 64);
    store64(val512 + 32, 1);
    p256_reduce(reduced, val512);
    var expected_2_256_modp = u256_from_hex(
        "00000000fffffffeffffffffffffffffffffffff000000000000000000000001");
    assert_eq(u256_eq(reduced, expected_2_256_modp), 1, "reduce(2^256) == 2^256 - p");

    # 2e: differential KAT (3.7.0) — the Solinas fast path (p256_reduce)
    # must agree byte-for-byte with the long-division reference
    # (_p256_reduce_longdiv) over 64 pseudo-random 512-bit inputs
    # (SHA-256 of a counter fills each half) plus edge cases.
    var ld = alloc(32);
    var ctr = alloc(8);
    var h = alloc(32);
    var ki = 0;
    var diffs = 0;
    while (ki < 64) {
        store64(ctr, ki);
        sha256(ctr, 8, h);
        memcpy(val512, h, 32);
        store64(ctr, ki + 1000);
        sha256(ctr, 8, h);
        memcpy(val512 + 32, h, 32);
        p256_reduce(reduced, val512);
        _p256_reduce_longdiv(ld, val512);
        if (u256_eq(reduced, ld) == 0) { diffs = diffs + 1; }
        ki = ki + 1;
    }
    assert_eq(diffs, 0, "Solinas == long-div over 64 random 512-bit inputs");

    # Edge: all-ones (2^512 - 1).
    memset(val512, 0xFF, 64);
    p256_reduce(reduced, val512);
    _p256_reduce_longdiv(ld, val512);
    assert_eq(u256_eq(reduced, ld), 1, "Solinas == long-div for 2^512-1");

    # Edge: high half all-ones, low half zero.
    memset(val512, 0, 64);
    memset(val512 + 32, 0xFF, 32);
    p256_reduce(reduced, val512);
    _p256_reduce_longdiv(ld, val512);
    assert_eq(u256_eq(reduced, ld), 1, "Solinas == long-div for high-half all-ones");

    # 2f: field-inverse fixed addition chain (3.7.x) — the new
    # `fp_p256_inv` (a^(p-2) via 2^k-1 blocks) must agree byte-for-byte
    # with the generic Fermat reference `_fp_p256_inv_generic` over 64
    # pseudo-random field elements, AND satisfy a*inv ≡ 1 mod p directly
    # (the gold-standard check, independent of the reference).
    test_group("fp_p256_inv chain == generic + a*inv==1");
    var inv_chain = alloc(32);
    var inv_gen = alloc(32);
    var fa = alloc(32);
    var prod = alloc(32);
    var one_p = alloc(32);
    store64(one_p, 1); store64(one_p + 8, 0); store64(one_p + 16, 0); store64(one_p + 24, 0);
    var idiffs = 0;
    var inv_bad = 0;
    var kj = 0;
    while (kj < 64) {
        store64(ctr, kj + 50000);
        sha256(ctr, 8, h);
        memcpy(val512, h, 32);
        store64(ctr, kj + 60000);
        sha256(ctr, 8, h);
        memcpy(val512 + 32, h, 32);
        p256_reduce(fa, val512);            # fa = random field element in [0, p)
        fp_p256_inv(inv_chain, fa);
        _fp_p256_inv_generic(inv_gen, fa);
        if (u256_eq(inv_chain, inv_gen) == 0) { idiffs = idiffs + 1; }
        fp_p256_mul(prod, fa, inv_chain);   # fa * fa^-1 must be 1 (fa != 0 w.h.p.)
        if (u256_eq(prod, one_p) == 0) { inv_bad = inv_bad + 1; }
        kj = kj + 1;
    }
    assert_eq(idiffs, 0, "fp_p256_inv chain == generic over 64 random field elems");
    assert_eq(inv_bad, 0, "fp_p256_inv: a*inv ≡ 1 mod p over 64 random elems");

    # Edges: a = 1 (inv = 1) and a = p-1 (self-inverse, (p-1)^2 ≡ 1).
    fp_p256_inv(inv_chain, one_p);
    assert_eq(u256_eq(inv_chain, one_p), 1, "fp_p256_inv(1) == 1");
    var iv_pm1 = u256_clone(_p256_p);
    store64(iv_pm1, load64(iv_pm1) - 1);     # p - 1
    fp_p256_inv(inv_chain, iv_pm1);
    _fp_p256_inv_generic(inv_gen, iv_pm1);
    assert_eq(u256_eq(inv_chain, inv_gen), 1, "fp_p256_inv(p-1) chain == generic");
    fp_p256_mul(prod, iv_pm1, inv_chain);
    assert_eq(u256_eq(prod, one_p), 1, "fp_p256_inv(p-1): a*inv ≡ 1");

    # 2g: scalar-inverse 4-bit window (3.7.x) — the new `fn_p256_inv`
    # (a^(n-2) windowed) must agree byte-for-byte with the generic
    # reference `_fn_p256_inv_generic` over 64 pseudo-random scalars in
    # [0, n), AND satisfy a*inv ≡ 1 mod n directly.
    test_group("fn_p256_inv window == generic + a*inv==1 mod n");
    var sinv_chain = alloc(32);
    var sinv_gen = alloc(32);
    var sa = alloc(32);
    var sprod = alloc(32);
    var sdiffs = 0;
    var sbad = 0;
    var ks = 0;
    while (ks < 64) {
        store64(ctr, ks + 70000);
        sha256(ctr, 8, h);
        memcpy(val512, h, 32);
        store64(ctr, ks + 80000);
        sha256(ctr, 8, h);
        memcpy(val512 + 32, h, 32);
        n_reduce(sa, val512);               # sa = random scalar in [0, n)
        fn_p256_inv(sinv_chain, sa);
        _fn_p256_inv_generic(sinv_gen, sa);
        if (u256_eq(sinv_chain, sinv_gen) == 0) { sdiffs = sdiffs + 1; }
        fn_p256_mul(sprod, sa, sinv_chain); # sa * sa^-1 must be 1
        if (u256_eq(sprod, one_p) == 0) { sbad = sbad + 1; }
        ks = ks + 1;
    }
    assert_eq(sdiffs, 0, "fn_p256_inv window == generic over 64 random scalars");
    assert_eq(sbad, 0, "fn_p256_inv: a*inv ≡ 1 mod n over 64 random scalars");

    # 2h: mixed Jacobian+affine addition (3.7.x) — pt_add_mixed(P, Qaff)
    # must equal the general pt_add(P, Qjac) (both reduced to affine) over
    # 24 (P, Q) = (k1·G, k2·G) pairs with non-trivial Jacobian Z on P, plus
    # the two H==0 branches (P==Q → double; P==-Q → infinity).
    test_group("pt_add_mixed == pt_add (+ double / -Q edges)");
    var mG = pt_alloc();
    pt_from_affine(mG, _p256_gx, _p256_gy);
    var mP = pt_alloc();
    var mQ = pt_alloc();
    var mQj = pt_alloc();
    var mqx = alloc(32);  var mqy = alloc(32);
    var rgen = pt_alloc();  var rmix = pt_alloc();
    var rgx = alloc(32);  var rgy = alloc(32);
    var rmx = alloc(32);  var rmy = alloc(32);
    var mk1 = alloc(32);  var mk2 = alloc(32);
    var madd_diffs = 0;
    var mi = 1;
    while (mi <= 24) {
        memset(mk1, 0, 32); store64(mk1, mi);
        memset(mk2, 0, 32); store64(mk2, mi * 7 + 3);
        pt_scalarmul(mP, mk1, mG);          # P = k1·G (Jacobian, Z != 1)
        pt_scalarmul(mQ, mk2, mG);          # Q = k2·G
        pt_to_affine(mqx, mqy, mQ);         # Q in affine
        pt_from_affine(mQj, mqx, mqy);      # Q as Jacobian (Z = 1)
        pt_add(rgen, mP, mQj);
        pt_add_mixed(rmix, mP, mqx, mqy);
        pt_to_affine(rgx, rgy, rgen);
        pt_to_affine(rmx, rmy, rmix);
        var same = 1;
        if (u256_eq(rgx, rmx) == 0) { same = 0; }
        if (u256_eq(rgy, rmy) == 0) { same = 0; }
        if (same == 0) { madd_diffs = madd_diffs + 1; }
        mi = mi + 1;
    }
    assert_eq(madd_diffs, 0, "pt_add_mixed == pt_add over 24 (P,Q) pairs");

    # Edge: P == Q  →  pt_add_mixed must equal pt_double(P).
    memset(mk1, 0, 32); store64(mk1, 5);
    pt_scalarmul(mP, mk1, mG);              # P = 5·G
    pt_to_affine(mqx, mqy, mP);             # Q = affine(P)
    pt_add_mixed(rmix, mP, mqx, mqy);
    pt_double(rgen, mP);
    pt_to_affine(rgx, rgy, rgen);
    pt_to_affine(rmx, rmy, rmix);
    var dbl_ok = 1;
    if (u256_eq(rgx, rmx) == 0) { dbl_ok = 0; }
    if (u256_eq(rgy, rmy) == 0) { dbl_ok = 0; }
    assert_eq(dbl_ok, 1, "pt_add_mixed(P, affine(P)) == 2P");

    # Edge: P == -Q  (Q = (Px, p - Py))  →  result is the point at infinity.
    var negy = alloc(32);
    u256_sub(negy, _p256_p, mqy);           # p - Py
    pt_add_mixed(rmix, mP, mqx, negy);
    assert_eq(pt_is_infinity(rmix), 1, "pt_add_mixed(P, -P) == O");

    # 2i: the windowed + batch-inversion variable-point mul (3.7.17 lever 2b)
    # — p256_scalarmul_var(k, Qaff) must equal the trusted constant-time
    # Montgomery ladder pt_scalarmul(k, Qjac) (both reduced to affine) over
    # 16 (k, Q) pairs with random k ∈ [0, n) and Q = m·G. Validates the affine
    # Q-table + Montgomery batch inversion end-to-end against the reference.
    test_group("p256_scalarmul_var == pt_scalarmul (windowed + batch-inv)");
    var smv_ref = pt_alloc();
    var smv_new = pt_alloc();
    var smv_qj = pt_alloc();
    var smvx = alloc(32);  var smvy = alloc(32);
    var refx = alloc(32);  var refy = alloc(32);
    var newx = alloc(32);  var newy = alloc(32);
    var smk = alloc(32);   var smm = alloc(32);
    var smv_diffs = 0;
    var si = 1;
    while (si <= 16) {
        memset(smm, 0, 32); store64(smm, si * 3 + 1);
        pt_scalarmul(smv_qj, smm, mG);          # Q = m·G (Jacobian)
        pt_to_affine(smvx, smvy, smv_qj);       # Q affine
        pt_from_affine(smv_qj, smvx, smvy);     # Q as Jacobian (Z=1) for the ref
        store64(ctr, si + 90000); sha256(ctr, 8, h); memcpy(val512, h, 32);
        store64(ctr, si + 91000); sha256(ctr, 8, h); memcpy(val512 + 32, h, 32);
        n_reduce(smk, val512);                  # k ∈ [0, n)
        pt_scalarmul(smv_ref, smk, smv_qj);     # reference: CT ladder
        p256_scalarmul_var(smv_new, smk, smvx, smvy);   # new: window + batch-inv
        pt_to_affine(refx, refy, smv_ref);
        pt_to_affine(newx, newy, smv_new);
        var sok = 1;
        if (u256_eq(refx, newx) == 0) { sok = 0; }
        if (u256_eq(refy, newy) == 0) { sok = 0; }
        if (sok == 0) { smv_diffs = smv_diffs + 1; }
        si = si + 1;
    }
    assert_eq(smv_diffs, 0, "p256_scalarmul_var == pt_scalarmul over 16 (k,Q)");

    # 2j: Karatsuba u256_mul_full (3.7.17 lever 3) — the crown-jewel
    # 256×256→512 multiply under Ed25519 / X25519 / ECDSA. Must agree
    # byte-for-byte with `_u256_mul_full_schoolbook` over 200 pseudo-random
    # input pairs AND a battery of carry-boundary edges (all-ones halves
    # → aL+aH overflow, half-max, single-bit-128, 0). A carry bug = a wrong
    # product = signature mis-accept, so this gate is the security floor.
    test_group("Karatsuba u256_mul_full == schoolbook");
    var ka = alloc(32);  var kb = alloc(32);
    var kok = alloc(64); var ksc = alloc(64);
    var kdiffs = 0;
    var kn = 0;
    while (kn < 200) {
        store64(ctr, kn + 200000); sha256(ctr, 8, h); memcpy(ka, h, 32);
        store64(ctr, kn + 300000); sha256(ctr, 8, h); memcpy(kb, h, 32);
        u256_mul_full(kok, ka, kb);
        _u256_mul_full_schoolbook(ksc, ka, kb);
        var ci = 0;
        while (ci < 8) {
            if (load64(kok + ci * 8) != load64(ksc + ci * 8)) { kdiffs = kdiffs + 1; }
            ci = ci + 1;
        }
        kn = kn + 1;
    }
    assert_eq(kdiffs, 0, "Karatsuba == schoolbook over 200 random 256×256");

    # Carry-boundary edges (9 hand-picked + 5 from the 3.7.17 adversarial
    # carry-propagation review, each a maximal-stress case for a specific
    # carry path that the 5-lens audit flagged and proved correct).
    var kedge = 0;
    var ee = 0;
    while (ee < 14) {
        memset(ka, 0, 32); memset(kb, 0, 32);
        if (ee == 0) { memset(ka, 0xFF, 32); memset(kb, 0xFF, 32); }       # max × max (cs=ct=1)
        if (ee == 1) { memset(ka, 0xFF, 32); store64(kb, 1); }            # max × 1
        if (ee == 2) { memset(ka, 0xFF, 16); memset(kb, 0xFF, 16); }      # low-128 ones × low-128 ones
        if (ee == 3) { memset(ka + 16, 0xFF, 16); memset(kb + 16, 0xFF, 16); } # high-128 ones × high-128 ones
        if (ee == 4) { memset(ka, 0xFF, 16); memset(kb + 16, 0xFF, 16); } # aL ones × bH ones
        if (ee == 5) { store64(ka + 16, 1); store64(kb + 16, 1); }        # 2^128 × 2^128
        if (ee == 6) { memset(ka, 0xFF, 32); memset(kb, 0xFF, 16); }      # max × low-128 ones
        if (ee == 7) { store64(ka, 0 - 1); store64(kb, 0 - 1); }          # 2^64-1 × 2^64-1
        if (ee == 8) { memset(kb, 0xFF, 32); }                            # 0 × max
        # --- adversarial-review regressions ---
        if (ee == 9) {  # high128=max, low128=1: aL+aH = 2^128 exactly (cs=1 on the clean boundary)
            store64(ka, 1); memset(ka + 16, 0xFF, 16);
            store64(kb, 1); memset(kb + 16, 0xFF, 16);
        }
        if (ee == 10) { # every limb = 2^63: a1+a3 overflows to exactly 2^64 (cs/ct via the second-add carry)
            store64(ka, 1 << 63); store64(ka + 8, 1 << 63); store64(ka + 16, 1 << 63); store64(ka + 24, 1 << 63);
            store64(kb, 1 << 63); store64(kb + 8, 1 << 63); store64(kb + 16, 1 << 63); store64(kb + 24, 1 << 63);
        }
        if (ee == 11) { memset(ka, 0xAA, 32); memset(kb, 0x55, 32); }     # alternating 0xAA × 0x55 (dense mid-limb carries)
        if (ee == 12) { memset(ka, 0xFF, 32); store64(kb + 24, 1 << 63); } # max × 2^255 (lone carry rippling out[2]→out[7])
        if (ee == 13) { # each half = 2^128-2: maximal half-sums feeding the m4 corrections + out[7] ripple
            store64(ka, 0 - 2); store64(ka + 8, 0 - 1); store64(ka + 16, 0 - 2); store64(ka + 24, 0 - 1);
            store64(kb, 0 - 2); store64(kb + 8, 0 - 1); store64(kb + 16, 0 - 2); store64(kb + 24, 0 - 1);
        }
        u256_mul_full(kok, ka, kb);
        _u256_mul_full_schoolbook(ksc, ka, kb);
        var cj = 0;
        while (cj < 8) {
            if (load64(kok + cj * 8) != load64(ksc + cj * 8)) { kedge = kedge + 1; }
            cj = cj + 1;
        }
        ee = ee + 1;
    }
    assert_eq(kedge, 0, "Karatsuba == schoolbook over 14 carry-boundary + adversarial edges");

    # ============================================================
    # Group 3 — field arithmetic
    # ============================================================
    test_group("fp_p256_add / sub / neg");

    # 3a: 0 + 0 = 0
    var a = u256_zero();
    var b = u256_zero();
    var r = u256_zero();
    fp_p256_add(r, a, b);
    assert_eq(u256_is_zero(r), 1, "0 + 0 == 0");

    # 3b: 1 + 1 = 2
    store64(a, 1);
    store64(b, 1);
    fp_p256_add(r, a, b);
    assert_eq(load64(r), 2,        "1 + 1 == 2 (low limb)");
    assert_eq(load64(r + 8), 0,    "1 + 1 == 2 (limb 1)");

    # 3c: (p-1) + 1 = 0 mod p
    u256_copy(a, _p256_p);
    u256_sub(a, a, _p256_one);
    store64(b, 1);
    store64(b + 8, 0);
    store64(b + 16, 0);
    store64(b + 24, 0);
    fp_p256_add(r, a, b);
    assert_eq(u256_is_zero(r), 1, "(p-1) + 1 == 0 (mod p)");

    # 3d: 0 - 1 = p - 1
    store64(a, 0); store64(a + 8, 0); store64(a + 16, 0); store64(a + 24, 0);
    store64(b, 1); store64(b + 8, 0); store64(b + 16, 0); store64(b + 24, 0);
    fp_p256_sub(r, a, b);
    var pm1 = u256_clone(_p256_p);
    u256_sub(pm1, pm1, _p256_one);
    assert_eq(u256_eq(r, pm1), 1, "0 - 1 == p - 1 (mod p)");

    # 3e: -0 = 0
    fp_p256_neg(r, a);
    assert_eq(u256_is_zero(r), 1, "-0 == 0");

    # 3f: -1 = p - 1
    store64(a, 1); store64(a + 8, 0); store64(a + 16, 0); store64(a + 24, 0);
    fp_p256_neg(r, a);
    assert_eq(u256_eq(r, pm1), 1, "-1 == p - 1");

    test_group("fp_p256_mul / sq");

    # 3g: 1 * x = x for x = gx
    store64(a, 1); store64(a + 8, 0); store64(a + 16, 0); store64(a + 24, 0);
    fp_p256_mul(r, a, _p256_gx);
    assert_eq(u256_eq(r, _p256_gx), 1, "1 * gx == gx");

    # 3h: gx * 1 = gx
    fp_p256_mul(r, _p256_gx, a);
    assert_eq(u256_eq(r, _p256_gx), 1, "gx * 1 == gx");

    # 3i: 0 * gx = 0
    store64(a, 0);
    fp_p256_mul(r, a, _p256_gx);
    assert_eq(u256_is_zero(r), 1, "0 * gx == 0");

    # 3j: gx * gx (just check non-zero, non-equal to gx — basic sanity)
    fp_p256_sq(r, _p256_gx);
    assert_eq(u256_is_zero(r), 0,                "gx^2 != 0");
    assert_eq(u256_eq(r, _p256_gx), 0,           "gx^2 != gx");

    # 3k: curve-equation self-check — the base point G must satisfy
    #     gy^2 ≡ gx^3 - 3*gx + b   (mod p)
    # This single identity exercises mul, sq, add, sub, and reduction
    # together with constants we already trust (gx, gy, b are encoded
    # straight from FIPS 186-4). If reduction or the field op surface
    # is wrong anywhere, this test fails.
    test_group("base point on the curve");
    var lhs = u256_zero();        # gy^2
    var rhs = u256_zero();        # gx^3 - 3*gx + b
    var tmp = u256_zero();
    var three_gx = u256_zero();
    var two_gx = u256_zero();

    fp_p256_sq(lhs, _p256_gy);

    fp_p256_sq(tmp, _p256_gx);            # tmp = gx^2
    fp_p256_mul(rhs, tmp, _p256_gx);      # rhs = gx^3

    fp_p256_add(two_gx, _p256_gx, _p256_gx);
    fp_p256_add(three_gx, two_gx, _p256_gx);

    fp_p256_sub(rhs, rhs, three_gx);      # rhs = gx^3 - 3*gx
    fp_p256_add(rhs, rhs, _p256_b);       # rhs = gx^3 - 3*gx + b

    assert_eq(u256_eq(lhs, rhs), 1, "gy^2 == gx^3 - 3*gx + b (mod p)");

    # ============================================================
    # Group 4 — point arithmetic sanity
    # ============================================================
    test_group("point arithmetic");

    # Build G in Jacobian and round-trip back to affine — should recover (gx, gy).
    var G = pt_alloc();
    pt_from_affine(G, _p256_gx, _p256_gy);
    var ax = u256_zero();
    var ay = u256_zero();
    pt_to_affine(ax, ay, G);
    assert_eq(u256_eq(ax, _p256_gx), 1, "affine(G).x == gx");
    assert_eq(u256_eq(ay, _p256_gy), 1, "affine(G).y == gy");

    # 2G — compare against a published value.
    # From SEC 2 / NIST test vectors:
    #   2G.x = 7CF27B188D034F7E8A52380304B51AC3C08969E277F21B35A60B48FC47669978
    #   2G.y = 07775510DB8ED040293D9AC69F7430DBBA7DADE63CE982299E04B79D227873D1
    var G2 = pt_alloc();
    pt_double(G2, G);
    pt_to_affine(ax, ay, G2);
    # Compare via big-endian byte encoding — hex_encode reads bytes
    # left-to-right and the u256 LE limb layout would otherwise produce
    # a byte-reversed hex string.
    var ax_be = alloc(32);
    var ay_be = alloc(32);
    u256_store_be(ax_be, ax);
    u256_store_be(ay_be, ay);
    assert_streq(hex_encode(ax_be, 32),
        "7cf27b188d034f7e8a52380304b51ac3c08969e277f21b35a60b48fc47669978",
        "(2G).x matches published P-256 vector");
    assert_streq(hex_encode(ay_be, 32),
        "07775510db8ed040293d9ac69f7430dbba7dade63ce982299e04b79d227873d1",
        "(2G).y matches published P-256 vector");

    # G + G via pt_add should give the same as pt_double.
    var Gsum = pt_alloc();
    pt_add(Gsum, G, G);
    var bx = u256_zero(); var by = u256_zero();
    pt_to_affine(bx, by, Gsum);
    assert_eq(u256_eq(ax, bx), 1, "pt_add(G,G).x == pt_double(G).x");
    assert_eq(u256_eq(ay, by), 1, "pt_add(G,G).y == pt_double(G).y");

    # G + O == G (identity)
    var O = pt_alloc();
    pt_set_infinity(O);
    pt_add(Gsum, G, O);
    pt_to_affine(bx, by, Gsum);
    assert_eq(u256_eq(bx, _p256_gx), 1, "G + O == G (x)");
    assert_eq(u256_eq(by, _p256_gy), 1, "G + O == G (y)");

    # n * G == O (group order kills the base point)
    var nG = pt_alloc();
    pt_scalarmul(nG, _p256_n, G);
    assert_eq(pt_is_infinity(nG), 1, "n * G == O");

    # 1 * G == G
    var one = u256_clone(_p256_one);
    var oneG = pt_alloc();
    pt_scalarmul(oneG, one, G);
    pt_to_affine(bx, by, oneG);
    assert_eq(u256_eq(bx, _p256_gx), 1, "1 * G == G (x)");
    assert_eq(u256_eq(by, _p256_gy), 1, "1 * G == G (y)");

    # 2 * G == G + G
    var two = u256_clone(_p256_one);
    fp_p256_add(two, two, two);   # 2 in the scalar field — fine since 2 < n
    var twoG = pt_alloc();
    pt_scalarmul(twoG, two, G);
    pt_to_affine(bx, by, twoG);
    var bx_be = alloc(32);
    u256_store_be(bx_be, bx);
    assert_streq(hex_encode(bx_be, 32),
        "7cf27b188d034f7e8a52380304b51ac3c08969e277f21b35a60b48fc47669978",
        "2 * G via ladder matches 2G vector");

    # ============================================================
    # Group 4.5 — pt_is_on_curve (closes audit 2026-05-21 LOW-1)
    # ============================================================
    test_group("pt_is_on_curve");

    # G is on the curve.
    assert_eq(pt_is_on_curve(_p256_gx, _p256_gy), 1, "G is on curve");

    # The (0, 0) "infinity-like" affine pair is rejected.
    var zero = u256_zero();
    assert_eq(pt_is_on_curve(zero, zero), 0, "(0, 0) rejected");

    # (gx, gy + 1) is OFF the curve.
    var gy_plus_1 = u256_clone(_p256_gy);
    fp_p256_add(gy_plus_1, gy_plus_1, _p256_one);
    assert_eq(pt_is_on_curve(_p256_gx, gy_plus_1), 0, "(gx, gy+1) off-curve rejected");

    # Coordinate >= p is rejected (use p itself as x).
    assert_eq(pt_is_on_curve(_p256_p, _p256_gy), 0, "x == p rejected (out of range)");
    assert_eq(pt_is_on_curve(_p256_gx, _p256_p), 0, "y == p rejected (out of range)");

    # ============================================================
    # Group 5 — ECDSA verify (RFC 6979 Appendix A.2.5)
    # ============================================================
    test_group("ecdsa_p256_verify — RFC 6979 P-256/SHA-256");

    # Public key:
    #   Ux = 60FED4BA255A9D31C961EB74C6356D68C049B8923B61FA6CE669622E60F29FB6
    #   Uy = 7903FE1008B8BC99A41AE9E95628BC64F2F1B20C2D7E9F5177A3C294D4462299
    var pk = hex_decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299", 128);

    # Test 5a: message = "sample"
    #   r = EFD48B2AACB6A8FD1140DD9CD45E81D69D2C877B56AAF991C34D0EA84EAF3716
    #   s = F7CB1C942D657C41D436C7A1B6E29F65F3E900DBB9AFF4064DC4AB2F843ACDA8
    var sig1 = hex_decode("efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8", 128);
    assert_eq(ecdsa_p256_verify(pk, "sample", 6, sig1), 1,
        "RFC 6979 §A.2.5 sample-msg signature valid");

    # Test 5b: message = "test"
    #   r = F1ABB023518351CD71D881567B1EA663ED3EFCF6C5132B354F28D3B0B7D38367
    #   s = 019F4113742A2B14BD25926B49C649155F267E60D3814B4C0CC84250E46F0083
    var sig2 = hex_decode("f1abb023518351cd71d881567b1ea663ed3efcf6c5132b354f28d3b0b7d38367019f4113742a2b14bd25926b49c649155f267e60d3814b4c0cc84250e46f0083", 128);
    assert_eq(ecdsa_p256_verify(pk, "test", 4, sig2), 1,
        "RFC 6979 §A.2.5 test-msg signature valid");

    test_group("ecdsa_p256_verify — negative cases");

    # 5c: wrong message — same sig as 5a but msg = "Sample" (capital S)
    assert_eq(ecdsa_p256_verify(pk, "Sample", 6, sig1), 0,
        "modified message rejected");

    # 5d: flipped bit in r
    var sig_bad = alloc(64);
    memcpy(sig_bad, sig1, 64);
    store8(sig_bad, (load8(sig_bad) & 0xFF) ^ 0x01);
    assert_eq(ecdsa_p256_verify(pk, "sample", 6, sig_bad), 0,
        "flipped bit in r rejected");

    # 5e: flipped bit in s
    memcpy(sig_bad, sig1, 64);
    store8(sig_bad + 32, (load8(sig_bad + 32) & 0xFF) ^ 0x01);
    assert_eq(ecdsa_p256_verify(pk, "sample", 6, sig_bad), 0,
        "flipped bit in s rejected");

    # 5f: r = 0
    memcpy(sig_bad, sig1, 64);
    memset(sig_bad, 0, 32);
    assert_eq(ecdsa_p256_verify(pk, "sample", 6, sig_bad), 0,
        "r == 0 rejected");

    # 5g: s = 0
    memcpy(sig_bad, sig1, 64);
    memset(sig_bad + 32, 0, 32);
    assert_eq(ecdsa_p256_verify(pk, "sample", 6, sig_bad), 0,
        "s == 0 rejected");

    # 5h: r = n (out of range)
    memcpy(sig_bad, sig1, 64);
    u256_store_be(sig_bad, _p256_n);
    assert_eq(ecdsa_p256_verify(pk, "sample", 6, sig_bad), 0,
        "r == n rejected (out of range)");

    # 5i: s = n
    memcpy(sig_bad, sig1, 64);
    u256_store_be(sig_bad + 32, _p256_n);
    assert_eq(ecdsa_p256_verify(pk, "sample", 6, sig_bad), 0,
        "s == n rejected (out of range)");

    test_group("ecdsa_p256_verify_der — DER wrapper");

    # 5j: DER-encode sig1 and verify through the wrapper.
    # SEQUENCE { INTEGER r, INTEGER s }
    # r starts with 0xEF (high bit set) → DER 0x00 prefix needed → 33 B int
    # s starts with 0xF7 (high bit set) → DER 0x00 prefix needed → 33 B int
    # SEQUENCE body = 2 + 33 + 2 + 33 = 70 bytes
    # Whole DER = 0x30, 0x46 (=70), <body> → 72 bytes
    var sig_der = alloc(72);
    store8(sig_der, 0x30);
    store8(sig_der + 1, 70);
    store8(sig_der + 2, 0x02);
    store8(sig_der + 3, 33);
    store8(sig_der + 4, 0x00);
    memcpy(sig_der + 5, sig1, 32);
    store8(sig_der + 37, 0x02);
    store8(sig_der + 38, 33);
    store8(sig_der + 39, 0x00);
    memcpy(sig_der + 40, sig1 + 32, 32);
    assert_eq(ecdsa_p256_verify_der(pk, "sample", 6, sig_der, 72), 1,
        "DER-encoded sig1 verifies");

    # 5k: malformed DER — wrong SEQUENCE tag
    store8(sig_der, 0x31);
    assert_eq(ecdsa_p256_verify_der(pk, "sample", 6, sig_der, 72), 0,
        "DER with wrong outer tag rejected");
    store8(sig_der, 0x30);    # restore

    # 5l: malformed DER — truncated
    assert_eq(ecdsa_p256_verify_der(pk, "sample", 6, sig_der, 5), 0,
        "truncated DER rejected");

    # ============================================================
    # Group 6 — off-diagonal: P-256 issuer key, SHA-384 hash.
    # FIPS 186-4 §6.4 leftmost-bits: the 48-byte digest is LONGER than the
    # 32-byte field, so e is its leftmost 32 bytes (the MSBs). Vector from
    # OpenSSL (P-256 key, ecdsa-with-SHA384), independently
    # `openssl dgst -sha384 -verify`-confirmed. Exercises the
    # `_ecdsa_p256_verify_digest` core that x509 off-diagonal chain-link
    # verify dispatches to.
    # ============================================================
    test_group("ecdsa_p256 off-diagonal — P-256 key / SHA-384 digest");

    var pkB = hex_decode("fbc7e7d4c340eab11516e1a6e566aa109ec4b4671949adc1481953ec496126b8817b604280b0d37200e5ad02afdec6acf5a922f1527bc8028632e12c176452fa", 128);
    var sigB = hex_decode("d4a01f2965d34d287ddfe15a38db7d240f9cc7641bd3ea9d7c7e02f82bdb35841efb5973c4aef869fb122cf88c277de91aa809938c952ab9335f4117f8bfb137", 128);
    var digB = hex_decode("6b15f1d2e9185279a9e2b97cdda95bff3c3a909f6a35338bae11fb02e0e9785d6747716ca2112142d3574b840deeb2ca", 96);

    assert_eq(_ecdsa_p256_verify_digest(pkB, digB, 48, sigB), 1,
        "P-256 key + SHA-384 digest (off-diagonal) verifies");

    # Tampered in the LEFTMOST 32 bytes (the bytes actually used) → reject.
    store8(digB, (load8(digB) & 0xFF) ^ 0x01);
    assert_eq(_ecdsa_p256_verify_digest(pkB, digB, 48, sigB), 0,
        "off-diagonal P-256/SHA-384: tampered MSB digest byte rejected");
    store8(digB, (load8(digB) & 0xFF) ^ 0x01);

    # Tampered signature (s) → reject.
    store8(sigB + 32, (load8(sigB + 32) & 0xFF) ^ 0x01);
    assert_eq(_ecdsa_p256_verify_digest(pkB, digB, 48, sigB), 0,
        "off-diagonal P-256/SHA-384: tampered s rejected");
    store8(sigB + 32, (load8(sigB + 32) & 0xFF) ^ 0x01);

    # Leftmost-bits truncation check: only the leftmost 32 bytes feed e,
    # so flipping a byte in the truncated-away TAIL (byte 40 of 48) must
    # still VERIFY — proving the mapping discards the low bits per spec.
    store8(digB + 40, (load8(digB + 40) & 0xFF) ^ 0x01);
    assert_eq(_ecdsa_p256_verify_digest(pkB, digB, 48, sigB), 1,
        "off-diagonal P-256/SHA-384: truncated-away tail byte does not affect e");
    store8(digB + 40, (load8(digB + 40) & 0xFF) ^ 0x01);

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
