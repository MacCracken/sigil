# x509_offdiag.tcyr — off-diagonal ECDSA chain-link verification.
#
# P1 roadmap item (docs/development/issues/2026-06-06-x509-off-diagonal
# -ecdsa-verify.md): a chain LINK whose signature HASH differs from the
# issuer key's CURVE. `_x509_verify_link` now picks the hash from the
# child's sig-algorithm OID and the curve/primitive from the issuer key
# INDEPENDENTLY, so all four {P-256,P-384} x {SHA-256,SHA-384} combos
# verify (FIPS 186-4 §6.4 maps the digest to the scalar). The two
# DIAGONAL combos are already covered (x509.tcyr / x509_p384.tcyr); this
# file covers the two OFF-DIAGONAL ones with real OpenSSL-issued certs,
# each independently confirmed with `openssl verify`.
#
# Chain C: P-384 CA signs a leaf with ecdsa-with-SHA256
#          -> off-diagonal: P-384 issuer + SHA-256 child (sig_len 96).
# Chain D: P-256 CA signs a leaf with ecdsa-with-SHA384
#          -> off-diagonal: P-256 issuer + SHA-384 child (sig_len 64).
# Chain D also pins the 3.7.x parse "point 3" width fix: a SHA-384 child
# signed by a P-256 issuer has 32-byte r,s and must store sig_len 64
# (not the 96 the old hash-derived width would have produced).

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/bignum.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"
include "src/ecdsa_p384.cyr"
include "src/x509.cyr"
include "src/rsa.cyr"

# Chain C — P-384 CA (self-signed SHA-256) signs a P-256 leaf with SHA-256.
var C_CA_LEN = 419;
var C_CA_HEX = "";
var C_LEAF_LEN = 408;
var C_LEAF_HEX = "";

# Chain D — P-256 CA (self-signed SHA-384) signs a P-256 leaf with SHA-384.
var D_CA_LEN = 359;
var D_CA_HEX = "";
var D_LEAF_LEN = 377;
var D_LEAF_HEX = "";

var NOW_IN_WINDOW = 1782518400;   # 2026-06-15, inside both certs' windows

fn main() {
    alloc_init();
    sakshi_set_level(SK_WARN);
    var inters = alloc(8);    # empty intermediates list (direct root->leaf)

    # ============================================================
    # Chain C — off-diagonal: P-384 issuer + SHA-256 child.
    # ============================================================
    test_group("off-diagonal link — P-384 issuer signs SHA-256 child");

    var c_ca = x509_cert_alloc();
    var c_leaf = x509_cert_alloc();
    assert_eq(x509_parse(hex_decode(C_CA_HEX, 2 * C_CA_LEN), C_CA_LEN, c_ca), 1, "C: P-384 CA parses");
    assert_eq(x509_cert_curve(c_ca), X509_CURVE_P384, "C: CA curve = P-384");
    assert_eq(x509_cert_is_ca(c_ca), 1, "C: CA basicConstraints CA:TRUE");
    assert_eq(x509_parse(hex_decode(C_LEAF_HEX, 2 * C_LEAF_LEN), C_LEAF_LEN, c_leaf), 1, "C: leaf parses");
    assert_eq(x509_cert_sig_algo(c_leaf), X509_SIG_ECDSA_SHA256, "C: leaf sig algo = ECDSA-SHA256");
    # P-384 issuer -> the parse must store the 48-byte r,s (sig_len 96).
    assert_eq(load64(c_leaf + 208), 96, "C: leaf sig_len = 96 (P-384 issuer width)");
    assert_eq(_x509_verify_link(c_leaf, c_ca), 1, "C: off-diagonal P-384/SHA-256 link verifies");
    assert_eq(x509_verify_chain(c_leaf, inters, 0, c_ca, NOW_IN_WINDOW), 1, "C: full chain verifies");

    # Tamper the stored signature -> reject.
    var c_sp = load64(c_leaf + 200);
    store8(c_sp + 10, (load8(c_sp + 10) & 0xFF) ^ 0x01);
    assert_eq(_x509_verify_link(c_leaf, c_ca), 0, "C: tampered signature rejected");
    store8(c_sp + 10, (load8(c_sp + 10) & 0xFF) ^ 0x01);   # restore

    # ============================================================
    # Chain D — off-diagonal: P-256 issuer + SHA-384 child.
    # ============================================================
    test_group("off-diagonal link — P-256 issuer signs SHA-384 child");

    var d_ca = x509_cert_alloc();
    var d_leaf = x509_cert_alloc();
    assert_eq(x509_parse(hex_decode(D_CA_HEX, 2 * D_CA_LEN), D_CA_LEN, d_ca), 1, "D: P-256 CA parses");
    assert_eq(x509_cert_curve(d_ca), X509_CURVE_P256, "D: CA curve = P-256");
    assert_eq(x509_cert_is_ca(d_ca), 1, "D: CA basicConstraints CA:TRUE");
    assert_eq(x509_parse(hex_decode(D_LEAF_HEX, 2 * D_LEAF_LEN), D_LEAF_LEN, d_leaf), 1, "D: leaf parses");
    assert_eq(x509_cert_sig_algo(d_leaf), X509_SIG_ECDSA_SHA384, "D: leaf sig algo = ECDSA-SHA384");
    # P-256 issuer -> 32-byte r,s -> sig_len 64 (the parse "point 3" fix;
    # the old SHA-384-derived width would have stored 96 and false-rejected).
    assert_eq(load64(d_leaf + 208), 64, "D: leaf sig_len = 64 (P-256 issuer width)");
    assert_eq(_x509_verify_link(d_leaf, d_ca), 1, "D: off-diagonal P-256/SHA-384 link verifies");
    assert_eq(x509_verify_chain(d_leaf, inters, 0, d_ca, NOW_IN_WINDOW), 1, "D: full chain verifies");

    # Tamper the stored signature -> reject.
    var d_sp = load64(d_leaf + 200);
    store8(d_sp + 10, (load8(d_sp + 10) & 0xFF) ^ 0x01);
    assert_eq(_x509_verify_link(d_leaf, d_ca), 0, "D: tampered signature rejected");
    store8(d_sp + 10, (load8(d_sp + 10) & 0xFF) ^ 0x01);   # restore

    # ============================================================
    # Cross-issuer negatives — wrong CA must reject (no false-accept
    # across the width/curve boundary).
    # ============================================================
    test_group("off-diagonal — wrong-issuer rejection");

    # C leaf (96-byte sig, P-384 issuer expected) against the D P-256 CA:
    # want_len for a P-256 issuer is 64, the stored sig_len is 96 -> reject.
    assert_eq(_x509_verify_link(c_leaf, d_ca), 0, "C leaf under P-256 CA rejected (width mismatch)");
    # D leaf (64-byte sig, P-256 issuer expected) against the C P-384 CA:
    # want_len for a P-384 issuer is 96, the stored sig_len is 64 -> reject.
    assert_eq(_x509_verify_link(d_leaf, c_ca), 0, "D leaf under P-384 CA rejected (width mismatch)");

    return assert_summary();
}
