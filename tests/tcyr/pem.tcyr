# pem.tcyr — PEM decoder tests.
#
# Sigil 3.5 — bite 1 of the TEE-attestation completion arc.
#
# Test fixtures: the existing root + leaf P-256 certs from
# `tests/tcyr/x509.tcyr` re-encoded as PEM (base64 + markers,
# 64-col line breaks). The decoder round-trip must reproduce the
# original DER bytes exactly so we can chain into x509_parse +
# x509_verify_chain.

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ecdsa_p256.cyr"
include "src/x509.cyr"
include "src/pem.cyr"

# ------------------------------------------------------------------
# Fixtures — generated 2026-05-22 by gen_pem_fixtures.py against the
# existing x509.tcyr root + leaf DER. The PEMs use the 64-col line
# break that `openssl x509` produces by default.
# ------------------------------------------------------------------

var ROOT_DER_HEX = "";
var ROOT_DER_LEN = 421;

var LEAF_DER_HEX = "";
var LEAF_DER_LEN = 413;

var ROOT_PEM_HEX = "";
var ROOT_PEM_LEN = 627;

var LEAF_PEM_HEX = "";
var LEAF_PEM_LEN = 615;

var CHAIN_PEM_HEX = "";
var CHAIN_PEM_LEN = 1242;

# Helper: byte-by-byte equality.
fn bytes_eq(a, b, len): i64 {
    var i = 0;
    while (i < len) {
        if ((load8(a + i) & 0xFF) != (load8(b + i) & 0xFF)) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn main() {
    alloc_init();
    _p256_init();

    var root_der = hex_decode(ROOT_DER_HEX, 2 * ROOT_DER_LEN);
    var leaf_der = hex_decode(LEAF_DER_HEX, 2 * LEAF_DER_LEN);
    var root_pem = hex_decode(ROOT_PEM_HEX, 2 * ROOT_PEM_LEN);
    var leaf_pem = hex_decode(LEAF_PEM_HEX, 2 * LEAF_PEM_LEN);
    var chain_pem = hex_decode(CHAIN_PEM_HEX, 2 * CHAIN_PEM_LEN);

    var chain[64];   # 4 entries × 16 bytes
    memset(&chain, 0, 64);

    # ============================================================
    # Group 1 — Single-cert decode (root)
    # ============================================================
    test_group("pem_decode_certs — single cert (root)");

    var n = pem_decode_certs(root_pem, ROOT_PEM_LEN, &chain, 4);
    assert_eq(n, 1, "root PEM decodes to 1 cert");
    var p0 = load64(&chain + 0);
    var l0 = load64(&chain + 8);
    assert_eq(l0, ROOT_DER_LEN, "root DER length matches");
    assert_eq(bytes_eq(p0, root_der, ROOT_DER_LEN), 1, "root DER bytes round-trip");

    # ============================================================
    # Group 2 — Single-cert decode (leaf)
    # ============================================================
    test_group("pem_decode_certs — single cert (leaf)");

    memset(&chain, 0, 64);
    n = pem_decode_certs(leaf_pem, LEAF_PEM_LEN, &chain, 4);
    assert_eq(n, 1, "leaf PEM decodes to 1 cert");
    var pL = load64(&chain + 0);
    var lL = load64(&chain + 8);
    assert_eq(lL, LEAF_DER_LEN, "leaf DER length matches");
    assert_eq(bytes_eq(pL, leaf_der, LEAF_DER_LEN), 1, "leaf DER bytes round-trip");

    # ============================================================
    # Group 3 — Multi-cert decode (chain)
    # ============================================================
    test_group("pem_decode_certs — chain (root then leaf)");

    memset(&chain, 0, 64);
    n = pem_decode_certs(chain_pem, CHAIN_PEM_LEN, &chain, 4);
    assert_eq(n, 2, "chain PEM decodes to 2 certs");

    var c0_ptr = load64(&chain + 0);
    var c0_len = load64(&chain + 8);
    var c1_ptr = load64(&chain + 16);
    var c1_len = load64(&chain + 24);
    assert_eq(c0_len, ROOT_DER_LEN, "chain[0] (root) DER length");
    assert_eq(c1_len, LEAF_DER_LEN, "chain[1] (leaf) DER length");
    assert_eq(bytes_eq(c0_ptr, root_der, ROOT_DER_LEN), 1, "chain[0] bytes match root DER");
    assert_eq(bytes_eq(c1_ptr, leaf_der, LEAF_DER_LEN), 1, "chain[1] bytes match leaf DER");

    # ============================================================
    # Group 4 — Decoded chain verifies via x509_verify_chain
    # ============================================================
    test_group("pem_decode_certs — round-trip through x509_verify_chain");

    var root_cert = x509_cert_alloc();
    assert_eq(x509_parse(c0_ptr, c0_len, root_cert), 1, "decoded root parses");

    var leaf_cert = x509_cert_alloc();
    assert_eq(x509_parse(c1_ptr, c1_len, leaf_cert), 1, "decoded leaf parses");

    var inters = alloc(0);
    assert_eq(x509_verify_chain(leaf_cert, inters, 0, root_cert, 1781481600), 1,
              "decoded leaf → root chain verifies (round-trip end-to-end)");

    # ============================================================
    # Group 5 — _into variant: caller-provided pool
    # ============================================================
    test_group("pem_decode_certs_into — caller pool");

    var pool[2048];
    memset(&pool, 0, 2048);
    memset(&chain, 0, 64);
    n = pem_decode_certs_into(chain_pem, CHAIN_PEM_LEN, &chain, 4, &pool, 2048);
    assert_eq(n, 2, "_into decodes 2 certs with caller-provided pool");
    # Pointers should land inside `pool`.
    var p_into = load64(&chain + 0);
    assert_eq(p_into >= &pool, 1, "_into entry pointer ≥ pool start");
    assert_eq(p_into + load64(&chain + 8) <= &pool + 2048, 1,
              "_into entry pointer + len within pool");

    # ============================================================
    # Group 6 — _into variant: pool too small
    # ============================================================
    test_group("pem_decode_certs_into — pool exhaustion");

    var tiny[64];
    memset(&tiny, 0, 64);
    memset(&chain, 0, 64);
    n = pem_decode_certs_into(chain_pem, CHAIN_PEM_LEN, &chain, 4, &tiny, 64);
    assert_eq(n, 0 - 1, "_into rejects when pool can't hold decoded DER");

    # ============================================================
    # Group 7 — max_certs enforcement
    # ============================================================
    test_group("pem_decode_certs — max_certs enforcement");

    memset(&chain, 0, 64);
    n = pem_decode_certs(chain_pem, CHAIN_PEM_LEN, &chain, 1);
    assert_eq(n, 0 - 1, "chain with 2 certs but max_certs=1 returns -1");

    memset(&chain, 0, 64);
    n = pem_decode_certs(root_pem, ROOT_PEM_LEN, &chain, 1);
    assert_eq(n, 1, "single cert with max_certs=1 returns 1");

    # ============================================================
    # Group 8 — Malformed input rejection
    # ============================================================
    test_group("pem_decode_certs — malformed inputs");

    # Empty input
    var empty = alloc(1);
    memset(&chain, 0, 64);
    assert_eq(pem_decode_certs(empty, 0, &chain, 4), 0 - 1, "empty input rejected");

    # No BEGIN marker
    var no_begin = "no markers here just garbage bytes";
    memset(&chain, 0, 64);
    assert_eq(pem_decode_certs(no_begin, 34, &chain, 4), 0 - 1,
              "input with no BEGIN marker rejected");

    # BEGIN but no END
    var no_end = alloc(50);
    memcpy(no_end, "-----BEGIN CERTIFICATE-----\nAAAA\n", 33);
    memset(&chain, 0, 64);
    assert_eq(pem_decode_certs(no_end, 33, &chain, 4), 0 - 1,
              "BEGIN without matching END rejected");

    # Invalid base64 char inside body
    var bad_b64 = alloc(80);
    memcpy(bad_b64, "-----BEGIN CERTIFICATE-----\nAAAA*AAAA\n-----END CERTIFICATE-----\n", 64);
    memset(&chain, 0, 64);
    assert_eq(pem_decode_certs(bad_b64, 64, &chain, 4), 0 - 1,
              "invalid base64 character rejected");

    # Empty body between markers
    var empty_body = alloc(80);
    memcpy(empty_body, "-----BEGIN CERTIFICATE-----\n-----END CERTIFICATE-----\n", 54);
    memset(&chain, 0, 64);
    assert_eq(pem_decode_certs(empty_body, 54, &chain, 4), 0 - 1,
              "empty body rejected");

    # Excess padding (three `=` in final quad)
    # 8 alphabet chars → 2 quads, but tail "===" is invalid.
    var bad_pad = alloc(80);
    memcpy(bad_pad, "-----BEGIN CERTIFICATE-----\nAAAA====\n-----END CERTIFICATE-----\n", 63);
    memset(&chain, 0, 64);
    assert_eq(pem_decode_certs(bad_pad, 63, &chain, 4), 0 - 1,
              "excess padding rejected");

    # Alphabet char after padding
    var pad_then_alpha = alloc(80);
    memcpy(pad_then_alpha, "-----BEGIN CERTIFICATE-----\nAAA=AAAA\n-----END CERTIFICATE-----\n", 63);
    memset(&chain, 0, 64);
    assert_eq(pem_decode_certs(pad_then_alpha, 63, &chain, 4), 0 - 1,
              "alphabet char following padding rejected");

    # ============================================================
    # Group 9 — Padding variants (0/1/2 chars), known-good
    # ============================================================
    test_group("pem_decode_certs — padding variants");

    # 0-pad (3-byte body). base64("foo") = "Zm9v"
    var pem0 = alloc(80);
    memcpy(pem0, "-----BEGIN CERTIFICATE-----\nZm9v\n-----END CERTIFICATE-----\n", 59);
    memset(&chain, 0, 64);
    n = pem_decode_certs(pem0, 59, &chain, 4);
    assert_eq(n, 1, "0-padding (3-byte body) decodes");
    var po = load64(&chain + 0);
    var lo = load64(&chain + 8);
    assert_eq(lo, 3, "decoded length = 3");
    assert_eq(load8(po) & 0xFF, 0x66, "byte[0] = 'f'");
    assert_eq(load8(po + 1) & 0xFF, 0x6F, "byte[1] = 'o'");
    assert_eq(load8(po + 2) & 0xFF, 0x6F, "byte[2] = 'o'");

    # 1-pad (2-byte body). base64("fo") = "Zm8="
    var pem1 = alloc(80);
    memcpy(pem1, "-----BEGIN CERTIFICATE-----\nZm8=\n-----END CERTIFICATE-----\n", 59);
    memset(&chain, 0, 64);
    n = pem_decode_certs(pem1, 59, &chain, 4);
    assert_eq(n, 1, "1-padding (2-byte body) decodes");
    assert_eq(load64(&chain + 8), 2, "decoded length = 2");
    var p1 = load64(&chain + 0);
    assert_eq(load8(p1) & 0xFF, 0x66, "byte[0] = 'f'");
    assert_eq(load8(p1 + 1) & 0xFF, 0x6F, "byte[1] = 'o'");

    # 2-pad (1-byte body). base64("f") = "Zg=="
    var pem2 = alloc(80);
    memcpy(pem2, "-----BEGIN CERTIFICATE-----\nZg==\n-----END CERTIFICATE-----\n", 59);
    memset(&chain, 0, 64);
    n = pem_decode_certs(pem2, 59, &chain, 4);
    assert_eq(n, 1, "2-padding (1-byte body) decodes");
    assert_eq(load64(&chain + 8), 1, "decoded length = 1");
    var p2 = load64(&chain + 0);
    assert_eq(load8(p2) & 0xFF, 0x66, "byte[0] = 'f'");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
