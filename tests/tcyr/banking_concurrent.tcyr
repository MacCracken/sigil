# banking_concurrent.tcyr — race-detector for the 3.8.0 ChaCha20 + X25519
# per-worker banking (src/crypto_scratch.cyr cbank() lanes).
#
# The banked working arrays (chacha20 st/ws/ks, x25519 W/ub/base) are
# Cyrius static function-scope globals (quirk #1). The banking widens each
# to SIGIL_CRYPTO_BANKS lanes and indexes by cbank(); distinct concurrent
# banks => disjoint lanes => no race. This test PROVES that: N worker
# threads (banks 1..N) each recompute a deterministic x25519 + chacha20
# result in a tight loop; if any two lanes overlapped (a banking bug) the
# concurrent results would be corrupted and differ from the serial (bank-0)
# reference. A serial KAT at bank 0 alone can't catch a wrong lane stride
# (offset 0 hides it) — only this non-zero-bank concurrent run does.

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/ct.cyr"
include "lib/thread.cyr"
include "lib/thread_local.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/crypto_scratch.cyr"
include "src/hex.cyr"
include "src/bigint_ext.cyr"
include "src/x25519.cyr"
include "src/chacha20.cyr"
include "src/poly1305.cyr"
include "src/chacha20poly1305.cyr"

var _bc_scalars   = 0;   # N × 32  x25519 scalars
var _bc_keys      = 0;   # N × 32  chacha keys
var _bc_nonce     = 0;   # 12 B    shared (read-only) nonce
var _bc_x_results = 0;   # N × 32  x25519 results (worker-written)
var _bc_c_results = 0;   # N × 64  chacha block results (worker-written)

# AEAD (3.9.7) — concurrent ChaCha20-Poly1305 encrypt/decrypt. Exercises
# the new streaming-Poly1305 banked state (src/poly1305.cyr _p1305_state)
# + the _cp_tag fl_alloc removal across distinct lanes.
var _ae_keys   = 0;   # N × 32
var _ae_nonces = 0;   # N × 12
var _ae_aad    = 0;   # N × 12
var _ae_pt     = 0;   # N × 64  plaintext
var _ae_ct     = 0;   # N × 64  ciphertext (worker-written)
var _ae_tags   = 0;   # N × 16  tags (worker-written)
var _ae_rec    = 0;   # N × 64  recovered plaintext (worker-written)
var _ae_drc    = 0;   # N × 8   decrypt return codes (worker-written)

# One worker: set its bank, then recompute its slot's x25519 + chacha20
# many times (widening the race window). No `var X[N]` locals here — those
# would themselves be shared statics; only the banked primitives + distinct
# result slots are touched.
fn _bc_worker(arg): i64 {
    var bank = load64(arg + 0);
    var idx  = load64(arg + 8);
    crypto_bank_set(bank);
    var rep = 0;
    while (rep < 40) {
        x25519_base(_bc_scalars + idx * 32, _bc_x_results + idx * 32);
        chacha20_block(_bc_keys + idx * 32, _bc_nonce, idx + 1, _bc_c_results + idx * 64);
        rep = rep + 1;
    }
    return 0;
}

# One AEAD worker: encrypt then decrypt-verify its own slot, many times.
# A cross-lane clobber of the streaming Poly1305 state would corrupt the
# tag (mismatch vs serial) or fail the decrypt round-trip.
fn _ae_worker(arg): i64 {
    var bank = load64(arg + 0);
    var idx  = load64(arg + 8);
    crypto_bank_set(bank);
    var rep = 0;
    while (rep < 40) {
        chacha20poly1305_encrypt(_ae_keys + idx * 32, _ae_nonces + idx * 12,
            _ae_aad + idx * 12, 12, _ae_pt + idx * 64, 64,
            _ae_ct + idx * 64, _ae_tags + idx * 16);
        var rc = chacha20poly1305_decrypt(_ae_keys + idx * 32, _ae_nonces + idx * 12,
            _ae_aad + idx * 12, 12, _ae_ct + idx * 64, 64,
            _ae_tags + idx * 16, _ae_rec + idx * 64);
        store64(_ae_drc + idx * 8, rc);
        rep = rep + 1;
    }
    return 0;
}

fn main() {
    alloc_init();
    crypto_tls_main_init();

    var N = 4;                       # workers on banks 1..4 (SIGIL_CRYPTO_BANKS=64)
    _bc_scalars   = alloc(N * 32);
    _bc_keys      = alloc(N * 32);
    _bc_nonce     = alloc(12);
    _bc_x_results = alloc(N * 32);
    _bc_c_results = alloc(N * 64);
    memset(_bc_nonce, 0, 12);
    var exp_x = alloc(N * 32);
    var exp_c = alloc(N * 64);

    # Distinct per-slot scalars/keys; serial (bank-0) reference results.
    var i = 0;
    while (i < N) {
        memset(_bc_scalars + i * 32, 0, 32);
        store8(_bc_scalars + i * 32, (i + 1) * 9 + 1);
        store8(_bc_scalars + i * 32 + 31, 0x40);
        memset(_bc_keys + i * 32, 0, 32);
        store8(_bc_keys + i * 32, (i + 1) * 13 + 7);
        x25519_base(_bc_scalars + i * 32, exp_x + i * 32);
        chacha20_block(_bc_keys + i * 32, _bc_nonce, i + 1, exp_c + i * 64);
        i = i + 1;
    }

    # Fan out: each worker on a distinct bank 1..N, computing its own slot.
    var args = alloc(N * 16);
    var ths  = alloc(N * 8);
    i = 0;
    while (i < N) {
        store64(args + i * 16 + 0, i + 1);   # bank
        store64(args + i * 16 + 8, i);       # slot index
        store64(ths + i * 8, thread_create(&_bc_worker, args + i * 16));
        i = i + 1;
    }
    i = 0;
    while (i < N) { thread_join(load64(ths + i * 8)); i = i + 1; }

    # Concurrent results must equal the serial reference, byte-for-byte.
    test_group("ChaCha20 + X25519 banking — concurrent == serial");
    var x_bad = 0;
    var c_bad = 0;
    i = 0;
    while (i < N) {
        if (ct_eq_bytes(_bc_x_results + i * 32, exp_x + i * 32, 32) == 0) { x_bad = x_bad + 1; }
        if (ct_eq_bytes(_bc_c_results + i * 64, exp_c + i * 64, 64) == 0) { c_bad = c_bad + 1; }
        i = i + 1;
    }
    assert_eq(x_bad, 0, "4 concurrent x25519 workers (banks 1-4) match serial");
    assert_eq(c_bad, 0, "4 concurrent chacha20 workers (banks 1-4) match serial");

    # ============================================================
    # AEAD (3.9.7) — concurrent ChaCha20-Poly1305 across banks 1..NA.
    # Each worker encrypts then decrypt-verifies its own distinct slot
    # in a tight loop; the streaming Poly1305 state (_p1305_state) is
    # banked per lane, so any lane overlap corrupts the tag (mismatch
    # vs the serial bank-0 reference) or breaks the decrypt round-trip.
    # ============================================================
    var NA = 8;                      # 8 lanes — exceeds the pre-3.9.6 cap
    _ae_keys   = alloc(NA * 32);
    _ae_nonces = alloc(NA * 12);
    _ae_aad    = alloc(NA * 12);
    _ae_pt     = alloc(NA * 64);
    _ae_ct     = alloc(NA * 64);
    _ae_tags   = alloc(NA * 16);
    _ae_rec    = alloc(NA * 64);
    _ae_drc    = alloc(NA * 8);
    var exp_tags = alloc(NA * 16);

    # Distinct per-slot inputs; serial (bank-0) reference tags.
    i = 0;
    while (i < NA) {
        var k = 0;
        while (k < 32) { store8(_ae_keys + i * 32 + k, (i * 7 + k * 3 + 1) & 0xFF); k = k + 1; }
        k = 0;
        while (k < 12) { store8(_ae_nonces + i * 12 + k, (i * 5 + k + 2) & 0xFF); k = k + 1; }
        k = 0;
        while (k < 12) { store8(_ae_aad + i * 12 + k, (i * 11 + k + 3) & 0xFF); k = k + 1; }
        k = 0;
        while (k < 64) { store8(_ae_pt + i * 64 + k, (i * 13 + k * 17 + 5) & 0xFF); k = k + 1; }
        # Serial reference tag for this slot (bank 0).
        chacha20poly1305_encrypt(_ae_keys + i * 32, _ae_nonces + i * 12,
            _ae_aad + i * 12, 12, _ae_pt + i * 64, 64,
            _ae_ct + i * 64, exp_tags + i * 16);
        i = i + 1;
    }

    var aargs = alloc(NA * 16);
    var aths  = alloc(NA * 8);
    i = 0;
    while (i < NA) {
        store64(aargs + i * 16 + 0, i + 1);   # bank 1..NA
        store64(aargs + i * 16 + 8, i);       # slot index
        store64(aths + i * 8, thread_create(&_ae_worker, aargs + i * 16));
        i = i + 1;
    }
    i = 0;
    while (i < NA) { thread_join(load64(aths + i * 8)); i = i + 1; }

    test_group("ChaCha20-Poly1305 AEAD banking — concurrent == serial");
    var tag_bad = 0;
    var rec_bad = 0;
    var drc_bad = 0;
    i = 0;
    while (i < NA) {
        if (ct_eq_bytes(_ae_tags + i * 16, exp_tags + i * 16, 16) == 0) { tag_bad = tag_bad + 1; }
        if (ct_eq_bytes(_ae_rec + i * 64, _ae_pt + i * 64, 64) == 0) { rec_bad = rec_bad + 1; }
        if (load64(_ae_drc + i * 8) != SIGIL_ERR_NONE) { drc_bad = drc_bad + 1; }
        i = i + 1;
    }
    assert_eq(tag_bad, 0, "8 concurrent AEAD workers (banks 1-8) tags match serial");
    assert_eq(rec_bad, 0, "8 concurrent AEAD workers decrypt-recover original plaintext");
    assert_eq(drc_bad, 0, "8 concurrent AEAD workers decrypt OK (tag verified)");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
