# rsa.tcyr -- RSA PKCS#1 v1.5 signature verification (RFC 8017).
#
# Real RSA-2048 key + signatures, generated with a pure-Python RSA
# (seeded keygen + manual PKCS#1 v1.5 encode; each signature self-
# checked `pow(s, e, n) == EM` at generation). e = 65537.
#   msg     = "sigil RSA PKCS#1 v1.5 KAT message"
#   verify SHA-256 signature -> 1
#   verify SHA-384 signature -> 1
#   tampered signature (last byte ^1) -> 0
#   correct sig over a different message -> 0
#   wrong signature length -> 0

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"
include "src/x509.cyr"
include "src/bignum.cyr"
include "src/rsa.cyr"

fn main() {
    alloc_init();

    var n = hex_decode("", 512);
    var e = hex_decode("010001", 6);
    var msg = hex_decode("736967696c2052534120504b435323312076312e35204b4154206d657373616765", 66);  # 33 bytes
    var sig256 = hex_decode("", 512);
    var sig384 = hex_decode("", 512);
    var sigbad = hex_decode("", 512);

    test_group("RSA PKCS#1 v1.5 verify");

    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, sig256, 256), 1,
        "valid SHA-256 signature accepted");
    assert_eq(rsa_pkcs1v15_verify_sha384(n, 256, e, 3, msg, 33, sig384, 256), 1,
        "valid SHA-384 signature accepted");

    test_group("RSA PKCS#1 v1.5 rejects");

    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, sigbad, 256), 0,
        "tampered signature rejected");
    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, "different message", 17, sig256, 256), 0,
        "valid sig over wrong message rejected");
    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, sig256, 255), 0,
        "wrong signature length rejected");
    # SHA-384 verify against a SHA-256 signature must fail (wrong DigestInfo).
    assert_eq(rsa_pkcs1v15_verify_sha384(n, 256, e, 3, msg, 33, sig256, 256), 0,
        "SHA-256 sig rejected by SHA-384 verify");

    # ============================================================
    # Public-key DER parsing (3.6.3a) -- parse then verify with the
    # extracted (n, e). DER generated from the same key.
    # ============================================================
    test_group("RSA pubkey DER parse");

    var np[512];
    var ep[16];
    var el[8];

    # PKCS#1 RSAPublicKey: SEQUENCE { INTEGER n, INTEGER e }  (270 bytes)
    var rsapub = hex_decode("", 540);
    var nl1 = rsa_pubkey_from_der(rsapub, 270, &np, 512, &ep, 16, &el);
    assert_eq(nl1, 256, "PKCS#1 pubkey: modulus length 256");
    assert_eq(load64(&el), 3, "PKCS#1 pubkey: exponent length 3");
    assert_eq(rsa_pkcs1v15_verify_sha256(&np, nl1, &ep, load64(&el), msg, 33, sig256, 256), 1,
        "verify with parsed PKCS#1 public key");

    # X.509 SubjectPublicKeyInfo (rsaEncryption)  (294 bytes)
    var spki = hex_decode("", 588);
    var nl2 = rsa_pubkey_from_der(spki, 294, &np, 512, &ep, 16, &el);
    assert_eq(nl2, 256, "SPKI pubkey: modulus length 256");
    assert_eq(rsa_pkcs1v15_verify_sha256(&np, nl2, &ep, load64(&el), msg, 33, sig256, 256), 1,
        "verify with parsed SPKI public key");

    # Malformed (truncated) DER is rejected.
    assert_eq(rsa_pubkey_from_der(rsapub, 4, &np, 512, &ep, 16, &el), 0 - 1,
        "truncated DER rejected");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
