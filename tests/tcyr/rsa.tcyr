# rsa.tcyr -- RSA PKCS#1 v1.5 signature verification (RFC 8017).
#
# Real RSA-2048 key + signatures, generated with a pure-Python RSA
# (seeded keygen + manual PKCS#1 v1.5 encode; each signature self-
# checked `pow(s, e, n) == EM` at generation). e = 65537.
#   msg     = "sigil RSA PKCS#1 v1.5 KAT message"
#   verify SHA-256 signature -> 1
#   verify SHA-384 signature -> 1
#   tampered signature (last byte ^1) -> 0
#   correct sig over a different message -> 0
#   wrong signature length -> 0

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"
include "src/x509.cyr"
include "src/bignum.cyr"
include "src/rsa.cyr"

fn main() {
    alloc_init();

    var n = hex_decode("", 512);
    var e = hex_decode("010001", 6);
    var msg = hex_decode("736967696c2052534120504b435323312076312e35204b4154206d657373616765", 66);  # 33 bytes
    var sig256 = hex_decode("", 512);
    var sig384 = hex_decode("", 512);
    var sigbad = hex_decode("", 512);

    test_group("RSA PKCS#1 v1.5 verify");

    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, sig256, 256), 1,
        "valid SHA-256 signature accepted");
    assert_eq(rsa_pkcs1v15_verify_sha384(n, 256, e, 3, msg, 33, sig384, 256), 1,
        "valid SHA-384 signature accepted");

    test_group("RSA PKCS#1 v1.5 rejects");

    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, sigbad, 256), 0,
        "tampered signature rejected");
    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, "different message", 17, sig256, 256), 0,
        "valid sig over wrong message rejected");
    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, sig256, 255), 0,
        "wrong signature length rejected");
    # Even modulus rejected (3.6.6 odd-modulus precondition for the
    # Montgomery verify ladder). n with its LSB cleared is even/malformed.
    var n_even = hex_decode("", 512);
    assert_eq(rsa_pkcs1v15_verify_sha256(n_even, 256, e, 3, msg, 33, sig256, 256), 0,
        "even modulus rejected");
    # SHA-384 verify against a SHA-256 signature must fail (wrong DigestInfo).
    assert_eq(rsa_pkcs1v15_verify_sha384(n, 256, e, 3, msg, 33, sig256, 256), 0,
        "SHA-256 sig rejected by SHA-384 verify");

    # ============================================================
    # Public-key DER parsing (3.6.3a) -- parse then verify with the
    # extracted (n, e). DER generated from the same key.
    # ============================================================
    test_group("RSA pubkey DER parse");

    var np[512];
    var ep[16];
    var el[8];

    # PKCS#1 RSAPublicKey: SEQUENCE { INTEGER n, INTEGER e }  (270 bytes)
    var rsapub = hex_decode("", 540);
    var nl1 = rsa_pubkey_from_der(rsapub, 270, &np, 512, &ep, 16, &el);
    assert_eq(nl1, 256, "PKCS#1 pubkey: modulus length 256");
    assert_eq(load64(&el), 3, "PKCS#1 pubkey: exponent length 3");
    assert_eq(rsa_pkcs1v15_verify_sha256(&np, nl1, &ep, load64(&el), msg, 33, sig256, 256), 1,
        "verify with parsed PKCS#1 public key");

    # X.509 SubjectPublicKeyInfo (rsaEncryption)  (294 bytes)
    var spki = hex_decode("", 588);
    var nl2 = rsa_pubkey_from_der(spki, 294, &np, 512, &ep, 16, &el);
    assert_eq(nl2, 256, "SPKI pubkey: modulus length 256");
    assert_eq(rsa_pkcs1v15_verify_sha256(&np, nl2, &ep, load64(&el), msg, 33, sig256, 256), 1,
        "verify with parsed SPKI public key");

    # Malformed (truncated) DER is rejected.
    assert_eq(rsa_pubkey_from_der(rsapub, 4, &np, 512, &ep, 16, &el), 0 - 1,
        "truncated DER rejected");

    # ============================================================
    # Private-key DER parsing (3.6.3b). PKCS#1 RSAPrivateKey + PKCS#8,
    # same key. Strong check: parsed p*q == parsed n (bignum multiply).
    # ============================================================
    test_group("RSA privkey DER parse");

    var key[2384];   # RSAK_SIZE

    var rpk = hex_decode("", 2384);
    assert_eq(rsa_privkey_from_der(rpk, 1192, &key), 0, "PKCS#1 privkey parse ok");
    assert_eq(load64(&key + 2320), 256, "privkey n length 256");   # RSAK_NLEN
    assert_eq(load64(&key + 2328), 3,   "privkey e length 3");     # RSAK_ELEN
    assert_eq(load64(&key + 2336), 256, "privkey d length 256");   # RSAK_DLEN
    assert_eq(load64(&key + 2344), 128, "privkey p length 128");   # RSAK_PLEN
    assert_eq(load64(&key + 2352), 128, "privkey q length 128");   # RSAK_QLEN
    assert_streq(hex_encode(&key + 0, 256), hex_encode(n, 256), "privkey n matches");

    # Strong check: p * q == n (confirms p, q parsed correctly).
    var pbn[128];
    var qbn[128];
    var pq[256];
    bn_from_be(&pbn, 16, &key + 1040, 128);   # RSAK_P
    bn_from_be(&qbn, 16, &key + 1296, 128);   # RSAK_Q
    bn_mul(&pq, &pbn, &qbn, 16);
    var pqbytes[256];
    bn_to_be(&pqbytes, 256, &pq, 32);
    assert_streq(hex_encode(&pqbytes, 256), hex_encode(n, 256), "parsed p * q == n");

    # PKCS#8 wrapper -> same modulus.
    var key8[2384];
    var pkcs8 = hex_decode("", 2436);
    assert_eq(rsa_privkey_from_der(pkcs8, 1218, &key8), 0, "PKCS#8 privkey parse ok");
    assert_streq(hex_encode(&key8 + 0, 256), hex_encode(n, 256), "PKCS#8 n matches");

    # ============================================================
    # PKCS#1 v1.5 sign (3.6.3d). Deterministic, so the signature must
    # match the Python KAT byte-for-byte; also sign->verify roundtrips.
    # `key` was parsed from the PKCS#1 RSAPrivateKey above.
    # ============================================================
    test_group("RSA PKCS#1 v1.5 sign");

    var mysig[256];
    var sl = rsa_pkcs1v15_sign_sha256(&key, msg, 33, &mysig);
    assert_eq(sl, 256, "sign returns k = 256");
    assert_streq(hex_encode(&mysig, 256),
        "",
        "SHA-256 signature matches Python KAT");
    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, &mysig, 256), 1,
        "sign -> verify roundtrip (SHA-256)");

    var mysig384[256];
    rsa_pkcs1v15_sign_sha384(&key, msg, 33, &mysig384);
    assert_streq(hex_encode(&mysig384, 256),
        "",
        "SHA-384 signature matches Python KAT");
    assert_eq(rsa_pkcs1v15_verify_sha384(n, 256, e, 3, msg, 33, &mysig384, 256), 1,
        "sign -> verify roundtrip (SHA-384)");

    # ============================================================
    # RSASSA-PSS (3.6.5). External KATs generated by a pure-Python
    # EMSA-PSS encoder over the SAME RSA-2048 key, with a fixed
    # salt (0xAA repeated, len = hLen) so the signature bytes are
    # deterministic and reproducible. sigil's verify is salt-length
    # -agnostic, so it accepts these regardless of how the salt was
    # chosen. Sign uses a random salt, so it's covered by sign->verify
    # roundtrips (not byte-for-byte KATs).
    # ============================================================
    test_group("RSA-PSS verify (external KAT)");

    var pss256 = hex_decode("", 512);
    var pss384 = hex_decode("", 512);

    assert_eq(rsa_pss_verify_sha256(n, 256, e, 3, msg, 33, pss256, 256), 1,
        "valid PSS SHA-256 signature accepted");
    assert_eq(rsa_pss_verify_sha384(n, 256, e, 3, msg, 33, pss384, 256), 1,
        "valid PSS SHA-384 signature accepted");

    test_group("RSA-PSS rejects");

    # Tamper the last byte of the PSS SHA-256 signature.
    var pssbad = hex_decode("", 512);
    assert_eq(rsa_pss_verify_sha256(n, 256, e, 3, msg, 33, pssbad, 256), 0,
        "tampered PSS signature rejected");
    assert_eq(rsa_pss_verify_sha256(n, 256, e, 3, "different message", 17, pss256, 256), 0,
        "PSS sig over wrong message rejected");
    assert_eq(rsa_pss_verify_sha384(n, 256, e, 3, msg, 33, pss256, 256), 0,
        "PSS SHA-256 sig rejected by SHA-384 verify");
    assert_eq(rsa_pss_verify_sha256(n, 256, e, 3, msg, 33, pss256, 255), 0,
        "wrong PSS signature length rejected");

    test_group("RSA-PSS sign -> verify roundtrip");

    var psssig[256];
    var psl = rsa_pss_sign_sha256(&key, msg, 33, &psssig);
    assert_eq(psl, 256, "PSS sign returns k = 256");
    assert_eq(rsa_pss_verify_sha256(n, 256, e, 3, msg, 33, &psssig, 256), 1,
        "PSS sign -> verify roundtrip (SHA-256)");

    var psssig384[256];
    rsa_pss_sign_sha384(&key, msg, 33, &psssig384);
    assert_eq(rsa_pss_verify_sha384(n, 256, e, 3, msg, 33, &psssig384, 256), 1,
        "PSS sign -> verify roundtrip (SHA-384)");
    # A PSS signature must NOT verify under PKCS#1 v1.5 (different scheme).
    assert_eq(rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, &psssig, 256), 0,
        "PSS signature rejected by v1.5 verify");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
