# tdx_verify_full.tcyr — TDX end-to-end verify orchestrator tests
# covering BOTH att_key_type variants (P-256/SHA-256 and P-384/SHA-384).
#
# Sigil 3.5 — bite 4 of the TEE-attestation completion arc.
#
# Composes: pem_decode_certs → x509_parse (×n + root) →
# x509_verify_chain → tdx_quote_verify_with_pck (which dispatches
# internally on att_key_type).
#
# Fixture origin (2026-05-22, scripts/tdx-verify-full-fixture.out):
# synthesized TDX v4 quotes with real PCK PEM chain (test PCK leaf
# + self-signed test root). Same root + PCK keypair as the SGX
# fixture (Intel PCK is shared across SGX/TDX).
#
# Test groups:
#   1. tdx_quote_verify_full — att_key_type=2 (P-256) happy path
#   2. tdx_quote_verify_full — att_key_type=3 (P-384) happy path
#   3. cert_data_type mismatch rejection
#   4. wrong root anchor rejection
#   5. tampered quote rejection (P-384 path)
#   6. malformed att_key_type rejection (parse-level)

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ecdsa_p256.cyr"
include "src/ecdsa_p384.cyr"
include "src/x509.cyr"
include "src/pem.cyr"
include "src/tdx.cyr"

# ----------------------------------------------------------------
# Synthesized fixture (2026-05-22)
# ----------------------------------------------------------------

var ROOT_DER_LEN = 425;
var ROOT_DER_HEX = "";

# att_key_type=2 (P-256)
var P256_QUOTE_LEN = 2510;
var P256_QUOTE_HEX = "";

# att_key_type=3 (P-384)
var P384_QUOTE_LEN = 2574;
var P384_QUOTE_HEX = "";

var NOW_IN_WINDOW = 1782518400;

fn main() {
    alloc_init();
    _p256_init();
    _p384_init();

    var root_der = hex_decode(ROOT_DER_HEX, 2 * ROOT_DER_LEN);

    # ============================================================
    # Group 1 — att_key_type=2 (P-256) happy path
    # ============================================================
    test_group("tdx_quote_verify_full — att_key_type=2 (P-256) happy path");

    var quote_p256 = hex_decode(P256_QUOTE_HEX, 2 * P256_QUOTE_LEN);
    var q2 = tdx_quote_alloc();
    assert_eq(tdx_quote_parse(quote_p256, P256_QUOTE_LEN, q2), 1, "P-256 quote parses");
    assert_eq(tdx_quote_att_key_type(q2), TDX_ATT_KEY_TYPE_ECDSA_P256, "att_key_type=2");
    assert_eq(tdx_quote_ak_size(q2), 64, "AK size 64 for P-256");
    assert_eq(tdx_quote_ecdsa_sig_size(q2), 64, "sig size 64 for P-256");
    assert_eq(tdx_quote_verify_full(q2, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 1,
              "P-256 end-to-end verify");

    # ============================================================
    # Group 2 — att_key_type=3 (P-384) happy path
    # ============================================================
    test_group("tdx_quote_verify_full — att_key_type=3 (P-384) happy path");

    var quote_p384 = hex_decode(P384_QUOTE_HEX, 2 * P384_QUOTE_LEN);
    var q3 = tdx_quote_alloc();
    assert_eq(tdx_quote_parse(quote_p384, P384_QUOTE_LEN, q3), 1, "P-384 quote parses");
    assert_eq(tdx_quote_att_key_type(q3), TDX_ATT_KEY_TYPE_ECDSA_P384, "att_key_type=3");
    assert_eq(tdx_quote_ak_size(q3), 96, "AK size 96 for P-384");
    assert_eq(tdx_quote_ecdsa_sig_size(q3), 96, "sig size 96 for P-384");
    assert_eq(tdx_quote_verify_full(q3, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 1,
              "P-384 end-to-end verify");

    # ============================================================
    # Group 3 — cert_data_type mismatch
    # ============================================================
    test_group("tdx_quote_verify_full — cert_data_type mismatch");

    var q3_bad = tdx_quote_alloc();
    memcpy(q3_bad, q3, 256);
    store64(q3_bad + 112, 1);    # cert_data_type slot
    assert_eq(tdx_quote_verify_full(q3_bad, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 0,
              "non-PEM cert_data_type rejected");

    # ============================================================
    # Group 4 — wrong root anchor
    # ============================================================
    test_group("tdx_quote_verify_full — wrong root anchor");

    var WRONG_ROOT_HEX = "";
    var wrong_root = hex_decode(WRONG_ROOT_HEX, 842);
    assert_eq(tdx_quote_verify_full(q3, wrong_root, 421, NOW_IN_WINDOW), 0,
              "wrong root → P-384 verify rejected");
    assert_eq(tdx_quote_verify_full(q2, wrong_root, 421, NOW_IN_WINDOW), 0,
              "wrong root → P-256 verify rejected");

    # ============================================================
    # Group 5 — P-384 tamper rejection
    # ============================================================
    test_group("tdx_quote_verify_full — P-384 tamper rejection");

    # Flip a byte inside the MRTD region (offset 48 [header] + 136 [td_body MRTD]).
    var quote_t = alloc(P384_QUOTE_LEN);
    memcpy(quote_t, quote_p384, P384_QUOTE_LEN);
    var mrtd_off = 48 + 136;
    store8(quote_t + mrtd_off, (load8(quote_t + mrtd_off) & 0xFF) ^ 0x01);
    var q3_t = tdx_quote_alloc();
    assert_eq(tdx_quote_parse(quote_t, P384_QUOTE_LEN, q3_t), 1, "tampered quote still parses");
    assert_eq(tdx_quote_verify_full(q3_t, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 0,
              "P-384 MRTD tamper fails AK→quote signature");

    # ============================================================
    # Group 6 — malformed att_key_type rejection (parse-level)
    # ============================================================
    test_group("tdx_quote_parse — unsupported att_key_type rejection");

    # Replace att_key_type with an invalid value (e.g., 4) in the header.
    var bad_q = alloc(P256_QUOTE_LEN);
    memcpy(bad_q, quote_p256, P256_QUOTE_LEN);
    store8(bad_q + 2, 4);   # att_key_type LE byte 0
    store8(bad_q + 3, 0);
    var qbad = tdx_quote_alloc();
    assert_eq(tdx_quote_parse(bad_q, P256_QUOTE_LEN, qbad), 0,
              "att_key_type=4 (unsupported) rejected");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
