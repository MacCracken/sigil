# x509_keyusage_eku.tcyr — keyUsage + extendedKeyUsage parsing (CVE-17).
#
# A P-256 cert with X509v3 extensions:
#   keyUsage         = critical, digitalSignature + keyCertSign
#   extendedKeyUsage = serverAuth
#   basicConstraints = critical, CA:TRUE, pathlen:3
# Verifies the v3.7.12 keyUsage/EKU parse + the grown (256→272) struct fields.
include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/ct.cyr"
include "lib/thread_local.cyr"
include "dist/sigil.cyr"

test_group("x509 keyUsage + extendedKeyUsage parse (CVE-17)");

var der = hex_decode("", 860);
var cert = x509_cert_alloc();
assert_eq(x509_parse(der, 430, cert), 1, "keyUsage/EKU cert parses");

# keyUsage = present(0x100) | digitalSignature(0x80) + keyCertSign(0x04) = 0x184
assert_eq(x509_cert_key_usage(cert), 0x184, "keyUsage bits = digitalSignature + keyCertSign");
# the individual bits the TLS walker checks:
assert_eq(x509_cert_key_usage(cert) & 0x80, 0x80, "  digitalSignature bit set");
assert_eq(x509_cert_key_usage(cert) & 0x04, 0x04, "  keyCertSign bit set");
assert_eq(x509_cert_key_usage(cert) & 0x100, 0x100, "  keyUsage present marker");

# EKU = present(0x100) | serverAuth(0x01) = 0x101
assert_eq(x509_cert_eku(cert), 0x101, "EKU = serverAuth");

# basicConstraints
assert_eq(x509_cert_is_ca(cert), 1, "basicConstraints CA:TRUE");
assert_eq(x509_cert_path_len(cert), 3, "pathLenConstraint = 3");

var r = assert_summary();
