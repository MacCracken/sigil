# sgx_verify_full.tcyr — end-to-end verify orchestrator test.
#
# Sigil 3.5 — bite 2 of the TEE-attestation completion arc.
#
# Composes: pem_decode_certs → x509_parse (×n + root) →
# x509_verify_chain → sgx_quote_verify_with_pck.
#
# Fixture origin (2026-05-22, scripts/sgx-verify-full-fixture.out
# — kept as a build artifact, not regenerable from this file
# alone): a synthesized DCAP v3 quote whose qe_cert_data carries a
# real PEM cert chain (test PCK leaf + self-signed test root).
# Leaf cert holds the PCK pubkey that signed the QE report; the
# AK pubkey embedded in the quote signed the quote body.
#
# Test groups:
#   1. sgx_quote_verify_full — happy path
#   2. cert_data_type mismatch rejection
#   3. PEM-decode failure rejection
#   4. wrong root anchor rejection (chain walk fails)
#   5. time-window rejection
#   6. tampered quote rejection

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ecdsa_p256.cyr"
include "src/x509.cyr"
include "src/pem.cyr"
include "src/sgx.cyr"

# ----------------------------------------------------------------
# Synthesized fixture (2026-05-22 — scripts/sgx-verify-full-fixture.out)
# ----------------------------------------------------------------

var AK_PUB_HEX = "1b790b783f1e88745bd7f81ad2b902084c84fbfffff028934bf7faeb9703a162a2859cfc21232d01aaa982c9132a205140233473482d4594b2b357516d1bff3c";
var PCK_PUB_HEX = "43f6bd678039ea95c4050e7486516b06528e16c552ff46ea5117cbfc4de2ae2d2f66636793492cdd688144d6290d1348fbfbbda40387e03b2ee592ee69ec5beb";

var ROOT_DER_LEN = 425;
var ROOT_DER_HEX = "";

var QUOTE_LEN = 2310;
var QUOTE_HEX = "";

# Cert validity window: notBefore = 2026-05-22 22:11:16 UTC,
# notAfter (leaf) = 2027-05-22 22:11:16 UTC.
var NOW_IN_WINDOW = 1782518400;     # 2026-06-15 — comfortably inside
var NOW_PRE_WINDOW = 1748520000;    # 2025-05-29 — before notBefore
var NOW_POST_WINDOW = 1820000000;   # 2027-09 — after leaf notAfter

fn main() {
    alloc_init();
    _p256_init();

    var quote_buf = hex_decode(QUOTE_HEX, 2 * QUOTE_LEN);
    var root_der  = hex_decode(ROOT_DER_HEX, 2 * ROOT_DER_LEN);

    var q = sgx_quote_alloc();
    assert_eq(sgx_quote_parse(quote_buf, QUOTE_LEN, q), 1, "fixture quote parses");

    # ============================================================
    # Group 1 — Happy path
    # ============================================================
    test_group("sgx_quote_verify_full — happy path");
    assert_eq(sgx_quote_verify_full(q, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 1,
              "end-to-end verify against synthesized PEM chain");

    # now_unix = 0 disables time-window check.
    assert_eq(sgx_quote_verify_full(q, root_der, ROOT_DER_LEN, 0), 1,
              "now_unix=0 disables time check (still verifies)");

    # ============================================================
    # Group 2 — cert_data_type mismatch
    # ============================================================
    test_group("sgx_quote_verify_full — cert_data_type mismatch");

    # Forge a parsed quote with cert_data_type = 1 (PPID, not PCK PEM).
    # Mutate the parsed struct — easier than rebuilding the quote.
    var q_bad_type = sgx_quote_alloc();
    memcpy(q_bad_type, q, 256);
    store64(q_bad_type + 104, 1);    # cert_data_type slot
    assert_eq(sgx_quote_verify_full(q_bad_type, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 0,
              "non-PEM cert_data_type rejected");

    # ============================================================
    # Group 3 — Time-window rejection
    # ============================================================
    test_group("sgx_quote_verify_full — time-window rejection");

    assert_eq(sgx_quote_verify_full(q, root_der, ROOT_DER_LEN, NOW_PRE_WINDOW), 0,
              "now before leaf notBefore rejected");
    assert_eq(sgx_quote_verify_full(q, root_der, ROOT_DER_LEN, NOW_POST_WINDOW), 0,
              "now after leaf notAfter rejected");

    # ============================================================
    # Group 4 — Wrong root anchor
    # ============================================================
    test_group("sgx_quote_verify_full — wrong root anchor");

    # Use the existing x509.tcyr root (not the one that signed our chain).
    # Chain walk should fail at the issuer-DN match.
    var WRONG_ROOT_HEX = "";
    var wrong_root = hex_decode(WRONG_ROOT_HEX, 842);
    assert_eq(sgx_quote_verify_full(q, wrong_root, 421, NOW_IN_WINDOW), 0,
              "verify against unrelated root rejected");

    # ============================================================
    # Group 5 — Malformed root DER
    # ============================================================
    test_group("sgx_quote_verify_full — malformed root DER");

    var bad_root = alloc(50);
    memset(bad_root, 0xFF, 50);
    assert_eq(sgx_quote_verify_full(q, bad_root, 50, NOW_IN_WINDOW), 0,
              "malformed root DER rejected");

    # Zero-length root.
    assert_eq(sgx_quote_verify_full(q, root_der, 0, NOW_IN_WINDOW), 0,
              "zero-length root rejected");

    # ============================================================
    # Group 6 — Tampered quote body
    # ============================================================
    test_group("sgx_quote_verify_full — quote tamper rejection");

    # Flip a byte inside the enclave report body. AK→quote-body
    # signature should fail.
    var quote_t = alloc(QUOTE_LEN);
    memcpy(quote_t, quote_buf, QUOTE_LEN);
    # Flip mr_enclave[0] (header is 48 B, mr_enclave at body offset 64).
    var mre_off = 48 + 64;
    store8(quote_t + mre_off, (load8(quote_t + mre_off) & 0xFF) ^ 0x01);
    var q_t = sgx_quote_alloc();
    assert_eq(sgx_quote_parse(quote_t, QUOTE_LEN, q_t), 1, "tampered quote still parses");
    # ============================================================
    # Group N — _into (caller-scratch arena) no-drift path (3.7.3)
    # ============================================================
    test_group("sgx_quote_verify_full_into — arena, no drift");

    var arena = arena_new(16384);
    # First verify into the arena: same result as the bump path (1).
    assert_eq(sgx_quote_verify_full_into(q, root_der, ROOT_DER_LEN, NOW_IN_WINDOW, arena), 1,
              "_into verify matches bump path (valid)");
    var used_after_one = arena_used(arena);
    assert_eq(used_after_one > 0, 1, "_into consumed arena scratch");

    # Loop with arena_reset between calls. Two independent drift
    # witnesses: (a) arena_used returns to exactly the same value each
    # iteration (arena reuse), and (b) the GLOBAL heap (alloc_used) does
    # not grow across the whole loop — the decisive check, since
    # arena_used alone cannot see a residual global-bump alloc. g0 is
    # captured AFTER the first _into call so all init-once tables (OID /
    # PEM / mdays) are already warm. The pre-3.7.3 path grew the global
    # heap on every call.
    var g0 = alloc_used();
    var li = 0;
    var drift = 0;
    while (li < 50) {
        arena_reset(arena);
        if (sgx_quote_verify_full_into(q, root_der, ROOT_DER_LEN, NOW_IN_WINDOW, arena) != 1) { drift = drift + 1; }
        if (arena_used(arena) != used_after_one) { drift = drift + 1; }
        li = li + 1;
    }
    assert_eq(drift, 0, "50 reset+verify iterations: stable, bounded arena use");
    assert_eq(alloc_used() - g0, 0, "no GLOBAL-heap drift across 50 _into iterations");

    # A too-small arena fails closed (returns 0), no crash.
    var tiny = arena_new(64);
    assert_eq(sgx_quote_verify_full_into(q, root_der, ROOT_DER_LEN, NOW_IN_WINDOW, tiny), 0,
              "exhausted arena fails closed");

    # The bump wrapper still works (delegates to _into with arena=0).
    assert_eq(sgx_quote_verify_full(q, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 1,
              "bump wrapper still verifies");

    assert_eq(sgx_quote_verify_full(q_t, root_der, ROOT_DER_LEN, NOW_IN_WINDOW), 0,
              "tampered mr_enclave fails verify_full");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
