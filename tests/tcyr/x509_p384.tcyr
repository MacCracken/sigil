# x509_p384.tcyr — P-384 SPKI parser tests.
#
# Sigil 3.4.1 — bite 1 of the SEV-SNP completion arc.
#
# Tests the new secp384r1 path in _xp_parse_spki:
#   1. A P-384 VCEK leaf cert parses to curve=P-384, pubkey_len=96.
#   2. The extracted pubkey matches the openssl-derived raw bytes.
#   3. The P-384 leaf chains correctly under a P-256 root via
#      x509_verify_chain (chain-link sig is still ECDSA-SHA256
#      since the root signed with P-256).
#   4. An issuer with curve=P-384 is rejected by _x509_verify_link
#      (mixed-curve chains are out of 3.4.1 scope).
#
# Fixture: /tmp/sgx_fx/vcek.pem — P-384 cert signed by the same
# root.pem used in sgx_verify_full + tdx_verify_full fixtures.

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ecdsa_p256.cyr"
include "src/ecdsa_p384.cyr"
include "src/x509.cyr"

# Same root.pem used in sgx_verify_full / tdx_verify_full fixtures.
var ROOT_DER_LEN = 425;
var ROOT_DER_HEX = "";

# P-384 VCEK leaf cert signed by the root.
var VCEK_DER_LEN = 451;
var VCEK_DER_HEX = "";

# Expected raw 96-byte Qx||Qy pubkey (derived via `openssl ec -pubout`).
var VCEK_PUB_HEX = "a519623d0ce2c586308cd29613307b021377b40bfa2ea7b82356ad23afa18a7633b9c62634dcc5c2e0be0d7d1837e44426e7e2a1f44761668b3bc76d5b4bb30089f9118ebdcaa69da461ade37c12afd21d85dd0e36772e78aafbeb8d8cddc65c";

var NOW_IN_WINDOW = 1782518400;   # 2026-06-15, well inside both certs

fn bytes_eq(a, b, len): i64 {
    var i = 0;
    while (i < len) {
        if ((load8(a + i) & 0xFF) != (load8(b + i) & 0xFF)) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn main() {
    alloc_init();
    _p256_init();
    _p384_init();

    var root_der = hex_decode(ROOT_DER_HEX, 2 * ROOT_DER_LEN);
    var vcek_der = hex_decode(VCEK_DER_HEX, 2 * VCEK_DER_LEN);
    var vcek_pub_expected = hex_decode(VCEK_PUB_HEX, 192);

    # ============================================================
    # Group 1 — P-384 SPKI parsing
    # ============================================================
    test_group("x509_parse — P-384 leaf SPKI");

    var vcek = x509_cert_alloc();
    assert_eq(x509_parse(vcek_der, VCEK_DER_LEN, vcek), 1, "P-384 cert parses");
    assert_eq(x509_cert_curve(vcek), X509_CURVE_P384, "curve = P-384");
    assert_eq(x509_cert_pubkey_len(vcek), 96, "pubkey_len = 96");
    assert_eq(x509_cert_is_ca(vcek), 0, "VCEK is end-entity (CA=FALSE)");
    assert_eq(x509_cert_sig_algo(vcek), X509_SIG_ECDSA_SHA256, "VCEK signed by ECDSA-SHA256");

    var pk = x509_cert_pubkey(vcek);
    assert_eq(bytes_eq(pk, vcek_pub_expected, 96), 1,
              "extracted P-384 pubkey matches openssl reference");

    # ============================================================
    # Group 2 — P-256 root
    # ============================================================
    test_group("x509_parse — P-256 root for reference");

    var root = x509_cert_alloc();
    assert_eq(x509_parse(root_der, ROOT_DER_LEN, root), 1, "root parses");
    assert_eq(x509_cert_curve(root), X509_CURVE_P256, "root curve = P-256");
    assert_eq(x509_cert_pubkey_len(root), 64, "root pubkey_len = 64");

    # ============================================================
    # Group 3 — Chain walk: P-256 root → P-384 leaf
    # ============================================================
    test_group("x509_verify_chain — P-256 root signs P-384 leaf");

    var inters = alloc(0);
    assert_eq(x509_verify_chain(vcek, inters, 0, root, NOW_IN_WINDOW), 1,
              "P-256 root → P-384 leaf chain verifies");
    assert_eq(x509_verify_chain(vcek, inters, 0, root, 0), 1,
              "now_unix=0 disables time check (still verifies)");

    # ============================================================
    # Group 4 — wrong-issuer rejection (signature-width guard)
    # ============================================================
    # Off-diagonal links ARE now supported — a P-384 issuer can sign a
    # SHA-256 child (see x509_offdiag.tcyr). But `vcek` was actually signed
    # by the P-256 root, so its stored signature is 64 bytes. Verifying it
    # against the P-384 `vcek`-as-issuer must still be REJECTED: a P-384
    # issuer's r,s are 96 bytes, so the 64-byte signature cannot match that
    # width — the link did not happen. (Genuine off-diagonal P-384-issuer
    # green paths live in x509_offdiag.tcyr; the diagonal P-384 path is
    # Group 5.)
    test_group("x509_verify_chain — 64-byte sig vs P-384 issuer rejected");

    var leaf_clone = x509_cert_alloc();
    memcpy(leaf_clone, vcek, 256);
    assert_eq(x509_verify_chain(leaf_clone, inters, 0, vcek, NOW_IN_WINDOW), 0,
              "64-byte (P-256-signed) child rejected against a P-384 issuer");

    # ============================================================
    # Group 5 — P-384 chain-link green path (3.6.7)
    # ============================================================
    # Real P-384 CA (secp384r1, self-signed ecdsa-with-SHA384) signing a
    # P-384 leaf with ecdsa-with-SHA384. Generated 2026-06-04 via OpenSSL
    # 3.6.2; `openssl verify -CAfile ca.crt leaf.crt` -> OK.
    test_group("x509_verify_chain — P-384 CA signs P-384 leaf (SHA-384)");

    var P384CA_HEX = "";
    var P384LEAF_HEX = "";
    var p384ca = x509_cert_alloc();
    var p384leaf = x509_cert_alloc();
    assert_eq(x509_parse(hex_decode(P384CA_HEX, 988), 494, p384ca), 1, "P-384 CA parses");
    assert_eq(x509_cert_curve(p384ca), X509_CURVE_P384, "P-384 CA curve = P-384");
    assert_eq(x509_cert_is_ca(p384ca), 1, "P-384 CA basicConstraints CA:TRUE");
    assert_eq(x509_parse(hex_decode(P384LEAF_HEX, 908), 454, p384leaf), 1, "P-384 leaf parses");
    assert_eq(x509_cert_sig_algo(p384leaf), X509_SIG_ECDSA_SHA384, "leaf sig algo = ECDSA-SHA384");
    assert_eq(x509_verify_chain(p384leaf, inters, 0, p384ca, 1782864000), 1,
              "P-384 CA → P-384 leaf (SHA-384) chain verifies");
    assert_eq(_x509_verify_link(p384leaf, p384ca), 1, "direct P-384 link verify");
    # Tamper the leaf's last signature byte → reject.
    var p384leaf_bad = x509_cert_alloc();
    var bad_der = hex_decode(P384LEAF_HEX, 908);
    store8(bad_der + 453, (load8(bad_der + 453) ^ 0x01) & 0xFF);
    assert_eq(x509_parse(bad_der, 454, p384leaf_bad), 1, "tampered P-384 leaf parses");
    assert_eq(_x509_verify_link(p384leaf_bad, p384ca), 0, "tampered P-384 signature rejected");

    # ============================================================
    # Group 6 — x509_parse_into P-384 arena no-drift (3.7.3)
    # ============================================================
    # An ECDSA-SHA384 cert allocates a 96-byte raw_sig (r||s); via _into
    # it must come from the arena, leaving the GLOBAL heap unchanged
    # across a reset+parse loop. Warm-up parse first (init-once tables).
    var p384_der = hex_decode(P384LEAF_HEX, 908);
    var arena = arena_new(8192);
    var wc = x509_cert_alloc_into(arena);
    assert_eq(x509_parse_into(p384_der, 454, wc, arena), 1, "P-384 leaf parses via _into");
    assert_eq(x509_cert_sig_algo(wc), X509_SIG_ECDSA_SHA384, "_into P-384 leaf sig algo");
    var g0 = alloc_used();
    var li = 0;
    var bad = 0;
    while (li < 50) {
        arena_reset(arena);
        var c2 = x509_cert_alloc_into(arena);
        if (c2 == 0) { bad = bad + 1; }
        if (x509_parse_into(p384_der, 454, c2, arena) != 1) { bad = bad + 1; }
        li = li + 1;
    }
    assert_eq(bad, 0, "50 P-384 x509_parse_into iterations all succeed");
    assert_eq(alloc_used() - g0, 0, "no GLOBAL-heap drift: P-384 raw_sig is arena-routed");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
