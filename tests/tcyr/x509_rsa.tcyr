# x509_rsa.tcyr -- X.509 chain-link verification with an RSA issuer
# (sigil 3.6.5). Exercises the RSA SPKI parse + rsa-with-SHA256/384
# signature-algorithm dispatch added to src/x509.cyr, feeding the
# issuer's parsed (n, e) to rsa_pkcs1v15_verify_*.
#
# Test chain (generated 2026-06-04 with OpenSSL 3.6.2):
#   openssl genrsa -out ca.key 2048
#   openssl req -new -x509 -key ca.key -sha256 -days 3650
#     -subj "/CN=Sigil RSA Test Root CA"
#     -addext basicConstraints=critical,CA:TRUE,pathlen:1
#     -addext keyUsage=critical,keyCertSign,cRLSign           (ca.crt)
#   openssl genrsa -out leaf.key 2048
#   openssl req -new -key leaf.key -subj "/CN=Sigil RSA Test Leaf"
#   openssl x509 -req -CA ca.crt -CAkey ca.key -sha256 ...     (leaf256.crt)
#   openssl x509 -req -CA ca.crt -CAkey ca.key -sha384 ...     (leaf384.crt)
# `openssl verify -CAfile ca.crt leaf256.crt` -> OK (both).
# DER via `openssl x509 -outform DER | xxd -p -c100000`.
#
# CA / leaf validity: 2026-06-04 18:15:15 UTC .. (CA 2036 / leaf 2027).

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"
include "src/x509.cyr"
include "src/bignum.cyr"
include "src/rsa.cyr"

var CA_HEX = "";

var LEAF256_HEX = "";

var LEAF384_HEX = "";

# Tampered SHA-256 leaf: final signature octet 0x01 -> 0x02. Parses
# fine (signature bytes aren't validated at parse), verify must fail.
var LEAF256_BAD_HEX = "";

# 2026-07-01 00:00:00 UTC (inside both validity windows).
var NOW = 1782864000;

fn main() {
    alloc_init();
    _p256_init();

    var ca = hex_decode(CA_HEX, 1652);            # 826 bytes
    var leaf256 = hex_decode(LEAF256_HEX, 1574);  # 787 bytes
    var leaf384 = hex_decode(LEAF384_HEX, 1574);
    var leafbad = hex_decode(LEAF256_BAD_HEX, 1574);

    var cacert = x509_cert_alloc();
    var l256 = x509_cert_alloc();
    var l384 = x509_cert_alloc();
    var lbad = x509_cert_alloc();

    # ============================================================
    test_group("x509_parse — RSA CA + leaves");

    assert_eq(x509_parse(ca, 826, cacert), 1, "RSA CA parses");
    assert_eq(x509_cert_curve(cacert), X509_CURVE_RSA, "CA key type = RSA");
    var rblk = x509_cert_rsa_pubkey(cacert);
    assert_eq(load64(rblk + 528), 256, "CA modulus length = 256 (RSA-2048)");
    assert_eq(load64(rblk + 536), 3, "CA exponent length = 3");
    assert_eq(x509_cert_is_ca(cacert), 1, "CA basicConstraints CA:TRUE");

    assert_eq(x509_parse(leaf256, 787, l256), 1, "SHA-256 leaf parses");
    assert_eq(x509_cert_sig_algo(l256), X509_SIG_RSA_SHA256, "leaf256 sig algo = RSA-SHA256");
    assert_eq(x509_cert_curve(l256), X509_CURVE_RSA, "leaf256 key type = RSA");

    assert_eq(x509_parse(leaf384, 787, l384), 1, "SHA-384 leaf parses");
    assert_eq(x509_cert_sig_algo(l384), X509_SIG_RSA_SHA384, "leaf384 sig algo = RSA-SHA384");

    # ============================================================
    test_group("x509_verify_chain — RSA issuer (green path)");

    var inters = alloc(8);   # zero intermediates
    assert_eq(x509_verify_chain(l256, inters, 0, cacert, NOW), 1,
        "RSA CA signs SHA-256 leaf (in window)");
    assert_eq(x509_verify_chain(l384, inters, 0, cacert, NOW), 1,
        "RSA CA signs SHA-384 leaf (in window)");
    assert_eq(x509_verify_chain(l256, inters, 0, cacert, 0), 1,
        "verify with time check disabled (now_unix = 0)");

    # Direct link verify (bypasses DN/window checks).
    assert_eq(_x509_verify_link(l256, cacert), 1, "direct link verify (RSA-SHA256)");
    assert_eq(_x509_verify_link(l384, cacert), 1, "direct link verify (RSA-SHA384)");

    # ============================================================
    test_group("x509_verify_chain — RSA rejects");

    assert_eq(x509_parse(leafbad, 787, lbad), 1, "tampered leaf still parses");
    assert_eq(x509_verify_chain(lbad, inters, 0, cacert, NOW), 0,
        "tampered RSA signature rejected");
    assert_eq(_x509_verify_link(lbad, cacert), 0,
        "tampered RSA signature rejected (direct link)");

    # Wrong issuer key: verify the leaf's link against the LEAF as issuer.
    # The signature was made by the CA key, not the leaf key -> reject.
    assert_eq(_x509_verify_link(l256, l256), 0,
        "leaf signature does not verify under the leaf's own key");

    # DN mismatch: leaf.issuer ("Root CA") != leaf.subject ("Leaf"), so a
    # self-issued chain is rejected before the signature is even checked.
    assert_eq(x509_verify_chain(l256, inters, 0, l256, NOW), 0,
        "issuer DN mismatch rejected (leaf as its own root)");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
