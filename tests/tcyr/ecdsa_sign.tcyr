# ecdsa_sign.tcyr — ECDSA P-256/P-384 deterministic signing (RFC 6979).
#
# Known-answer vectors from RFC 6979 Appendix A.2.5 (P-256/SHA-256)
# and A.2.6 (P-384/SHA-384), messages "sample" and "test". The exact
# (r, s) outputs were independently reproduced with a stdlib-only
# Python RFC 6979 implementation and match the RFC byte-for-byte.
#
# Verifies for each curve:
#   - exact (r||s) against the RFC vector (proves the deterministic
#     nonce derivation + signing equation);
#   - determinism (same key+msg → identical signature);
#   - sign → verify roundtrip with the RFC public key (raw + DER);
#   - DER structure (SEQUENCE tag) + verify_der acceptance.

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/hmac.cyr"
include "src/hmac_sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"
include "src/ecdsa_p384.cyr"
include "src/ecdsa_sign.cyr"

fn main() {
    alloc_init();

    var msg_sample = "sample";
    var msg_test   = "test";

    # ============================================================
    # P-256 / SHA-256 — RFC 6979 A.2.5
    # ============================================================
    test_group("ECDSA P-256 RFC 6979 sign");

    var x256 = hex_decode("c9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721", 64);
    var pub256 = hex_decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299", 128);

    var sig256[64];
    assert_eq(ecdsa_p256_sign(x256, msg_sample, 6, &sig256), 0, "p256 sign sample rc=0");
    assert_streq(hex_encode(&sig256, 64),
        "efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8",
        "p256 sample r||s == RFC 6979");
    # Deterministic: signing again yields the identical signature.
    var sig256b[64];
    ecdsa_p256_sign(x256, msg_sample, 6, &sig256b);
    assert_eq(ct_eq_bytes(&sig256, &sig256b, 64), 1, "p256 deterministic");
    # Roundtrip verify with the RFC public key.
    assert_eq(ecdsa_p256_verify(pub256, msg_sample, 6, &sig256), 1, "p256 sample verify");

    var sig256t[64];
    assert_eq(ecdsa_p256_sign(x256, msg_test, 4, &sig256t), 0, "p256 sign test rc=0");
    assert_streq(hex_encode(&sig256t, 64),
        "f1abb023518351cd71d881567b1ea663ed3efcf6c5132b354f28d3b0b7d38367019f4113742a2b14bd25926b49c649155f267e60d3814b4c0cc84250e46f0083",
        "p256 test r||s == RFC 6979");
    assert_eq(ecdsa_p256_verify(pub256, msg_test, 4, &sig256t), 1, "p256 test verify");

    # DER form (TLS 1.3 CertificateVerify shape).
    var der256[80];
    var dl256 = ecdsa_p256_sign_der(x256, msg_sample, 6, &der256, 80);
    assert_gt(dl256, 0, "p256 sign_der length > 0");
    assert_eq(load8(&der256) & 0xFF, 0x30, "p256 DER SEQUENCE tag");
    assert_eq(ecdsa_p256_verify_der(pub256, msg_sample, 6, &der256, dl256), 1, "p256 verify_der");

    # ============================================================
    # P-384 / SHA-384 — RFC 6979 A.2.6
    # ============================================================
    test_group("ECDSA P-384 RFC 6979 sign");

    var x384 = hex_decode("6b9d3dad2e1b8c1c05b19875b6659f4de23c3b667bf297ba9aa47740787137d896d5724e4c70a825f872c9ea60d2edf5", 96);
    var pub384 = hex_decode("ec3a4e415b4e19a4568618029f427fa5da9a8bc4ae92e02e06aae5286b300c64def8f0ea9055866064a254515480bc138015d9b72d7d57244ea8ef9ac0c621896708a59367f9dfb9f54ca84b3f1c9db1288b231c3ae0d4fe7344fd2533264720", 192);

    var sig384[96];
    assert_eq(ecdsa_p384_sign(x384, msg_sample, 6, &sig384), 0, "p384 sign sample rc=0");
    assert_streq(hex_encode(&sig384, 96),
        "94edbb92a5ecb8aad4736e56c691916b3f88140666ce9fa73d64c4ea95ad133c81a648152e44acf96e36dd1e80fabe4699ef4aeb15f178cea1fe40db2603138f130e740a19624526203b6351d0a3a94fa329c145786e679e7b82c71a38628ac8",
        "p384 sample r||s == RFC 6979");
    var sig384b[96];
    ecdsa_p384_sign(x384, msg_sample, 6, &sig384b);
    assert_eq(ct_eq_bytes(&sig384, &sig384b, 96), 1, "p384 deterministic");
    assert_eq(ecdsa_p384_verify(pub384, msg_sample, 6, &sig384), 1, "p384 sample verify");

    var sig384t[96];
    assert_eq(ecdsa_p384_sign(x384, msg_test, 4, &sig384t), 0, "p384 sign test rc=0");
    assert_streq(hex_encode(&sig384t, 96),
        "8203b63d3c853e8d77227fb377bcf7b7b772e97892a80f36ab775d509d7a5feb0542a7f0812998da8f1dd3ca3cf023dbddd0760448d42d8a43af45af836fce4de8be06b485e9b61b827c2f13173923e06a739f040649a667bf3b828246baa5a5",
        "p384 test r||s == RFC 6979");
    assert_eq(ecdsa_p384_verify(pub384, msg_test, 4, &sig384t), 1, "p384 test verify");

    # No ecdsa_p384_verify_der in sigil yet; the shared DER encoder is
    # already validated end-to-end by the P-256 verify_der path above,
    # so here we check the structure (SEQUENCE tag + length byte).
    var der384[112];
    var dl384 = ecdsa_p384_sign_der(x384, msg_sample, 6, &der384, 112);
    assert_gt(dl384, 0, "p384 sign_der length > 0");
    assert_eq(load8(&der384) & 0xFF, 0x30, "p384 DER SEQUENCE tag");
    assert_eq(load8(&der384 + 1) & 0xFF, dl384 - 2, "p384 DER length byte consistent");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
