# ecdsa_p384.tcyr — ECDSA P-384 verify, plus field-arithmetic
# groundwork tests.
#
# Sigil 3.2.4 — bite 4 of the TEE attestation arc.
#
# Test groups:
#   1. u384 BE codec roundtrip
#   2. p384_reduce — corner cases
#   3. fp_p384 field arithmetic
#   4. curve-equation self-check on the base point G
#   5. pt_p384_is_on_curve
#   6. Jacobian point arithmetic — 2G against published vector
#   7. ECDSA verify — RFC 6979 §A.2.6 (P-384 / SHA-384)
#   8. ECDSA verify — negative cases

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"
include "src/ecdsa_p384.cyr"

fn main() {
    alloc_init();
    _p384_init();

    # ============================================================
    # Group 1 — u384 BE codec roundtrip
    # ============================================================
    test_group("u384 big-endian load/store roundtrip");

    var gx_bytes = hex_decode("aa87ca22be8b05378eb1c71ef320ad746e1d3b628ba79b9859f741e082542a385502f25dbf55296c3a545e3872760ab7", 96);
    var loaded = alloc(48);
    u384_load_be(loaded, gx_bytes);
    assert_eq(u384_eq(loaded, _p384_gx), 1, "load_be(gx_bytes) == gx");

    var stored = alloc(48);
    u384_store_be(stored, loaded);
    assert_streq(hex_encode(stored, 48),
        "aa87ca22be8b05378eb1c71ef320ad746e1d3b628ba79b9859f741e082542a385502f25dbf55296c3a545e3872760ab7",
        "store_be(load_be(gx)) == gx");

    # ============================================================
    # Group 2 — p384_reduce
    # ============================================================
    test_group("p384_reduce");

    # 2a: 7 reduces to 7.
    var val768 = alloc(96);
    memset(val768, 0, 96);
    store64(val768, 7);
    var reduced = alloc(48);
    p384_reduce(reduced, val768);
    assert_eq(load64(reduced), 7, "reduce(7) low limb");

    # 2b: p reduces to 0.
    memset(val768, 0, 96);
    memcpy(val768, _p384_p, 48);
    p384_reduce(reduced, val768);
    assert_eq(u384_is_zero(reduced), 1, "reduce(p) == 0");

    # 2c: p + 1 reduces to 1.
    memset(val768, 0, 96);
    var p_plus_one = u384_clone(_p384_p);
    u384_add(p_plus_one, p_plus_one, _p384_one);
    memcpy(val768, p_plus_one, 48);
    p384_reduce(reduced, val768);
    assert_eq(load64(reduced), 1, "reduce(p+1) low limb");
    assert_eq(load64(reduced + 8), 0, "reduce(p+1) limb 1");
    assert_eq(load64(reduced + 40), 0, "reduce(p+1) limb 5");

    # ============================================================
    # Group 3 — fp_p384 arithmetic
    # ============================================================
    test_group("fp_p384 add / sub / neg");

    var a = u384_zero();
    var b = u384_zero();
    var r = u384_zero();

    # 0 + 0 = 0
    fp_p384_add(r, a, b);
    assert_eq(u384_is_zero(r), 1, "0 + 0 == 0");

    # 1 + 1 = 2
    store64(a, 1);
    store64(b, 1);
    fp_p384_add(r, a, b);
    assert_eq(load64(r), 2, "1 + 1 == 2");

    # (p-1) + 1 = 0 mod p
    u384_copy(a, _p384_p);
    u384_sub(a, a, _p384_one);
    memset(b, 0, 48);
    store64(b, 1);
    fp_p384_add(r, a, b);
    assert_eq(u384_is_zero(r), 1, "(p-1) + 1 == 0 (mod p)");

    # -1 = p - 1
    store64(a, 1);
    var i = 1;
    while (i < 6) { store64(a + i * 8, 0); i = i + 1; }
    fp_p384_neg(r, a);
    var pm1 = u384_clone(_p384_p);
    u384_sub(pm1, pm1, _p384_one);
    assert_eq(u384_eq(r, pm1), 1, "-1 == p - 1");

    test_group("fp_p384 mul / sq");
    # 1 * gx = gx
    store64(a, 1);
    i = 1;
    while (i < 6) { store64(a + i * 8, 0); i = i + 1; }
    fp_p384_mul(r, a, _p384_gx);
    assert_eq(u384_eq(r, _p384_gx), 1, "1 * gx == gx");

    # 0 * gx = 0
    memset(a, 0, 48);
    fp_p384_mul(r, a, _p384_gx);
    assert_eq(u384_is_zero(r), 1, "0 * gx == 0");

    # ============================================================
    # Group 4 — curve-equation self-check on G
    # ============================================================
    test_group("base point on the curve");
    var lhs = u384_zero();
    var rhs = u384_zero();
    var tmp = u384_zero();
    var three_x = u384_zero();
    var two_x = u384_zero();
    fp_p384_sq(lhs, _p384_gy);
    fp_p384_sq(tmp, _p384_gx);
    fp_p384_mul(rhs, tmp, _p384_gx);
    fp_p384_add(two_x, _p384_gx, _p384_gx);
    fp_p384_add(three_x, two_x, _p384_gx);
    fp_p384_sub(rhs, rhs, three_x);
    fp_p384_add(rhs, rhs, _p384_b);
    assert_eq(u384_eq(lhs, rhs), 1, "gy^2 == gx^3 - 3*gx + b (mod p)");

    # ============================================================
    # Group 5 — pt_p384_is_on_curve
    # ============================================================
    test_group("pt_p384_is_on_curve");
    assert_eq(pt_p384_is_on_curve(_p384_gx, _p384_gy), 1, "G is on curve");

    var zero = u384_zero();
    assert_eq(pt_p384_is_on_curve(zero, zero), 0, "(0, 0) rejected");

    var gy_plus_1 = u384_clone(_p384_gy);
    fp_p384_add(gy_plus_1, gy_plus_1, _p384_one);
    assert_eq(pt_p384_is_on_curve(_p384_gx, gy_plus_1), 0, "(gx, gy+1) off-curve rejected");

    assert_eq(pt_p384_is_on_curve(_p384_p, _p384_gy), 0, "x == p rejected (out of range)");
    assert_eq(pt_p384_is_on_curve(_p384_gx, _p384_p), 0, "y == p rejected (out of range)");

    # ============================================================
    # Group 6 — point arithmetic (2G against published vector)
    # ============================================================
    test_group("point arithmetic");

    var G = pt384_alloc();
    pt384_from_affine(G, _p384_gx, _p384_gy);

    # Round-trip via affine
    var ax = u384_zero();
    var ay = u384_zero();
    pt384_to_affine(ax, ay, G);
    assert_eq(u384_eq(ax, _p384_gx), 1, "affine(G).x == gx");
    assert_eq(u384_eq(ay, _p384_gy), 1, "affine(G).y == gy");

    # 2G — from SEC 2 / NIST test data:
    #   2G.x = 08D999057BA3D2D969260045C55B97F089025959A6F434D651D207D19FB96E9E
    #          4FE0E86EBE0E64F85B96A9C75295DF61
    #   2G.y = 8E80F1FA5B1B3CEDB7BFE8DFFD6DBA74B275D875BC6CC43E904E505F256AB425
    #          5FFD43E94D39E22D61501E700A940E80
    var G2 = pt384_alloc();
    pt384_double(G2, G);
    pt384_to_affine(ax, ay, G2);
    var ax_be = alloc(48);
    var ay_be = alloc(48);
    u384_store_be(ax_be, ax);
    u384_store_be(ay_be, ay);
    assert_streq(hex_encode(ax_be, 48),
        "08d999057ba3d2d969260045c55b97f089025959a6f434d651d207d19fb96e9e4fe0e86ebe0e64f85b96a9c75295df61",
        "(2G).x matches published P-384 vector");
    assert_streq(hex_encode(ay_be, 48),
        "8e80f1fa5b1b3cedb7bfe8dffd6dba74b275d875bc6cc43e904e505f256ab4255ffd43e94d39e22d61501e700a940e80",
        "(2G).y matches published P-384 vector");

    # G + O = G
    var O = pt384_alloc();
    pt384_set_infinity(O);
    var Gsum = pt384_alloc();
    pt384_add(Gsum, G, O);
    var bx = u384_zero(); var by = u384_zero();
    pt384_to_affine(bx, by, Gsum);
    assert_eq(u384_eq(bx, _p384_gx), 1, "G + O == G (x)");
    assert_eq(u384_eq(by, _p384_gy), 1, "G + O == G (y)");

    # n * G = O
    var nG = pt384_alloc();
    pt384_scalarmul(nG, _p384_n, G);
    assert_eq(pt384_is_infinity(nG), 1, "n * G == O");

    # ============================================================
    # Group 7 — ECDSA verify (RFC 6979 §A.2.6)
    # ============================================================
    test_group("ecdsa_p384_verify — RFC 6979 P-384/SHA-384");

    # Pubkey:
    #   Ux = ec3a4e415b4e19a4568618029f427fa5da9a8bc4ae92e02e06aae5286b300c64def8f0ea9055866064a254515480bc13
    #   Uy = 8015d9b72d7d57244ea8ef9ac0c621896708a59367f9dfb9f54ca84b3f1c9db1288b231c3ae0d4fe7344fd2533264720
    var pk = hex_decode("ec3a4e415b4e19a4568618029f427fa5da9a8bc4ae92e02e06aae5286b300c64def8f0ea9055866064a254515480bc138015d9b72d7d57244ea8ef9ac0c621896708a59367f9dfb9f54ca84b3f1c9db1288b231c3ae0d4fe7344fd2533264720", 192);

    # Test 7a: message = "sample"
    # r = 94EDBB92A5ECB8AAD4736E56C691916B3F88140666CE9FA73D64C4EA95AD133C81A648152E44ACF96E36DD1E80FABE46
    # s = 99EF4AEB15F178CEA1FE40DB2603138F130E740A19624526203B6351D0A3A94FA329C145786E679E7B82C71A38628AC8
    var sig1 = hex_decode("94edbb92a5ecb8aad4736e56c691916b3f88140666ce9fa73d64c4ea95ad133c81a648152e44acf96e36dd1e80fabe4699ef4aeb15f178cea1fe40db2603138f130e740a19624526203b6351d0a3a94fa329c145786e679e7b82c71a38628ac8", 192);
    assert_eq(ecdsa_p384_verify(pk, "sample", 6, sig1), 1,
        "RFC 6979 §A.2.6 sample-msg signature valid");

    # Test 7b: message = "test"
    # r = 8203B63D3C853E8D77227FB377BCF7B7B772E97892A80F36AB775D509D7A5FEB0542A7F0812998DA8F1DD3CA3CF023DB
    # s = DDD0760448D42D8A43AF45AF836FCE4DE8BE06B485E9B61B827C2F13173923E06A739F040649A667BF3B828246BAA5A5
    var sig2 = hex_decode("8203b63d3c853e8d77227fb377bcf7b7b772e97892a80f36ab775d509d7a5feb0542a7f0812998da8f1dd3ca3cf023dbddd0760448d42d8a43af45af836fce4de8be06b485e9b61b827c2f13173923e06a739f040649a667bf3b828246baa5a5", 192);
    assert_eq(ecdsa_p384_verify(pk, "test", 4, sig2), 1,
        "RFC 6979 §A.2.6 test-msg signature valid");

    # ============================================================
    # Group 8 — negative cases
    # ============================================================
    test_group("ecdsa_p384_verify — negative cases");

    # Wrong message
    assert_eq(ecdsa_p384_verify(pk, "Sample", 6, sig1), 0,
        "modified message rejected");

    # Flipped bit in r
    var sig_bad = alloc(96);
    memcpy(sig_bad, sig1, 96);
    store8(sig_bad, (load8(sig_bad) & 0xFF) ^ 0x01);
    assert_eq(ecdsa_p384_verify(pk, "sample", 6, sig_bad), 0,
        "flipped bit in r rejected");

    # Flipped bit in s
    memcpy(sig_bad, sig1, 96);
    store8(sig_bad + 48, (load8(sig_bad + 48) & 0xFF) ^ 0x01);
    assert_eq(ecdsa_p384_verify(pk, "sample", 6, sig_bad), 0,
        "flipped bit in s rejected");

    # r = 0
    memcpy(sig_bad, sig1, 96);
    memset(sig_bad, 0, 48);
    assert_eq(ecdsa_p384_verify(pk, "sample", 6, sig_bad), 0,
        "r == 0 rejected");

    # s = 0
    memcpy(sig_bad, sig1, 96);
    memset(sig_bad + 48, 0, 48);
    assert_eq(ecdsa_p384_verify(pk, "sample", 6, sig_bad), 0,
        "s == 0 rejected");

    # r = n (out of range)
    memcpy(sig_bad, sig1, 96);
    u384_store_be(sig_bad, _p384_n);
    assert_eq(ecdsa_p384_verify(pk, "sample", 6, sig_bad), 0,
        "r == n rejected");

    # s = n
    memcpy(sig_bad, sig1, 96);
    u384_store_be(sig_bad + 48, _p384_n);
    assert_eq(ecdsa_p384_verify(pk, "sample", 6, sig_bad), 0,
        "s == n rejected");

    # Off-curve public key — flip a bit in Qy.
    var pk_bad = alloc(96);
    memcpy(pk_bad, pk, 96);
    store8(pk_bad + 48, (load8(pk_bad + 48) & 0xFF) ^ 0x01);
    assert_eq(ecdsa_p384_verify(pk_bad, "sample", 6, sig1), 0,
        "off-curve pubkey rejected");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
