# rsa.bcyr — RSA verify / sign / modexp benchmarks (3.6.6).
#
# Standalone bench file (NOT folded into sigil.bcyr) because the RSA
# stack (bignum + rsa + x509) on top of sigil.bcyr's mldsa include would
# push the preprocessor expansion past the 1 MB cap (CLAUDE.md quirk #8).
#
# Rows quantify the 3.6.6 Montgomery-on-verify switch and the CRT sign
# speed-up:
#   rsa2048_verify_sha256       end-to-end PKCS#1 v1.5 verify (Montgomery)
#   rsa2048_verify_schoolbook   direct s^e mod n via bn_modexp   (pre-3.6.6)
#   rsa2048_verify_montgomery   direct s^e mod n via bn_mont_modexp (3.6.6)
#   rsa2048_sign_sha256_crt     end-to-end v1.5 sign (CRT + blinding)
#   rsa2048_modexp_fullwidth    direct m^d mod n full-width (no CRT)

include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/string.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bench.cyr"
include "lib/bigint.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/sha512.cyr"
include "src/sha384.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"
include "src/x509.cyr"
include "src/bignum.cyr"
include "src/rsa.cyr"

fn main() {
    alloc_init();

    var n = hex_decode("", 512);
    var e = hex_decode("010001", 6);
    var msg = hex_decode("736967696c2052534120504b435323312076312e35204b4154206d657373616765", 66);
    var sig = hex_decode("", 512);

    # Parse the PKCS#1 private key into an RSAK struct (for sign + d).
    var rpk = hex_decode("", 2384);
    var key = alloc(2384);
    rsa_privkey_from_der(rpk, 1192, key);
    var d = key + 528;                  # RSAK_D
    var dlen = load64(key + 2336);      # RSAK_DLEN

    # Bignum operands (2048-bit = 32 limbs).
    var s_bn[512];  bn_from_be(&s_bn, 32, sig, 256);
    var n_bn[512];  bn_from_be(&n_bn, 32, n, 256);
    var mx_out[512];

    var benches = vec_new();
    var rounds = 10;
    var ri = 0;
    var bi = 0;

    # End-to-end PKCS#1 v1.5 verify (Montgomery on the modexp).
    var b_v = bench_new("rsa2048_verify_sha256");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_v);
        bi = 0;
        while (bi < 50) { rsa_pkcs1v15_verify_sha256(n, 256, e, 3, msg, 33, sig, 256); bi = bi + 1; }
        bench_batch_stop(b_v, 50);
        ri = ri + 1;
    }
    vec_push(benches, b_v);

    # Direct verify modexp: schoolbook (pre-3.6.6) vs Montgomery (3.6.6).
    var b_sch = bench_new("rsa2048_verify_schoolbook");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_sch);
        bi = 0;
        while (bi < 50) { bn_modexp(&mx_out, &s_bn, e, 3, &n_bn, 32); bi = bi + 1; }
        bench_batch_stop(b_sch, 50);
        ri = ri + 1;
    }
    vec_push(benches, b_sch);

    var b_mont = bench_new("rsa2048_verify_montgomery");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_mont);
        bi = 0;
        while (bi < 50) { bn_mont_modexp(&mx_out, &s_bn, e, 3, &n_bn, 32); bi = bi + 1; }
        bench_batch_stop(b_mont, 50);
        ri = ri + 1;
    }
    vec_push(benches, b_mont);

    # End-to-end v1.5 sign (CRT + base blinding + verify-after-sign).
    var sigout = alloc(256);
    var b_sign = bench_new("rsa2048_sign_sha256_crt");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_sign);
        bi = 0;
        while (bi < 5) { rsa_pkcs1v15_sign_sha256(key, msg, 33, sigout); bi = bi + 1; }
        bench_batch_stop(b_sign, 5);
        ri = ri + 1;
    }
    vec_push(benches, b_sign);

    # Direct full-width secret modexp m^d mod n (the cost CRT avoids).
    var b_full = bench_new("rsa2048_modexp_fullwidth");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_full);
        bi = 0;
        while (bi < 5) { bn_mont_modexp(&mx_out, &s_bn, d, dlen, &n_bn, 32); bi = bi + 1; }
        bench_batch_stop(b_full, 5);
        ri = ri + 1;
    }
    vec_push(benches, b_full);

    syscall(1, 1, "=== Sigil RSA Benchmarks ===\n", 28);
    bench_report_all(benches);
    return 0;
}

var r = main();
syscall(60, r);
