# sigil.bcyr — benchmarks for sigil crypto operations

include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/string.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bench.cyr"
include "lib/bigint.cyr"

include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "lib/ct.cyr"
include "src/ct.cyr"
include "src/hmac.cyr"
include "src/hkdf.cyr"
include "src/aes_gcm.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/mldsa_params.cyr"
include "src/mldsa_reduce.cyr"
include "src/mldsa_ntt.cyr"

fn main() {
    alloc_init();
    ed25519_init();

    var data = alloc(4096);
    memset(data, 0x42, 4096);

    var benches = vec_new();
    var rounds = 10;

    # ============================================================
    # SHA-256 (4KB)
    # ============================================================
    var b1 = bench_new("sha256_4kb");
    var digest = alloc(32);
    var ri = 0;
    while (ri < rounds) {
        bench_batch_start(b1);
        var bi = 0;
        while (bi < 100) {
            sha256(data, 4096, digest);
            bi = bi + 1;
        }
        bench_batch_stop(b1, 100);
        ri = ri + 1;
    }
    vec_push(benches, b1);

    # ============================================================
    # SHA-512 (4KB)
    # ============================================================
    var b2 = bench_new("sha512_4kb");
    var digest512 = alloc(64);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b2);
        var bi = 0;
        while (bi < 100) {
            sha512(data, 4096, digest512);
            bi = bi + 1;
        }
        bench_batch_stop(b2, 100);
        ri = ri + 1;
    }
    vec_push(benches, b2);

    # ============================================================
    # Field multiply (fp_mul)
    # ============================================================
    var b3 = bench_new("fp_mul");
    var fa = u256_from_hex("6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296");
    var fb = u256_from_hex("4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5");
    var fr = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b3);
        var bi = 0;
        while (bi < 1000) {
            fp_mul(fr, fa, fb);
            bi = bi + 1;
        }
        bench_batch_stop(b3, 1000);
        ri = ri + 1;
    }
    vec_push(benches, b3);

    # ============================================================
    # Field inversion (fp_inv) — 255 iterations of fp_mul
    # ============================================================
    var b4 = bench_new("fp_inv");
    var finv = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b4);
        var bi = 0;
        while (bi < 10) {
            fp_inv(finv, fa);
            bi = bi + 1;
        }
        bench_batch_stop(b4, 10);
        ri = ri + 1;
    }
    vec_push(benches, b4);

    # ============================================================
    # Scalar reduce (sc_reduce)
    # ============================================================
    var b5 = bench_new("sc_reduce");
    var scr_in = alloc(64);
    memset(scr_in, 0xAB, 64);
    var scr_out = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b5);
        var bi = 0;
        while (bi < 100) {
            sc_reduce(scr_out, scr_in);
            bi = bi + 1;
        }
        bench_batch_stop(b5, 100);
        ri = ri + 1;
    }
    vec_push(benches, b5);

    # ============================================================
    # Point double (ge_double)
    # ============================================================
    var b6 = bench_new("ge_double");
    var pt = ge_alloc();
    var pt2 = ge_alloc();
    ge_copy(pt, _ed_B);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b6);
        var bi = 0;
        while (bi < 100) {
            ge_double(pt2, pt);
            bi = bi + 1;
        }
        bench_batch_stop(b6, 100);
        ri = ri + 1;
    }
    vec_push(benches, b6);

    # ============================================================
    # Scalar multiply [s]B (full 256-bit)
    # ============================================================
    var b7 = bench_new("ge_scalarmult");
    var scalar = hex_decode("307c83864f2833cb427a2ef1c00a013cfdff2768d980c0a3a520f006904de94f", 64);
    var sm_out = ge_alloc();
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b7);
        ge_scalarmult(sm_out, scalar, _ed_B);
        bench_batch_stop(b7, 1);
        ri = ri + 1;
    }
    vec_push(benches, b7);

    # ============================================================
    # Ed25519 keypair
    # ============================================================
    var b8 = bench_new("ed25519_keypair");
    var seed = hex_decode("9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60", 64);
    var sk = alloc(64);
    var pk = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b8);
        ed25519_keypair(seed, sk, pk);
        bench_batch_stop(b8, 1);
        ri = ri + 1;
    }
    vec_push(benches, b8);

    # ============================================================
    # Ed25519 sign
    # ============================================================
    var b9 = bench_new("ed25519_sign");
    ed25519_keypair(seed, sk, pk);
    var sig = alloc(64);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b9);
        ed25519_sign(sk, "benchmark message", 17, sig);
        bench_batch_stop(b9, 1);
        ri = ri + 1;
    }
    vec_push(benches, b9);

    # ============================================================
    # Ed25519 verify — [S]B uses fixed-base table, [h]A uses
    # variable-base constant-time scalarmult, so this bench covers
    # both the fast path and the CT path.
    # ============================================================
    var b_verify = bench_new("ed25519_verify");
    ed25519_sign(sk, "benchmark message", 17, sig);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_verify);
        ed25519_verify(pk, "benchmark message", 17, sig);
        bench_batch_stop(b_verify, 1);
        ri = ri + 1;
    }
    vec_push(benches, b_verify);

    # ============================================================
    # Constant-time compare (32 bytes)
    # ============================================================
    var b10 = bench_new("ct_eq_32b");
    var ca = alloc(32);
    var cb = alloc(32);
    memset(ca, 0xFF, 32);
    memset(cb, 0xFF, 32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b10);
        var bi = 0;
        while (bi < 10000) {
            ct_eq_32(ca, cb);
            bi = bi + 1;
        }
        bench_batch_stop(b10, 10000);
        ri = ri + 1;
    }
    vec_push(benches, b10);

    # ============================================================
    # Hex encode (32 bytes)
    # ============================================================
    var b11 = bench_new("hex_encode_32b");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b11);
        var bi = 0;
        while (bi < 10000) {
            hex_encode(digest, 32);
            bi = bi + 1;
        }
        bench_batch_stop(b11, 10000);
        ri = ri + 1;
    }
    vec_push(benches, b11);

    # ============================================================
    # AES-256 key expansion — 32-byte key → 240-byte round-key schedule
    # ============================================================
    var b_aes_kx = bench_new("aes256_key_expansion");
    var aes_key = hex_decode("feffe9928665731c6d6a8f9467308308feffe9928665731c6d6a8f9467308308", 64);
    var aes_rk = alloc(240);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_aes_kx);
        var bi = 0;
        while (bi < 1000) {
            aes256_key_expand(aes_key, aes_rk);
            bi = bi + 1;
        }
        bench_batch_stop(b_aes_kx, 1000);
        ri = ri + 1;
    }
    vec_push(benches, b_aes_kx);

    # ============================================================
    # AES-256 single-block encrypt — 16-byte input, 14 rounds
    # ============================================================
    var b_aes_enc = bench_new("aes256_encrypt_block");
    var aes_blk_in = alloc(16);
    memset(aes_blk_in, 0x00, 16);
    var aes_blk_out = alloc(16);
    aes256_key_expand(aes_key, aes_rk);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_aes_enc);
        var bi = 0;
        while (bi < 10000) {
            aes256_encrypt_block(aes_rk, aes_blk_in, aes_blk_out);
            bi = bi + 1;
        }
        bench_batch_stop(b_aes_enc, 10000);
        ri = ri + 1;
    }
    vec_push(benches, b_aes_enc);

    # ============================================================
    # AES-GCM encrypt 1 KB — CTR path + GHASH over 64 blocks
    # ============================================================
    var b_gcm_enc = bench_new("aes_gcm_encrypt_1kb");
    var gcm_iv = hex_decode("cafebabefacedbaddecaf888", 24);
    var gcm_pt = alloc(1024);
    memset(gcm_pt, 0x42, 1024);
    var gcm_ct = alloc(1024);
    var gcm_tag = alloc(16);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_gcm_enc);
        var bi = 0;
        while (bi < 100) {
            aes_gcm_encrypt(aes_key, gcm_iv, 0, 0, gcm_pt, 1024, gcm_ct, gcm_tag);
            bi = bi + 1;
        }
        bench_batch_stop(b_gcm_enc, 100);
        ri = ri + 1;
    }
    vec_push(benches, b_gcm_enc);

    # ============================================================
    # AES-GCM decrypt 1 KB — valid tag path (full CTR decrypt)
    # ============================================================
    # Produce one known-good (ct, tag) pair to decrypt in the loop.
    aes_gcm_encrypt(aes_key, gcm_iv, 0, 0, gcm_pt, 1024, gcm_ct, gcm_tag);
    var gcm_dec_out = alloc(1024);
    var b_gcm_dec = bench_new("aes_gcm_decrypt_1kb_valid");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_gcm_dec);
        var bi = 0;
        while (bi < 100) {
            aes_gcm_decrypt(aes_key, gcm_iv, 0, 0, gcm_ct, 1024, gcm_tag, gcm_dec_out);
            bi = bi + 1;
        }
        bench_batch_stop(b_gcm_dec, 100);
        ri = ri + 1;
    }
    vec_push(benches, b_gcm_dec);

    # ============================================================
    # AES-GCM decrypt 1 KB — forged tag path
    # MUST be within ~10% of the valid-tag bench — constant-time
    # tag verification (no early exit on mismatch, no CTR skip
    # on failure). If this is dramatically faster than _valid,
    # there is an early-exit bug.
    # ============================================================
    var gcm_forged_tag = alloc(16);
    memcpy(gcm_forged_tag, gcm_tag, 16);
    store8(gcm_forged_tag, (load8(gcm_forged_tag) ^ 0x01) & 0xFF);
    var b_gcm_forged = bench_new("aes_gcm_decrypt_1kb_forged");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_gcm_forged);
        var bi = 0;
        while (bi < 100) {
            aes_gcm_decrypt(aes_key, gcm_iv, 0, 0, gcm_ct, 1024, gcm_forged_tag, gcm_dec_out);
            bi = bi + 1;
        }
        bench_batch_stop(b_gcm_forged, 100);
        ri = ri + 1;
    }
    vec_push(benches, b_gcm_forged);

    # ============================================================
    # HKDF-SHA256 extract — PRK = HMAC(salt, IKM) over 64B IKM + 32B salt
    # ============================================================
    var b_hkdf_extract = bench_new("hkdf_extract");
    var hkdf_ikm = alloc(64);
    memset(hkdf_ikm, 0x0B, 64);
    var hkdf_salt = alloc(32);
    memset(hkdf_salt, 0x42, 32);
    var hkdf_prk = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_hkdf_extract);
        var bi = 0;
        while (bi < 1000) {
            hkdf_extract(hkdf_salt, 32, hkdf_ikm, 64, hkdf_prk);
            bi = bi + 1;
        }
        bench_batch_stop(b_hkdf_extract, 1000);
        ri = ri + 1;
    }
    vec_push(benches, b_hkdf_extract);

    # ============================================================
    # HKDF-SHA256 expand — derive 4096 bytes of OKM per iteration
    # (128 SHA-256 HMAC rounds per call; this is the expensive path)
    # ============================================================
    var b_hkdf_expand = bench_new("hkdf_expand_4kb");
    # Drive the expander from a well-formed PRK produced by extract.
    hkdf_extract(hkdf_salt, 32, hkdf_ikm, 64, hkdf_prk);
    var hkdf_info = alloc(32);
    memset(hkdf_info, 0x73, 32);
    var hkdf_okm = alloc(4096);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_hkdf_expand);
        var bi = 0;
        while (bi < 100) {
            hkdf_expand(hkdf_prk, 32, hkdf_info, 32, hkdf_okm, 4096);
            bi = bi + 1;
        }
        bench_batch_stop(b_hkdf_expand, 100);
        ri = ri + 1;
    }
    vec_push(benches, b_hkdf_expand);

    # ============================================================
    # ML-DSA NTT (forward) — one 256-coeff poly per iteration.
    # The NTT dominates keygen / sign / verify cost; this bench
    # measures the primitive in isolation so regressions show up
    # before they hit the full signature bench.
    # ============================================================
    mldsa_ntt_init();
    var ntt_poly = alloc(256 * 8);
    var ntt_i = 0;
    while (ntt_i < 256) {
        store64(ntt_poly + ntt_i * 8, ntt_i);
        ntt_i = ntt_i + 1;
    }
    var b_ntt = bench_new("mldsa_ntt");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_ntt);
        var bi = 0;
        while (bi < 100) {
            mldsa_ntt(ntt_poly);
            bi = bi + 1;
        }
        bench_batch_stop(b_ntt, 100);
        ri = ri + 1;
    }
    vec_push(benches, b_ntt);

    var b_invntt = bench_new("mldsa_invntt");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b_invntt);
        var bi = 0;
        while (bi < 100) {
            mldsa_invntt_tomont(ntt_poly);
            bi = bi + 1;
        }
        bench_batch_stop(b_invntt, 100);
        ri = ri + 1;
    }
    vec_push(benches, b_invntt);

    # Report
    syscall(1, 1, "=== Sigil Benchmarks ===\n", 24);
    bench_report_all(benches);
    return 0;
}

var r = main();
syscall(60, r);
