# sigil.bcyr — benchmarks for sigil crypto operations

include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/string.cyr"
include "lib/json.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bench.cyr"
include "lib/bigint.cyr"

include "src/types.cyr"
include "src/error.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/ct.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"

fn main() {
    alloc_init();
    ed25519_init();

    var data = alloc(4096);
    memset(data, 0x42, 4096);

    var benches = vec_new();
    var rounds = 10;

    # ============================================================
    # SHA-256 (4KB)
    # ============================================================
    var b1 = bench_new("sha256_4kb");
    var digest = alloc(32);
    var ri = 0;
    while (ri < rounds) {
        bench_batch_start(b1);
        var bi = 0;
        while (bi < 100) {
            sha256(data, 4096, digest);
            bi = bi + 1;
        }
        bench_batch_stop(b1, 100);
        ri = ri + 1;
    }
    vec_push(benches, b1);

    # ============================================================
    # SHA-512 (4KB)
    # ============================================================
    var b2 = bench_new("sha512_4kb");
    var digest512 = alloc(64);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b2);
        var bi = 0;
        while (bi < 100) {
            sha512(data, 4096, digest512);
            bi = bi + 1;
        }
        bench_batch_stop(b2, 100);
        ri = ri + 1;
    }
    vec_push(benches, b2);

    # ============================================================
    # Field multiply (fp_mul)
    # ============================================================
    var b3 = bench_new("fp_mul");
    var fa = u256_from_hex("6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296");
    var fb = u256_from_hex("4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5");
    var fr = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b3);
        var bi = 0;
        while (bi < 1000) {
            fp_mul(fr, fa, fb);
            bi = bi + 1;
        }
        bench_batch_stop(b3, 1000);
        ri = ri + 1;
    }
    vec_push(benches, b3);

    # ============================================================
    # Field inversion (fp_inv) — 255 iterations of fp_mul
    # ============================================================
    var b4 = bench_new("fp_inv");
    var finv = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b4);
        var bi = 0;
        while (bi < 10) {
            fp_inv(finv, fa);
            bi = bi + 1;
        }
        bench_batch_stop(b4, 10);
        ri = ri + 1;
    }
    vec_push(benches, b4);

    # ============================================================
    # Scalar reduce (sc_reduce)
    # ============================================================
    var b5 = bench_new("sc_reduce");
    var scr_in = alloc(64);
    memset(scr_in, 0xAB, 64);
    var scr_out = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b5);
        var bi = 0;
        while (bi < 100) {
            sc_reduce(scr_out, scr_in);
            bi = bi + 1;
        }
        bench_batch_stop(b5, 100);
        ri = ri + 1;
    }
    vec_push(benches, b5);

    # ============================================================
    # Point double (ge_double)
    # ============================================================
    var b6 = bench_new("ge_double");
    var pt = ge_alloc();
    var pt2 = ge_alloc();
    ge_copy(pt, _ed_B);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b6);
        var bi = 0;
        while (bi < 100) {
            ge_double(pt2, pt);
            bi = bi + 1;
        }
        bench_batch_stop(b6, 100);
        ri = ri + 1;
    }
    vec_push(benches, b6);

    # ============================================================
    # Scalar multiply [s]B (full 256-bit)
    # ============================================================
    var b7 = bench_new("ge_scalarmult");
    var scalar = hex_decode("307c83864f2833cb427a2ef1c00a013cfdff2768d980c0a3a520f006904de94f", 64);
    var sm_out = ge_alloc();
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b7);
        ge_scalarmult(sm_out, scalar, _ed_B);
        bench_batch_stop(b7, 1);
        ri = ri + 1;
    }
    vec_push(benches, b7);

    # ============================================================
    # Ed25519 keypair
    # ============================================================
    var b8 = bench_new("ed25519_keypair");
    var seed = hex_decode("9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60", 64);
    var sk = alloc(64);
    var pk = alloc(32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b8);
        ed25519_keypair(seed, sk, pk);
        bench_batch_stop(b8, 1);
        ri = ri + 1;
    }
    vec_push(benches, b8);

    # ============================================================
    # Ed25519 sign
    # ============================================================
    var b9 = bench_new("ed25519_sign");
    ed25519_keypair(seed, sk, pk);
    var sig = alloc(64);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b9);
        ed25519_sign(sk, "benchmark message", 17, sig);
        bench_batch_stop(b9, 1);
        ri = ri + 1;
    }
    vec_push(benches, b9);

    # ============================================================
    # Constant-time compare (32 bytes)
    # ============================================================
    var b10 = bench_new("ct_eq_32b");
    var ca = alloc(32);
    var cb = alloc(32);
    memset(ca, 0xFF, 32);
    memset(cb, 0xFF, 32);
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b10);
        var bi = 0;
        while (bi < 10000) {
            ct_eq_32(ca, cb);
            bi = bi + 1;
        }
        bench_batch_stop(b10, 10000);
        ri = ri + 1;
    }
    vec_push(benches, b10);

    # ============================================================
    # Hex encode (32 bytes)
    # ============================================================
    var b11 = bench_new("hex_encode_32b");
    ri = 0;
    while (ri < rounds) {
        bench_batch_start(b11);
        var bi = 0;
        while (bi < 10000) {
            hex_encode(digest, 32);
            bi = bi + 1;
        }
        bench_batch_stop(b11, 10000);
        ri = ri + 1;
    }
    vec_push(benches, b11);

    # Report
    syscall(1, 1, "=== Sigil Benchmarks ===\n", 24);
    bench_report_all(benches);
    return 0;
}

var r = main();
syscall(60, r);
