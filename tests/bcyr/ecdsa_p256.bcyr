# ecdsa_p256.bcyr — verify-path benchmarks for the 3.2.1 ECDSA
# surface. Single row: ecdsa_p256_verify on the RFC 6979 "sample"
# vector. Baseline for the 3.2.x bench-tuning passes that will land
# Solinas-style P-256 reduction once the verify path is in tree.

include "lib/alloc.cyr"
include "lib/freelist.cyr"
include "lib/str.cyr"
include "lib/string.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fmt.cyr"
include "lib/bayan.cyr"
include "lib/sakshi.cyr"
include "lib/chrono.cyr"
include "lib/bench.cyr"
include "lib/ct.cyr"

include "lib/thread_local.cyr"
include "src/crypto_scratch.cyr"
include "src/types.cyr"
include "src/error.cyr"
include "lib/random.cyr"
include "src/random.cyr"
include "src/sha_ni.cyr"
include "src/sha256.cyr"
include "src/hex.cyr"
include "src/hmac.cyr"
include "src/hkdf.cyr"
include "src/sha512.cyr"
include "src/bigint_ext.cyr"
include "src/ed25519.cyr"
include "src/ecdsa_p256.cyr"

fn main() {
    alloc_init();
    _p256_init();

    var benches = vec_new();

    # RFC 6979 §A.2.5 sample-msg vector.
    var pk = hex_decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299", 128);
    var sig = hex_decode("efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8", 128);

    # Warm caches — first verify also pulls in init tables.
    ecdsa_p256_verify(pk, "sample", 6, sig);

    var b_verify = bench_new("ecdsa_p256_verify");
    var ri = 0;
    while (ri < 5) {
        bench_batch_start(b_verify);
        var bi = 0;
        while (bi < 3) {
            ecdsa_p256_verify(pk, "sample", 6, sig);
            bi = bi + 1;
        }
        bench_batch_stop(b_verify, 3);
        ri = ri + 1;
    }
    vec_push(benches, b_verify);

    syscall(1, 1, "=== ECDSA P-256 Benchmarks ===\n", 30);
    bench_report_all(benches);
    return 0;
}

var r = main();
syscall(60, r);
