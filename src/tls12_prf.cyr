# tls12_prf.cyr -- TLS 1.2 pseudorandom function (RFC 5246 sec 5)
#
# TLS 1.2's key schedule is:
#   PRF(sec, label, seed) = P_<hash>(sec, label || seed)
#   P_hash(sec, seed) = HMAC_hash(sec, A(1) || seed)
#                        || HMAC_hash(sec, A(2) || seed)
#                        || HMAC_hash(sec, A(3) || seed) || ...
#   with A(0) = seed,  A(i) = HMAC_hash(sec, A(i-1)).
#
# TLS 1.2 (RFC 5246 sec 5) replaced the TLS 1.0/1.1 MD5xorSHA-1 split PRF
# with a single negotiated hash: the default cipher suites use
# `P_SHA256`; the `*_SHA384` suites (RFC 5288/5289) use `P_SHA384`.
# Both are provided here. Built directly on the existing
# `hmac_sha256` (src/hmac.cyr) and `hmac_sha384` (src/hmac_sha384.cyr);
# no new hashing primitive is introduced.
#
# Scope: this is the TLS 1.2 master-secret / key-block / Finished KDF
# for the cyrius native-TLS arc. The working buffers are function-scope
# `var X[N]` arrays, i.e. STATIC globals (CLAUDE.md quirk #1) — and a
# `secret var X[N]` array is ALSO a function-scope static (the `secret`
# qualifier only adds a whole-array zeroize on scope exit; it does NOT
# make the array per-call). They are therefore SHARED across threads and
# raced concurrent PRF callers. 3.9.7 banked them across `cbank()` lanes
# (each `var X[N]` widened to `[N*SIGIL_CRYPTO_BANKS]`, fn operates on
# `&X + cbank()*N`; see src/crypto_scratch.cyr). Output (master secret /
# key block) is key material, so each fn `memset`s ONLY its own lane
# before return (quirk #9 / ADR 0004 — plain `var`, NEVER `secret var`,
# whose whole-array wipe would clobber a sibling worker's live lane). The
# caller owns zeroization of `out`.
#
# Combined `label || seed` is capped at TLS12_PRF_SEED_MAX bytes
# (generous: real TLS seeds are label<=~15 + two 32-byte randoms ~ 80).
# Over-cap inputs return 0 (no output written) rather than truncating.

var TLS12_PRF_SEED_MAX = 256;   # max length of (label || seed)

# Internal P_hash core. `is384` selects HMAC-SHA384 (hlen 48) vs
# HMAC-SHA256 (hlen 32). `seedp`/`seedp_len` is the already-built
# `label || seed`. Writes exactly `out_len` bytes to `out`; returns
# `out_len`, or 0 if `seedp_len` exceeds the cap.
fn _tls12_p_hash(is384, sec, secret_len, seedp, seedp_len, out, out_len): i64 {
    if (seedp_len > TLS12_PRF_SEED_MAX) { return 0; }
    var hlen = 32;
    if (is384 == 1) { hlen = 48; }

    # A(i), one HMAC output block, and the HMAC input `A(i) || seedp`,
    # banked across `cbank()` lanes (quirk #1: these are STATIC globals,
    # raced by concurrent PRF callers). All hold derived key material, so
    # the calling worker's lane is `memset` to 0 before every return
    # (quirk #9 — plain `var` + per-lane wipe, NEVER `secret var`).
    var bk = cbank();
    var A[3072];     var Ab     = &A     + bk * 48;    # 48  * SIGIL_CRYPTO_BANKS
    var block[3072]; var blockb = &block + bk * 48;
    var hin[19456];  var hinb   = &hin   + bk * 304;   # 304 * SIGIL_CRYPTO_BANKS

    # A(1) = HMAC(sec, seedp)
    if (is384 == 1) { hmac_sha384(sec, secret_len, seedp, seedp_len, Ab); }
    else { hmac_sha256(sec, secret_len, seedp, seedp_len, Ab); }

    var filled = 0;
    while (filled < out_len) {
        # block = HMAC(sec, A(i) || seedp)
        memcpy(hinb, Ab, hlen);
        memcpy(hinb + hlen, seedp, seedp_len);
        if (is384 == 1) { hmac_sha384(sec, secret_len, hinb, hlen + seedp_len, blockb); }
        else { hmac_sha256(sec, secret_len, hinb, hlen + seedp_len, blockb); }

        # Emit min(hlen, remaining) bytes of this block.
        var take = hlen;
        var rem = out_len - filled;
        if (take > rem) { take = rem; }
        memcpy(out + filled, blockb, take);
        filled = filled + take;

        # A(i+1) = HMAC(sec, A(i))
        if (is384 == 1) { hmac_sha384(sec, secret_len, Ab, hlen, blockb); }
        else { hmac_sha256(sec, secret_len, Ab, hlen, blockb); }
        memcpy(Ab, blockb, hlen);
    }
    # Wipe this lane's secret PRF state (quirk #9).
    memset(Ab, 0, 48);
    memset(blockb, 0, 48);
    memset(hinb, 0, 304);
    return out_len;
}

# TLS 1.2 PRF over SHA-256 (RFC 5246 sec 5). Derives `out_len` bytes into
# `out` from `secret`, the ASCII `label`, and `seed`. Returns `out_len`
# on success, or 0 if `label_len + seed_len > TLS12_PRF_SEED_MAX`.
fn tls12_prf_sha256(sec, secret_len, label, label_len, seed, seed_len, out, out_len): i64 {
    var slen = label_len + seed_len;
    if (slen > TLS12_PRF_SEED_MAX) { return 0; }
    # `label || seed`, banked across `cbank()` lanes (quirk #1: STATIC
    # global raced by concurrent callers). Holds key-schedule input, so
    # the calling worker's lane is wiped before return (quirk #9 — plain
    # `var` + per-lane memset, NEVER `secret var`).
    var bk = cbank();
    var seedp[16384];           var seedpb = &seedp + bk * 256;   # 256 * SIGIL_CRYPTO_BANKS
    memcpy(seedpb, label, label_len);
    memcpy(seedpb + label_len, seed, seed_len);
    var rc = _tls12_p_hash(0, sec, secret_len, seedpb, slen, out, out_len);
    memset(seedpb, 0, 256);
    return rc;
}

# TLS 1.2 PRF over SHA-384 (RFC 5246 sec 5 with the SHA-384 suites'
# negotiated hash). Same contract as `tls12_prf_sha256`.
fn tls12_prf_sha384(sec, secret_len, label, label_len, seed, seed_len, out, out_len): i64 {
    var slen = label_len + seed_len;
    if (slen > TLS12_PRF_SEED_MAX) { return 0; }
    # `label || seed`, banked across `cbank()` lanes (see tls12_prf_sha256).
    var bk = cbank();
    var seedp[16384];           var seedpb = &seedp + bk * 256;   # 256 * SIGIL_CRYPTO_BANKS
    memcpy(seedpb, label, label_len);
    memcpy(seedpb + label_len, seed, seed_len);
    var rc = _tls12_p_hash(1, sec, secret_len, seedpb, slen, out, out_len);
    memset(seedpb, 0, 256);
    return rc;
}
