# ecdsa_sign.cyr — ECDSA P-256 / P-384 signing with RFC 6979
# deterministic nonces. Issue line item 3 of the cyrius native-TLS
# arc (3.5.9). Pairs with the existing ecdsa_p256_verify /
# ecdsa_p384_verify and consumes the private scalars parsed by
# src/privkey.cyr (3.5.8).
#
# Construction (SEC 1 §4.1.3 + RFC 6979 §3.2):
#   e   = leftmost qlen bits of H(m), reduced mod n
#   k   = RFC 6979 deterministic nonce (HMAC_DRBG over the curve hash)
#   R   = k·G ; r = R.x mod n
#   s   = k^(-1) · (e + r·d) mod n
#   sig = r || s  (raw, big-endian, fixed length) or DER SEQUENCE.
#
# Determinism (RFC 6979) removes the catastrophic dependence on a
# per-signature random nonce — a repeated or biased k leaks the
# private key (PS3 / Sony 2010). The nonce is derived from (d, H(m))
# via HMAC_DRBG keyed on the curve's hash (SHA-256 for P-256,
# SHA-384 for P-384), so signing is a pure function of key + message.
#
# Security floor (CLAUDE.md § Security Hardening):
#   - The nonce k, the HMAC_DRBG state (K, V), the private scalar, and
#     every (e + r·d) / k^(-1) intermediate live in `secret var` stack
#     buffers, zeroized on scope exit. r and s are public outputs.
#   - Scalar inversion / multiply reuse the curve's existing mod-n
#     primitives (fn_p256_inv / fn_p256_mul, etc.).
#   - add-mod-n is carry-correct (the lib `u256_addmod` drops the
#     2^256 carry, which is wrong for the P-256/P-384 scalar field
#     where n ≈ 2^256 and a+b can exceed 2^256 — see _ecs_addmod_*).

# ================================================================
# Carry-correct scalar add mod n
# ================================================================
# r = (a + b) mod n, for a, b < n (n < 2^256). a+b can be up to
# 2n-2 > 2^256, so the 2^256 carry from u256_add MUST be honored.
# When carry == 1 the true sum is 2^256 + low; since a,b < n the low
# limbs are < n, so a single `u256_sub(r, r, n)` (which borrows and
# wraps, adding 2^256-n) yields the correct residue in [0, n).
fn _ecs_addmod_n_p256(r, a, b): i64 {
    var carry = u256_add(r, a, b);
    if (carry == 1) {
        u256_sub(r, r, _p256_n);
    } else {
        if (u256_cmp(r, _p256_n) >= 0) { u256_sub(r, r, _p256_n); }
    }
    return 0;
}

fn _ecs_addmod_n_p384(r, a, b): i64 {
    var carry = u384_add(r, a, b);
    if (carry == 1) {
        u384_sub(r, r, _p384_n);
    } else {
        if (u384_cmp(r, _p384_n) >= 0) { u384_sub(r, r, _p384_n); }
    }
    return 0;
}

# ================================================================
# RFC 6979 §3.2 — deterministic nonce (P-256 / HMAC-SHA256)
# ================================================================
# d_be:  32-byte big-endian private scalar (int2octets(x)).
# h1oct: 32-byte big-endian bits2octets(H(m)) = int2octets(e mod n).
# k_out: 32-byte big-endian nonce in [1, n-1].
# Returns 0 on success, -1 if no valid nonce within the retry bound.
#
# qlen == hlen == 256 for this curve/hash pair, so each HMAC round
# yields exactly one qlen block (T = V), and bits2int(T) = T.

# data = V(32) || sep(1) || d(32) || h1(32)  →  97 bytes
fn _rfc6979_build_p256(data, V, sep, d, h1): i64 {
    memcpy(data, V, 32);
    store8(data + 32, sep & 0xFF);
    memcpy(data + 33, d, 32);
    memcpy(data + 65, h1, 32);
    return 0;
}

# Per-lane secret zeroization of this function's banked HMAC_DRBG scratch
# (quirk #9 / ADR 0004). The V/K/Kt/Vt/data/d1/kint arrays are
# function-scope `var X[N]`, i.e. STATIC globals (quirk #1) — shared
# across concurrent signers, so they are banked across `cbank()` lanes
# (the concurrent-signers race in ecdsa_concurrent.tcyr). They carry the
# secret nonce / DRBG state, so they are plain `var` + a per-lane wipe
# (NEVER `secret var`: a whole-array wipe would clobber a sibling lane).
# Wipes ONLY the calling worker's lane.
fn _rfc6979_scrub_p256_lanes(V, K, Kt, Vt, data, d1, kint): i64 {
    memset(V, 0, 32);
    memset(K, 0, 32);
    memset(Kt, 0, 32);
    memset(Vt, 0, 32);
    memset(data, 0, 97);
    memset(d1, 0, 33);
    memset(kint, 0, 32);
    return 0;
}

fn _rfc6979_k_p256(d_be, h1oct, k_out): i64 {
    var bk = cbank();
    var V[2048];    var Vb    = &V    + bk * 32;   # 32 * SIGIL_CRYPTO_BANKS
    var K[2048];    var Kb    = &K    + bk * 32;
    var Kt[2048];   var Ktb   = &Kt   + bk * 32;
    var Vt[2048];   var Vtb   = &Vt   + bk * 32;
    var data[6208]; var datab = &data + bk * 97;   # 97 * SIGIL_CRYPTO_BANKS
    var d1[2112];   var d1b   = &d1   + bk * 33;    # 33 * SIGIL_CRYPTO_BANKS
    var kint[2048]; var kintb = &kint + bk * 32;

    var i = 0;
    while (i < 32) { store8(Vb + i, 0x01); store8(Kb + i, 0x00); i = i + 1; }

    # K = HMAC_K(V || 0x00 || int2octets(x) || bits2octets(h1))
    _rfc6979_build_p256(datab, Vb, 0x00, d_be, h1oct);
    hmac_sha256(Kb, 32, datab, 97, Ktb);
    memcpy(Kb, Ktb, 32);
    # V = HMAC_K(V)
    hmac_sha256(Kb, 32, Vb, 32, Vtb);
    memcpy(Vb, Vtb, 32);
    # K = HMAC_K(V || 0x01 || int2octets(x) || bits2octets(h1))
    _rfc6979_build_p256(datab, Vb, 0x01, d_be, h1oct);
    hmac_sha256(Kb, 32, datab, 97, Ktb);
    memcpy(Kb, Ktb, 32);
    # V = HMAC_K(V)
    hmac_sha256(Kb, 32, Vb, 32, Vtb);
    memcpy(Vb, Vtb, 32);

    var tries = 0;
    while (tries < 256) {
        # T = HMAC_K(V) (one block = qlen)
        hmac_sha256(Kb, 32, Vb, 32, Vtb);
        memcpy(Vb, Vtb, 32);
        # k = bits2int(T); accept iff 1 <= k <= n-1.
        u256_load_be(kintb, Vb);
        if (u256_is_zero(kintb) == 0) {
            if (u256_cmp(kintb, _p256_n) < 0) {
                u256_store_be(k_out, kintb);
                _rfc6979_scrub_p256_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
                return 0;
            }
        }
        # Reject: K = HMAC_K(V || 0x00); V = HMAC_K(V).
        memcpy(d1b, Vb, 32);
        store8(d1b + 32, 0x00);
        hmac_sha256(Kb, 32, d1b, 33, Ktb);
        memcpy(Kb, Ktb, 32);
        hmac_sha256(Kb, 32, Vb, 32, Vtb);
        memcpy(Vb, Vtb, 32);
        tries = tries + 1;
    }
    _rfc6979_scrub_p256_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
    return 0 - 1;
}

# ================================================================
# RFC 6979 §3.2 — deterministic nonce (P-384 / HMAC-SHA384)
# ================================================================
# 48-byte HMAC-SHA384 blocks; qlen == hlen == 384.

# data = V(48) || sep(1) || d(48) || h1(48)  →  145 bytes
fn _rfc6979_build_p384(data, V, sep, d, h1): i64 {
    memcpy(data, V, 48);
    store8(data + 48, sep & 0xFF);
    memcpy(data + 49, d, 48);
    memcpy(data + 97, h1, 48);
    return 0;
}

# Per-lane secret zeroization of this function's banked HMAC_DRBG scratch
# (quirk #9 / ADR 0004) — the P-384 mirror of _rfc6979_scrub_p256_lanes.
# The V/K/Kt/Vt/data/d1/kint arrays are function-scope `var X[N]`, i.e.
# STATIC globals (quirk #1) shared across concurrent signers, so they are
# banked across `cbank()` lanes (the concurrent-signers race in
# ecdsa_concurrent.tcyr). They carry the secret nonce / DRBG state, so they
# are plain `var` + a per-lane wipe (NEVER `secret var`: a whole-array wipe
# would clobber a sibling lane). Wipes ONLY the calling worker's lane.
fn _rfc6979_scrub_p384_lanes(V, K, Kt, Vt, data, d1, kint): i64 {
    memset(V, 0, 48);
    memset(K, 0, 48);
    memset(Kt, 0, 48);
    memset(Vt, 0, 48);
    memset(data, 0, 145);
    memset(d1, 0, 49);
    memset(kint, 0, 48);
    return 0;
}

fn _rfc6979_k_p384(d_be, h1oct, k_out): i64 {
    var bk = cbank();
    var V[3072];    var Vb    = &V    + bk * 48;    # 48 * SIGIL_CRYPTO_BANKS
    var K[3072];    var Kb    = &K    + bk * 48;
    var Kt[3072];   var Ktb   = &Kt   + bk * 48;
    var Vt[3072];   var Vtb   = &Vt   + bk * 48;
    var data[9280]; var datab = &data + bk * 145;   # 145 * SIGIL_CRYPTO_BANKS
    var d1[3136];   var d1b   = &d1   + bk * 49;     # 49 * SIGIL_CRYPTO_BANKS
    var kint[3072]; var kintb = &kint + bk * 48;

    var i = 0;
    while (i < 48) { store8(Vb + i, 0x01); store8(Kb + i, 0x00); i = i + 1; }

    _rfc6979_build_p384(datab, Vb, 0x00, d_be, h1oct);
    hmac_sha384(Kb, 48, datab, 145, Ktb);
    memcpy(Kb, Ktb, 48);
    hmac_sha384(Kb, 48, Vb, 48, Vtb);
    memcpy(Vb, Vtb, 48);
    _rfc6979_build_p384(datab, Vb, 0x01, d_be, h1oct);
    hmac_sha384(Kb, 48, datab, 145, Ktb);
    memcpy(Kb, Ktb, 48);
    hmac_sha384(Kb, 48, Vb, 48, Vtb);
    memcpy(Vb, Vtb, 48);

    var tries = 0;
    while (tries < 256) {
        hmac_sha384(Kb, 48, Vb, 48, Vtb);
        memcpy(Vb, Vtb, 48);
        u384_load_be(kintb, Vb);
        if (u384_is_zero(kintb) == 0) {
            if (u384_cmp(kintb, _p384_n) < 0) {
                u384_store_be(k_out, kintb);
                _rfc6979_scrub_p384_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
                return 0;
            }
        }
        memcpy(d1b, Vb, 48);
        store8(d1b + 48, 0x00);
        hmac_sha384(Kb, 48, d1b, 49, Ktb);
        memcpy(Kb, Ktb, 48);
        hmac_sha384(Kb, 48, Vb, 48, Vtb);
        memcpy(Vb, Vtb, 48);
        tries = tries + 1;
    }
    _rfc6979_scrub_p384_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
    return 0 - 1;
}

# ================================================================
# Point scratch (allocated once; G and R are public data)
# ================================================================
var _ecs256_inited = 0;
var _ecs256_G = 0;
var _ecs256_R = 0;

fn _ecs256_init(): i64 {
    if (_ecs256_inited == 1) { return 0; }
    _p256_init();
    _ecs256_G = pt_alloc();                      # generator, set once, read-only — unbanked
    _ecs256_R = alloc(96 * SIGIL_CRYPTO_BANKS);  # per-sign k·G output point — lane-banked
    pt_from_affine(_ecs256_G, _p256_gx, _p256_gy);
    _ecs256_inited = 1;
    return 0;
}

# Per-lane zeroization of every secret-tainted P-256 scratch buffer
# (CLAUDE.md quirk #9 / ADR 0004). The banked field/scalar/point scratch
# in ecdsa_p256.cyr is plain `var`/`alloc` (never `secret var`), so a
# whole-array wipe would clobber a concurrent worker's live lane. This
# scrubs ONLY the calling thread's lane (`cbank()`), preserving per-call
# secret zeroization on the sign path. Called on every return of
# ecdsa_p256_sign. Each buffer is guarded against the not-yet-allocated
# (lazy `_init`) case. NOTE: only the secret-carrying buffers (nonce k,
# k·G, private scalar d, and their intermediates) are scrubbed; the
# verify-only buffers (_ecv_*, _ecq_*, _onc_*, _p256fi_*, _p256_inv_*,
# _p256_R, _p256_sol_t, _p256_ninv_*) hold public data and are left
# alone (they are banked for race-freedom but need no wipe).
fn _p256_scrub_secret_lanes(): i64 {
    var bk = cbank();
    # Montgomery-ladder point set (k·G with secret k) — 96 B each.
    if (_ptm_r0  != 0) { memset(_ptm_r0  + bk * 96, 0, 96); }
    if (_ptm_r1  != 0) { memset(_ptm_r1  + bk * 96, 0, 96); }
    if (_ptm_sum != 0) { memset(_ptm_sum + bk * 96, 0, 96); }
    if (_ptm_dbl != 0) { memset(_ptm_dbl + bk * 96, 0, 96); }
    # pt_double temps — 9 × 32 B.
    if (_ptd_delta != 0) { memset(_ptd_delta + bk * 32, 0, 32); }
    if (_ptd_gamma != 0) { memset(_ptd_gamma + bk * 32, 0, 32); }
    if (_ptd_beta  != 0) { memset(_ptd_beta  + bk * 32, 0, 32); }
    if (_ptd_alpha != 0) { memset(_ptd_alpha + bk * 32, 0, 32); }
    if (_ptd_t1    != 0) { memset(_ptd_t1    + bk * 32, 0, 32); }
    if (_ptd_t2    != 0) { memset(_ptd_t2    + bk * 32, 0, 32); }
    if (_ptd_x3    != 0) { memset(_ptd_x3    + bk * 32, 0, 32); }
    if (_ptd_y3    != 0) { memset(_ptd_y3    + bk * 32, 0, 32); }
    if (_ptd_z3    != 0) { memset(_ptd_z3    + bk * 32, 0, 32); }
    # pt_add / pt_add_mixed temps — 16 × 32 B.
    if (_pta_z1z1 != 0) { memset(_pta_z1z1 + bk * 32, 0, 32); }
    if (_pta_z2z2 != 0) { memset(_pta_z2z2 + bk * 32, 0, 32); }
    if (_pta_u1   != 0) { memset(_pta_u1   + bk * 32, 0, 32); }
    if (_pta_u2   != 0) { memset(_pta_u2   + bk * 32, 0, 32); }
    if (_pta_s1   != 0) { memset(_pta_s1   + bk * 32, 0, 32); }
    if (_pta_s2   != 0) { memset(_pta_s2   + bk * 32, 0, 32); }
    if (_pta_h    != 0) { memset(_pta_h    + bk * 32, 0, 32); }
    if (_pta_i    != 0) { memset(_pta_i    + bk * 32, 0, 32); }
    if (_pta_j    != 0) { memset(_pta_j    + bk * 32, 0, 32); }
    if (_pta_r    != 0) { memset(_pta_r    + bk * 32, 0, 32); }
    if (_pta_v    != 0) { memset(_pta_v    + bk * 32, 0, 32); }
    if (_pta_t1   != 0) { memset(_pta_t1   + bk * 32, 0, 32); }
    if (_pta_t2   != 0) { memset(_pta_t2   + bk * 32, 0, 32); }
    if (_pta_x3   != 0) { memset(_pta_x3   + bk * 32, 0, 32); }
    if (_pta_y3   != 0) { memset(_pta_y3   + bk * 32, 0, 32); }
    if (_pta_z3   != 0) { memset(_pta_z3   + bk * 32, 0, 32); }
    # pt_to_affine z-inverse temps — 3 × 32 B.
    if (_pt_aff_zinv  != 0) { memset(_pt_aff_zinv  + bk * 32, 0, 32); }
    if (_pt_aff_zinv2 != 0) { memset(_pt_aff_zinv2 + bk * 32, 0, 32); }
    if (_pt_aff_zinv3 != 0) { memset(_pt_aff_zinv3 + bk * 32, 0, 32); }
    # scalar-inverse window (k^-1 / s^-1) — 512 B table + 32 B acc.
    if (_p256si_tbl != 0) { memset(_p256si_tbl + bk * 512, 0, 512); }
    if (_p256si_acc != 0) { memset(_p256si_acc + bk * 32, 0, 32); }
    # mod-n product / reduce scratch (carries r·d, k^-1·hpd) — 64 + 32 B.
    if (_p256_n_prod != 0) { memset(_p256_n_prod + bk * 64, 0, 64); }
    if (_p256_n_R    != 0) { memset(_p256_n_R    + bk * 32, 0, 32); }
    # field product / temps — 64 + 32 + 32 B.
    if (_p256_prod != 0) { memset(_p256_prod + bk * 64, 0, 64); }
    if (_p256_tmp1 != 0) { memset(_p256_tmp1 + bk * 32, 0, 32); }
    if (_p256_tmp2 != 0) { memset(_p256_tmp2 + bk * 32, 0, 32); }
    # per-sign k·G output point (ecdsa_sign.cyr) — 96 B.
    if (_ecs256_R != 0) { memset(_ecs256_R + bk * 96, 0, 96); }
    return 0;
}

var _ecs384_inited = 0;
var _ecs384_G = 0;
var _ecs384_R = 0;

fn _ecs384_init(): i64 {
    if (_ecs384_inited == 1) { return 0; }
    _p384_init();
    _ecs384_G = alloc(144);                       # generator, set once, read-only — unbanked
    _ecs384_R = alloc(144 * SIGIL_CRYPTO_BANKS);  # per-sign k·G output point — lane-banked
    pt384_from_affine(_ecs384_G, _p384_gx, _p384_gy);
    _ecs384_inited = 1;
    return 0;
}

# Per-lane zeroization of every secret-tainted P-384 scratch buffer
# (CLAUDE.md quirk #9 / ADR 0004) — the P-384 mirror of
# _p256_scrub_secret_lanes. The banked field/scalar/point scratch in
# ecdsa_p384.cyr is plain `var`/`alloc` (never `secret var`), so a
# whole-array wipe would clobber a concurrent worker's live lane. This
# scrubs ONLY the calling thread's lane (`cbank()`), preserving per-call
# secret zeroization on the sign path. Called on every return of
# ecdsa_p384_sign. Each buffer is guarded against the not-yet-allocated
# (lazy `_init`) case. Only secret-carrying buffers (nonce k, k·G,
# private scalar d, and their intermediates) are scrubbed; the verify-only
# buffers (_ecv384_*, _ecq384_*, _onc384_*, _p384_inv_*, _p384_ninv_*,
# _p384_R, _p384_sol_t) hold public data and are left alone (banked for
# race-freedom, no wipe needed).
fn _p384_scrub_secret_lanes(): i64 {
    var bk = cbank();
    # Montgomery-ladder point set (k·G with secret k) — 144 B each.
    if (_ptm384_r0  != 0) { memset(_ptm384_r0  + bk * 144, 0, 144); }
    if (_ptm384_r1  != 0) { memset(_ptm384_r1  + bk * 144, 0, 144); }
    if (_ptm384_sum != 0) { memset(_ptm384_sum + bk * 144, 0, 144); }
    if (_ptm384_dbl != 0) { memset(_ptm384_dbl + bk * 144, 0, 144); }
    # pt384_double temps — 9 × 48 B.
    if (_ptd384_delta != 0) { memset(_ptd384_delta + bk * 48, 0, 48); }
    if (_ptd384_gamma != 0) { memset(_ptd384_gamma + bk * 48, 0, 48); }
    if (_ptd384_beta  != 0) { memset(_ptd384_beta  + bk * 48, 0, 48); }
    if (_ptd384_alpha != 0) { memset(_ptd384_alpha + bk * 48, 0, 48); }
    if (_ptd384_t1    != 0) { memset(_ptd384_t1    + bk * 48, 0, 48); }
    if (_ptd384_t2    != 0) { memset(_ptd384_t2    + bk * 48, 0, 48); }
    if (_ptd384_x3    != 0) { memset(_ptd384_x3    + bk * 48, 0, 48); }
    if (_ptd384_y3    != 0) { memset(_ptd384_y3    + bk * 48, 0, 48); }
    if (_ptd384_z3    != 0) { memset(_ptd384_z3    + bk * 48, 0, 48); }
    # pt384_add temps — 16 × 48 B.
    if (_pta384_z1z1 != 0) { memset(_pta384_z1z1 + bk * 48, 0, 48); }
    if (_pta384_z2z2 != 0) { memset(_pta384_z2z2 + bk * 48, 0, 48); }
    if (_pta384_u1   != 0) { memset(_pta384_u1   + bk * 48, 0, 48); }
    if (_pta384_u2   != 0) { memset(_pta384_u2   + bk * 48, 0, 48); }
    if (_pta384_s1   != 0) { memset(_pta384_s1   + bk * 48, 0, 48); }
    if (_pta384_s2   != 0) { memset(_pta384_s2   + bk * 48, 0, 48); }
    if (_pta384_h    != 0) { memset(_pta384_h    + bk * 48, 0, 48); }
    if (_pta384_i    != 0) { memset(_pta384_i    + bk * 48, 0, 48); }
    if (_pta384_j    != 0) { memset(_pta384_j    + bk * 48, 0, 48); }
    if (_pta384_r    != 0) { memset(_pta384_r    + bk * 48, 0, 48); }
    if (_pta384_v    != 0) { memset(_pta384_v    + bk * 48, 0, 48); }
    if (_pta384_t1   != 0) { memset(_pta384_t1   + bk * 48, 0, 48); }
    if (_pta384_t2   != 0) { memset(_pta384_t2   + bk * 48, 0, 48); }
    if (_pta384_x3   != 0) { memset(_pta384_x3   + bk * 48, 0, 48); }
    if (_pta384_y3   != 0) { memset(_pta384_y3   + bk * 48, 0, 48); }
    if (_pta384_z3   != 0) { memset(_pta384_z3   + bk * 48, 0, 48); }
    # pt384_to_affine z-inverse temps — 3 × 48 B.
    if (_pt384_aff_zinv  != 0) { memset(_pt384_aff_zinv  + bk * 48, 0, 48); }
    if (_pt384_aff_zinv2 != 0) { memset(_pt384_aff_zinv2 + bk * 48, 0, 48); }
    if (_pt384_aff_zinv3 != 0) { memset(_pt384_aff_zinv3 + bk * 48, 0, 48); }
    # scalar-inverse working regs (k^-1 / s^-1) — 3 × 48 B.
    if (_p384_ninv_tmp  != 0) { memset(_p384_ninv_tmp  + bk * 48, 0, 48); }
    if (_p384_ninv_res  != 0) { memset(_p384_ninv_res  + bk * 48, 0, 48); }
    if (_p384_ninv_base != 0) { memset(_p384_ninv_base + bk * 48, 0, 48); }
    # mod-n product / reduce scratch (carries r·d, k^-1·hpd) — 96 + 48 B.
    if (_p384_n_prod != 0) { memset(_p384_n_prod + bk * 96, 0, 96); }
    if (_p384_n_R    != 0) { memset(_p384_n_R    + bk * 48, 0, 48); }
    # field product / temps — 96 + 48 + 48 B.
    if (_p384_prod != 0) { memset(_p384_prod + bk * 96, 0, 96); }
    if (_p384_tmp1 != 0) { memset(_p384_tmp1 + bk * 48, 0, 48); }
    if (_p384_tmp2 != 0) { memset(_p384_tmp2 + bk * 48, 0, 48); }
    # _p384_mul64 lo/hi product slot (intermediate secret products) — 16 B.
    if (_p384_m64 != 0) { memset(_p384_m64 + bk * 16, 0, 16); }
    # per-sign k·G output point (ecdsa_sign.cyr) — 144 B.
    if (_ecs384_R != 0) { memset(_ecs384_R + bk * 144, 0, 144); }
    return 0;
}

# ================================================================
# ecdsa_p256_sign — raw r||s (64 bytes, big-endian)
# ================================================================
# d_be: 32-byte big-endian private scalar in [1, n-1].
# Hashes msg with SHA-256 internally (matches ecdsa_p256_verify).
# Returns 0 on success, -1 on failure (degenerate r/s or no nonce).
fn ecdsa_p256_sign(d_be, msg, msg_len, sig_out): i64 {
    _ecs256_init();
    var bk = cbank();
    var _ecs256_Rb = _ecs256_R + bk * 96;

    # One secret scratch block; carve 13 × 32-byte slots by offset. This
    # `var sc[N]` is a function-scope STATIC global (quirk #1), shared
    # across concurrent signers, so it is banked across `cbank()` lanes
    # (the concurrent-signers race in ecdsa_concurrent.tcyr). It carries
    # key-derived / nonce material, so it is plain `var` + a per-lane wipe
    # before every return (quirk #9 / ADR 0004 — NEVER `secret var`, whose
    # whole-array wipe would clobber a sibling worker's live lane). Slots
    # are offset from the calling worker's lane base `scb`.
    var sc[26624];            # 416 * SIGIL_CRYPTO_BANKS
    var scb    = &sc + bk * 416;
    var digest = scb + 0;
    var e      = scb + 32;
    var h1oct  = scb + 64;
    var k      = scb + 96;
    var kint   = scb + 128;
    var kinv   = scb + 160;
    var dint   = scb + 192;
    var rint   = scb + 224;
    var sint   = scb + 256;
    var rd     = scb + 288;
    var hpd    = scb + 320;
    var Rx     = scb + 352;
    var Ry     = scb + 384;

    # e = SHA-256(msg) as BE int, reduced mod n.
    sha256(msg, msg_len, digest);
    u256_load_be(e, digest);
    if (u256_cmp(e, _p256_n) >= 0) { u256_sub(e, e, _p256_n); }
    # bits2octets(H(m)) = int2octets(e mod n)
    u256_store_be(h1oct, e);

    # k = RFC 6979 deterministic nonce.
    if (_rfc6979_k_p256(d_be, h1oct, k) != 0) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }
    u256_load_be(kint, k);

    # R = k·G ; r = R.x mod n.
    pt_scalarmul(_ecs256_Rb, kint, _ecs256_G);
    if (pt_is_infinity(_ecs256_Rb) == 1) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }
    pt_to_affine(Rx, Ry, _ecs256_Rb);
    fn_p256_reduce256(rint, Rx);
    if (u256_is_zero(rint) == 1) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }

    # s = k^(-1) · (e + r·d) mod n.
    u256_load_be(dint, d_be);
    fn_p256_mul(rd, rint, dint);
    _ecs_addmod_n_p256(hpd, e, rd);
    fn_p256_inv(kinv, kint);
    fn_p256_mul(sint, kinv, hpd);
    if (u256_is_zero(sint) == 1) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }

    u256_store_be(sig_out, rint);
    u256_store_be(sig_out + 32, sint);
    memset(scb, 0, 416);
    _p256_scrub_secret_lanes();
    return 0;
}

# ================================================================
# ecdsa_p256_warm — main-thread prewarm (ADR 0007)
# ================================================================
# The per-call P-256 scratch is lane-banked (3.9.7) for race-freedom, but
# the lazy `_init` allocations themselves use the NON-thread-safe bump
# allocator (quirk #7), so the FIRST touch of each must happen on a single
# thread. A server that fans ECDSA work out to worker threads MUST call
# this once on the MAIN thread at startup, before spawning workers — the
# same prewarm contract as `crypto_tls_main_init`. One sign + one verify
# exercises every sign- AND verify-path lazy alloc / table build (the
# verify-only inits `_ecv_init`/`_ecq_init` are not reached by signing, so
# both paths must run). Returns 0.
fn ecdsa_p256_warm(): i64 {
    var d[32]; memset(&d, 0, 32); store8(&d + 31, 7);   # any scalar in [1, n-1]
    var sig[64];
    ecdsa_p256_sign(&d, "warm", 4, &sig);               # sign-path inits
    var pk[64];
    u256_store_be(&pk, _p256_gx);
    u256_store_be(&pk + 32, _p256_gy);                  # pk = G (a valid point)
    ecdsa_p256_verify(&pk, "warm", 4, &sig);            # verify-path inits (result ignored)
    return 0;
}

# ================================================================
# ecdsa_p384_sign — raw r||s (96 bytes, big-endian)
# ================================================================
fn ecdsa_p384_sign(d_be, msg, msg_len, sig_out): i64 {
    _ecs384_init();
    var bk = cbank();
    var _ecs384_Rb = _ecs384_R + bk * 144;

    # One secret scratch block; carve 13 × 48-byte slots by offset. This
    # `var sc[N]` is a function-scope STATIC global (quirk #1), shared
    # across concurrent signers, so it is banked across `cbank()` lanes
    # (the concurrent-signers race in ecdsa_concurrent.tcyr). It carries
    # key-derived / nonce material, so it is plain `var` + a per-lane wipe
    # before every return (quirk #9 / ADR 0004 — NEVER `secret var`, whose
    # whole-array wipe would clobber a sibling worker's live lane). Slots
    # are offset from the calling worker's lane base `scb`.
    var sc[39936];            # 624 * SIGIL_CRYPTO_BANKS
    var scb    = &sc + bk * 624;
    var digest = scb + 0;
    var e      = scb + 48;
    var h1oct  = scb + 96;
    var k      = scb + 144;
    var kint   = scb + 192;
    var kinv   = scb + 240;
    var dint   = scb + 288;
    var rint   = scb + 336;
    var sint   = scb + 384;
    var rd     = scb + 432;
    var hpd    = scb + 480;
    var Rx     = scb + 528;
    var Ry     = scb + 576;

    sha384(msg, msg_len, digest);
    u384_load_be(e, digest);
    if (u384_cmp(e, _p384_n) >= 0) { u384_sub(e, e, _p384_n); }
    u384_store_be(h1oct, e);

    if (_rfc6979_k_p384(d_be, h1oct, k) != 0) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }
    u384_load_be(kint, k);

    pt384_scalarmul(_ecs384_Rb, kint, _ecs384_G);
    if (pt384_is_infinity(_ecs384_Rb) == 1) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }
    pt384_to_affine(Rx, Ry, _ecs384_Rb);
    fn_p384_reduce384(rint, Rx);
    if (u384_is_zero(rint) == 1) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }

    u384_load_be(dint, d_be);
    fn_p384_mul(rd, rint, dint);
    _ecs_addmod_n_p384(hpd, e, rd);
    fn_p384_inv(kinv, kint);
    fn_p384_mul(sint, kinv, hpd);
    if (u384_is_zero(sint) == 1) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }

    u384_store_be(sig_out, rint);
    u384_store_be(sig_out + 48, sint);
    memset(scb, 0, 624);
    _p384_scrub_secret_lanes();
    return 0;
}

# ================================================================
# ecdsa_p384_warm — main-thread prewarm (ADR 0007)
# ================================================================
# P-384 mirror of ecdsa_p256_warm. The per-call P-384 scratch is lane-
# banked for race-freedom, but the lazy `_init` allocations themselves use
# the NON-thread-safe bump allocator (quirk #7), so the FIRST touch of each
# must happen on a single thread. A server that fans P-384 ECDSA work out to
# worker threads MUST call this once on the MAIN thread at startup, before
# spawning workers. One sign + one verify exercises every sign- AND
# verify-path lazy alloc / table build (the verify-only inits _ecv384_init /
# _ecq384_init / _onc384_init are not reached by signing, so both paths must
# run). Returns 0.
fn ecdsa_p384_warm(): i64 {
    var d[48]; memset(&d, 0, 48); store8(&d + 47, 7);   # any scalar in [1, n-1]
    var sig[96];
    ecdsa_p384_sign(&d, "warm", 4, &sig);               # sign-path inits
    var pk[96];
    u384_store_be(&pk, _p384_gx);
    u384_store_be(&pk + 48, _p384_gy);                  # pk = G (a valid point)
    ecdsa_p384_verify(&pk, "warm", 4, &sig);            # verify-path inits (result ignored)
    return 0;
}

# ================================================================
# DER encoding — SEQUENCE { INTEGER r, INTEGER s }
# ================================================================
# Emit one minimal DER INTEGER from a `len`-byte big-endian value:
# strip leading zero bytes (keep at least one), prepend 0x00 when the
# top bit of the leading byte is set. Returns bytes written.
fn _ecs_der_emit_int(out, val, len): i64 {
    var start = 0;
    var done = 0;
    while (done == 0) {
        if (start >= len - 1) { done = 1; }
        else {
            if ((load8(val + start) & 0xFF) != 0) { done = 1; }
            else { start = start + 1; }
        }
    }
    var vlen = len - start;
    var pad = 0;
    if ((load8(val + start) & 0xFF) >= 0x80) { pad = 1; }
    var p = 0;
    store8(out + p, 0x02); p = p + 1;
    store8(out + p, (vlen + pad) & 0xFF); p = p + 1;
    if (pad == 1) { store8(out + p, 0x00); p = p + 1; }
    var i = 0;
    while (i < vlen) {
        store8(out + p, load8(val + start + i) & 0xFF);
        p = p + 1;
        i = i + 1;
    }
    return p;
}

# Wrap a raw r||s signature (each `comp_len` BE bytes) as DER. Returns
# the DER byte length, or -1 if it would exceed `out_max`. For P-256
# /P-384 the total content is < 128 bytes, so the SEQUENCE length is
# always single-byte.
fn _ecs_der_from_raw(sig, comp_len, out, out_max): i64 {
    var body[110];
    var bp = 0;
    bp = bp + _ecs_der_emit_int(&body + bp, sig, comp_len);
    bp = bp + _ecs_der_emit_int(&body + bp, sig + comp_len, comp_len);
    var total = 2 + bp;
    if (total > out_max) { return 0 - 1; }
    store8(out + 0, 0x30);
    store8(out + 1, bp & 0xFF);
    memcpy(out + 2, &body, bp);
    return total;
}

# ecdsa_p256_sign_der — DER-encoded signature (TLS 1.3 CertificateVerify
# form, RFC 8446 §4.2.3 ecdsa_secp256r1_sha256). Returns the DER byte
# length, or -1 on failure / insufficient `out_max`.
fn ecdsa_p256_sign_der(d_be, msg, msg_len, out, out_max): i64 {
    # Banked (3.9.7): the raw r||s scratch was `secret var sig[64]`, a
    # function-scope STATIC (quirk #1) — `secret var` arrays are NOT
    # per-call (the v6.2.25 "arena fix" only stopped a bump-heap leak),
    # so concurrent CertificateVerify signers raced it. Plain banked `var`
    # + per-lane wipe (quirk #9); r||s is public, so the wipe is hygiene.
    var bk = cbank();
    var sig[4096];   var sigb = &sig + bk * 64;   # 64 * SIGIL_CRYPTO_BANKS
    if (ecdsa_p256_sign(d_be, msg, msg_len, sigb) != 0) { memset(sigb, 0, 64); return 0 - 1; }
    var rc = _ecs_der_from_raw(sigb, 32, out, out_max);
    memset(sigb, 0, 64);
    return rc;
}

# ecdsa_p384_sign_der — DER-encoded P-384 signature
# (ecdsa_secp384r1_sha384). Returns the DER byte length, or -1.
fn ecdsa_p384_sign_der(d_be, msg, msg_len, out, out_max): i64 {
    # Banked (3.9.7) — see ecdsa_p256_sign_der; was `secret var sig[96]`.
    var bk = cbank();
    var sig[6144];   var sigb = &sig + bk * 96;   # 96 * SIGIL_CRYPTO_BANKS
    if (ecdsa_p384_sign(d_be, msg, msg_len, sigb) != 0) { memset(sigb, 0, 96); return 0 - 1; }
    var rc = _ecs_der_from_raw(sigb, 48, out, out_max);
    memset(sigb, 0, 96);
    return rc;
}
