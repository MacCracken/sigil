# ecdsa_p256.cyr — ECDSA verify on NIST P-256 (secp256r1)
#
# Surface (Sigil 3.2.1):
#   fn ecdsa_p256_verify(pk, msg, msg_len, sig): i64
#   fn ecdsa_p256_verify_der(pk, msg, msg_len, sig_der, sig_der_len): i64
#
# Inputs (big-endian byte strings, per SEC 1 v2.0 §2.3):
#   pk:  64 bytes — Qx || Qy uncompressed affine public key
#   sig: 64 bytes — r || s, both big-endian
#
# Implementation references:
#   • FIPS 186-5 §6 — ECDSA algorithm
#   • SEC 1 v2.0 §4.1.4 — verifying operation
#   • FIPS 186-4 D.1.2.3 / SP 800-186 — P-256 curve parameters
#
# Constant-time discipline:
#   • Verify takes only public inputs (msg, pk, sig). No secret-data
#     branches exist on this path. The Montgomery-ladder scalar
#     multiplication is still used because (a) it's the same shape a
#     future sign path would need and (b) defense in depth — any
#     future caller composing internal sign / DH against the same
#     point-mul primitive inherits constant-time behaviour for free.
#   • Final r comparison uses OR-accumulation (`ct_eq_bytes_lens`
#     from `lib/ct.cyr`), matching the pattern in `ed25519.cyr`.
#
# All working state lives in module globals because Cyrius'
# single-pass compiler can clobber locals across nested call chains
# (CLAUDE.md quirk #1). Same pattern as `bigint_ext.cyr` and
# `ed25519.cyr`.

# ================================================================
# Curve constants — initialised on first call via `_p256_init`.
# ================================================================

# Field prime p = 2^256 - 2^224 + 2^192 + 2^96 - 1
#   = 0xFFFFFFFF00000001 0000000000000000 00000000FFFFFFFF FFFFFFFFFFFFFFFF
var _p256_p = 0;

# Group order n =
#   0xFFFFFFFF00000000 FFFFFFFFFFFFFFFF BCE6FAADA7179E84 F3B9CAC2FC632551
var _p256_n = 0;

# Curve coefficient b for y^2 = x^3 - 3x + b:
#   b = 0x5AC635D8AA3A93E7 B3EBBD55769886BC 651D06B0CC53B0F6 3BCE3C3E27D2604B
var _p256_b = 0;

# Base point G (affine) — Gx, Gy
var _p256_gx = 0;
var _p256_gy = 0;

# Long-lived scratch (one allocation each, reused per call)
var _p256_prod = 0;        # 512-bit (64 B) full-product scratch
var _p256_tmp1 = 0;        # 32 B scratch
var _p256_tmp2 = 0;        # 32 B scratch
var _p256_one  = 0;        # constant 1 (256-bit)

var _p256_inited = 0;

fn _p256_init(): i64 {
    if (_p256_inited == 1) { return 0; }
    _p256_p  = u256_from_hex("ffffffff00000001000000000000000000000000ffffffffffffffffffffffff");
    _p256_n  = u256_from_hex("ffffffff00000000ffffffffffffffffbce6faada7179e84f3b9cac2fc632551");
    _p256_b  = u256_from_hex("5ac635d8aa3a93e7b3ebbd55769886bc651d06b0cc53b0f63bce3c3e27d2604b");
    _p256_gx = u256_from_hex("6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296");
    _p256_gy = u256_from_hex("4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5");
    _p256_prod = alloc(64);
    _p256_tmp1 = alloc(32);
    _p256_tmp2 = alloc(32);
    _p256_one  = u256_from(1);
    _p256_inited = 1;
    return 0;
}

# ================================================================
# Big-endian byte ⇄ u256 codec
#
# SEC 1 §2.3.5: integers are encoded most-significant-byte-first.
# This differs from Ed25519 (RFC 8032 little-endian) so we cannot
# reuse `u256_load_le` from `bigint_ext.cyr` — the byte order
# inverts. Defined here local to the P-256 module.
# ================================================================

# Load 32 big-endian bytes from src into dst as four LE i64 limbs.
fn u256_load_be(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        # limb[i] (low → high) holds bytes [src + (3-i)*8 .. src + (3-i)*8 + 7]
        # where byte 0 of that range is the MSB of the limb.
        var off = (3 - i) * 8;
        store64(dst + i * 8,
        ((load8(src + off + 0) & 0xFF) << 56)
        | ((load8(src + off + 1) & 0xFF) << 48)
        | ((load8(src + off + 2) & 0xFF) << 40)
        | ((load8(src + off + 3) & 0xFF) << 32)
        | ((load8(src + off + 4) & 0xFF) << 24)
        | ((load8(src + off + 5) & 0xFF) << 16)
        | ((load8(src + off + 6) & 0xFF) << 8)
        | (load8(src + off + 7) & 0xFF));
        i = i + 1;
    }
    return 0;
}

# Store src (four LE i64 limbs) as 32 big-endian bytes at dst.
fn u256_store_be(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        var off = (3 - i) * 8;
        var v = load64(src + i * 8);
        store8(dst + off + 0, (v >> 56) & 0xFF);
        store8(dst + off + 1, (v >> 48) & 0xFF);
        store8(dst + off + 2, (v >> 40) & 0xFF);
        store8(dst + off + 3, (v >> 32) & 0xFF);
        store8(dst + off + 4, (v >> 24) & 0xFF);
        store8(dst + off + 5, (v >> 16) & 0xFF);
        store8(dst + off + 6, (v >> 8) & 0xFF);
        store8(dst + off + 7, v & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Modular reduction mod p256 (or any 256-bit prime)
#
# Algorithm: textbook long-division.
#   R = 0
#   For each bit of val from bit 511 down to bit 0:
#       R = (R << 1) | bit
#       if R >= p, R -= p
#   Return R
#
# Each iteration runs on 256-bit values plus a single carry bit; the
# 257-bit transient (R = 2·prev_R + bit, which may exceed 2^256) is
# folded back via the identity:
#   (2^256 + R')  mod p  =  R' - p  mod 2^256     when R' < p
# i.e. when the carry bit is set, an unconditional `R -= p` realises
# the correct residue because the 256-bit unsigned wraparound supplies
# the missing +2^256 implicitly. After the conditional subtract,
# R < p again, restoring the loop invariant.
#
# 256 iterations × ~12 limb ops per iteration — slow but trivially
# correct. The Solinas word-level reduction that superseded this on the
# hot path shipped in 3.7.0 (`_p256_solinas_reduce`); this long-division
# form is retained as the differential-KAT reference.
# ================================================================

# Process bits 255 .. 0 of `lo` into accumulator R (mod p),
# given an initial R that is already in [0, p). Used by both p256_reduce
# (val high half pre-loaded) and modular ops that need it directly.
var _p256_R = 0;

fn _p256_long_div_reduce(R, lo): i64 {
    var i = 255;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u256_shl1(R, R);
        store64(R, load64(R) | bit);

        # Single conditional subtract covers both branches:
        #   • carry == 1 → V ∈ [2^256, 2p), V - p ∈ [2^256 - p, p), always valid
        #   • carry == 0, R >= p → standard reduce
        # When carry == 1 the unsigned wraparound of R - p gives the correct
        # residue because the implied +2^256 cancels.
        if (carry == 1) {
            u256_sub(R, R, _p256_p);
        } else {
            if (u256_cmp(R, _p256_p) >= 0) { u256_sub(R, R, _p256_p); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod p256 (val is 512-bit, r is 256-bit) — textbook long
# division. Retained as the correctness reference for the Solinas
# differential KAT (tests/tcyr/ecdsa_p256.tcyr); `p256_reduce` itself
# now uses the fast Solinas path below (3.7.0).
fn _p256_reduce_longdiv(out, val): i64 {
    _p256_init();
    if (_p256_R == 0) { _p256_R = alloc(32); }

    # Initialise R = high half of val, pre-reduce if R >= p.
    store64(_p256_R + 0, load64(val + 32));
    store64(_p256_R + 8, load64(val + 40));
    store64(_p256_R + 16, load64(val + 48));
    store64(_p256_R + 24, load64(val + 56));
    if (u256_cmp(_p256_R, _p256_p) >= 0) { u256_sub(_p256_R, _p256_R, _p256_p); }

    _p256_long_div_reduce(_p256_R, val);
    u256_copy(out, _p256_R);
    return 0;
}

# ================================================================
# Solinas fast reduction mod p256 (3.7.0)
#
# p256 = 2^256 − 2^224 + 2^192 + 2^96 − 1 is a Solinas (generalized
# Mersenne) prime, so a 512-bit product reduces via a fixed permutation
# of its sixteen 32-bit words c0..c15 (c0 = least significant) into nine
# 256-bit terms, combined as (FIPS 186-4 App. D.2 / GECC Alg. 2.29):
#
#   r = s1 + 2·s2 + 2·s3 + s4 + s5 − s6 − s7 − s8 − s9  (mod p256)
#
# Each term is < 2^256 (one conditional subtract reduces it into [0,p)),
# then combined with the audited constant-time-free fp_p256_add /
# fp_p256_sub (operands in [0,p), result stays in [0,p)). This replaces
# the 256-iteration bit-by-bit long division — ~20-50× fewer limb ops.
# Validated byte-for-byte against `_p256_reduce_longdiv` over random and
# edge inputs in ecdsa_p256.tcyr.
# ================================================================
var _p256_sol_t = 0;        # single 256-bit term scratch

# Read 32-bit word `idx` (0..15, little-endian) from a 64-byte product.
fn _p256_wd(prod, idx): i64 {
    var limb = load64(prod + (idx / 2) * 8);
    if ((idx & 1) == 0) { return limb & 0xFFFFFFFF; }
    return (limb >> 32) & 0xFFFFFFFF;
}

# Assemble a 256-bit value (32 bytes, little-endian) from eight 32-bit
# words w0 (low) .. w7 (high).
fn _p256_mk(out, w0, w1, w2, w3, w4, w5, w6, w7): i64 {
    store64(out + 0,  (w0 & 0xFFFFFFFF) | (w1 << 32));
    store64(out + 8,  (w2 & 0xFFFFFFFF) | (w3 << 32));
    store64(out + 16, (w4 & 0xFFFFFFFF) | (w5 << 32));
    store64(out + 24, (w6 & 0xFFFFFFFF) | (w7 << 32));
    return 0;
}

# Reduce a single term in [0, 2^256) into [0, p256): one conditional
# subtract (a term < 2^256 < 2·p256).
fn _p256_sol_red1(t): i64 {
    if (u256_cmp(t, _p256_p) >= 0) { u256_sub(t, t, _p256_p); }
    return 0;
}

fn _p256_solinas_reduce(out, val): i64 {
    _p256_init();
    if (_p256_sol_t == 0) { _p256_sol_t = alloc(32); }
    var T = _p256_sol_t;

    var c0 = _p256_wd(val, 0);   var c1 = _p256_wd(val, 1);
    var c2 = _p256_wd(val, 2);   var c3 = _p256_wd(val, 3);
    var c4 = _p256_wd(val, 4);   var c5 = _p256_wd(val, 5);
    var c6 = _p256_wd(val, 6);   var c7 = _p256_wd(val, 7);
    var c8 = _p256_wd(val, 8);   var c9 = _p256_wd(val, 9);
    var c10 = _p256_wd(val, 10); var c11 = _p256_wd(val, 11);
    var c12 = _p256_wd(val, 12); var c13 = _p256_wd(val, 13);
    var c14 = _p256_wd(val, 14); var c15 = _p256_wd(val, 15);

    # s1 = (c7 c6 c5 c4 c3 c2 c1 c0)
    _p256_mk(out, c0, c1, c2, c3, c4, c5, c6, c7);
    _p256_sol_red1(out);

    # + 2·s2 ; s2 = (c15 c14 c13 c12 c11 0 0 0)
    _p256_mk(T, 0, 0, 0, c11, c12, c13, c14, c15); _p256_sol_red1(T);
    fp_p256_add(out, out, T); fp_p256_add(out, out, T);

    # + 2·s3 ; s3 = (0 c15 c14 c13 c12 0 0 0)
    _p256_mk(T, 0, 0, 0, c12, c13, c14, c15, 0); _p256_sol_red1(T);
    fp_p256_add(out, out, T); fp_p256_add(out, out, T);

    # + s4 ; s4 = (c15 c14 0 0 0 c10 c9 c8)
    _p256_mk(T, c8, c9, c10, 0, 0, 0, c14, c15); _p256_sol_red1(T);
    fp_p256_add(out, out, T);

    # + s5 ; s5 = (c8 c13 c15 c14 c13 c11 c10 c9)
    _p256_mk(T, c9, c10, c11, c13, c14, c15, c13, c8); _p256_sol_red1(T);
    fp_p256_add(out, out, T);

    # − s6 ; s6 = (c10 c8 0 0 0 c13 c12 c11)
    _p256_mk(T, c11, c12, c13, 0, 0, 0, c8, c10); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    # − s7 ; s7 = (c11 c9 0 0 c15 c14 c13 c12)
    _p256_mk(T, c12, c13, c14, c15, 0, 0, c9, c11); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    # − s8 ; s8 = (c12 0 c10 c9 c8 c15 c14 c13)
    _p256_mk(T, c13, c14, c15, c8, c9, c10, 0, c12); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    # − s9 ; s9 = (c13 0 c11 c10 c9 0 c15 c14)
    _p256_mk(T, c14, c15, 0, c9, c10, c11, 0, c13); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    return 0;
}

# r = val mod p256 (val is 512-bit, r is 256-bit) — Solinas fast path.
fn p256_reduce(out, val): i64 {
    _p256_solinas_reduce(out, val);
    return 0;
}

# ================================================================
# Field arithmetic mod p256
# ================================================================

# r = (a + b) mod p
fn fp_p256_add(r, a, b): i64 {
    _p256_init();
    var carry = u256_add(r, a, b);
    # If a 257-bit carry occurred, treat as (R + 2^256) and subtract p
    # (same trick as the long-division reduce: u256_sub wraparound
    # supplies the implicit +2^256). After: r < 2^256 always.
    if (carry == 1) {
        u256_sub(r, r, _p256_p);
    }
    if (u256_cmp(r, _p256_p) >= 0) { u256_sub(r, r, _p256_p); }
    return 0;
}

# r = (a - b) mod p (handles underflow by adding p)
fn fp_p256_sub(r, a, b): i64 {
    _p256_init();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _p256_p); }
    return 0;
}

# r = (-a) mod p
fn fp_p256_neg(r, a): i64 {
    _p256_init();
    if (u256_is_zero(a) == 1) { u256_copy(r, a); return 0; }
    u256_sub(r, _p256_p, a);
    return 0;
}

# r = (a * b) mod p
fn fp_p256_mul(r, a, b): i64 {
    _p256_init();
    u256_mul_full(_p256_prod, a, b);
    p256_reduce(r, _p256_prod);
    return 0;
}

# r = a^2 mod p
fn fp_p256_sq(r, a): i64 {
    return fp_p256_mul(r, a, a);
}

# ================================================================
# Affine public-key validation — closes audit 2026-05-21 LOW-1.
#
# Verify that (x, y) satisfies the P-256 curve equation:
#     y^2 ≡ x^3 - 3*x + b  (mod p)
# and that both coordinates are in the field [0, p). Rejects the
# point at infinity ((0, 0) treated as such here per SEC 1 §3.2.2),
# off-curve points (invalid-curve attack, Bos et al. 2014), and
# coordinates outside the canonical range.
#
# Returns 1 if (x, y) is a valid affine point on P-256, 0 otherwise.
# x and y are 32-byte LE u256 limb buffers (the post-load_be form).
# ================================================================

var _onc_lhs = 0;
var _onc_rhs = 0;
var _onc_tmp = 0;
var _onc_three_x = 0;
var _onc_inited = 0;

fn _onc_init(): i64 {
    if (_onc_inited == 1) { return 0; }
    _p256_init();
    _onc_lhs = alloc(32);
    _onc_rhs = alloc(32);
    _onc_tmp = alloc(32);
    _onc_three_x = alloc(32);
    _onc_inited = 1;
    return 0;
}

fn pt_is_on_curve(x, y): i64 {
    _onc_init();
    # Range check: 0 ≤ x < p and 0 ≤ y < p.
    if (u256_cmp(x, _p256_p) >= 0) { return 0; }
    if (u256_cmp(y, _p256_p) >= 0) { return 0; }
    # Reject point at infinity (encoded as (0, 0) in affine).
    if (u256_is_zero(x) == 1) {
        if (u256_is_zero(y) == 1) { return 0; }
    }
    # lhs = y^2
    fp_p256_sq(_onc_lhs, y);
    # rhs = x^3 - 3x + b
    fp_p256_sq(_onc_tmp, x);
    fp_p256_mul(_onc_rhs, _onc_tmp, x);
    fp_p256_add(_onc_tmp, x, x);
    fp_p256_add(_onc_three_x, _onc_tmp, x);
    fp_p256_sub(_onc_rhs, _onc_rhs, _onc_three_x);
    fp_p256_add(_onc_rhs, _onc_rhs, _p256_b);
    if (u256_eq(_onc_lhs, _onc_rhs) == 1) { return 1; }
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p (Fermat's little theorem)
#
# Generic square-and-multiply over the 256-bit exponent p-2.
# Cost: 256 squarings + ~128 multiplies (Hamming weight of p-2 ≈ 128).
# An addition-chain optimisation (à la `fp_inv` in `bigint_ext.cyr`)
# can drop this to ~265 muls — tracked as the "scalar-inversion
# addition-chain" backlog item in docs/development/roadmap.md.
# ================================================================

var _p256_inv_tmp = 0;
var _p256_inv_res = 0;
var _p256_inv_base = 0;
var _p256_inv_exp = 0;     # p-2, precomputed
var _p256_inv_inited = 0;

fn _p256_inv_init(): i64 {
    if (_p256_inv_inited == 1) { return 0; }
    _p256_init();
    _p256_inv_tmp  = alloc(32);
    _p256_inv_res  = alloc(32);
    _p256_inv_base = alloc(32);
    _p256_inv_exp  = u256_clone(_p256_p);
    # exp = p - 2
    store64(_p256_inv_exp, load64(_p256_inv_exp) - 2);
    _p256_inv_inited = 1;
    return 0;
}

# r = a^(-1) mod p, generic binary square-and-multiply (Fermat a^(p-2)).
# RETAINED AS THE KAT ORACLE / REFERENCE for the fixed addition-chain
# `fp_p256_inv` below (differential KAT in ecdsa_p256.tcyr). Not on the
# hot path anymore. If a == 0 the result is 0 (caller gates on s != 0).
fn _fp_p256_inv_generic(r, a): i64 {
    _p256_inv_init();
    # res = 1
    store64(_p256_inv_res + 0, 1);
    store64(_p256_inv_res + 8, 0);
    store64(_p256_inv_res + 16, 0);
    store64(_p256_inv_res + 24, 0);
    u256_copy(_p256_inv_base, a);

    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p256_inv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_p256_mul(_p256_inv_tmp, _p256_inv_res, _p256_inv_base);
            u256_copy(_p256_inv_res, _p256_inv_tmp);
        }
        fp_p256_sq(_p256_inv_tmp, _p256_inv_base);
        u256_copy(_p256_inv_base, _p256_inv_tmp);
        i = i + 1;
    }
    u256_copy(r, _p256_inv_res);
    return 0;
}

# ----------------------------------------------------------------
# Fixed addition-chain field inverse a^(p-2) mod p  (3.7.x perf)
#
# p = 2^256 - 2^224 + 2^192 + 2^96 - 1, so p-2 has bit-runs (MSB->LSB):
#   [255:224]=1^32, [223:193]=0^31, [192]=1, [191:96]=0^96,
#   [95:32]=1^64, [31:2]=1^30, [1]=0, [0]=1.
# Built from 2^k-1 blocks (à la `fp_inv` in bigint_ext.cyr) in
# ~255 squarings + 12 multiplications, vs the generic loop's 256 sq +
# ~128 mul. The exponent (p-2) is a PUBLIC constant, so this is not a
# secret-dependent path — no CT concern. KAT-gated against
# `_fp_p256_inv_generic` (ecdsa_p256.tcyr differential test).
# ----------------------------------------------------------------
var _p256fi_t1 = 0;  var _p256fi_t2 = 0;  var _p256fi_t3 = 0;
var _p256fi_t6 = 0;  var _p256fi_t12 = 0; var _p256fi_t15 = 0;
var _p256fi_t30 = 0; var _p256fi_t32 = 0; var _p256fi_acc = 0;
var _p256fi_inited = 0;

fn _p256fi_init(): i64 {
    if (_p256fi_inited == 1) { return 0; }
    _p256_init();
    _p256fi_t1  = alloc(32);  _p256fi_t2  = alloc(32);  _p256fi_t3  = alloc(32);
    _p256fi_t6  = alloc(32);  _p256fi_t12 = alloc(32);  _p256fi_t15 = alloc(32);
    _p256fi_t30 = alloc(32);  _p256fi_t32 = alloc(32);  _p256fi_acc = alloc(32);
    _p256fi_inited = 1;
    return 0;
}

# In-place square `buf` n times (field, mod p). fp_p256_mul reads both
# operands into _p256_prod before writing r, so r==a is alias-safe.
fn _fp_p256_sq_n(buf, n): i64 {
    var i = 0;
    while (i < n) {
        fp_p256_sq(buf, buf);
        i = i + 1;
    }
    return 0;
}

# r = a^(-1) mod p via the fixed addition chain. a == 0 → 0.
fn fp_p256_inv(r, a): i64 {
    _p256fi_init();
    # --- 2^k-1 blocks ---
    u256_copy(_p256fi_t1, a);                            # t1  = a^(2^1-1)
    fp_p256_sq(_p256fi_t2, _p256fi_t1);                  #       a^2
    fp_p256_mul(_p256fi_t2, _p256fi_t2, _p256fi_t1);     # t2  = a^(2^2-1)
    fp_p256_sq(_p256fi_t3, _p256fi_t2);                  #       a^6
    fp_p256_mul(_p256fi_t3, _p256fi_t3, _p256fi_t1);     # t3  = a^(2^3-1)
    u256_copy(_p256fi_t6, _p256fi_t3);
    _fp_p256_sq_n(_p256fi_t6, 3);
    fp_p256_mul(_p256fi_t6, _p256fi_t6, _p256fi_t3);     # t6  = a^(2^6-1)
    u256_copy(_p256fi_t12, _p256fi_t6);
    _fp_p256_sq_n(_p256fi_t12, 6);
    fp_p256_mul(_p256fi_t12, _p256fi_t12, _p256fi_t6);   # t12 = a^(2^12-1)
    u256_copy(_p256fi_t15, _p256fi_t12);
    _fp_p256_sq_n(_p256fi_t15, 3);
    fp_p256_mul(_p256fi_t15, _p256fi_t15, _p256fi_t3);   # t15 = a^(2^15-1)
    u256_copy(_p256fi_t30, _p256fi_t15);
    _fp_p256_sq_n(_p256fi_t30, 15);
    fp_p256_mul(_p256fi_t30, _p256fi_t30, _p256fi_t15);  # t30 = a^(2^30-1)
    u256_copy(_p256fi_t32, _p256fi_t30);
    _fp_p256_sq_n(_p256fi_t32, 2);
    fp_p256_mul(_p256fi_t32, _p256fi_t32, _p256fi_t2);   # t32 = a^(2^32-1)
    # --- assemble a^(p-2) ---
    u256_copy(_p256fi_acc, _p256fi_t32);                 # [255:224] 1^32
    _fp_p256_sq_n(_p256fi_acc, 31);                      # [223:193] 0^31
    fp_p256_sq(_p256fi_acc, _p256fi_acc);                # [192] 1
    fp_p256_mul(_p256fi_acc, _p256fi_acc, _p256fi_t1);
    _fp_p256_sq_n(_p256fi_acc, 96);                      # [191:96] 0^96
    _fp_p256_sq_n(_p256fi_acc, 32);                      # [95:64] 1^32
    fp_p256_mul(_p256fi_acc, _p256fi_acc, _p256fi_t32);
    _fp_p256_sq_n(_p256fi_acc, 32);                      # [63:32] 1^32
    fp_p256_mul(_p256fi_acc, _p256fi_acc, _p256fi_t32);
    _fp_p256_sq_n(_p256fi_acc, 30);                      # [31:2] 1^30
    fp_p256_mul(_p256fi_acc, _p256fi_acc, _p256fi_t30);
    fp_p256_sq(_p256fi_acc, _p256fi_acc);                # [1] 0
    fp_p256_sq(_p256fi_acc, _p256fi_acc);                # [0] 1
    fp_p256_mul(r, _p256fi_acc, _p256fi_t1);
    return 0;
}

# ================================================================
# Scalar field arithmetic mod n (group order)
#
# Same long-division reduction as the field, but parameterised on
# `_p256_n` instead of `_p256_p`. ECDSA verify needs:
#   • reduce e (the SHA-256 message digest) mod n
#   • r, s ∈ [1, n-1] range checks (no reduction needed)
#   • s^(-1) mod n
#   • u1 = e * s^(-1) mod n, u2 = r * s^(-1) mod n
# ================================================================

var _p256_n_R = 0;

fn _p256_long_div_reduce_n(R, lo): i64 {
    var i = 255;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u256_shl1(R, R);
        store64(R, load64(R) | bit);

        if (carry == 1) {
            u256_sub(R, R, _p256_n);
        } else {
            if (u256_cmp(R, _p256_n) >= 0) { u256_sub(R, R, _p256_n); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod n (val is 512-bit, r is 256-bit)
fn n_reduce(out, val): i64 {
    _p256_init();
    if (_p256_n_R == 0) { _p256_n_R = alloc(32); }
    store64(_p256_n_R + 0, load64(val + 32));
    store64(_p256_n_R + 8, load64(val + 40));
    store64(_p256_n_R + 16, load64(val + 48));
    store64(_p256_n_R + 24, load64(val + 56));
    if (u256_cmp(_p256_n_R, _p256_n) >= 0) { u256_sub(_p256_n_R, _p256_n_R, _p256_n); }
    _p256_long_div_reduce_n(_p256_n_R, val);
    u256_copy(out, _p256_n_R);
    return 0;
}

# r = a mod n for a 256-bit `a` (avoid full 512-bit reduce when not needed).
fn fn_p256_reduce256(out, a): i64 {
    _p256_init();
    u256_copy(out, a);
    if (u256_cmp(out, _p256_n) >= 0) { u256_sub(out, out, _p256_n); }
    return 0;
}

# r = (a * b) mod n
var _p256_n_prod = 0;

fn fn_p256_mul(r, a, b): i64 {
    _p256_init();
    if (_p256_n_prod == 0) { _p256_n_prod = alloc(64); }
    u256_mul_full(_p256_n_prod, a, b);
    n_reduce(r, _p256_n_prod);
    return 0;
}

# r = a^(-1) mod n (Fermat: a^(n-2) mod n).
var _p256_ninv_tmp = 0;
var _p256_ninv_res = 0;
var _p256_ninv_base = 0;
var _p256_ninv_exp = 0;
var _p256_ninv_inited = 0;

fn _p256_ninv_init(): i64 {
    if (_p256_ninv_inited == 1) { return 0; }
    _p256_init();
    _p256_ninv_tmp  = alloc(32);
    _p256_ninv_res  = alloc(32);
    _p256_ninv_base = alloc(32);
    _p256_ninv_exp  = u256_clone(_p256_n);
    store64(_p256_ninv_exp, load64(_p256_ninv_exp) - 2);
    _p256_ninv_inited = 1;
    return 0;
}

# Generic binary square-and-multiply scalar inverse (Fermat a^(n-2)).
# RETAINED AS THE KAT ORACLE / REFERENCE for the windowed `fn_p256_inv`
# below. Each fn_p256_mul here is expensive (u256_mul_full + 256-iter
# long-division n_reduce), so the window's mul-count reduction is the
# real win on this path.
fn _fn_p256_inv_generic(r, a): i64 {
    _p256_ninv_init();
    store64(_p256_ninv_res + 0, 1);
    store64(_p256_ninv_res + 8, 0);
    store64(_p256_ninv_res + 16, 0);
    store64(_p256_ninv_res + 24, 0);
    u256_copy(_p256_ninv_base, a);

    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p256_ninv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fn_p256_mul(_p256_ninv_tmp, _p256_ninv_res, _p256_ninv_base);
            u256_copy(_p256_ninv_res, _p256_ninv_tmp);
        }
        fn_p256_mul(_p256_ninv_tmp, _p256_ninv_base, _p256_ninv_base);
        u256_copy(_p256_ninv_base, _p256_ninv_tmp);
        i = i + 1;
    }
    u256_copy(r, _p256_ninv_res);
    return 0;
}

# ----------------------------------------------------------------
# Windowed scalar inverse a^(n-2) mod n  (3.7.x perf)
#
# n-2's low 128 bits are irregular (no clean 2^k-1 decomposition like
# the field prime), so instead of a hand-derived optimal addition chain
# this uses a fixed 4-bit window: precompute a^1..a^15, then process the
# 64 nibbles of n-2 MSB->LSB (4 squarings + one table-mul per non-zero
# nibble). ~14 + 256 + ~55 = ~325 `fn_p256_mul` calls vs the generic
# 256 + ~128 = ~384 — and every saved mul avoids a 256-iteration
# long-division n_reduce, which is where this path's cost lives. The
# exponent (n-2) is a PUBLIC constant → no CT concern. `fn_p256_mul`
# writes r only after consuming a,b into _p256_n_prod, so r==a==b
# (in-place squaring) is alias-safe. KAT-gated vs the generic above.
# ----------------------------------------------------------------
var _p256si_tbl = 0;     # 16 × 32 B table; table[i] = a^i at +i*32
var _p256si_acc = 0;
var _p256si_inited = 0;

fn _p256si_init(): i64 {
    if (_p256si_inited == 1) { return 0; }
    _p256_ninv_init();           # ensures _p256_ninv_exp = n - 2
    _p256si_tbl = alloc(512);
    _p256si_acc = alloc(32);
    _p256si_inited = 1;
    return 0;
}

fn fn_p256_inv(r, a): i64 {
    _p256si_init();
    # table[1] = a; table[i] = table[i-1] * a  (i = 2..15)
    u256_copy(_p256si_tbl + 32, a);
    var ti = 2;
    while (ti < 16) {
        fn_p256_mul(_p256si_tbl + ti * 32, _p256si_tbl + (ti - 1) * 32, a);
        ti = ti + 1;
    }
    # acc = 1
    store64(_p256si_acc + 0, 1);
    store64(_p256si_acc + 8, 0);
    store64(_p256si_acc + 16, 0);
    store64(_p256si_acc + 24, 0);
    # process nibbles of (n-2) from MSB (nibble 63) to LSB (nibble 0)
    var ni = 63;
    while (ni >= 0) {
        fn_p256_mul(_p256si_acc, _p256si_acc, _p256si_acc);   # ^2
        fn_p256_mul(_p256si_acc, _p256si_acc, _p256si_acc);   # ^4
        fn_p256_mul(_p256si_acc, _p256si_acc, _p256si_acc);   # ^8
        fn_p256_mul(_p256si_acc, _p256si_acc, _p256si_acc);   # ^16
        var limb = load64(_p256_ninv_exp + (ni / 16) * 8);
        var nib = (limb >> ((ni & 15) * 4)) & 15;
        if (nib != 0) {
            fn_p256_mul(_p256si_acc, _p256si_acc, _p256si_tbl + nib * 32);
        }
        ni = ni - 1;
    }
    u256_copy(r, _p256si_acc);
    return 0;
}

# ================================================================
# Jacobian point arithmetic on P-256
#
# Representation: 96 bytes per point — concatenation of X, Y, Z (each
# 32 B, little-endian limbs). Affine (x, y) = (X/Z^2, Y/Z^3) for Z≠0;
# Z == 0 represents the point at infinity (identity element).
#
# Formulas: explicit-formulas-database "dbl-2001-b" (for a=-3) and
# "add-2007-bl" (general affine + Jacobian add). 4M+4S for double,
# 12M+4S for add — matches openssl/ec/ecp_nistz256.c reference.
# ================================================================

# Field offsets within a 96-byte point.
fn _pt_x(p): i64 { return p; }
fn _pt_y(p): i64 { return p + 32; }
fn _pt_z(p): i64 { return p + 64; }

# Allocate a fresh point (zeroed; represents point at infinity).
fn pt_alloc(): i64 {
    var p = alloc(96);
    memset(p, 0, 96);
    return p;
}

fn pt_set_infinity(p): i64 {
    memset(p, 0, 96);
    return 0;
}

fn pt_is_infinity(p): i64 {
    if (u256_is_zero(_pt_z(p)) == 1) { return 1; }
    return 0;
}

fn pt_copy(dst, src): i64 {
    memcpy(dst, src, 96);
    return 0;
}

# Constant-time conditional swap of two 96-byte points.
#   if swap == 1: a <-> b
#   if swap == 0: no change
# No branches on point data. (swap itself is treated as public — it
# is derived from the public scalar bits during Montgomery-ladder
# scalar multiplication.)
fn pt_cswap(swap, a, b): i64 {
    var mask = 0 - swap;     # 0 or 0xFF..FF
    var i = 0;
    while (i < 12) {         # 12 × 8 bytes = 96
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var t  = mask & (av ^ bv);
        store64(a + i * 8, av ^ t);
        store64(b + i * 8, bv ^ t);
        i = i + 1;
    }
    return 0;
}

# Load an affine point (x, y) into Jacobian (x, y, 1).
fn pt_from_affine(p, x, y): i64 {
    u256_copy(_pt_x(p), x);
    u256_copy(_pt_y(p), y);
    store64(_pt_z(p) + 0, 1);
    store64(_pt_z(p) + 8, 0);
    store64(_pt_z(p) + 16, 0);
    store64(_pt_z(p) + 24, 0);
    return 0;
}

# Convert Jacobian → affine. Out_x, out_y receive the affine coords.
# Returns 0 if p is the point at infinity (no inverse), 1 otherwise.
var _pt_aff_zinv  = 0;
var _pt_aff_zinv2 = 0;
var _pt_aff_zinv3 = 0;

fn pt_to_affine(out_x, out_y, p): i64 {
    if (pt_is_infinity(p) == 1) { return 0; }
    if (_pt_aff_zinv  == 0) { _pt_aff_zinv  = alloc(32); }
    if (_pt_aff_zinv2 == 0) { _pt_aff_zinv2 = alloc(32); }
    if (_pt_aff_zinv3 == 0) { _pt_aff_zinv3 = alloc(32); }

    fp_p256_inv(_pt_aff_zinv, _pt_z(p));
    fp_p256_sq(_pt_aff_zinv2, _pt_aff_zinv);
    fp_p256_mul(_pt_aff_zinv3, _pt_aff_zinv2, _pt_aff_zinv);
    fp_p256_mul(out_x, _pt_x(p), _pt_aff_zinv2);
    fp_p256_mul(out_y, _pt_y(p), _pt_aff_zinv3);
    return 1;
}

# ----------------------------------------------------------------
# Point doubling — Jacobian, a = -3
# Source: explicit-formulas-database dbl-2001-b
#   delta = Z^2
#   gamma = Y^2
#   beta  = X * gamma
#   alpha = 3 * (X - delta) * (X + delta)         (uses a = -3)
#   X3 = alpha^2 - 8*beta
#   Z3 = (Y + Z)^2 - gamma - delta
#   Y3 = alpha * (4*beta - X3) - 8 * gamma^2
# ----------------------------------------------------------------

var _ptd_delta = 0;
var _ptd_gamma = 0;
var _ptd_beta  = 0;
var _ptd_alpha = 0;
var _ptd_t1    = 0;
var _ptd_t2    = 0;
var _ptd_x3    = 0;
var _ptd_y3    = 0;
var _ptd_z3    = 0;
var _ptd_inited = 0;

fn _ptd_init(): i64 {
    if (_ptd_inited == 1) { return 0; }
    _ptd_delta = alloc(32);
    _ptd_gamma = alloc(32);
    _ptd_beta  = alloc(32);
    _ptd_alpha = alloc(32);
    _ptd_t1    = alloc(32);
    _ptd_t2    = alloc(32);
    _ptd_x3    = alloc(32);
    _ptd_y3    = alloc(32);
    _ptd_z3    = alloc(32);
    _ptd_inited = 1;
    return 0;
}

fn pt_double(out, p): i64 {
    _p256_init();
    _ptd_init();
    if (pt_is_infinity(p) == 1) { pt_set_infinity(out); return 0; }

    # delta = Z^2
    fp_p256_sq(_ptd_delta, _pt_z(p));
    # gamma = Y^2
    fp_p256_sq(_ptd_gamma, _pt_y(p));
    # beta = X * gamma
    fp_p256_mul(_ptd_beta, _pt_x(p), _ptd_gamma);

    # alpha = 3 * (X - delta) * (X + delta)
    fp_p256_sub(_ptd_t1, _pt_x(p), _ptd_delta);
    fp_p256_add(_ptd_t2, _pt_x(p), _ptd_delta);
    fp_p256_mul(_ptd_alpha, _ptd_t1, _ptd_t2);
    # alpha = 3*alpha
    fp_p256_add(_ptd_t1, _ptd_alpha, _ptd_alpha);
    fp_p256_add(_ptd_alpha, _ptd_t1, _ptd_alpha);

    # X3 = alpha^2 - 8*beta
    fp_p256_sq(_ptd_x3, _ptd_alpha);
    # 8*beta
    fp_p256_add(_ptd_t1, _ptd_beta, _ptd_beta);      # 2*beta
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 4*beta
    fp_p256_add(_ptd_t2, _ptd_t1, _ptd_t1);          # 8*beta
    fp_p256_sub(_ptd_x3, _ptd_x3, _ptd_t2);

    # Z3 = (Y + Z)^2 - gamma - delta
    fp_p256_add(_ptd_t1, _pt_y(p), _pt_z(p));
    fp_p256_sq(_ptd_z3, _ptd_t1);
    fp_p256_sub(_ptd_z3, _ptd_z3, _ptd_gamma);
    fp_p256_sub(_ptd_z3, _ptd_z3, _ptd_delta);

    # Y3 = alpha * (4*beta - X3) - 8 * gamma^2
    fp_p256_add(_ptd_t1, _ptd_beta, _ptd_beta);      # 2*beta
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 4*beta
    fp_p256_sub(_ptd_t1, _ptd_t1, _ptd_x3);          # 4*beta - X3
    fp_p256_mul(_ptd_y3, _ptd_alpha, _ptd_t1);
    fp_p256_sq(_ptd_t2, _ptd_gamma);                 # gamma^2
    fp_p256_add(_ptd_t1, _ptd_t2, _ptd_t2);          # 2*gamma^2
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 4*gamma^2
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 8*gamma^2
    fp_p256_sub(_ptd_y3, _ptd_y3, _ptd_t1);

    u256_copy(_pt_x(out), _ptd_x3);
    u256_copy(_pt_y(out), _ptd_y3);
    u256_copy(_pt_z(out), _ptd_z3);
    return 0;
}

# ----------------------------------------------------------------
# Point addition — Jacobian P + Q
# Source: explicit-formulas-database add-2007-bl
#   Z1Z1 = Z1^2,  Z2Z2 = Z2^2
#   U1 = X1 * Z2Z2,  U2 = X2 * Z1Z1
#   S1 = Y1 * Z2 * Z2Z2,  S2 = Y2 * Z1 * Z1Z1
#   H  = U2 - U1
#   I  = (2H)^2,  J = H * I
#   r  = 2*(S2 - S1)
#   V  = U1 * I
#   X3 = r^2 - J - 2V
#   Y3 = r * (V - X3) - 2 * S1 * J
#   Z3 = ((Z1 + Z2)^2 - Z1Z1 - Z2Z2) * H
#
# Handles all special cases: P=O → out=Q, Q=O → out=P, P=Q → double,
# P=-Q → infinity.
# ----------------------------------------------------------------

var _pta_z1z1 = 0;
var _pta_z2z2 = 0;
var _pta_u1   = 0;
var _pta_u2   = 0;
var _pta_s1   = 0;
var _pta_s2   = 0;
var _pta_h    = 0;
var _pta_i    = 0;
var _pta_j    = 0;
var _pta_r    = 0;
var _pta_v    = 0;
var _pta_t1   = 0;
var _pta_t2   = 0;
var _pta_x3   = 0;
var _pta_y3   = 0;
var _pta_z3   = 0;
var _pta_inited = 0;

fn _pta_init(): i64 {
    if (_pta_inited == 1) { return 0; }
    _pta_z1z1 = alloc(32);
    _pta_z2z2 = alloc(32);
    _pta_u1   = alloc(32);
    _pta_u2   = alloc(32);
    _pta_s1   = alloc(32);
    _pta_s2   = alloc(32);
    _pta_h    = alloc(32);
    _pta_i    = alloc(32);
    _pta_j    = alloc(32);
    _pta_r    = alloc(32);
    _pta_v    = alloc(32);
    _pta_t1   = alloc(32);
    _pta_t2   = alloc(32);
    _pta_x3   = alloc(32);
    _pta_y3   = alloc(32);
    _pta_z3   = alloc(32);
    _pta_inited = 1;
    return 0;
}

fn pt_add(out, p, q): i64 {
    _p256_init();
    _pta_init();

    if (pt_is_infinity(p) == 1) { pt_copy(out, q); return 0; }
    if (pt_is_infinity(q) == 1) { pt_copy(out, p); return 0; }

    # Z1Z1, Z2Z2
    fp_p256_sq(_pta_z1z1, _pt_z(p));
    fp_p256_sq(_pta_z2z2, _pt_z(q));

    # U1 = X1 * Z2Z2; U2 = X2 * Z1Z1
    fp_p256_mul(_pta_u1, _pt_x(p), _pta_z2z2);
    fp_p256_mul(_pta_u2, _pt_x(q), _pta_z1z1);

    # S1 = Y1 * Z2 * Z2Z2; S2 = Y2 * Z1 * Z1Z1
    fp_p256_mul(_pta_t1, _pt_z(q), _pta_z2z2);
    fp_p256_mul(_pta_s1, _pt_y(p), _pta_t1);
    fp_p256_mul(_pta_t1, _pt_z(p), _pta_z1z1);
    fp_p256_mul(_pta_s2, _pt_y(q), _pta_t1);

    # H = U2 - U1
    fp_p256_sub(_pta_h, _pta_u2, _pta_u1);

    # If H == 0: either P == Q (double) or P == -Q (infinity).
    if (u256_is_zero(_pta_h) == 1) {
        if (u256_eq(_pta_s1, _pta_s2) == 1) {
            return pt_double(out, p);
        } else {
            pt_set_infinity(out);
            return 0;
        }
    }

    # I = (2H)^2
    fp_p256_add(_pta_t1, _pta_h, _pta_h);            # 2H
    fp_p256_sq(_pta_i, _pta_t1);
    # J = H * I
    fp_p256_mul(_pta_j, _pta_h, _pta_i);
    # r = 2 * (S2 - S1)
    fp_p256_sub(_pta_t1, _pta_s2, _pta_s1);
    fp_p256_add(_pta_r, _pta_t1, _pta_t1);
    # V = U1 * I
    fp_p256_mul(_pta_v, _pta_u1, _pta_i);

    # X3 = r^2 - J - 2V
    fp_p256_sq(_pta_x3, _pta_r);
    fp_p256_sub(_pta_x3, _pta_x3, _pta_j);
    fp_p256_add(_pta_t1, _pta_v, _pta_v);            # 2V
    fp_p256_sub(_pta_x3, _pta_x3, _pta_t1);

    # Y3 = r * (V - X3) - 2 * S1 * J
    fp_p256_sub(_pta_t1, _pta_v, _pta_x3);
    fp_p256_mul(_pta_y3, _pta_r, _pta_t1);
    fp_p256_mul(_pta_t1, _pta_s1, _pta_j);
    fp_p256_add(_pta_t2, _pta_t1, _pta_t1);          # 2*S1*J
    fp_p256_sub(_pta_y3, _pta_y3, _pta_t2);

    # Z3 = ((Z1 + Z2)^2 - Z1Z1 - Z2Z2) * H
    fp_p256_add(_pta_t1, _pt_z(p), _pt_z(q));
    fp_p256_sq(_pta_t2, _pta_t1);
    fp_p256_sub(_pta_t2, _pta_t2, _pta_z1z1);
    fp_p256_sub(_pta_t2, _pta_t2, _pta_z2z2);
    fp_p256_mul(_pta_z3, _pta_t2, _pta_h);

    u256_copy(_pt_x(out), _pta_x3);
    u256_copy(_pt_y(out), _pta_y3);
    u256_copy(_pt_z(out), _pta_z3);
    return 0;
}

# ----------------------------------------------------------------
# Mixed addition: Jacobian P + affine Q (Z2 == 1 implicit).  (3.7.x perf)
#
# Formula "madd-2007-bl" (explicit-formulas-database). With Z2=1 the
# Z2Z2 / U1=X1*Z2Z2 / S1=Y1*Z2*Z2Z2 multiplies vanish, dropping the cost
# to ~7M+4S vs the general add's ~11M+5S — ~4 muls saved per add. Used
# on the verify-only comb-G path (affine fixed-base table), where every
# table entry is affine. PUBLIC data only (same non-CT caveat as pt_add
# on the comb path). `out` may alias `p`: every coord of `p` is read
# before any coord of `out` is written. q is given as separate qx, qy
# 32-byte limb buffers (never the point at infinity here — the comb
# skips the nibble==0 / identity entry).
fn pt_add_mixed(out, p, qx, qy): i64 {
    _p256_init();
    _pta_init();

    if (pt_is_infinity(p) == 1) {
        u256_copy(_pt_x(out), qx);
        u256_copy(_pt_y(out), qy);
        store64(_pt_z(out) + 0, 1);
        store64(_pt_z(out) + 8, 0);
        store64(_pt_z(out) + 16, 0);
        store64(_pt_z(out) + 24, 0);
        return 0;
    }

    # Z1Z1 = Z1^2
    fp_p256_sq(_pta_z1z1, _pt_z(p));
    # U2 = X2 * Z1Z1   (U1 = X1 since Z2 = 1)
    fp_p256_mul(_pta_u2, qx, _pta_z1z1);
    # S2 = Y2 * Z1 * Z1Z1   (S1 = Y1)
    fp_p256_mul(_pta_t1, _pt_z(p), _pta_z1z1);
    fp_p256_mul(_pta_s2, qy, _pta_t1);
    # H = U2 - X1
    fp_p256_sub(_pta_h, _pta_u2, _pt_x(p));

    # H == 0: P == Q (double) or P == -Q (infinity).
    if (u256_is_zero(_pta_h) == 1) {
        if (u256_eq(_pt_y(p), _pta_s2) == 1) {
            return pt_double(out, p);
        } else {
            pt_set_infinity(out);
            return 0;
        }
    }

    # HH = H^2  (kept in _pta_i for Z3)
    fp_p256_sq(_pta_i, _pta_h);
    # I = 4*HH   (in _pta_t1)
    fp_p256_add(_pta_t1, _pta_i, _pta_i);
    fp_p256_add(_pta_t1, _pta_t1, _pta_t1);
    # J = H * I
    fp_p256_mul(_pta_j, _pta_h, _pta_t1);
    # r = 2*(S2 - Y1)
    fp_p256_sub(_pta_t2, _pta_s2, _pt_y(p));
    fp_p256_add(_pta_r, _pta_t2, _pta_t2);
    # V = X1 * I
    fp_p256_mul(_pta_v, _pt_x(p), _pta_t1);

    # X3 = r^2 - J - 2V
    fp_p256_sq(_pta_x3, _pta_r);
    fp_p256_sub(_pta_x3, _pta_x3, _pta_j);
    fp_p256_add(_pta_t2, _pta_v, _pta_v);
    fp_p256_sub(_pta_x3, _pta_x3, _pta_t2);

    # Y3 = r*(V - X3) - 2*Y1*J
    fp_p256_sub(_pta_t2, _pta_v, _pta_x3);
    fp_p256_mul(_pta_y3, _pta_r, _pta_t2);
    fp_p256_mul(_pta_t2, _pt_y(p), _pta_j);
    fp_p256_add(_pta_t1, _pta_t2, _pta_t2);          # 2*Y1*J
    fp_p256_sub(_pta_y3, _pta_y3, _pta_t1);

    # Z3 = (Z1 + H)^2 - Z1Z1 - HH
    fp_p256_add(_pta_t1, _pt_z(p), _pta_h);
    fp_p256_sq(_pta_z3, _pta_t1);
    fp_p256_sub(_pta_z3, _pta_z3, _pta_z1z1);
    fp_p256_sub(_pta_z3, _pta_z3, _pta_i);

    u256_copy(_pt_x(out), _pta_x3);
    u256_copy(_pt_y(out), _pta_y3);
    u256_copy(_pt_z(out), _pta_z3);
    return 0;
}

# ----------------------------------------------------------------
# Constant-time scalar multiplication via Montgomery ladder.
#   R0 = O, R1 = P, prev = 0
#   for i = 255 .. 0:
#       bit = scalar bit i
#       cswap(R0, R1, prev XOR bit)   # bring "double target" to R0
#       R1 = R0 + R1
#       R0 = 2 * R0
#       prev = bit
#   cswap(R0, R1, prev)               # final unswap
#   return R0
#
# Branches only on public swap masks; field/point ops always run in
# fixed sequence. Defense-in-depth: ECDSA verify inputs are public,
# but any future sign / DH path through this primitive inherits the
# constant-time behaviour for free.
# ----------------------------------------------------------------

var _ptm_r0 = 0;
var _ptm_r1 = 0;
var _ptm_sum = 0;
var _ptm_dbl = 0;
var _ptm_scalar = 0;
var _ptm_inited = 0;

fn _ptm_init(): i64 {
    if (_ptm_inited == 1) { return 0; }
    _ptm_r0 = pt_alloc();
    _ptm_r1 = pt_alloc();
    _ptm_sum = pt_alloc();
    _ptm_dbl = pt_alloc();
    _ptm_inited = 1;
    return 0;
}

# out = k * P, where k is a 256-bit scalar (LE limbs) and P is Jacobian.
fn pt_scalarmul(out, k, P): i64 {
    _p256_init();
    _ptm_init();

    pt_set_infinity(_ptm_r0);
    pt_copy(_ptm_r1, P);

    _ptm_scalar = k;
    var prev = 0;
    var i = 255;
    while (i >= 0) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_ptm_scalar + limb_idx * 8) >> bit_idx) & 1;
        var swap = prev ^ bit;
        pt_cswap(swap, _ptm_r0, _ptm_r1);

        pt_add(_ptm_sum, _ptm_r0, _ptm_r1);
        pt_double(_ptm_dbl, _ptm_r0);
        pt_copy(_ptm_r1, _ptm_sum);
        pt_copy(_ptm_r0, _ptm_dbl);

        prev = bit;
        i = i - 1;
    }
    pt_cswap(prev, _ptm_r0, _ptm_r1);
    pt_copy(out, _ptm_r0);
    return 0;
}

# ================================================================
# Fixed-base comb for the generator G (verify-only, NON-constant-time)
#
# G is a public constant, and `ecdsa_p256_verify` consumes only public
# data (digest, signature, public key), so the `u1·G` term can use a
# fast table-indexed comb instead of the constant-time Montgomery ladder
# (`pt_scalarmul`). **This must never be used on a secret scalar** — the
# table index leaks the scalar nibble via cache timing. The signing path
# (`ecdsa_sign.cyr`, secret nonce k·G) deliberately stays on
# `pt_scalarmul`; only the verify `u1·G` site calls this.
#
# 4-bit windowed comb (the same shape ed25519 uses for its base point):
#   table[i][k] = k · 16^i · G   for window i ∈ [0,64), digit k ∈ [0,16)
#   k·G = Σ_i table[i][ nibble_i(k) ]
# Cost: 64 table reads + 64 Jacobian adds, zero doublings on the hot
# path (the 4 doublings per window happen once, at table-build time).
# Table: 64 × 16 × 96 B = 98304 B, built once on the main thread (ECDSA
# verify is not on the parallel batch path, so no banking is needed).
# ================================================================

# Affine comb table (3.7.x): table[i][k] = k · 16^i · G stored as affine
# x||y (64 B each) so the comb hot path uses the cheaper mixed add. The
# [i][0] entry (= O, identity) is unused — the main loop skips nibble 0.
var _p256_G_table_aff = 0;  # 64*16 affine points (64 B each)
var _p256_Gt_inited   = 0;
var _p256_gt_tmp      = 0;  # scratch point for the 4× doubling at build time
var _p256_gt_row      = 0;  # 16-Jacobian-point scratch row (1536 B), reused per i

# Build table[i][k] = k · 16^i · G in affine form. Runs once; the ~960
# one-time `pt_to_affine` inversions are amortized over the process.
fn _build_p256_G_table(): i64 {
    if (_p256_Gt_inited == 1) { return 0; }
    _p256_init();
    _ptm_init();
    _p256_G_table_aff = alloc(65536);             # 64 * 16 * 64
    if (_p256_gt_tmp == 0) { _p256_gt_tmp = pt_alloc(); }
    if (_p256_gt_row == 0) { _p256_gt_row = alloc(1536); }   # 16 * 96

    # basept walks Bi = 16^i · G, starting at B0 = G.
    var basept = pt_alloc();
    pt_from_affine(basept, _p256_gx, _p256_gy);

    var i = 0;
    while (i < 64) {
        # Build the Jacobian row in scratch: row[1] = Bi, row[k] = row[k-1] + Bi.
        pt_copy(_p256_gt_row + 96, basept);       # row[1] = Bi
        var k = 2;
        while (k < 16) {
            pt_add(_p256_gt_row + k * 96, _p256_gt_row + (k - 1) * 96, basept);
            k = k + 1;
        }
        # Convert row[1..15] to affine into table[i][1..15]; [i][0] left unused.
        var arow = _p256_G_table_aff + i * 16 * 64;
        var kk = 1;
        while (kk < 16) {
            pt_to_affine(arow + kk * 64, arow + kk * 64 + 32, _p256_gt_row + kk * 96);
            kk = kk + 1;
        }
        if (i < 63) {                             # Bi+1 = 16·Bi (four doublings)
            pt_double(_p256_gt_tmp, basept);      # 2Bi
            pt_double(basept, _p256_gt_tmp);      # 4Bi
            pt_double(_p256_gt_tmp, basept);      # 8Bi
            pt_double(basept, _p256_gt_tmp);      # 16Bi
        }
        i = i + 1;
    }
    _p256_Gt_inited = 1;
    return 0;
}

# out = k · G via the fixed-base comb. PUBLIC scalar only (non-CT).
# k is 256-bit LE limbs (4 × i64); nibble i = bits [4i, 4i+3]. nibble 0
# is the identity (skipped); other nibbles use the mixed add against the
# affine table.
fn p256_scalarmul_base(out, k): i64 {
    if (_p256_Gt_inited == 0) { _build_p256_G_table(); }
    pt_set_infinity(out);
    var i = 0;
    while (i < 64) {
        var limb = load64(k + (i / 16) * 8);
        var nib  = (limb >> ((i % 16) * 4)) & 0xF;
        if (nib != 0) {
            var ent = _p256_G_table_aff + (i * 16 + nib) * 64;
            pt_add_mixed(out, out, ent, ent + 32);
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Windowed scalar mul for a VARIABLE point Q (verify-only, NON-CT).
#
# Q (the public key) changes every verify, so a fixed-base comb does
# not apply — but the scalar (u2) and Q are still public, so we replace
# the constant-time Montgomery ladder (`pt_scalarmul`, 256 adds + 256
# doubles) with a 4-bit left-to-right windowed double-and-add:
#   precompute Qtab[k] = k·Q for k ∈ [0,16)   (15 adds, once per call)
#   acc = O; for nibble i = 63..0: acc = 16·acc + Qtab[nibble_i]
# Cost: 256 doubles + 64 adds + 15 precompute ≈ 1.5× fewer point ops
# than the ladder. **Public data only** (table index leaks the nibble);
# the secret-nonce signing path stays on `pt_scalarmul`.
# ================================================================

var _ecq_tab    = 0;    # 16 Jacobian multiples k·Q (96 B each)
var _ecq_acc    = 0;    # accumulator
var _ecq_inited = 0;

fn _ecq_init(): i64 {
    if (_ecq_inited == 1) { return 0; }
    _ecq_tab = alloc(1536);     # 16 * 96
    _ecq_acc = pt_alloc();
    _ecq_inited = 1;
    return 0;
}

fn p256_scalarmul_var(out, k, Q): i64 {
    _p256_init();
    _ecq_init();

    # Qtab[0] = O, Qtab[1] = Q, Qtab[k] = Qtab[k-1] + Q.
    pt_set_infinity(_ecq_tab);
    pt_copy(_ecq_tab + 96, Q);
    var j = 2;
    while (j < 16) {
        pt_add(_ecq_tab + j * 96, _ecq_tab + (j - 1) * 96, Q);
        j = j + 1;
    }

    # acc = Σ nibble_i · 16^i · Q, scanning MS→LS. pt_double/pt_add are
    # safe in place (all reads precede the writes), and pt_double(O)=O so
    # the leading no-op doublings need no special case.
    pt_set_infinity(_ecq_acc);
    var i = 63;
    while (i >= 0) {
        pt_double(_ecq_acc, _ecq_acc);
        pt_double(_ecq_acc, _ecq_acc);
        pt_double(_ecq_acc, _ecq_acc);
        pt_double(_ecq_acc, _ecq_acc);
        var limb = load64(k + (i / 16) * 8);
        var nib  = (limb >> ((i % 16) * 4)) & 0xF;
        pt_add(_ecq_acc, _ecq_acc, _ecq_tab + nib * 96);
        i = i - 1;
    }
    pt_copy(out, _ecq_acc);
    return 0;
}

# ================================================================
# ECDSA verify (SEC 1 v2.0 §4.1.4 / FIPS 186-5 §6.4.2)
#
# Inputs:
#   pk    — 64 bytes, Qx || Qy (big-endian)
#   msg   — raw message bytes (this entry hashes them internally)
#   sig   — 64 bytes, r || s   (big-endian)
#
# Algorithm:
#   1. Verify r, s ∈ [1, n-1].
#   2. e = leftmost 256 bits of SHA-256(msg) — for P-256 this is the
#      full digest; reduce mod n.
#   3. w = s^(-1) mod n
#   4. u1 = e*w mod n,  u2 = r*w mod n
#   5. R = u1*G + u2*Q  (Jacobian, then to affine)
#   6. If R is the point at infinity, reject.
#   7. v = Rx mod n. Accept iff v == r.
# ================================================================

var _ecv_e        = 0;
var _ecv_r        = 0;
var _ecv_s        = 0;
var _ecv_w        = 0;
var _ecv_u1       = 0;
var _ecv_u2       = 0;
var _ecv_qx       = 0;
var _ecv_qy       = 0;
var _ecv_digest   = 0;
var _ecv_digest_padded = 0;
var _ecv_P_u1G    = 0;
var _ecv_P_u2Q    = 0;
var _ecv_R        = 0;
var _ecv_Rx       = 0;
var _ecv_Ry       = 0;
var _ecv_Rx_modn  = 0;
var _ecv_Q        = 0;
var _ecv_inited   = 0;

fn _ecv_init(): i64 {
    if (_ecv_inited == 1) { return 0; }
    _p256_init();
    _ecv_e        = alloc(32);
    _ecv_r        = alloc(32);
    _ecv_s        = alloc(32);
    _ecv_w        = alloc(32);
    _ecv_u1       = alloc(32);
    _ecv_u2       = alloc(32);
    _ecv_qx       = alloc(32);
    _ecv_qy       = alloc(32);
    _ecv_digest   = alloc(32);
    _ecv_digest_padded = alloc(64);
    _ecv_P_u1G    = pt_alloc();
    _ecv_P_u2Q    = pt_alloc();
    _ecv_R        = pt_alloc();
    _ecv_Rx       = alloc(32);
    _ecv_Ry       = alloc(32);
    _ecv_Rx_modn  = alloc(32);
    _ecv_Q        = pt_alloc();
    _build_p256_G_table();        # fixed-base comb for the u1·G term
    _ecv_inited = 1;
    return 0;
}

# Public entry. Returns 1 on valid, 0 on invalid. Hashes msg with
# SHA-256 internally, then defers to the digest-taking core. The 4-arg
# signature is preserved byte-for-byte for the sgx/tdx/snp/dist callers.
fn ecdsa_p256_verify(pk, msg, msg_len, sig): i64 {
    _ecv_init();
    sha256(msg, msg_len, _ecv_digest);
    return _ecdsa_p256_verify_digest(pk, _ecv_digest, 32, sig);
}

# Digest-taking core. Verifies a P-256 signature against a PRECOMPUTED
# digest of `digest_len` bytes — the hash is the caller's choice,
# DECOUPLED from the curve. This is what lets x509 verify an off-diagonal
# chain link (a P-256 issuer signing a SHA-384 child). The message
# representative e is the leftmost bitlen(n) = 256 bits of the digest
# (FIPS 186-4 §6.4 / SEC 1 §4.1.4 step 3): bitlen(n_p256) is exactly 256,
# so for a digest of >= 32 bytes that is its leftmost 32 bytes (the MSBs;
# e.g. the top 32 of a 48-byte SHA-384 digest); a shorter digest is used
# whole, left-zero-padded. e is then reduced mod n with a single
# conditional subtract (e < 2^256 < 2n, so one subtract is exact).
fn _ecdsa_p256_verify_digest(pk, digest, digest_len, sig): i64 {
    _ecv_init();

    # 1. Decode r, s from sig (big-endian). Range check r, s ∈ [1, n-1].
    u256_load_be(_ecv_r, sig);
    u256_load_be(_ecv_s, sig + 32);
    if (u256_is_zero(_ecv_r) == 1) { return 0; }
    if (u256_is_zero(_ecv_s) == 1) { return 0; }
    if (u256_cmp(_ecv_r, _p256_n) >= 0) { return 0; }
    if (u256_cmp(_ecv_s, _p256_n) >= 0) { return 0; }

    # 2. Decode Q from pk and validate it is on the curve.
    # Closes audit 2026-05-21 LOW-1 (invalid-curve attack — Bos et al.
    # 2014). pt_is_on_curve also rejects (0,0) and out-of-range
    # coordinates so the prior explicit checks are subsumed.
    u256_load_be(_ecv_qx, pk);
    u256_load_be(_ecv_qy, pk + 32);
    if (pt_is_on_curve(_ecv_qx, _ecv_qy) == 0) { return 0; }
    pt_from_affine(_ecv_Q, _ecv_qx, _ecv_qy);

    # 3. e = leftmost 256 bits of digest, mod n (FIPS 186-4 §6.4).
    #    Assemble the 32 scalar bytes big-endian: leftmost 32 of the
    #    digest when it is >= 32 bytes (pad == 0); whole digest left-
    #    zero-padded otherwise. (_ecv_digest_padded is 64-byte scratch.)
    var take = 32;
    if (digest_len < 32) { take = digest_len; }
    var pad = 32 - take;
    memset(_ecv_digest_padded, 0, 32);
    var i = 0;
    while (i < take) {
        store8(_ecv_digest_padded + pad + i, load8(digest + i) & 0xFF);
        i = i + 1;
    }
    u256_load_be(_ecv_e, _ecv_digest_padded);
    if (u256_cmp(_ecv_e, _p256_n) >= 0) { u256_sub(_ecv_e, _ecv_e, _p256_n); }

    # 4. w = s^-1 mod n
    fn_p256_inv(_ecv_w, _ecv_s);

    # 5. u1 = e*w mod n, u2 = r*w mod n
    fn_p256_mul(_ecv_u1, _ecv_e, _ecv_w);
    fn_p256_mul(_ecv_u2, _ecv_r, _ecv_w);

    # 6. R = u1*G + u2*Q. u1·G via the fixed-base comb (public scalar);
    #    u2·Q via the Montgomery ladder (Q varies per call). Both inputs
    #    are public, so the comb's non-CT table index is acceptable here.
    p256_scalarmul_base(_ecv_P_u1G, _ecv_u1);
    p256_scalarmul_var(_ecv_P_u2Q, _ecv_u2, _ecv_Q);
    pt_add(_ecv_R, _ecv_P_u1G, _ecv_P_u2Q);

    if (pt_is_infinity(_ecv_R) == 1) { return 0; }

    # 7. v = Rx mod n; accept iff v == r.
    pt_to_affine(_ecv_Rx, _ecv_Ry, _ecv_R);
    fn_p256_reduce256(_ecv_Rx_modn, _ecv_Rx);
    if (u256_eq(_ecv_Rx_modn, _ecv_r) == 1) { return 1; }
    return 0;
}

# ================================================================
# DER signature decode wrapper
#
# X.509 / DER-encoded ECDSA signature shape:
#   SEQUENCE { INTEGER r, INTEGER s }
# Tag bytes: 0x30 (SEQUENCE), 0x02 (INTEGER).
# Each INTEGER may be 32 or 33 bytes (leading 0x00 if the MSB would
# otherwise set the sign bit). Short ints (< 32 bytes) are 0-padded
# on the left to 32 bytes for raw verify.
# ================================================================

# Decode one DER INTEGER starting at off into a big-endian destination
# of field width `fw` bytes (32 for P-256, 48 for P-384). Returns the
# next offset on success, or -1 on any malformed input. `dst` must be
# `fw` bytes; on success, contents are the big-endian r/s value
# zero-padded on the left.
fn _ecdsa_der_int_w(src, off, src_len, dst, fw): i64 {
    if (off + 2 > src_len) { return 0 - 1; }
    if ((load8(src + off) & 0xFF) != 0x02) { return 0 - 1; }
    var raw_len = load8(src + off + 1) & 0xFF;
    if (raw_len > fw + 1) { return 0 - 1; }      # too long for this field
    if (off + 2 + raw_len > src_len) { return 0 - 1; }

    var int_off = off + 2;
    var int_len = raw_len;
    # Strip a single leading 0x00 sign byte, if any. (DER requires it
    # when the next byte's high bit is set; we tolerate either.)
    if (raw_len == fw + 1) {
        if ((load8(src + int_off) & 0xFF) != 0x00) { return 0 - 1; }
        int_off = int_off + 1;
        int_len = int_len - 1;
    }
    if (int_len > fw) { return 0 - 1; }

    # Left-pad with zeros into the `fw`-byte big-endian destination.
    memset(dst, 0, fw);
    var pad = fw - int_len;
    var i = 0;
    while (i < int_len) {
        store8(dst + pad + i, load8(src + int_off + i) & 0xFF);
        i = i + 1;
    }
    return off + 2 + raw_len;   # consume the original encoded length
}

# P-256 (32-byte field) wrapper — preserves the original contract.
fn _ecdsa_der_int(src, off, src_len, dst): i64 {
    return _ecdsa_der_int_w(src, off, src_len, dst, 32);
}

fn ecdsa_p256_verify_der(pk, msg, msg_len, sig_der, sig_der_len): i64 {
    if (sig_der_len < 8) { return 0; }
    if ((load8(sig_der) & 0xFF) != 0x30) { return 0; }
    var seq_len = load8(sig_der + 1) & 0xFF;
    if (seq_len >= 0x80) { return 0; }   # short-form length only (always under 71 bytes for P-256)
    if (2 + seq_len > sig_der_len) { return 0; }

    var raw_sig = alloc(64);
    var off = _ecdsa_der_int(sig_der, 2, sig_der_len, raw_sig);
    if (off < 0) { return 0; }
    off = _ecdsa_der_int(sig_der, off, sig_der_len, raw_sig + 32);
    if (off < 0) { return 0; }

    return ecdsa_p256_verify(pk, msg, msg_len, raw_sig);
}
