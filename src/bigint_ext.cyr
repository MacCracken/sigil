# bigint_ext.cyr — extended 256-bit arithmetic for Ed25519
# Adds: full 512-bit multiply, modular reduction for p=2^255-19,
# modular inversion, modular exponentiation, LE byte codec.
# Builds on lib/bigint.cyr

# ================================================================
# u256 <-> little-endian byte codec
# Previously inlined at 7 sites (5 decode + 2 encode loops, ~11 lines
# each) across ed25519.cyr. Safe to factor out: no nested function
# calls inside the loop body, so locals survive despite Cyrius'
# parameter-clobber rule.
# ================================================================

# Load 32 little-endian bytes from src into dst as four i64 limbs.
fn u256_load_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        store64(dst + i * 8,
        (load8(src + i*8) & 0xFF)
        | ((load8(src + i*8 + 1) & 0xFF) << 8)
        | ((load8(src + i*8 + 2) & 0xFF) << 16)
        | ((load8(src + i*8 + 3) & 0xFF) << 24)
        | ((load8(src + i*8 + 4) & 0xFF) << 32)
        | ((load8(src + i*8 + 5) & 0xFF) << 40)
        | ((load8(src + i*8 + 6) & 0xFF) << 48)
        | ((load8(src + i*8 + 7) & 0xFF) << 56));
        i = i + 1;
    }
    return 0;
}

# Store src (four i64 limbs) as 32 little-endian bytes at dst.
fn u256_store_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        var v = load64(src + i * 8);
        store8(dst + i*8, v & 0xFF);
        store8(dst + i*8 + 1, (v >> 8) & 0xFF);
        store8(dst + i*8 + 2, (v >> 16) & 0xFF);
        store8(dst + i*8 + 3, (v >> 24) & 0xFF);
        store8(dst + i*8 + 4, (v >> 32) & 0xFF);
        store8(dst + i*8 + 5, (v >> 40) & 0xFF);
        store8(dst + i*8 + 6, (v >> 48) & 0xFF);
        store8(dst + i*8 + 7, (v >> 56) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Full 256×256 → 512-bit multiply
# out: 64 bytes (8 limbs)
# ================================================================
# 3.3: per-call working state. The pre-3.3 module-globals were a
# cycc 3 local-clobbering workaround that cycc 6.0.1 no longer
# needs. `_mul64_full` is inlined here — it was its only caller
# and returning two values via globals (`_m64_lo` / `_m64_hi`)
# had no clean local equivalent.

# Schoolbook 256×256→512 multiply. RETAINED AS THE KAT ORACLE / REFERENCE
# for the Karatsuba `u256_mul_full` below (differential KAT in bigint.tcyr).
# Thread-safe: scalar locals + caller's `out` only, no static scratch (it
# runs on the Ed25519 parallel batch-verify path).
fn _u256_mul_full_schoolbook(out, a, b): i64 {
    memset(out, 0, 64);
    var sbit = 1 << 63;
    var mask32 = 0xFFFFFFFF;
    var i = 0;
    while (i < 4) {
        var carry = 0;
        var j = 0;
        while (j < 4) {
            # Inlined 64×64 → 128-bit multiply.
            var av = load64(a + i * 8);
            var bv = load64(b + j * 8);
            var aL = av & mask32;
            var aH = (av >> 32) & mask32;
            var bL = bv & mask32;
            var bH = (bv >> 32) & mask32;
            var ll = aL * bL;
            var lh = aL * bH;
            var hl = aH * bL;
            var hh = aH * bH;
            var mid = lh + hl;
            var mid_carry = 0;
            if ((mid ^ sbit) < (lh ^ sbit)) { mid_carry = 1; }
            var m_lo = ll + (mid << 32);
            var lo_carry = 0;
            if ((m_lo ^ sbit) < (ll ^ sbit)) { lo_carry = 1; }
            var m_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;

            var k = i + j;
            var prev = load64(out + k * 8);

            # s1 = prev + m_lo; c1 = overflow
            var s1 = prev + m_lo;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }

            # s2 = s1 + carry; c2 = overflow
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }

            store64(out + k * 8, s2);
            carry = m_hi + c1 + c2;
            j = j + 1;
        }
        if (i + 4 < 8) {
            store64(out + (i + 4) * 8, load64(out + (i + 4) * 8) + carry);
        }
        i = i + 1;
    }
    return 0;
}

# Thread-safe 128×128→256 schoolbook (2×2 limbs). `out` is 4 limbs (32 B);
# `a`, `b` are 2 limbs (16 B) each. Scalar locals only — no static scratch.
fn _u256k_mul128(out, a, b): i64 {
    memset(out, 0, 32);
    var sbit = 1 << 63;
    var mask32 = 0xFFFFFFFF;
    var i = 0;
    while (i < 2) {
        var carry = 0;
        var j = 0;
        while (j < 2) {
            var av = load64(a + i * 8);
            var bv = load64(b + j * 8);
            var aL = av & mask32; var aH = (av >> 32) & mask32;
            var bL = bv & mask32; var bH = (bv >> 32) & mask32;
            var ll = aL * bL; var lh = aL * bH; var hl = aH * bL; var hh = aH * bH;
            var mid = lh + hl;
            var mid_carry = 0;
            if ((mid ^ sbit) < (lh ^ sbit)) { mid_carry = 1; }
            var m_lo = ll + (mid << 32);
            var lo_carry = 0;
            if ((m_lo ^ sbit) < (ll ^ sbit)) { lo_carry = 1; }
            var m_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;
            var k = i + j;
            var prev = load64(out + k * 8);
            var s1 = prev + m_lo;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
            store64(out + k * 8, s2);
            carry = m_hi + c1 + c2;
            j = j + 1;
        }
        store64(out + (i + 2) * 8, load64(out + (i + 2) * 8) + carry);
        i = i + 1;
    }
    return 0;
}

# Karatsuba 256×256→512. a = aL + aH·2^128, b = bL + bH·2^128 (each half
# 2 limbs). z0 = aL·bL, z2 = aH·bH, z1 = (aL+aH)(bL+bH) − z0 − z2 (= aL·bH
# + aH·bL); out = z0 + z1·2^128 + z2·2^256. 12 × 64×64 muls vs the
# schoolbook's 16. THREAD-SAFE (scalar locals + caller's `out` + the
# stateless _u256k_mul128 helper — no static scratch, so it is safe on the
# Ed25519 parallel batch-verify path). KAT-gated byte-for-byte against
# `_u256_mul_full_schoolbook` (bigint.tcyr).
fn u256_mul_full(out, a, b): i64 {
    var sbit = 1 << 63;
    var mask32 = 0xFFFFFFFF;

    # z0 = aL·bL → out[0..3];  z2 = aH·bH → out[4..7].
    # (out now holds z0 + z2·2^256 — the result minus the middle term.)
    _u256k_mul128(out, a, b);
    _u256k_mul128(out + 32, a + 16, b + 16);

    var a0 = load64(a + 0);  var a1 = load64(a + 8);
    var a2 = load64(a + 16); var a3 = load64(a + 24);
    var b0 = load64(b + 0);  var b1 = load64(b + 8);
    var b2 = load64(b + 16); var b3 = load64(b + 24);

    # sL = aL + aH = (sl0, sl1) + cs·2^128   (cs ∈ {0,1})
    var sl0 = a0 + a2;
    var sc = 0; if ((sl0 ^ sbit) < (a0 ^ sbit)) { sc = 1; }
    var sl1 = a1 + a3;
    var cs = 0; if ((sl1 ^ sbit) < (a1 ^ sbit)) { cs = 1; }
    var sl1c = sl1 + sc; if ((sl1c ^ sbit) < (sl1 ^ sbit)) { cs = cs + 1; }
    sl1 = sl1c;

    # tL = bL + bH = (tl0, tl1) + ct·2^128
    var tl0 = b0 + b2;
    var tc = 0; if ((tl0 ^ sbit) < (b0 ^ sbit)) { tc = 1; }
    var tl1 = b1 + b3;
    var ct = 0; if ((tl1 ^ sbit) < (b1 ^ sbit)) { ct = 1; }
    var tl1c = tl1 + tc; if ((tl1c ^ sbit) < (tl1 ^ sbit)) { ct = ct + 1; }
    tl1 = tl1c;

    # m = (sl0,sl1) × (tl0,tl1) → m0..m3 (2×2 schoolbook, inline).
    var vL = sl0 & mask32; var vH = (sl0 >> 32) & mask32;
    var wL = tl0 & mask32; var wH = (tl0 >> 32) & mask32;
    var ll = vL * wL; var lh = vL * wH; var hl = vH * wL; var hh = vH * wH;
    var md = lh + hl; var mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p00lo = ll + (md << 32); var lc = 0; if ((p00lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p00hi = hh + (md >> 32) + (mc << 32) + lc;

    vL = sl0 & mask32; vH = (sl0 >> 32) & mask32; wL = tl1 & mask32; wH = (tl1 >> 32) & mask32;
    ll = vL * wL; lh = vL * wH; hl = vH * wL; hh = vH * wH;
    md = lh + hl; mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p01lo = ll + (md << 32); lc = 0; if ((p01lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p01hi = hh + (md >> 32) + (mc << 32) + lc;

    vL = sl1 & mask32; vH = (sl1 >> 32) & mask32; wL = tl0 & mask32; wH = (tl0 >> 32) & mask32;
    ll = vL * wL; lh = vL * wH; hl = vH * wL; hh = vH * wH;
    md = lh + hl; mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p10lo = ll + (md << 32); lc = 0; if ((p10lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p10hi = hh + (md >> 32) + (mc << 32) + lc;

    vL = sl1 & mask32; vH = (sl1 >> 32) & mask32; wL = tl1 & mask32; wH = (tl1 >> 32) & mask32;
    ll = vL * wL; lh = vL * wH; hl = vH * wL; hh = vH * wH;
    md = lh + hl; mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p11lo = ll + (md << 32); lc = 0; if ((p11lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p11hi = hh + (md >> 32) + (mc << 32) + lc;

    var m0 = p00lo;
    var t = p00hi + p01lo; var cm = 0; if ((t ^ sbit) < (p00hi ^ sbit)) { cm = 1; }
    var m1 = t + p10lo; if ((m1 ^ sbit) < (t ^ sbit)) { cm = cm + 1; }
    var u = p01hi + p10hi; var cm2 = 0; if ((u ^ sbit) < (p01hi ^ sbit)) { cm2 = 1; }
    var u2 = u + p11lo; if ((u2 ^ sbit) < (u ^ sbit)) { cm2 = cm2 + 1; }
    var m2 = u2 + cm; if ((m2 ^ sbit) < (u2 ^ sbit)) { cm2 = cm2 + 1; }
    var m3 = p11hi + cm2;
    var m4 = 0; if ((m3 ^ sbit) < (p11hi ^ sbit)) { m4 = 1; }

    # corrections: m += cs·(tl0,tl1)·2^128 + ct·(sl0,sl1)·2^128 + (cs·ct)·2^256
    if (cs == 1) {
        var n0 = m2 + tl0; var nc = 0; if ((n0 ^ sbit) < (m2 ^ sbit)) { nc = 1; } m2 = n0;
        var n1 = m3 + tl1; if ((n1 ^ sbit) < (m3 ^ sbit)) { m4 = m4 + 1; }
        m3 = n1 + nc; if ((m3 ^ sbit) < (n1 ^ sbit)) { m4 = m4 + 1; }
    }
    if (ct == 1) {
        var o0 = m2 + sl0; var oc = 0; if ((o0 ^ sbit) < (m2 ^ sbit)) { oc = 1; } m2 = o0;
        var o1 = m3 + sl1; if ((o1 ^ sbit) < (m3 ^ sbit)) { m4 = m4 + 1; }
        m3 = o1 + oc; if ((m3 ^ sbit) < (o1 ^ sbit)) { m4 = m4 + 1; }
    }
    if (cs == 1) { if (ct == 1) { m4 = m4 + 1; } }

    # z1 = m − z0 − z2  (z0 = out[0..3], z2 = out[4..7]; result ≥ 0).
    var z00 = load64(out + 0);  var z01 = load64(out + 8);
    var z02 = load64(out + 16); var z03 = load64(out + 24);
    var z20 = load64(out + 32); var z21 = load64(out + 40);
    var z22 = load64(out + 48); var z23 = load64(out + 56);
    var br = 0; var dq = 0; var dq2 = 0; var nb = 0;
    dq = m0 - z00; br = 0; if ((m0 ^ sbit) < (z00 ^ sbit)) { br = 1; } m0 = dq;
    dq = m1 - z01; nb = 0; if ((m1 ^ sbit) < (z01 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m1 = dq2; br = nb;
    dq = m2 - z02; nb = 0; if ((m2 ^ sbit) < (z02 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m2 = dq2; br = nb;
    dq = m3 - z03; nb = 0; if ((m3 ^ sbit) < (z03 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m3 = dq2; br = nb;
    m4 = m4 - br;
    dq = m0 - z20; br = 0; if ((m0 ^ sbit) < (z20 ^ sbit)) { br = 1; } m0 = dq;
    dq = m1 - z21; nb = 0; if ((m1 ^ sbit) < (z21 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m1 = dq2; br = nb;
    dq = m2 - z22; nb = 0; if ((m2 ^ sbit) < (z22 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m2 = dq2; br = nb;
    dq = m3 - z23; nb = 0; if ((m3 ^ sbit) < (z23 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m3 = dq2; br = nb;
    m4 = m4 - br;

    # out += z1·2^128  (add m0..m4 into out[2..6], carry to out[7]).
    var oc2 = 0; var p = 0; var p2 = 0; var nc2 = 0;
    p = load64(out + 16) + m0; if ((p ^ sbit) < (m0 ^ sbit)) { oc2 = 1; } store64(out + 16, p);
    p = load64(out + 24) + m1; nc2 = 0; if ((p ^ sbit) < (m1 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 24, p2); oc2 = nc2;
    p = load64(out + 32) + m2; nc2 = 0; if ((p ^ sbit) < (m2 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 32, p2); oc2 = nc2;
    p = load64(out + 40) + m3; nc2 = 0; if ((p ^ sbit) < (m3 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 40, p2); oc2 = nc2;
    p = load64(out + 48) + m4; nc2 = 0; if ((p ^ sbit) < (m4 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 48, p2); oc2 = nc2;
    store64(out + 56, load64(out + 56) + oc2);
    return 0;
}

# ================================================================
# Reduction mod p = 2^255 - 19
# Uses: 2^256 ≡ 38 (mod p), so for 512-bit val = aH*2^256 + aL:
#   val mod p ≡ aL + 38*aH (mod p)
# May need 1-2 further subtractions.
# ================================================================

# Read-only-after-init: curve modulus p = 2^255 - 19 and the
# Solinas constant 38 (= 2 · 19) used in 2^256 ≡ 38 (mod p).
var _ed_p = 0;
var _ed_p_inited = 0;
var _mod_38 = 0;

fn _init_ed_p(): i64 {
    if (_ed_p_inited == 1) { return 0; }
    _ed_p = u256_from_hex("7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffed");
    _mod_38 = u256_from(38);
    _ed_p_inited = 1;
    return 0;
}

fn u512_mod_p(out, val): i64 {
    _init_ed_p();

    # Per-thread banked scratch (3.6): every `var X[N]` here is a
    # static function-scope global (CLAUDE.md quirk #1), so each
    # batch-verify worker carves its own lane. One `cbank()` read per
    # call; all lanes derive from the same bank index.
    var bk = cbank();
    var aH[2048];   var aHb = &aH + bk * 32;     # 32 * SIGIL_CRYPTO_BANKS
    var aL[2048];   var aLb = &aL + bk * 32;
    var prod[4096]; var prodb = &prod + bk * 64; # 64 * SIGIL_CRYPTO_BANKS
    var lowp[2048]; var lowpb = &lowp + bk * 32;
    var r[2048];    var rb = &r + bk * 32;
    var extra[2048];var extrab = &extra + bk * 32;

    store64(aHb, load64(val + 32));
    store64(aHb + 8, load64(val + 40));
    store64(aHb + 16, load64(val + 48));
    store64(aHb + 24, load64(val + 56));

    store64(aLb, load64(val));
    store64(aLb + 8, load64(val + 8));
    store64(aLb + 16, load64(val + 16));
    store64(aLb + 24, load64(val + 24));

    u256_mul_full(prodb, aHb, _mod_38);

    store64(lowpb, load64(prodb));
    store64(lowpb + 8, load64(prodb + 8));
    store64(lowpb + 16, load64(prodb + 16));
    store64(lowpb + 24, load64(prodb + 24));

    var carry = u256_add(rb, aLb, lowpb);
    var overflow = carry + load64(prodb + 32);

    while (overflow > 0) {
        store64(extrab, overflow * 38);
        store64(extrab + 8, 0);
        store64(extrab + 16, 0);
        store64(extrab + 24, 0);
        overflow = u256_add(rb, rb, extrab);
    }

    while (u256_cmp(rb, _ed_p) >= 0) {
        u256_sub(rb, rb, _ed_p);
    }

    u256_copy(out, rb);
    return 0;
}

# ================================================================
# Field arithmetic mod p
# ================================================================

fn fp_add(r, a, b): i64 {
    _init_ed_p();
    u256_add(r, a, b);
    if (u256_cmp(r, _ed_p) >= 0) { u256_sub(r, r, _ed_p); }
    return 0;
}

fn fp_sub(r, a, b): i64 {
    _init_ed_p();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _ed_p); }
    return 0;
}

fn fp_neg(r, a): i64 {
    _init_ed_p();
    if (u256_is_zero(a) == 1) {
        u256_copy(r, a);
        return 0;
    }
    u256_sub(r, _ed_p, a);
    return 0;
}

fn fp_mul(r, a, b): i64 {
    # Per-thread banked scratch (3.6): `var prod[N]` is a static
    # function-scope global (CLAUDE.md quirk #1). Each batch-verify
    # worker uses its own 64-byte lane so concurrent field
    # multiplies on the [h]A / [S]B ladders never collide.
    var prod[4096];                       # 64 * SIGIL_CRYPTO_BANKS
    var prodb = &prod + cbank() * 64;
    u256_mul_full(prodb, a, b);
    u512_mod_p(r, prodb);
    return 0;
}

fn fp_sq(r, a): i64 {
    return fp_mul(r, a, a);
}

# ================================================================
# Modular exponentiation: r = base^exp mod p
# ================================================================

fn fp_pow(r, base, exp): i64 {
    _init_ed_p();
    # Per-thread banked scratch (3.6) — see fp_mul / u512_mod_p.
    var bk = cbank();
    var tmp[2048];      var tmpb = &tmp + bk * 32;       # 32 * SIGIL_CRYPTO_BANKS
    var result[2048];   var resultb = &result + bk * 32;
    var base_buf[2048]; var base_bufb = &base_buf + bk * 32;
    store64(resultb, 1);
    store64(resultb + 8, 0);
    store64(resultb + 16, 0);
    store64(resultb + 24, 0);
    u256_copy(base_bufb, base);
    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx = i % 64;
        var bit = (load64(exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_mul(tmpb, resultb, base_bufb);
            u256_copy(resultb, tmpb);
        }
        fp_mul(tmpb, base_bufb, base_bufb);
        u256_copy(base_bufb, tmpb);
        i = i + 1;
    }
    u256_copy(r, resultb);
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p for p = 2^255 - 19
# Bernstein's addition chain from the curve25519 reference:
# 254 squarings + 11 multiplies = 265 fp_mul calls
# (vs the generic fp_pow(p-2): ~512 fp_mul calls).
# ================================================================

fn _fpi_sq_n(buf, n): i64 {
    # In-place square `buf` n times.
    var i = 0;
    while (i < n) {
        fp_sq(buf, buf);
        i = i + 1;
    }
    return 0;
}

fn fp_inv(r, a): i64 {
    _init_ed_p();
    # Per-thread banked scratch (3.6): these 8 chain temporaries are
    # static function-scope globals (CLAUDE.md quirk #1) and fp_inv is
    # on the parallel verify path (ge_to_bytes → fp_inv), so each
    # worker inverts into its own lane. One `cbank()` read per call.
    var bk = cbank();
    var t0[2048];    var t0b = &t0 + bk * 32;       # 32 * SIGIL_CRYPTO_BANKS
    var z9[2048];    var z9b = &z9 + bk * 32;
    var z11[2048];   var z11b = &z11 + bk * 32;
    var z5[2048];    var z5b = &z5 + bk * 32;
    var z10[2048];   var z10b = &z10 + bk * 32;
    var z50[2048];   var z50b = &z50 + bk * 32;
    var z100[2048];  var z100b = &z100 + bk * 32;
    var a_buf[2048]; var a_bufb = &a_buf + bk * 32;
    u256_copy(a_bufb, a);

    # z2 in t0: t0 = a^2
    fp_sq(t0b, a_bufb);
    # z9 = t0^4 * a   = a^9
    fp_sq(z9b, t0b);
    fp_sq(z9b, z9b);
    fp_mul(z9b, z9b, a_bufb);
    # z11 = z9 * z2(=t0) = a^11
    fp_mul(z11b, z9b, t0b);
    # z5 = z11^2 * z9  = a^(2^5 - 1) = a^31
    fp_sq(z5b, z11b);
    fp_mul(z5b, z5b, z9b);

    # z10 = z5^(2^5) * z5 = a^(2^10 - 1)
    fp_sq(z10b, z5b);
    _fpi_sq_n(z10b, 4);
    fp_mul(z10b, z10b, z5b);

    # t0 = z10^(2^10) * z10 = a^(2^20 - 1)
    fp_sq(t0b, z10b);
    _fpi_sq_n(t0b, 9);
    fp_mul(t0b, t0b, z10b);

    # t0 = t0^(2^20) * t0 = a^(2^40 - 1)
    # Save current t0 into z9 (which is dead after this point —
    # the last use was building z11).
    u256_copy(z9b, t0b);
    _fpi_sq_n(t0b, 20);
    fp_mul(t0b, t0b, z9b);

    # t0 = t0^(2^10) * z10 = a^(2^50 - 1)
    _fpi_sq_n(t0b, 10);
    fp_mul(z50b, t0b, z10b);

    # t0 = z50^(2^50) * z50 = a^(2^100 - 1)
    fp_sq(t0b, z50b);
    _fpi_sq_n(t0b, 49);
    fp_mul(z100b, t0b, z50b);

    # t0 = z100^(2^100) * z100 = a^(2^200 - 1)
    fp_sq(t0b, z100b);
    _fpi_sq_n(t0b, 99);
    fp_mul(t0b, t0b, z100b);

    # t0 = t0^(2^50) * z50 = a^(2^250 - 1)
    _fpi_sq_n(t0b, 50);
    fp_mul(t0b, t0b, z50b);

    # r = t0^(2^5) * z11 = a^(2^255 - 21) = a^(p - 2)
    _fpi_sq_n(t0b, 5);
    fp_mul(r, t0b, z11b);
    return 0;
}
