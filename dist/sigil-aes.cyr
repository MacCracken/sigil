# --- error.cyr ---

# error.cyr — sigil error codes and error construction
# Follows packed-struct pattern (like sakshi) for error objects.

# ================================================================
# Error codes
# ================================================================

enum SigilError {
    SIGIL_ERR_NONE = 0;
    SIGIL_ERR_KEY_NOT_FOUND = 1;
    SIGIL_ERR_SIGNATURE_INVALID = 2;
    SIGIL_ERR_REVOCATION = 3;
    SIGIL_ERR_INTEGRITY_MISMATCH = 4;
    SIGIL_ERR_INVALID_INPUT = 5;
    SIGIL_ERR_IO = 6;
    SIGIL_ERR_SERIALIZATION = 7;
    SIGIL_ERR_CRYPTO = 8;
}

# ================================================================
# Error predicates
# ================================================================

# Returns 1 if `code` is SIGIL_ERR_NONE (success), 0 otherwise.
fn sigil_is_ok(code): i64 {
    if (code == SIGIL_ERR_NONE) { return 1; }
    return 0;
}

# Returns 1 if `code` is any non-SIGIL_ERR_NONE error code, 0 otherwise.
fn sigil_is_err(code): i64 {
    if (code != SIGIL_ERR_NONE) { return 1; }
    return 0;
}

# ================================================================
# Error object (16 bytes)
# ================================================================
# Layout:
#   +0   code   (i64, ERR_* constant)
#   +8   msg    (C-string pointer)

# Allocates a 16-byte error object holding `code` and `msg` (a C-string
# pointer). Returns the object pointer; free with sigil_err_free.
fn sigil_err(code, msg): i64 {
    var e = fl_alloc(16);
    store64(e, code);
    store64(e + 8, msg);
    return e;
}

# Returns the ERR_* code stored in error object `e`.
fn sigil_err_code(e): i64 { return load64(e); }
# Returns the message C-string pointer stored in error object `e`.
fn sigil_err_msg(e): i64 { return load64(e + 8); }
# Frees an error object allocated by sigil_err. Returns 0.
fn sigil_err_free(e): i64 { fl_free(e); return 0; }

# --- crypto_scratch.cyr ---

# crypto_scratch.cyr — per-thread working-buffer bank selection for
# the parallel batch-verify path (sigil 3.6).
#
# WHY THIS EXISTS
# ---------------
# A `var X[N]` declared inside a function in cyrius is a STATIC
# function-scope global, not a per-call stack array (CLAUDE.md quirk
# #1; tests/tcyr/var_array_semantics.tcyr — re-confirmed under cycc
# 6.0.52 during the 3.6 open). The transient working arrays inside
# the crypto primitives (SHA-256/512 message schedules, the Ed25519
# field/group temporaries) are therefore shared across threads, which
# is exactly why `sv_verify_batch` had to serialise every artifact
# behind `_sigil_batch_mutex` (see the threading-safety contract in
# src/verify.cyr).
#
# THE 3.6 MECHANISM — per-thread BANKS
# ------------------------------------
# Each racing `var X[N]` is widened to `var X[N * SIGIL_CRYPTO_BANKS]`
# and the function operates on its own lane `&X + cbank()*N`. `cbank()`
# returns the calling thread's bank index, read from a thread-local
# slot (cyrius 6.0.52 `lib/thread_local.cyr`):
#   - the main thread / serial path uses bank 0 (a fresh TLS slot
#     reads 0);
#   - batch workers are assigned distinct banks 1..workers at spawn
#     (`crypto_bank_set`).
# Distinct concurrent banks ⇒ disjoint memory ⇒ no data race — with
# NO signature changes, NO caller changes, and NO cross-function
# offset map. Each function still owns its own array; a worker simply
# writes a different lane of it. Collisions are impossible by
# construction (every lane is owned by exactly one live thread).
#
# This is deliberately cheaper and far lower-risk than threading a
# caller-provided scratch pointer through every `fp_mul` / `ge_add` /
# `sha256_transform` signature (the shape the v3.6 roadmap sketched
# before cyrius shipped thread-local storage): no signature churn, and
# the bank arithmetic is local and self-evidently collision-free.
#
# TLS LIFECYCLE
# -------------
# Worker threads spawned via `thread_create` get a zeroed 4 KB TLS
# block installed automatically by CLONE_SETTLS (cyrius lib/thread.cyr),
# so they need no init — their slot reads 0 until `crypto_bank_set`
# overwrites it. The MAIN thread has no TLS block until one is
# installed, so `cbank()` self-installs one on first use (and the
# batch path pre-warms it on the main thread before fan-out). The
# `& (SIGIL_CRYPTO_BANKS-1)` mask makes an out-of-range slot value
# impossible to turn into an out-of-bounds lane — defence in depth.
#
# Requires: lib/thread_local.cyr (cyrius >= 6.0.52). Must be included
# before any banked crypto module (src/sha_ni.cyr onward).

# Number of concurrent crypto-scratch lanes. MUST be a power of two
# (the `cbank()` mask relies on it). Bank 0 is reserved for the
# main/serial path; banks 1..SIGIL_CRYPTO_BANKS-1 are handed to
# concurrent worker threads. 64 covers a 63-worker TLS termination
# pool (one worker per core on any realistic host) plus the main
# thread; widening only costs banked-array static scratch (each
# banked `var X[N]` is sized N*SIGIL_CRYPTO_BANKS bytes).
#
# 3.9.6 — concurrent-TLS-handshake fix: bumped 8 -> 64 and made
# `cbank()` AUTO-ASSIGN a private lane per thread (see below). Before
# 3.9.6 the only caller that ever set a non-zero bank was the
# batch-verify path (`crypto_bank_set`); every other concurrent caller
# — notably cyrius `tls_native` / sandhi TLS worker threads — collided
# on bank 0, racing the banked scratch (the concurrent-TLS-handshake
# crash). Auto-assignment removes the need for any per-worker
# cooperation: a worker's first `cbank()` claims the next free lane.
# See docs/development/issues/2026-06-28-concurrent-tls-handshake-
# global-scratch-race.md and ADR 0007.
var SIGIL_CRYPTO_BANKS = 64;
var _SIGIL_CBANK_MASK = 63;     # SIGIL_CRYPTO_BANKS - 1
# thread-local slot (cyrius thread_local_get/set namespace). Holds (bank+1):
# 0 = unassigned, v = bank (v-1).
#
# 3.9.9 (2026-07-01): MOVED 0 -> 8. cyrius's thread_local slot namespace is a
# small shared integer space (16 slots, no allocator), and slot 0 COLLIDED with
# patra's SQL-parse scratch (patra owns slots 0-4: TLS_PR/TLS_TOKS/TLS_NTOKS +
# TLS_SLAB_STACK=3/TLS_SLAB_TOP=4). In a server that links BOTH sigil + patra
# (e.g. a TLS termination pool serving a patra-backed API — SecureYeoman's
# yeo-cy-test), a patra query clobbered sigil's pinned bank in slot 0, so a later
# cbank() read patra's scratch value as the bank and indexed the WRONG lane of
# the process-global banked crypto buffers — corrupting an in-flight handshake's
# key schedule -> the client saw RECORD_LAYER_FAILURE (reproduced as "every 4th
# handshake fails" under a specific worker layout). Slot 8 is clear of patra
# (0-4) + the common consumer high slots (15). NOTE: the underlying fix is a
# slot ALLOCATOR in cyrius thread_local.cyr (filed) — until then, leaf crypto
# owns slot 8 by convention. See docs/development/issues/2026-06-28-concurrent-
# tls-handshake-global-scratch-race.md and cyrius issue multiworker-tls-record-
# layer-failure.
var _SIGIL_CBANK_SLOT = 8;
var _crypto_tls_inited = 0;
var _crypto_next_bank = 0;      # atomic counter; auto-assigned worker
                                # threads draw lanes 1..BANKS-1 from it.

# Install a TLS block on the calling (main) thread and claim bank 0
# for it so `cbank()` is well-defined on the serial path. Idempotent
# (a CAS guard makes concurrent first-callers init exactly once, so a
# worker that races here cannot double-`alloc` the TLS block — quirk
# #7: alloc is not thread-safe).
#
# MULTI-THREADED CONSUMER CONTRACT: a server that spawns crypto worker
# threads (e.g. a TLS termination pool) should call this once on the
# MAIN thread at startup, before spawning workers — it installs main's
# TLS block (main has none until installed; workers get a zeroed block
# via CLONE_SETTLS) and marks the subsystem inited so each worker's
# first `cbank()` only reads/auto-assigns and never races init. In
# practice any sigil crypto call on the main thread (e.g. parsing the
# server cert/key) triggers this via the lazy backstop in `cbank()`
# before workers start; the explicit call is belt-and-suspenders.
# Returns 0.
fn crypto_tls_main_init(): i64 {
    # CAS 0 -> 1: exactly one thread wins and runs the init.
    if (atomic_cas(&_crypto_tls_inited, 0, 1) == 0) { return 0; }
    thread_local_init();
    # Claim bank 0 for this (main) thread: slot = bank0 encoded = 1.
    thread_local_set(_SIGIL_CBANK_SLOT, 1);
    return 0;
}

# Explicitly assign the calling thread a bank index (legacy / batch
# path). Bank must be in 0 .. SIGIL_CRYPTO_BANKS-1. Stored as (bank+1)
# so a fresh (unassigned) slot reads 0. Most callers no longer need
# this — `cbank()` auto-assigns — but the batch-verify path keeps using
# it for deterministic lane fan-out. Returns 0.
fn crypto_bank_set(bank): i64 {
    thread_local_set(_SIGIL_CBANK_SLOT, bank + 1);
    return 0;
}

# Bank (lane) index for the calling thread. Bank 0 on the main/serial
# path; a distinct 1..BANKS-1 lane on each concurrent worker. On a
# thread whose slot is still unassigned (a fresh worker that never
# called crypto_bank_set), the FIRST call atomically claims the next
# lane from `_crypto_next_bank` (cycled into 1..BANKS-1 so bank 0 stays
# the exclusive main lane) and pins it in the thread-local slot for the
# life of the thread. This is what makes concurrent callers (TLS
# handshake workers) race-free with zero per-worker cooperation. The
# mask guarantees the result is always a valid lane index (defence in
# depth).
fn cbank(): i64 {
    if (_crypto_tls_inited == 0) { crypto_tls_main_init(); }
    var raw = thread_local_get(_SIGIL_CBANK_SLOT);
    if (raw == 0) {
        # Unassigned thread: claim the next lane. atomic_fetch_add
        # returns the prior counter value (0,1,2,...); map it onto
        # 1..BANKS-1 so we never alias the main thread's bank 0.
        var n = atomic_fetch_add(&_crypto_next_bank, 1);
        var bank = (n % (SIGIL_CRYPTO_BANKS - 1)) + 1;
        thread_local_set(_SIGIL_CBANK_SLOT, bank + 1);
        return bank & _SIGIL_CBANK_MASK;
    }
    return (raw - 1) & _SIGIL_CBANK_MASK;
}

# --- sha_ni.cyr ---

# sha_ni.cyr — SHA-NI hardware-acceleration dispatch.
#
# Include-guard marker: single-file consumers pull this in via the
# `#ifndef`-guarded `include "src/sha_ni.cyr"` in sha256.cyr / aes_gcm.cyr /
# lib.cyr, but the dist bundle (dist/sigil.cyr) already inlines this module —
# so the bundle's redundant include must NOT re-fire (the file is absent in the
# fold, and cyrius hard-errors on a missing include since v6.1.35). This marker
# makes those guarded includes self-skip once this module is present.
#define _SIGIL_SHA_NI_INCLUDED
#
# Lays the CPUID-probe + dispatch infrastructure for the Intel SHA
# extensions (SHA256RNDS2 / SHA256MSG1 / SHA256MSG2) and ships a
# byte-encoded single-block SHA-256 compress that `sha256_transform`
# (in src/sha256.cyr) routes to when `sha_ni_available()` returns 1.
#
# History:
#   2.9.2 — probe live, compress was a -1 stub.
#   2.9.3 — compress shipped; cross-path tested against the FIPS
#           180-4 software path on every input the test suite
#           exercises (empty, "abc", 56-byte two-block vector,
#           1KB, 64KB).
#
# Design and sourcing notes live in
# `docs/development/issues/archive/2026-04-25-sha-ni-compress-design.md`.
# The compress sequence below is byte-for-byte derived from the
# Linux kernel's arch/x86/crypto/sha256_ni_asm.S (Intel
# Corporation, dual BSD/GPLv2 — Sigil is GPL-3.0 so the GPL leg
# applies). State-pack/unpack at the function boundaries adapts
# the kernel's 4-dword digest layout to sigil's 8-byte-per-h_i
# context layout (see design doc §"State-layout impedance").
#
# Detection reference (Intel SDM Vol 2A §3.2):
#   CPUID leaf 7, sub-leaf 0 → EBX bit 29 = SHA extensions
#
# SHA-NI opcode reference (Intel SDM Vol 2A §3.2, §5):
#   SHA256RNDS2 xmm1, xmm2/m128, <XMM0>     0F 38 CB /r
#       Two SHA-256 rounds. K+W in implicit XMM0.
#       xmm1=CDGH input; xmm2=ABEF input; xmm1=new ABEF output.
#   SHA256MSG1  xmm1, xmm2/m128             0F 38 CC /r
#       xmm1 = xmm1 + sigma0(window from xmm1[1..3] || xmm2[0]).
#   SHA256MSG2  xmm1, xmm2/m128             0F 38 CD /r
#       xmm1 = xmm1 + sigma1(window built from xmm1 + xmm2).

# _sha_ni_cache: 2 = uncached, 0 = unavailable, 1 = available.
# Same sentinel discipline as _aes_ni_cache; one CPUID probe
# per process. The "available" gate requires BOTH the CPUID bit
# AND the FIPS 180-4 "abc" self-test passing. The parameter loads
# inside `_sha_ni_compress_one` now use the prologue-drift-proof
# `param_load` pseudo (3.7.8), so the primary SIGILL re-break class
# is fixed at the source; the self-test stays as defense-in-depth
# against any future wrong-output asm regression.
var _sha_ni_cache = 2;
var _sha_ni_probe_out = 0;      # 8-byte scratch for the probe's *out param
var _sha_ni_probe_lock = 0;     # CAS guard: serializes the one-time self-test (3.9.6)

# Self-test scratch — module-level so the 144-byte ctx and the
# expected-digest slots live in BSS rather than on the stack. ctx
# is touched by `_sha_ni_compress_one` via `movdqu` loads/stores
# only (no alignment requirement on ctx itself), but keeping the
# buffer at module scope avoids per-call zeroization cost in the
# happy path.
var _sha_ni_st_ctx[144];

# Runtime SHA-NI capability gate. Returns 1 if the CPU advertises the
# SHA extensions (CPUID leaf 7 EBX bit 29) AND the hardware compress
# reproduces the FIPS 180-4 "abc" digest; 0 otherwise. Result is
# cached after the first probe (one CPUID + self-test per process).
fn sha_ni_available(): i64 {
    if (_sha_ni_cache != 2) { return _sha_ni_cache; }
    # First-probe serialization (3.9.6): the self-test drives the
    # module-global `_sha_ni_st_ctx` scratch; CAS so exactly one thread
    # runs it and the rest spin for the published result (x86-only path,
    # x86-TSO visibility). Matches `aes_ni_available`.
    if (atomic_cas(&_sha_ni_probe_lock, 0, 1) == 0) {
        while (_sha_ni_cache == 2) { }
        return _sha_ni_cache;
    }
    if (_sha_ni_probe_out == 0) { _sha_ni_probe_out = alloc(8); }
    store64(_sha_ni_probe_out, 0);
    _sha_ni_cpuid_probe(_sha_ni_probe_out);
    var ebx = load64(_sha_ni_probe_out);
    # EBX bit 29 = SHA (Intel SDM Vol 2A §3.2 CPUID leaf 7 sub-leaf 0).
    if ((ebx & (1 << 29)) == 0) {
        _sha_ni_cache = 0;
        # Release the one-shot latch AFTER publishing the cache, so a
        # later re-probe (cache reset to the `2` sentinel — tests/benches
        # force a specific path that way) re-acquires the probe instead
        # of dead-spinning on a permanently-held lock (the 3.9.6 bench
        # hang). Production never resets the cache, so the self-test
        # still runs exactly once there and the concurrency guarantee
        # (one thread probes, the rest spin until publish) is unchanged.
        _sha_ni_probe_lock = 0;
        return 0;
    }
    # Defense-in-depth: confirm the NI compress produces the FIPS
    # 180-4 §B.1 single-block "abc" digest before going live. The
    # `[rbp-N]` parameter-load coupling that caused the original
    # SIGILL re-break is now removed (param_load, 3.7.8); this self-
    # test remains to downgrade to software on any *wrong-output* asm
    # regression the compiler change could still introduce. See
    # docs/development/issues/2026-05-10-cyrius-510-asm-stack-frame-
    # drift-breaks-ni-paths.md and the 2026-06-09 re-break issue.
    if (_sha_ni_self_test() == 0) {
        _sha_ni_cache = 1;
    } else {
        _sha_ni_cache = 0;
    }
    _sha_ni_probe_lock = 0;   # release the one-shot latch (see note above)
    return _sha_ni_cache;
}

# _sha_ni_cpuid_probe — write CPUID leaf 7 sub-leaf 0 EBX to *out.
# Caller-supplied pointer keeps the CPUID-clobbered registers'
# lifetime confined to the asm block; reload via load64 after.
fn _sha_ni_cpuid_probe(out): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Param out -> rdi via the prologue-drift-proof param_load
        # pseudo (cyrius 6.0.67+): the slot offset is resolved at emit
        # time, so it cannot read garbage if the prologue layout drifts.
        param_load(rdi, 0);            # out
        0x53;                          # push rbx (callee-saved; CPUID clobbers it)
        0xB8; 0x07; 0x00; 0x00; 0x00;  # mov eax, 7   (leaf 7)
        0x31; 0xC9;                    # xor ecx, ecx (sub-leaf 0)
        0x0F; 0xA2;                    # cpuid
        0x48; 0x89; 0x1F;              # mov [rdi], rbx  ; *out = ebx
        0x5B;                          # pop rbx
    }
    #endif
    return 0;
}

# ================================================================
# Read-only shared globals (lazy init on first transform).
#
#   _sha_ni_K          — 256 bytes: 64 packed dwords of the K constants
#   _sha_ni_bswap_src  — 16 bytes:  PSHUFFLE_BYTE_FLIP_MASK template
#                                   (memcpy'd into per-call buf+64)
#
# 3.3: the pre-3.3 design used a single module-global 80-byte
# `_sha_ni_buf` that held the packed-state in/out + ABEF/CDGH
# saves + bswap mask. That made the SHA-NI compress non-
# reentrant — concurrent batch-verify workers (3.3 dropped the
# serialising mutex) stomped each other's state every block.
#
# Splitting the bswap mask (read-only) out of the working area
# lets the working area become a per-call stack buffer.
# `_sha_ni_compress_one` keeps its 3-parameter signature (the
# safe cc5/cc6 prologue-spill shape).
#
# alloc() is 8-byte aligned but PSHUFB / PADDD with an m128
# operand both require the memory address to be 16-aligned or
# they raise #GP. Each buffer is over-allocated by 16 bytes and
# aligned via `_sha_ni_align16`.
# ================================================================

var _sha_ni_K = 0;
var _sha_ni_bswap_src = 0;

# _sha_ni_pack_k_word — write K[i] as 4 little-endian bytes at dst+0..3.
fn _sha_ni_pack_k_word(dst, k): i64 {
    store8(dst + 0, k & 0xFF);
    store8(dst + 1, (k >> 8) & 0xFF);
    store8(dst + 2, (k >> 16) & 0xFF);
    store8(dst + 3, (k >> 24) & 0xFF);
    return 0;
}

# _sha_ni_align16 — round addr up to a 16-byte boundary. The bump
# allocator is 8-byte aligned, but PSHUFB / PADDD with an m128
# operand both require the memory address to be 16-aligned or
# they raise #GP. Caller over-allocates by 16 bytes and aligns
# the returned base.
fn _sha_ni_align16(addr): i64 {
    var off = addr & 15;
    if (off == 0) { return addr; }
    return addr + (16 - off);
}

fn _sha_ni_init(): i64 {
    if (_sha_ni_K != 0) { return 0; }

    _sha_ni_bswap_src = _sha_ni_align16(alloc(16 + 16));
    _sha_ni_K         = _sha_ni_align16(alloc(256 + 16));

    # PSHUFFLE_BYTE_FLIP_MASK — reverses bytes within each 32-bit
    # dword. Matches the kernel constant
    # 0x0c0d0e0f08090a0b0405060700010203. Read-only after init;
    # memcpy'd into per-call bufs at the top of each transform.
    store8(_sha_ni_bswap_src + 0,  0x03); store8(_sha_ni_bswap_src + 1,  0x02);
    store8(_sha_ni_bswap_src + 2,  0x01); store8(_sha_ni_bswap_src + 3,  0x00);
    store8(_sha_ni_bswap_src + 4,  0x07); store8(_sha_ni_bswap_src + 5,  0x06);
    store8(_sha_ni_bswap_src + 6,  0x05); store8(_sha_ni_bswap_src + 7,  0x04);
    store8(_sha_ni_bswap_src + 8,  0x0B); store8(_sha_ni_bswap_src + 9,  0x0A);
    store8(_sha_ni_bswap_src + 10, 0x09); store8(_sha_ni_bswap_src + 11, 0x08);
    store8(_sha_ni_bswap_src + 12, 0x0F); store8(_sha_ni_bswap_src + 13, 0x0E);
    store8(_sha_ni_bswap_src + 14, 0x0D); store8(_sha_ni_bswap_src + 15, 0x0C);

    # K constants from FIPS 180-4 §4.2.2 — packed 64×4-byte LE dwords.
    # Embedded directly rather than read from sha256.cyr's _sha256_K
    # so this module has no init-order dependency on sha256.cyr.
    _sha_ni_pack_k_word(_sha_ni_K + 0,   0x428a2f98);
    _sha_ni_pack_k_word(_sha_ni_K + 4,   0x71374491);
    _sha_ni_pack_k_word(_sha_ni_K + 8,   0xb5c0fbcf);
    _sha_ni_pack_k_word(_sha_ni_K + 12,  0xe9b5dba5);
    _sha_ni_pack_k_word(_sha_ni_K + 16,  0x3956c25b);
    _sha_ni_pack_k_word(_sha_ni_K + 20,  0x59f111f1);
    _sha_ni_pack_k_word(_sha_ni_K + 24,  0x923f82a4);
    _sha_ni_pack_k_word(_sha_ni_K + 28,  0xab1c5ed5);
    _sha_ni_pack_k_word(_sha_ni_K + 32,  0xd807aa98);
    _sha_ni_pack_k_word(_sha_ni_K + 36,  0x12835b01);
    _sha_ni_pack_k_word(_sha_ni_K + 40,  0x243185be);
    _sha_ni_pack_k_word(_sha_ni_K + 44,  0x550c7dc3);
    _sha_ni_pack_k_word(_sha_ni_K + 48,  0x72be5d74);
    _sha_ni_pack_k_word(_sha_ni_K + 52,  0x80deb1fe);
    _sha_ni_pack_k_word(_sha_ni_K + 56,  0x9bdc06a7);
    _sha_ni_pack_k_word(_sha_ni_K + 60,  0xc19bf174);
    _sha_ni_pack_k_word(_sha_ni_K + 64,  0xe49b69c1);
    _sha_ni_pack_k_word(_sha_ni_K + 68,  0xefbe4786);
    _sha_ni_pack_k_word(_sha_ni_K + 72,  0x0fc19dc6);
    _sha_ni_pack_k_word(_sha_ni_K + 76,  0x240ca1cc);
    _sha_ni_pack_k_word(_sha_ni_K + 80,  0x2de92c6f);
    _sha_ni_pack_k_word(_sha_ni_K + 84,  0x4a7484aa);
    _sha_ni_pack_k_word(_sha_ni_K + 88,  0x5cb0a9dc);
    _sha_ni_pack_k_word(_sha_ni_K + 92,  0x76f988da);
    _sha_ni_pack_k_word(_sha_ni_K + 96,  0x983e5152);
    _sha_ni_pack_k_word(_sha_ni_K + 100, 0xa831c66d);
    _sha_ni_pack_k_word(_sha_ni_K + 104, 0xb00327c8);
    _sha_ni_pack_k_word(_sha_ni_K + 108, 0xbf597fc7);
    _sha_ni_pack_k_word(_sha_ni_K + 112, 0xc6e00bf3);
    _sha_ni_pack_k_word(_sha_ni_K + 116, 0xd5a79147);
    _sha_ni_pack_k_word(_sha_ni_K + 120, 0x06ca6351);
    _sha_ni_pack_k_word(_sha_ni_K + 124, 0x14292967);
    _sha_ni_pack_k_word(_sha_ni_K + 128, 0x27b70a85);
    _sha_ni_pack_k_word(_sha_ni_K + 132, 0x2e1b2138);
    _sha_ni_pack_k_word(_sha_ni_K + 136, 0x4d2c6dfc);
    _sha_ni_pack_k_word(_sha_ni_K + 140, 0x53380d13);
    _sha_ni_pack_k_word(_sha_ni_K + 144, 0x650a7354);
    _sha_ni_pack_k_word(_sha_ni_K + 148, 0x766a0abb);
    _sha_ni_pack_k_word(_sha_ni_K + 152, 0x81c2c92e);
    _sha_ni_pack_k_word(_sha_ni_K + 156, 0x92722c85);
    _sha_ni_pack_k_word(_sha_ni_K + 160, 0xa2bfe8a1);
    _sha_ni_pack_k_word(_sha_ni_K + 164, 0xa81a664b);
    _sha_ni_pack_k_word(_sha_ni_K + 168, 0xc24b8b70);
    _sha_ni_pack_k_word(_sha_ni_K + 172, 0xc76c51a3);
    _sha_ni_pack_k_word(_sha_ni_K + 176, 0xd192e819);
    _sha_ni_pack_k_word(_sha_ni_K + 180, 0xd6990624);
    _sha_ni_pack_k_word(_sha_ni_K + 184, 0xf40e3585);
    _sha_ni_pack_k_word(_sha_ni_K + 188, 0x106aa070);
    _sha_ni_pack_k_word(_sha_ni_K + 192, 0x19a4c116);
    _sha_ni_pack_k_word(_sha_ni_K + 196, 0x1e376c08);
    _sha_ni_pack_k_word(_sha_ni_K + 200, 0x2748774c);
    _sha_ni_pack_k_word(_sha_ni_K + 204, 0x34b0bcb5);
    _sha_ni_pack_k_word(_sha_ni_K + 208, 0x391c0cb3);
    _sha_ni_pack_k_word(_sha_ni_K + 212, 0x4ed8aa4a);
    _sha_ni_pack_k_word(_sha_ni_K + 216, 0x5b9cca4f);
    _sha_ni_pack_k_word(_sha_ni_K + 220, 0x682e6ff3);
    _sha_ni_pack_k_word(_sha_ni_K + 224, 0x748f82ee);
    _sha_ni_pack_k_word(_sha_ni_K + 228, 0x78a5636f);
    _sha_ni_pack_k_word(_sha_ni_K + 232, 0x84c87814);
    _sha_ni_pack_k_word(_sha_ni_K + 236, 0x8cc70208);
    _sha_ni_pack_k_word(_sha_ni_K + 240, 0x90befffa);
    _sha_ni_pack_k_word(_sha_ni_K + 244, 0xa4506ceb);
    _sha_ni_pack_k_word(_sha_ni_K + 248, 0xbef9a3f7);
    _sha_ni_pack_k_word(_sha_ni_K + 252, 0xc67178f2);
    return 0;
}

# ================================================================
# _sha_ni_compress_one — single-block SHA-NI compress.
#
# Parameters (loaded via the prologue-drift-proof `param_load`
# pseudo, cyrius 6.0.67+ — slots resolved at emit time):
#   idx 0  ctx     — 144-byte SHA-256 context (h0..h7 at +0,
#                     block buffer at +64)            -> rdi
#   idx 1  buf     — 80-byte per-call working area. Layout:
#                        +0..31  packed state in/out
#                        +32..47 ABEF_save
#                        +48..63 CDGH_save
#                        +64..79 PSHUFFLE_BYTE_FLIP_MASK  -> rsi
#   idx 2  kbuf    — 256-byte packed K table            -> rcx
#
# Pre-3.7.8 these were hand-emitted `mov r__, [rbp-N]` byte
# literals, which coupled to the cyrius prologue layout and
# SIGILL-re-broke when 6.1.20 shifted the param spill slots (see
# docs/development/issues/2026-06-09-cyrius-6120-rebreaks-ni-paths-
# sigill.md). `param_load` resolves each slot at emit time, so the
# loads track the prologue automatically.
#
# Register usage inside the asm block:
#   rdi = ctx, rsi = buf, rcx = kbuf, rdx = scalar tmp
#   xmm0 = MSG, xmm1 = STATE0 (ABEF), xmm2 = STATE1 (CDGH),
#   xmm3 = MSGTMP0, xmm4 = MSGTMP1, xmm5 = MSGTMP2, xmm6 = MSGTMP3,
#   xmm7 = MSGTMP4 (palignr scratch)
#
# All XMM registers are caller-saved in System V x86-64 — clobber
# is safe because the asm block is straight-line with no calls
# and Cyrius does not expect XMM state across the block.
# ================================================================
fn _sha_ni_compress_one(ctx, buf, kbuf): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # -- Param loads (prologue-drift-proof param_load, cyrius 6.0.67+) --
        #    The pseudo resolves each param's spill slot at emit time,
        #    so a future cyrius prologue change cannot shift these reads
        #    onto the wrong slot (the SIGILL re-break class, see header).
        param_load(rdi, 0);        # ctx
        param_load(rsi, 1);        # buf
        param_load(rcx, 2);        # kbuf

        # ── Pack ctx h0..h7 (8 sparse 64-bit slots, low 32 bits each)
        #    into scratch[0..31] (8 packed little-endian dwords).
        #    Each pair is `mov edx, [rdi+8i]` + `mov [rsi+4i], edx`.
        0x8B; 0x57; 0x00; 0x89; 0x56; 0x00;
        0x8B; 0x57; 0x08; 0x89; 0x56; 0x04;
        0x8B; 0x57; 0x10; 0x89; 0x56; 0x08;
        0x8B; 0x57; 0x18; 0x89; 0x56; 0x0C;
        0x8B; 0x57; 0x20; 0x89; 0x56; 0x10;
        0x8B; 0x57; 0x28; 0x89; 0x56; 0x14;
        0x8B; 0x57; 0x30; 0x89; 0x56; 0x18;
        0x8B; 0x57; 0x38; 0x89; 0x56; 0x1C;

        # ── State setup: load packed ABCD/EFGH, permute to ABEF/CDGH ─
        0xF3; 0x0F; 0x6F; 0x4E; 0x00;          # movdqu xmm1, [rsi+0]   STATE0=ABCD
        0xF3; 0x0F; 0x6F; 0x56; 0x10;          # movdqu xmm2, [rsi+16]  STATE1=EFGH
        0x66; 0x0F; 0x70; 0xC9; 0xB1;          # pshufd xmm1, xmm1, 0xB1   →[b,a,d,c]
        0x66; 0x0F; 0x70; 0xD2; 0x1B;          # pshufd xmm2, xmm2, 0x1B   →[h,g,f,e]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1     save pre-palignr
        0x66; 0x0F; 0x3A; 0x0F; 0xCA; 0x08;    # palignr xmm1, xmm2, 8 STATE0=ABEF=[f,e,b,a]
        0x66; 0x0F; 0x3A; 0x0E; 0xD7; 0xF0;    # pblendw xmm2, xmm7,F0 STATE1=CDGH=[h,g,d,c]

        # ── Save ABEF/CDGH for the post-loop add ──────────────────
        0xF3; 0x0F; 0x7F; 0x4E; 0x20;          # movdqu [rsi+32], xmm1  (ABEF_save)
        0xF3; 0x0F; 0x7F; 0x56; 0x30;          # movdqu [rsi+48], xmm2  (CDGH_save)

        # ── Iter 0 — Rounds 0..3 — load MSGTMP0 = W[0..3] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x40;          # movdqu xmm0, [rdi+64]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xD8;                # movdqa xmm3, xmm0      MSGTMP0
        0x66; 0x0F; 0xFE; 0x41; 0x00;          # paddd  xmm0, [rcx+0]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2

        # ── Iter 1 — Rounds 4..7 — load MSGTMP1 = W[4..7] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x50;          # movdqu xmm0, [rdi+80]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE0;                # movdqa xmm4, xmm0      MSGTMP1
        0x66; 0x0F; 0xFE; 0x41; 0x10;          # paddd  xmm0, [rcx+16]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4   MSGTMP0+=σ0

        # ── Iter 2 — Rounds 8..11 — load MSGTMP2 = W[8..11] ───────
        0xF3; 0x0F; 0x6F; 0x47; 0x60;          # movdqu xmm0, [rdi+96]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE8;                # movdqa xmm5, xmm0      MSGTMP2
        0x66; 0x0F; 0xFE; 0x41; 0x20;          # paddd  xmm0, [rcx+32]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5   MSGTMP1+=σ0

        # ── Iter 3 — Rounds 12..15 — load MSGTMP3 = W[12..15];
        #    also compute MSGTMP0 = W[16..19] for iter 4. ──────────
        0xF3; 0x0F; 0x6F; 0x47; 0x70;          # movdqu xmm0, [rdi+112]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xF0;                # movdqa xmm6, xmm0      MSGTMP3
        0x66; 0x0F; 0xFE; 0x41; 0x30;          # paddd  xmm0, [rcx+48]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6      tmp ← MSGTMP3
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4  W[9..12]
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7      MSGTMP0 += W[9..12]
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6  MSGTMP0 = W[16..19]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6   MSGTMP2+=σ0

        # ── Iter 4 — Rounds 16..19 — MSGTMP0 already W[16..19];
        #    compute MSGTMP1 = W[20..23]
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x41; 0x40;          # paddd  xmm0, [rcx+64]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3   MSGTMP1=W[20..23]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # ── Iter 5 — Rounds 20..23 — compute MSGTMP2 = W[24..27] ──
        0x66; 0x0F; 0x6F; 0xC4;                # movdqa xmm0, xmm4
        0x66; 0x0F; 0xFE; 0x41; 0x50;          # paddd  xmm0, [rcx+80]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;                # movdqa xmm7, xmm4
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;    # palignr xmm7, xmm3, 4
        0x66; 0x0F; 0xFE; 0xEF;                # paddd  xmm5, xmm7
        0x0F; 0x38; 0xCD; 0xEC;                # sha256msg2 xmm5, xmm4
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4

        # ── Iter 6 — Rounds 24..27 — compute MSGTMP3 = W[28..31] ──
        0x66; 0x0F; 0x6F; 0xC5;                # movdqa xmm0, xmm5
        0x66; 0x0F; 0xFE; 0x41; 0x60;          # paddd  xmm0, [rcx+96]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;                # movdqa xmm7, xmm5
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;    # palignr xmm7, xmm4, 4
        0x66; 0x0F; 0xFE; 0xF7;                # paddd  xmm6, xmm7
        0x0F; 0x38; 0xCD; 0xF5;                # sha256msg2 xmm6, xmm5
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5

        # ── Iter 7 — Rounds 28..31 — compute MSGTMP0 = W[32..35] ──
        0x66; 0x0F; 0x6F; 0xC6;                # movdqa xmm0, xmm6
        0x66; 0x0F; 0xFE; 0x41; 0x70;          # paddd  xmm0, [rcx+112]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6

        # ── Iter 8 — Rounds 32..35 — disp32 K offset 128 onward ──
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x81; 0x80; 0x00; 0x00; 0x00;  # paddd xmm0, [rcx+128]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # -- Iter 9 -- Rounds 36..39 --
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0x90; 0x00; 0x00; 0x00;  # [rcx+144]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;

        # -- Iter 10 -- Rounds 40..43 --
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xA0; 0x00; 0x00; 0x00;  # [rcx+160]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;

        # -- Iter 11 -- Rounds 44..47 --
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xB0; 0x00; 0x00; 0x00;  # [rcx+176]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;
        0x66; 0x0F; 0xFE; 0xDF;
        0x0F; 0x38; 0xCD; 0xDE;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;

        # -- Iter 12 -- Rounds 48..51 --
        0x66; 0x0F; 0x6F; 0xC3;
        0x66; 0x0F; 0xFE; 0x81; 0xC0; 0x00; 0x00; 0x00;  # [rcx+192]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;
        0x66; 0x0F; 0xFE; 0xE7;
        0x0F; 0x38; 0xCD; 0xE3;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;

        # ── Iter 13 — Rounds 52..55 — drop sha256msg1 (no longer
        #    needed: msg1 precomputes for iter+3 = 16, out of range) ─
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0xD0; 0x00; 0x00; 0x00;  # [rcx+208]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # -- Iter 14 -- Rounds 56..59 --
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xE0; 0x00; 0x00; 0x00;  # [rcx+224]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Iter 15 — Rounds 60..63 — drop ALL schedule work ───
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xF0; 0x00; 0x00; 0x00;  # [rcx+240]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Final add: STATE0 += ABEF_save; STATE1 += CDGH_save ──
        0x66; 0x0F; 0xFE; 0x4E; 0x20;          # paddd xmm1, [rsi+32]
        0x66; 0x0F; 0xFE; 0x56; 0x30;          # paddd xmm2, [rsi+48]

        # ── Reverse state setup: ABEF/CDGH → ABCD/EFGH packed ───
        0x66; 0x0F; 0x70; 0xC9; 0x1B;          # pshufd xmm1, xmm1, 0x1B → [A,B,E,F]
        0x66; 0x0F; 0x70; 0xD2; 0xB1;          # pshufd xmm2, xmm2, 0xB1 → [G,H,C,D]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1
        0x66; 0x0F; 0x3A; 0x0E; 0xCA; 0xF0;    # pblendw xmm1, xmm2, 0xF0 → [A,B,C,D]
        0x66; 0x0F; 0x3A; 0x0F; 0xD7; 0x08;    # palignr xmm2, xmm7, 8   → [E,F,G,H]
        0xF3; 0x0F; 0x7F; 0x4E; 0x00;          # movdqu [rsi+0],  xmm1
        0xF3; 0x0F; 0x7F; 0x56; 0x10;          # movdqu [rsi+16], xmm2

        # ── Unpack scratch packed dwords back to ctx h0..h7 with
        #    zero-extending 64-bit stores so the high 32 bits of
        #    each ctx slot stay zero (sha256.cyr's invariant). ────
        0x8B; 0x56; 0x00; 0x48; 0x89; 0x57; 0x00;
        0x8B; 0x56; 0x04; 0x48; 0x89; 0x57; 0x08;
        0x8B; 0x56; 0x08; 0x48; 0x89; 0x57; 0x10;
        0x8B; 0x56; 0x0C; 0x48; 0x89; 0x57; 0x18;
        0x8B; 0x56; 0x10; 0x48; 0x89; 0x57; 0x20;
        0x8B; 0x56; 0x14; 0x48; 0x89; 0x57; 0x28;
        0x8B; 0x56; 0x18; 0x48; 0x89; 0x57; 0x30;
        0x8B; 0x56; 0x1C; 0x48; 0x89; 0x57; 0x38;
    }
    #endif
    return 0;
}

# sha256_transform_ni — SHA-NI single-block compression (live in 2.9.3).
#
# Caller contract:
#   - ctx points to a 144-byte SHA-256 context (h0..h7 at +0,
#     buf at +64)
#   - returns 0 on success (compressed in hardware)
#
# `sha256_transform`'s dispatcher in src/sha256.cyr falls through
# to the FIPS 180-4 software path on hosts where the CPUID probe
# returns 0; this entry point is only invoked when SHA-NI is live.
fn sha256_transform_ni(ctx): i64 {
    if (_sha_ni_K == 0) { _sha_ni_init(); }
    # Per-call working area. 80 bytes needed; over-allocate by 16
    # so we can align the base to a 16-byte boundary (PSHUFB / PADDD
    # m128 reads of buf+0/+16/+64 require alignment). Banked per
    # thread (3.6): each batch worker writes its own 96-byte lane so
    # concurrent compresses never stomp this shared static scratch
    # (CLAUDE.md quirk #1). 96 is a multiple of 16, so each lane stays
    # 16-aligned and `_sha_ni_align16` is a no-op within it.
    var raw[6144];   # 96 * SIGIL_CRYPTO_BANKS
    var buf = _sha_ni_align16(&raw + cbank() * 96);
    memcpy(buf + 64, _sha_ni_bswap_src, 16);
    _sha_ni_compress_one(ctx, buf, _sha_ni_K);
    return 0;
}

# _sha_ni_self_test — run SHA-NI against the FIPS 180-4 §B.1 single-
# block "abc" example and compare the resulting state to the spec's
# published digest. Returns 0 on match (NI safe to enable), non-zero
# on mismatch (downgrade to software). Constant-time compare (OR-
# accumulating, no early exit).
#
# Calls `_sha_ni_compress_one` directly rather than going through
# `sha256_transform`'s dispatcher (which would call back into
# `sha_ni_available` → infinite recursion through this very fn).
# `_sha_ni_init` is idempotent so the K-table + bswap-mask setup
# costs nothing on the second-and-later probe.
#
# FIPS 180-4 §B.1 SHA-256 example:
#   Msg:     "abc"                        (3 bytes, single block)
#   Digest:  BA7816BF 8F01CFEA 414140DE 5DAE2223
#            B00361A3 96177A9C B410FF61 F20015AD
#
# Ctx layout (per src/sha256.cyr): h0..h7 at +0..+63 (8 slots × 8B,
# low 32 bits hold the dword), block buf at +64..+127, buf_len at
# +128, total_len at +136.
fn _sha_ni_self_test(): i64 {
    if (_sha_ni_K == 0) { _sha_ni_init(); }

    # Zero ctx slots.
    var i = 0;
    while (i < 144) { store8(&_sha_ni_st_ctx + i, 0); i = i + 1; }

    # FIPS 180-4 §5.3.3 initial hash values for SHA-256.
    store64(&_sha_ni_st_ctx +  0, 0x6a09e667);
    store64(&_sha_ni_st_ctx +  8, 0xbb67ae85);
    store64(&_sha_ni_st_ctx + 16, 0x3c6ef372);
    store64(&_sha_ni_st_ctx + 24, 0xa54ff53a);
    store64(&_sha_ni_st_ctx + 32, 0x510e527f);
    store64(&_sha_ni_st_ctx + 40, 0x9b05688c);
    store64(&_sha_ni_st_ctx + 48, 0x1f83d9ab);
    store64(&_sha_ni_st_ctx + 56, 0x5be0cd19);

    # Padded "abc" block at +64..+127:
    #   bytes 0..2 = 'a','b','c'
    #   byte 3     = 0x80 (padding terminator per FIPS 180-4 §5.1.1)
    #   bytes 4..62 = zeros
    #   bytes 56..63 = length-in-bits big-endian (3 * 8 = 24 = 0x18)
    store8(&_sha_ni_st_ctx + 64, 0x61);
    store8(&_sha_ni_st_ctx + 65, 0x62);
    store8(&_sha_ni_st_ctx + 66, 0x63);
    store8(&_sha_ni_st_ctx + 67, 0x80);
    store8(&_sha_ni_st_ctx + 127, 0x18);

    var raw[96];
    var buf = _sha_ni_align16(&raw);
    memcpy(buf + 64, _sha_ni_bswap_src, 16);
    _sha_ni_compress_one(&_sha_ni_st_ctx, buf, _sha_ni_K);

    # Compare h0..h7 to FIPS 180-4 §B.1 expected digest. The high 32
    # bits of each 64-bit slot are guaranteed zero by the asm's
    # zero-extending 64-bit stores at unpack time (see line 472 of
    # this file), so a `& 0xFFFFFFFF` mask is sufficient for the
    # XOR-accumulate compare.
    var diff = 0;
    diff = diff | ((load64(&_sha_ni_st_ctx +  0) ^ 0xba7816bf) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx +  8) ^ 0x8f01cfea) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 16) ^ 0x414140de) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 24) ^ 0x5dae2223) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 32) ^ 0xb00361a3) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 40) ^ 0x96177a9c) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 48) ^ 0xb410ff61) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 56) ^ 0xf20015ad) & 0xFFFFFFFF);
    return diff;
}

# --- aes_ni.cyr ---

# aes_ni.cyr — AES-NI hardware-acceleration dispatch (live since 2.9.1).
#
# Include-guard marker (see sha_ni.cyr for the full rationale): the dist bundle
# inlines this module, so the redundant `include "src/aes_ni.cyr"` in
# aes_gcm.cyr / lib.cyr is #ifndef-guarded against this marker and self-skips
# once present (cyrius hard-errors on the now-absent file since v6.1.35).
#define _SIGIL_AES_NI_INCLUDED
#
# Cyrius 5.5.21's array-global 16-byte alignment fix closed out the
# SSE m128-operand fault that had kept this path dormant through
# 2.9.0 and part of 2.9.x development. With `var rk[240]` reliably
# landing on a 16-aligned VA, PXOR / AESENC / AESENCLAST memory
# operands on the round-key table no longer trip #GP, and the
# inline-asm stores through caller-supplied output pointers reach
# memory cleanly. Verified against FIPS 197 §C.3 in
# tests/tcyr/aes_ni.tcyr.
#
# The module exposes three entry points:
#   - aes_ni_available()        — runtime CPUID probe, cached
#   - aes256_encrypt_block_ni(round_keys, in, out)
#                               — 14-round AES-256 block encrypt
#   - aes128_encrypt_block_ni(round_keys, in, out)
#                               — 10-round AES-128 block encrypt
# aes_gcm.cyr's aes256_encrypt_block / aes128_encrypt_block dispatch
# here when the probe returns 1, falling back to the FIPS 197 §5.1
# software path when the host lacks AES-NI. Downstream callers should
# call the dispatchers (aes256_encrypt_block / aes128_encrypt_block),
# not the _ni variants directly, unless they're writing their own
# fast path. The boot self-test validates BOTH the AES-256 (FIPS 197
# §C.3) and AES-128 (§C.1) NI paths before going live; either vector
# diverging pins the cache to 0 and routes both key sizes to software.
#
# AES-NI opcode reference (Intel SDM Vol 2A §3.2, §5):
#   AESENC xmm0, [rdi+disp]       66 0F 38 DC 47/87 <disp>
#   AESENCLAST xmm0, [rdi+disp]   66 0F 38 DD 47/87 <disp>
#   CPUID                          0F A2     (eax=1 → ECX bit 25 = AES-NI)
#   PXOR xmm0, [rdi]               66 0F EF 07
#   MOVDQU xmm0, [rsi]             F3 0F 6F 06
#   MOVDQU [rdx], xmm0             F3 0F 7F 02

# _aes_ni_cache: 2 = uncached, 0 = unavailable (software path), 1 = available.
# First call to aes_ni_available() runs the CPUID probe AND the
# FIPS 197 §C.3 self-test; on either gate failure the cache pins to
# 0 and sigil silently falls through to the software path. The probe
# is a serializing instruction so we want to pay it exactly once.
var _aes_ni_cache = 2;
var _aes_ni_probe_out = 0;      # 8-byte scratch for the probe's *out param
var _aes_ni_probe_lock = 0;     # CAS guard: serializes the one-time self-test (3.9.6)

# Self-test scratch — module-level so `var rk[240]` lands on a
# 16-byte boundary (CLAUDE.md quirk #6). Required because the
# `pxor xmm0, [rdi]` / `aesenc xmm0, [rdi+disp]` opcodes in
# aes256_encrypt_block_ni take m128 operands and #GP on unaligned
# addresses. Local-stack `var rk[240]` carries no alignment guarantee.
var _aes_ni_st_key[32];
var _aes_ni_st_rk[240];
var _aes_ni_st_pt[16];
var _aes_ni_st_ct[16];

fn aes_ni_available(): i64 {
    if (_aes_ni_cache != 2) { return _aes_ni_cache; }
    # First-probe serialization (3.9.6 — concurrent-TLS-handshake fix):
    # the self-test below drives the module-global `_aes_ni_st_*`
    # scratch, so two threads probing concurrently (the first AES on
    # each of two TLS workers, if the main thread never pre-warmed)
    # would race it and could spuriously downgrade NI to software. CAS
    # so exactly one thread runs the probe; the rest spin until it
    # publishes the cached result. x86-only path (CPUID/AES-NI), so the
    # plain cache read/write is visibility-safe under x86-TSO.
    if (atomic_cas(&_aes_ni_probe_lock, 0, 1) == 0) {
        while (_aes_ni_cache == 2) { }
        return _aes_ni_cache;
    }
    if (_aes_ni_probe_out == 0) { _aes_ni_probe_out = alloc(8); }
    store64(_aes_ni_probe_out, 0);
    _aes_ni_cpuid_probe(_aes_ni_probe_out);
    var ecx = load64(_aes_ni_probe_out);
    # ECX bit 25 = AES-NI (Intel SDM Vol 2A §3.2 CPUID leaf 1).
    if ((ecx & (1 << 25)) == 0) {
        _aes_ni_cache = 0;
        # Release the one-shot latch AFTER publishing the cache, so a
        # later re-probe (cache reset to the `2` sentinel) re-acquires
        # instead of dead-spinning on a permanently-held lock. Mirrors
        # the sha_ni_available() fix; production never resets the cache,
        # so the self-test still runs exactly once and the concurrency
        # guarantee is unchanged.
        _aes_ni_probe_lock = 0;
        return 0;
    }
    # Defense-in-depth: confirm the NI asm path produces FIPS 197 §C.3
    # output before going live. The hardcoded `[rbp-N]` parameter loads
    # that originally coupled to the cyrius prologue layout — and
    # SIGILL-re-broke under 6.1.20 when the param spill slots shifted —
    # are now replaced by the prologue-drift-proof `param_load` pseudo
    # (3.7.8; docs/development/issues/2026-06-09-cyrius-6120-rebreaks-ni-
    # paths-sigill.md). This self-test stays as belt-and-suspenders:
    # it catches any *wrong-output* asm regression a future compiler
    # change could still introduce (asm executes but produces nonsense)
    # and downgrades to software. It does NOT catch SIGILL — but
    # param_load removes the param-slot drift that caused it.
    # Validate both the AES-256 (§C.3) and AES-128 (§C.1) NI paths.
    # They share the CPUID feature bit and the asm-prologue parameter
    # shape, so a single mismatch in either downgrades both key sizes
    # to software — conservative and correct.
    if (_aes_ni_self_test() == 0) {
        if (_aes128_ni_self_test() == 0) {
            _aes_ni_cache = 1;
        } else {
            _aes_ni_cache = 0;
        }
    } else {
        _aes_ni_cache = 0;
    }
    _aes_ni_probe_lock = 0;   # release the one-shot latch (see note above)
    return _aes_ni_cache;
}

# _aes_ni_cpuid_probe — write CPUID leaf 1 ECX to *out.
# Takes a caller-supplied pointer to keep the CPUID-clobbered
# registers' lifetime confined to the inline-asm block; the caller
# reloads via load64 after the call returns.
fn _aes_ni_cpuid_probe(out): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Param out -> rdi via the prologue-drift-proof param_load
        # pseudo (cyrius 6.0.67+): the slot offset is resolved at emit
        # time, so it cannot read garbage if the prologue layout drifts.
        param_load(rdi, 0);            # out
        0x53;                          # push rbx (callee-saved; CPUID clobbers it)
        0xB8; 0x01; 0x00; 0x00; 0x00;  # mov eax, 1
        0x31; 0xC9;                    # xor ecx, ecx (subleaf 0)
        0x0F; 0xA2;                    # cpuid
        0x48; 0x89; 0x0F;              # mov [rdi], rcx  ; *out = ecx
        0x5B;                          # pop rbx
    }
    #endif
    return 0;
}

# aes256_encrypt_block_ni — hardware AES-256 single-block encrypt.
#
# Byte-accurate AESENC + AESENCLAST sequence over round_keys
# (240-byte expanded schedule, same layout as the software
# encryptor). Consumes:
#   round_keys — rdi — 15 round keys of 16 bytes each
#   in_block   — rsi — 16-byte plaintext
#   out_block  — rdx — 16-byte ciphertext (caller-allocated)
#
# Status: reaches the CPU's AESENC machinery correctly when called
# directly inside a single-compilation-unit build. Not wired into
# aes_gcm_encrypt in 2.9.0 (see module header).
fn aes256_encrypt_block_ni(round_keys, in_block, out_block): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Params -> regs via the prologue-drift-proof param_load pseudo
        # (cyrius 6.0.67+): slot offsets resolved at emit time, immune to
        # prologue-layout drift (the SIGILL re-break class; see header).
        param_load(rdi, 0);            # round_keys
        param_load(rsi, 1);            # in_block
        param_load(rdx, 2);            # out_block

        # movdqu xmm0, [rsi]           ; state = in_block
        0xF3; 0x0F; 0x6F; 0x06;
        # pxor xmm0, [rdi]             ; state ^= round_key[0]
        0x66; 0x0F; 0xEF; 0x07;

        # Rounds 1..7: AESENC xmm0, [rdi + N*16]  (disp8 form)
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x10;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x20;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x30;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x40;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x50;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x60;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x70;
        # Rounds 8..13: AESENC xmm0, [rdi + N*16]  (disp32 form; 128..208 beyond disp8 range)
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x80; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x90; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xA0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xB0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xC0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xD0; 0x00; 0x00; 0x00;
        # Round 14 (final): AESENCLAST xmm0, [rdi+224]
        0x66; 0x0F; 0x38; 0xDD; 0x87; 0xE0; 0x00; 0x00; 0x00;

        # movdqu [rdx], xmm0           ; out_block = state
        0xF3; 0x0F; 0x7F; 0x02;
    }
    #endif
    return 0;
}

# aes128_encrypt_block_ni — hardware AES-128 single-block encrypt.
#
# Identical AESENC pipeline to the AES-256 variant but only 10 rounds
# (9 AESENC + 1 AESENCLAST) over an 11-key / 176-byte expanded
# schedule. Round keys 0..10 sit at offsets 0x00..0xA0; offsets
# 0x10..0x70 use the disp8 AESENC form, 0x80/0x90/0xA0 the disp32
# form. Same prologue/parameter shape and alignment requirement as
# aes256_encrypt_block_ni. Consumes:
#   round_keys — rdi — 11 round keys of 16 bytes each (176 bytes)
#   in_block   — rsi — 16-byte plaintext
#   out_block  — rdx — 16-byte ciphertext (caller-allocated)
fn aes128_encrypt_block_ni(round_keys, in_block, out_block): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Params -> regs via the prologue-drift-proof param_load pseudo
        # (cyrius 6.0.67+): slot offsets resolved at emit time, immune to
        # prologue-layout drift (the SIGILL re-break class; see header).
        param_load(rdi, 0);            # round_keys
        param_load(rsi, 1);            # in_block
        param_load(rdx, 2);            # out_block

        # movdqu xmm0, [rsi]           ; state = in_block
        0xF3; 0x0F; 0x6F; 0x06;
        # pxor xmm0, [rdi]             ; state ^= round_key[0]
        0x66; 0x0F; 0xEF; 0x07;

        # Rounds 1..7: AESENC xmm0, [rdi + N*16]  (disp8 form)
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x10;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x20;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x30;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x40;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x50;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x60;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x70;
        # Rounds 8..9: AESENC xmm0, [rdi + N*16]  (disp32 form; 128/144 beyond disp8 range)
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x80; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x90; 0x00; 0x00; 0x00;
        # Round 10 (final): AESENCLAST xmm0, [rdi+160]
        0x66; 0x0F; 0x38; 0xDD; 0x87; 0xA0; 0x00; 0x00; 0x00;

        # movdqu [rdx], xmm0           ; out_block = state
        0xF3; 0x0F; 0x7F; 0x02;
    }
    #endif
    return 0;
}

# _aes_ni_self_test — run AES-NI against FIPS 197 §C.3 and compare
# the resulting ciphertext to the spec's published expected output.
# Returns 0 if the NI path produced the right ciphertext (NI is
# safe to enable), non-zero if the bytes diverged (downgrade to
# software). Constant-time compare (OR-accumulating, no early exit).
#
# Forward references `aes256_key_expand` from `src/aes_gcm.cyr`,
# which is included after this module in `src/lib.cyr`. Cyrius's
# symbol resolution is per-translation-unit, so by the time this
# fn executes at runtime, `aes256_key_expand` is fully registered.
#
# FIPS 197 §C.3 AES-256 vector:
#   Key:       000102…1F                              (32 bytes)
#   Plaintext: 00112233445566778899AABBCCDDEEFF       (16 bytes)
#   Expected:  8EA2B7CA516745BFEAFC49904B496089       (16 bytes)
fn _aes_ni_self_test(): i64 {
    var i = 0;
    while (i < 32) { store8(&_aes_ni_st_key + i, i); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_pt + i, (i * 17) & 0xFF); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_ct + i, 0xA5); i = i + 1; }   # sentinel
    i = 0;
    while (i < 240) { store8(&_aes_ni_st_rk + i, 0); i = i + 1; }

    aes256_key_expand(&_aes_ni_st_key, &_aes_ni_st_rk);
    aes256_encrypt_block_ni(&_aes_ni_st_rk, &_aes_ni_st_pt, &_aes_ni_st_ct);

    var diff = 0;
    diff = diff | ((load8(&_aes_ni_st_ct +  0) ^ 0x8E) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  1) ^ 0xA2) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  2) ^ 0xB7) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  3) ^ 0xCA) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  4) ^ 0x51) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  5) ^ 0x67) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  6) ^ 0x45) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  7) ^ 0xBF) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  8) ^ 0xEA) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  9) ^ 0xFC) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 10) ^ 0x49) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 11) ^ 0x90) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 12) ^ 0x4B) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 13) ^ 0x49) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 14) ^ 0x60) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 15) ^ 0x89) & 0xFF);
    return diff;
}

# _aes128_ni_self_test — run the AES-128 NI path against FIPS 197 §C.1
# and compare to the spec's published ciphertext. Reuses the §C.3
# self-test scratch globals (the §C.3 test runs first and completes
# before this one starts — sequential reuse, fully written before
# read; CLAUDE.md quirk #1). Returns 0 on a byte-for-byte match,
# non-zero on divergence. Constant-time OR-accumulating compare.
#
# Forward-references aes_128_key_expand from src/aes_gcm.cyr (included
# after this module) — resolved per-TU at runtime, same as the §C.3
# test's reference to aes256_key_expand.
#
# FIPS 197 §C.1 AES-128 vector:
#   Key:       000102030405060708090A0B0C0D0E0F       (16 bytes)
#   Plaintext: 00112233445566778899AABBCCDDEEFF       (16 bytes)
#   Expected:  69C4E0D86A7B0430D8CDB78070B4C55A       (16 bytes)
fn _aes128_ni_self_test(): i64 {
    var i = 0;
    while (i < 16) { store8(&_aes_ni_st_key + i, i); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_pt + i, (i * 17) & 0xFF); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_ct + i, 0xA5); i = i + 1; }   # sentinel
    i = 0;
    while (i < 176) { store8(&_aes_ni_st_rk + i, 0); i = i + 1; }

    aes_128_key_expand(&_aes_ni_st_key, &_aes_ni_st_rk);
    aes128_encrypt_block_ni(&_aes_ni_st_rk, &_aes_ni_st_pt, &_aes_ni_st_ct);

    var diff = 0;
    diff = diff | ((load8(&_aes_ni_st_ct +  0) ^ 0x69) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  1) ^ 0xC4) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  2) ^ 0xE0) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  3) ^ 0xD8) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  4) ^ 0x6A) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  5) ^ 0x7B) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  6) ^ 0x04) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  7) ^ 0x30) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  8) ^ 0xD8) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  9) ^ 0xCD) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 10) ^ 0xB7) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 11) ^ 0x80) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 12) ^ 0x70) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 13) ^ 0xB4) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 14) ^ 0xC5) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 15) ^ 0x5A) & 0xFF);
    return diff;
}

# --- aes_gcm.cyr ---

# aes_gcm.cyr — AES-256-GCM + AES-128-GCM (AEAD) implementation
# FIPS 197 (AES block cipher: 14 rounds for AES-256, 10 for AES-128)
# + NIST SP 800-38D (Galois/Counter Mode) — the AEAD primitive for
# the AGNOS ecosystem.
#
# Scope:
#   - AES-256 + AES-128 block cipher, forward direction only (GCM
#     never invokes the inverse cipher). Rijndael over 32-byte
#     (14-round) and 16-byte (10-round) keys, 16-byte blocks. The
#     two variants differ ONLY in the key schedule (240-byte / 15-key
#     vs 176-byte / 11-key table) and the round count; the block
#     transform, GHASH, CTR mode, and GCM framing are shared and
#     parametrized on the round count.
#   - GHASH under GF(2^128) with reduction polynomial
#     x^128 + x^7 + x^2 + x + 1, bit-by-bit multiply (constant-time).
#   - GCM encrypt / decrypt over 12-byte (96-bit) IVs (the RFC fast
#     path: J0 = IV || 0^31 || 1) AND arbitrary-length IVs (3.7.2, via
#     the GHASH-based J0 of SP 800-38D §7.1) — the `*_iv` entry points.
#   - Tag: 128-bit, constant-time compared via cyrius stdlib's
#     `ct_eq_bytes_lens` (was sigil's hand-rolled `ct_eq` pre-3.0.2).
#
# Security floor (matches CLAUDE.md § Security Hardening):
#   - AES block encrypt dispatches to AES-NI when available
#     (runtime CPUID probe in src/aes_ni.cyr), otherwise runs the
#     constant-time software path in this file. Both paths produce
#     byte-identical output against FIPS 197 §C.3.
#   - Constant-time tag compare; no early exit on secret data.
#   - No branches on key bytes or plaintext.
#   - Round-key buffers and the GHASH subkey H are zeroized
#     before free after every encrypt / decrypt call.
#   - Input lengths validated at the GCM boundary.
#
# Working state: per-call function locals. The pre-3.3 module-
# global pattern was a cycc 3 local-clobbering workaround that
# cycc 6.0.1 no longer needs (CLAUDE.md quirk #1, verified by
# tests/tcyr/sha256_locals_probe.tcyr). Read-only init tables
# (`_aes_sbox`, `_aes_rcon`) remain shared and safe under
# concurrent read.

# aes_ni.cyr supplies aes_ni_available() and aes256_encrypt_block_ni
# for the dispatcher in aes256_encrypt_block below. Including it
# here means any consumer of aes_gcm automatically pulls the
# hardware path in without having to list it separately.
#ifndef _SIGIL_AES_NI_INCLUDED
#endif

# ================================================================
# AES S-box (forward direction, FIPS 197 Fig. 7)
# ================================================================
# 256 bytes. Allocated once at init and never mutated. Read-only
# in the cipher body.

var _aes_sbox = 0;
var _aes_rcon = 0;
var _aes_inited = 0;

# S-box as a hex string (512 chars → 256 bytes). Single literal
# keeps the fixup count tiny — we decode it in a small loop at
# init time rather than emitting 256 store8 calls.
# Canonical Rijndael S-box, FIPS 197 Figure 7, rows 0..F:
#   row 0: 63 7c 77 7b f2 6b 6f c5 30 01 67 2b fe d7 ab 76
#   row 1: ca 82 c9 7d fa 59 47 f0 ad d4 a2 af 9c a4 72 c0
#   row 2: b7 fd 93 26 36 3f f7 cc 34 a5 e5 f1 71 d8 31 15
#   row 3: 04 c7 23 c3 18 96 05 9a 07 12 80 e2 eb 27 b2 75
#   row 4: 09 83 2c 1a 1b 6e 5a a0 52 3b d6 b3 29 e3 2f 84
#   row 5: 53 d1 00 ed 20 fc b1 5b 6a cb be 39 4a 4c 58 cf
#   row 6: d0 ef aa fb 43 4d 33 85 45 f9 02 7f 50 3c 9f a8
#   row 7: 51 a3 40 8f 92 9d 38 f5 bc b6 da 21 10 ff f3 d2
#   row 8: cd 0c 13 ec 5f 97 44 17 c4 a7 7e 3d 64 5d 19 73
#   row 9: 60 81 4f dc 22 2a 90 88 46 ee b8 14 de 5e 0b db
#   row a: e0 32 3a 0a 49 06 24 5c c2 d3 ac 62 91 95 e4 79
#   row b: e7 c8 37 6d 8d d5 4e a9 6c 56 f4 ea 65 7a ae 08
#   row c: ba 78 25 2e 1c a6 b4 c6 e8 dd 74 1f 4b bd 8b 8a
#   row d: 70 3e b5 66 48 03 f6 0e 61 35 57 b9 86 c1 1d 9e
#   row e: e1 f8 98 11 69 d9 8e 94 9b 1e 87 e9 ce 55 28 df
#   row f: 8c a1 89 0d bf e6 42 68 41 99 2d 0f b0 54 bb 16
fn _aes_sbox_hex(): i64 {
    return "";  #skip-lint: AES S-box hex constant (quirk #5 fixup-table workaround), cannot wrap
}

# rcon[0..10] as hex: rcon[0] is padding (8d), never used.
fn _aes_rcon_hex(): i64 {
    return "8d01020408102040801b36";
}

fn _aes_decode_nibble(c): i64 {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    return 0;
}

fn _aes_decode_hex(buf, hex_str, byte_len): i64 {
    var i = 0;
    while (i < byte_len) {
        var hi = _aes_decode_nibble(load8(hex_str + i * 2) & 0xFF);
        var lo = _aes_decode_nibble(load8(hex_str + i * 2 + 1) & 0xFF);
        store8(buf + i, ((hi << 4) | lo) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn aes_gcm_global_init(): i64 {
    if (_aes_inited == 1) { return 0; }
    _aes_sbox = alloc(256);
    _aes_rcon = alloc(16);
    _aes_decode_hex(_aes_sbox, _aes_sbox_hex(), 256);
    _aes_decode_hex(_aes_rcon, _aes_rcon_hex(), 11);
    _aes_inited = 1;
    return 0;
}

fn _aes_sub(b): i64 {
    return load8(_aes_sbox + (b & 0xFF)) & 0xFF;
}

# ================================================================
# xtime — multiply a byte by x in GF(2^8) with the AES polynomial
# (x^8 + x^4 + x^3 + x + 1). FIPS 197 § 4.2.1.
# ================================================================

fn _aes_xtime(b): i64 {
    var shifted = (b << 1) & 0xFF;
    if ((b & 0x80) != 0) {
        return (shifted ^ 0x1b) & 0xFF;
    }
    return shifted & 0xFF;
}

# ================================================================
# Key expansion — AES-256: 32-byte key → 240 bytes (15 round keys).
# FIPS 197 § 5.2 algorithm. Nk=8, Nr=14, total expanded size = 4*4*(Nr+1)=240.
# ================================================================

fn aes256_key_expand(key, round_keys): i64 {
    aes_gcm_global_init();
    # First 32 bytes of the expanded key = raw key material.
    memcpy(round_keys, key, 32);

    var i = 8;   # word index into the expanded key
    while (i < 60) {
        # temp = previous word (4 bytes)
        var base = (i - 1) * 4;
        var t0 = load8(round_keys + base + 0) & 0xFF;
        var t1 = load8(round_keys + base + 1) & 0xFF;
        var t2 = load8(round_keys + base + 2) & 0xFF;
        var t3 = load8(round_keys + base + 3) & 0xFF;

        if ((i & 7) == 0) {
            # RotWord
            var rot0 = t1;
            var rot1 = t2;
            var rot2 = t3;
            var rot3 = t0;
            # SubWord
            t0 = _aes_sub(rot0);
            t1 = _aes_sub(rot1);
            t2 = _aes_sub(rot2);
            t3 = _aes_sub(rot3);
            # XOR Rcon[i/8] into t0
            t0 = t0 ^ (load8(_aes_rcon + (i / 8)) & 0xFF);
        } else {
            if ((i & 3) == 0) {
                # Nk=8 path: SubWord only
                t0 = _aes_sub(t0);
                t1 = _aes_sub(t1);
                t2 = _aes_sub(t2);
                t3 = _aes_sub(t3);
            }
        }

        # W[i] = W[i-Nk] XOR temp
        var prev_base = (i - 8) * 4;
        var dst_base = i * 4;
        store8(round_keys + dst_base + 0, (load8(round_keys + prev_base + 0) ^ t0) & 0xFF);
        store8(round_keys + dst_base + 1, (load8(round_keys + prev_base + 1) ^ t1) & 0xFF);
        store8(round_keys + dst_base + 2, (load8(round_keys + prev_base + 2) ^ t2) & 0xFF);
        store8(round_keys + dst_base + 3, (load8(round_keys + prev_base + 3) ^ t3) & 0xFF);

        i = i + 1;
    }
    return 0;
}

# ================================================================
# Key expansion — AES-128: 16-byte key → 176 bytes (11 round keys).
# FIPS 197 § 5.2 algorithm. Nk=4, Nr=10, total expanded size = 4*4*(Nr+1)=176.
# ================================================================
# Differs from AES-256 only in Nk (4 vs 8) and the per-word
# transform schedule: every Nk=4th word gets RotWord+SubWord+Rcon;
# there is no separate "i%4==0 SubWord-only" branch (that branch in
# the AES-256 path exists only because Nk=8 > 4).

fn aes_128_key_expand(key, round_keys): i64 {
    aes_gcm_global_init();
    # First 16 bytes of the expanded key = raw key material.
    memcpy(round_keys, key, 16);

    var i = 4;   # word index into the expanded key
    while (i < 44) {
        # temp = previous word (4 bytes)
        var base = (i - 1) * 4;
        var t0 = load8(round_keys + base + 0) & 0xFF;
        var t1 = load8(round_keys + base + 1) & 0xFF;
        var t2 = load8(round_keys + base + 2) & 0xFF;
        var t3 = load8(round_keys + base + 3) & 0xFF;

        if ((i & 3) == 0) {
            # RotWord
            var rot0 = t1;
            var rot1 = t2;
            var rot2 = t3;
            var rot3 = t0;
            # SubWord
            t0 = _aes_sub(rot0);
            t1 = _aes_sub(rot1);
            t2 = _aes_sub(rot2);
            t3 = _aes_sub(rot3);
            # XOR Rcon[i/4] into t0
            t0 = t0 ^ (load8(_aes_rcon + (i / 4)) & 0xFF);
        }

        # W[i] = W[i-Nk] XOR temp
        var prev_base = (i - 4) * 4;
        var dst_base = i * 4;
        store8(round_keys + dst_base + 0, (load8(round_keys + prev_base + 0) ^ t0) & 0xFF);
        store8(round_keys + dst_base + 1, (load8(round_keys + prev_base + 1) ^ t1) & 0xFF);
        store8(round_keys + dst_base + 2, (load8(round_keys + prev_base + 2) ^ t2) & 0xFF);
        store8(round_keys + dst_base + 3, (load8(round_keys + prev_base + 3) ^ t3) & 0xFF);

        i = i + 1;
    }
    return 0;
}

# ================================================================
# AES single-block encrypt — forward direction (14 or 10 rounds)
# ================================================================
# state is laid out column-major in the spec, but since SubBytes
# and AddRoundKey are per-byte we keep it in native byte order
# and just transpose the ShiftRows / MixColumns accesses.
#
# Layout: state[r*4 + c] = byte at row r, column c.
# AES input is read column-major: in[0]=s[0,0], in[1]=s[1,0],
# in[2]=s[2,0], in[3]=s[3,0], in[4]=s[0,1], etc.
# We store state[col*4 + row] to match that wire order — so
# state[0..3] = column 0, state[4..7] = column 1, etc.

fn _aes_add_round_key(state, rk, round): i64 {
    var off = round * 16;
    var i = 0;
    while (i < 16) {
        store8(state + i,
        (load8(state + i) ^ load8(rk + off + i)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _aes_sub_bytes(state): i64 {
    var i = 0;
    while (i < 16) {
        store8(state + i, _aes_sub(load8(state + i) & 0xFF));
        i = i + 1;
    }
    return 0;
}

fn _aes_shift_rows(state): i64 {
    # State in column-major order: s[c,r] at state[c*4 + r].
    # ShiftRows rotates row r left by r columns: row 0 unchanged,
    # row 1 rotated by 1, row 2 by 2, row 3 by 3.
    # Read into tmp then write back permuted.
    # Banked (3.9.6): function-scope static (quirk #1) — raced under
    # concurrent AES-GCM (the encrypted TLS handshake flight + records).
    var bk = cbank();
    var tmp[1024];   var tb = &tmp + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    memcpy(tb, state, 16);

    # Row 0 (unchanged): columns 0,1,2,3
    # store8(state + 0*4 + 0, load8(tb + 0*4 + 0));  (no-op)

    # Row 1 rotated left by 1:
    #   new s[0,1] = old s[1,1]    → state[0*4+1] = tmp[1*4+1]
    #   new s[1,1] = old s[2,1]    → state[1*4+1] = tmp[2*4+1]
    #   new s[2,1] = old s[3,1]    → state[2*4+1] = tmp[3*4+1]
    #   new s[3,1] = old s[0,1]    → state[3*4+1] = tmp[0*4+1]
    store8(state +  1, load8(tb +  5));
    store8(state +  5, load8(tb +  9));
    store8(state +  9, load8(tb + 13));
    store8(state + 13, load8(tb +  1));

    # Row 2 rotated left by 2:
    store8(state +  2, load8(tb + 10));
    store8(state +  6, load8(tb + 14));
    store8(state + 10, load8(tb +  2));
    store8(state + 14, load8(tb +  6));

    # Row 3 rotated left by 3 (equivalently: right by 1):
    store8(state +  3, load8(tb + 15));
    store8(state +  7, load8(tb +  3));
    store8(state + 11, load8(tb +  7));
    store8(state + 15, load8(tb + 11));
    return 0;
}

fn _aes_mix_columns(state): i64 {
    # MixColumns transforms each column independently.
    # s'[0,c] = 2·s[0,c] ^ 3·s[1,c] ^ s[2,c] ^ s[3,c]
    # s'[1,c] = s[0,c] ^ 2·s[1,c] ^ 3·s[2,c] ^ s[3,c]
    # s'[2,c] = s[0,c] ^ s[1,c] ^ 2·s[2,c] ^ 3·s[3,c]
    # s'[3,c] = 3·s[0,c] ^ s[1,c] ^ s[2,c] ^ 2·s[3,c]
    # Where 2·x = xtime(x), 3·x = xtime(x) ^ x.
    var c = 0;
    while (c < 4) {
        var a0 = load8(state + c * 4 + 0) & 0xFF;
        var a1 = load8(state + c * 4 + 1) & 0xFF;
        var a2 = load8(state + c * 4 + 2) & 0xFF;
        var a3 = load8(state + c * 4 + 3) & 0xFF;

        var x0 = _aes_xtime(a0);
        var x1 = _aes_xtime(a1);
        var x2 = _aes_xtime(a2);
        var x3 = _aes_xtime(a3);

        var n0 = (x0 ^ (x1 ^ a1) ^ a2 ^ a3) & 0xFF;
        var n1 = (a0 ^ x1 ^ (x2 ^ a2) ^ a3) & 0xFF;
        var n2 = (a0 ^ a1 ^ x2 ^ (x3 ^ a3)) & 0xFF;
        var n3 = ((x0 ^ a0) ^ a1 ^ a2 ^ x3) & 0xFF;

        store8(state + c * 4 + 0, n0);
        store8(state + c * 4 + 1, n1);
        store8(state + c * 4 + 2, n2);
        store8(state + c * 4 + 3, n3);
        c = c + 1;
    }
    return 0;
}

# _aes_encrypt_block_sw — FIPS 197 §5.1 software block encrypt,
# parametrized on the round count `nr` (14 for AES-256, 10 for
# AES-128). The round transform is identical across key sizes; only
# the number of middle rounds and the index of the final round key
# differ. `nr - 1` middle rounds (SubBytes/ShiftRows/MixColumns/
# AddRoundKey), then the final round drops MixColumns.
fn _aes_encrypt_block_sw(round_keys, in_block, out_block, nr): i64 {
    # Banked (3.9.6): function-scope static (quirk #1) — raced under
    # concurrent AES-GCM. (Software fallback path; the AES-NI block
    # encrypt is the common case.)
    var bk = cbank();
    var state[1024];   var sb = &state + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    memcpy(sb, in_block, 16);

    # Initial round key
    _aes_add_round_key(sb, round_keys, 0);

    # Middle rounds
    var r = 1;
    while (r < nr) {
        _aes_sub_bytes(sb);
        _aes_shift_rows(sb);
        _aes_mix_columns(sb);
        _aes_add_round_key(sb, round_keys, r);
        r = r + 1;
    }

    # Final round (no MixColumns)
    _aes_sub_bytes(sb);
    _aes_shift_rows(sb);
    _aes_add_round_key(sb, round_keys, nr);

    memcpy(out_block, sb, 16);
    return 0;
}

# AES-NI dispatch note (applies to both block dispatchers below).
# The PXOR / AESENC memory-operand forms used by the _ni variants
# require the round_keys pointer to be 16-byte aligned (#GP
# otherwise). Cyrius 5.5.21 guarantees 16-alignment for array globals
# `var rk[240]` / `var rk[176]`, and `fl_alloc(N)` returns 16-aligned
# pointers because the block header is a multiple of 16.
# Bump-`alloc(N)` is only 8-byte aligned, so callers using that path
# bypass the NI branch here and run the software fallback — matches
# the CLAUDE.md discipline ("fl_alloc for round keys") without
# requiring every call site to know about the alignment invariant.

fn aes256_encrypt_block(round_keys, in_block, out_block): i64 {
    if (aes_ni_available() == 1) {
        if ((round_keys & 15) == 0) {
            aes256_encrypt_block_ni(round_keys, in_block, out_block);
            return 0;
        }
    }
    return _aes_encrypt_block_sw(round_keys, in_block, out_block, 14);
}

fn aes128_encrypt_block(round_keys, in_block, out_block): i64 {
    if (aes_ni_available() == 1) {
        if ((round_keys & 15) == 0) {
            aes128_encrypt_block_ni(round_keys, in_block, out_block);
            return 0;
        }
    }
    return _aes_encrypt_block_sw(round_keys, in_block, out_block, 10);
}

# Round-count-parametrized dispatch helpers — let the shared GCM /
# CTR machinery drive either key size by passing `nr` (14 = AES-256,
# 10 = AES-128). `nr` also fixes the expanded key-schedule size:
# rk_size = 16 * (nr + 1) → 240 for AES-256, 176 for AES-128.
fn _aes_keyexp(key, round_keys, nr): i64 {
    if (nr == 14) { return aes256_key_expand(key, round_keys); }
    return aes_128_key_expand(key, round_keys);
}

fn _aes_block_enc(round_keys, in_block, out_block, nr): i64 {
    if (nr == 14) { return aes256_encrypt_block(round_keys, in_block, out_block); }
    return aes128_encrypt_block(round_keys, in_block, out_block);
}

# ================================================================
# GHASH — GF(2^128) multiplication with reduction polynomial
# R = x^128 + x^7 + x^2 + x + 1. NIST SP 800-38D § 6.3.
# ================================================================
# Inputs are 128-bit blocks laid out big-endian (bit 0 is the MSB
# of byte 0 by GCM convention).
#
# Bit-by-bit right-shift multiply (Algorithm in NIST SP 800-38D
# Appendix A — constant-time, no table):
#     Z = 0, V = Y
#     for i = 0..127:
#         if bit i of X (high-to-low) == 1: Z ^= V
#         if V's LSbit == 0: V >>= 1
#         else: V = (V >> 1) ^ R_reduced
#
# The reduction polynomial R in the bit-reversed GCM convention
# becomes 0xE1000...00 as the MSByte after a right-shift on V.

fn _ghash_shift_right_and_reduce(v): i64 {
    # v is a 16-byte little-endian-of-bytes / big-endian-of-bits
    # block. Shift the whole block right by 1 bit, with carry
    # propagating from byte 0 → byte 1 → ... → byte 15.
    # If the original v[15] LSbit was 1, after the shift XOR 0xE1
    # into v[0] (the GCM reduction R').
    var lsb_set = load8(v + 15) & 1;
    var i = 15;
    while (i > 0) {
        var hi = (load8(v + i - 1) & 1) << 7;
        var cur = ((load8(v + i) & 0xFF) >> 1) & 0x7F;
        store8(v + i, (cur | hi) & 0xFF);
        i = i - 1;
    }
    store8(v, ((load8(v) & 0xFF) >> 1) & 0x7F);
    if (lsb_set == 1) {
        store8(v, (load8(v) ^ 0xE1) & 0xFF);
    }
    return 0;
}

fn _ghash_xor_16(dst, src): i64 {
    var i = 0;
    while (i < 16) {
        store8(dst + i, (load8(dst + i) ^ load8(src + i)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# _ghash_mul: Z = X * H in GF(2^128).
# X: 16 bytes (input, read-only). H: 16 bytes (hash subkey, read-only).
# z: 16 bytes (output, caller-provided, will be overwritten).
# V is a 16-byte working copy of H — secret material; `secret var`
# zeroizes it on every return path.
fn _ghash_mul(z, x, h): i64 {
    # Banked (3.9.6): `v` is a function-scope static (quirk #1) — GHASH
    # runs per AEAD block, so concurrent AES-GCM raced it. Plain `var` +
    # per-lane wipe (quirk #9; secret working copy of H).
    var bk = cbank();
    var v[1024];   var vb = &v + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    memcpy(vb, h, 16);
    memset(z, 0, 16);

    var byte = 0;
    while (byte < 16) {
        var b = load8(x + byte) & 0xFF;
        var bit = 0;
        while (bit < 8) {
            var mask = (b >> (7 - bit)) & 1;
            if (mask == 1) {
                _ghash_xor_16(z, vb);
            }
            _ghash_shift_right_and_reduce(vb);
            bit = bit + 1;
        }
        byte = byte + 1;
    }
    memset(vb, 0, 16);
    return 0;
}

# GHASH over an arbitrary-length buffer: splits into 16-byte
# blocks, zero-pads the tail, XOR-then-multiplies each block into
# the running tag. Caller supplies the 16-byte output buffer `y`
# initialized to zeros (for the outer GHASH call) or to the
# running accumulator.
fn _ghash_update(y, h, data, len): i64 {
    # block holds plaintext / ciphertext bytes during GHASH absorb;
    # scratch / scratch2 hold the GF(2^128) product. All three are
    # secret-derived — `secret var` zeroes them on return.
    # Banked (3.9.6): function-scope statics (quirk #1) raced under
    # concurrent AES-GCM. Plain `var` + per-lane wipe (secret-derived).
    var bk = cbank();
    var block[1024];    var blockb    = &block    + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    var scratch[1024];  var scratchb  = &scratch  + bk * 16;
    var scratch2[1024]; var scratch2b = &scratch2 + bk * 16;
    var pos = 0;
    while (pos + 16 <= len) {
        memcpy(blockb, data + pos, 16);
        _ghash_xor_16(y, blockb);
        # Z = Y * H, stored back into Y via scratch.
        _ghash_mul(scratchb, y, h);
        memcpy(y, scratchb, 16);
        pos = pos + 16;
    }
    var remaining = len - pos;
    if (remaining > 0) {
        # Re-zero block: only `remaining` bytes get copied in below;
        # the upper (16 - remaining) bytes must be zero for the
        # zero-padded tail-block convention.
        memset(blockb, 0, 16);
        memcpy(blockb, data + pos, remaining);
        _ghash_xor_16(y, blockb);
        _ghash_mul(scratch2b, y, h);
        memcpy(y, scratch2b, 16);
    }
    memset(blockb, 0, 16);
    memset(scratchb, 0, 16);
    memset(scratch2b, 0, 16);
    return 0;
}

# ================================================================
# Big-endian 64-bit store — used for GHASH length block
# ================================================================

fn _be64_store(buf, v): i64 {
    store8(buf + 0, (v >> 56) & 0xFF);
    store8(buf + 1, (v >> 48) & 0xFF);
    store8(buf + 2, (v >> 40) & 0xFF);
    store8(buf + 3, (v >> 32) & 0xFF);
    store8(buf + 4, (v >> 24) & 0xFF);
    store8(buf + 5, (v >> 16) & 0xFF);
    store8(buf + 6, (v >>  8) & 0xFF);
    store8(buf + 7,  v        & 0xFF);
    return 0;
}

fn _be32_store(buf, v): i64 {
    store8(buf + 0, (v >> 24) & 0xFF);
    store8(buf + 1, (v >> 16) & 0xFF);
    store8(buf + 2, (v >>  8) & 0xFF);
    store8(buf + 3,  v        & 0xFF);
    return 0;
}

fn _be32_load(buf): i64 {
    return ((load8(buf + 0) & 0xFF) << 24)
    | ((load8(buf + 1) & 0xFF) << 16)
    | ((load8(buf + 2) & 0xFF) <<  8)
    | ((load8(buf + 3) & 0xFF)      );
}

# ================================================================
# CTR-mode XOR: produce keystream block AES(K, counter) and XOR
# into data. The low 32 bits of the 16-byte counter increment
# between blocks (big-endian).
# ================================================================

fn _aes_gcm_ctr_xor(round_keys, counter, src, dst, len, nr): i64 {
    # CTR keystream block — XOR-masks the plaintext, so leakage
    # recovers plaintext. `secret var` zeroes on every return.
    # Banked (3.9.6): `ks` is a function-scope static (quirk #1) — the
    # CTR keystream block, raced under concurrent AES-GCM. Plain `var` +
    # per-lane wipe (XOR-mask, leakage recovers plaintext).
    var bk = cbank();
    var ks[1024];   var ksb = &ks + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    var pos = 0;
    while (pos < len) {
        _aes_block_enc(round_keys, counter, ksb, nr);
        var chunk = 16;
        if (len - pos < 16) { chunk = len - pos; }
        var i = 0;
        while (i < chunk) {
            store8(dst + pos + i,
            (load8(src + pos + i) ^ load8(ksb + i)) & 0xFF);
            i = i + 1;
        }
        # Increment low 32 bits, big-endian, in place.
        var ctr_val = _be32_load(counter + 12);
        ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
        _be32_store(counter + 12, ctr_val);
        pos = pos + chunk;
    }
    memset(ksb, 0, 16);
    return 0;
}

# ================================================================
# GCM AEAD encrypt — shared driver, parametrized on round count
# ================================================================
# `nr` selects the cipher: 14 = AES-256 (32-byte key), 10 = AES-128
# (16-byte key). rk_size = 16 * (nr + 1). All GCM framing (J0, CTR,
# GHASH, tag) is key-size-independent. Public entry points
# aes_gcm_encrypt / aes_128_gcm_encrypt wrap this with the fixed nr.
#
# Inputs:
#   key      — 32 bytes (nr=14) or 16 bytes (nr=10)
#   iv       — 12 bytes (96-bit IV; RFC fast path)
#   aad      — additional authenticated data, aad_len bytes (may be 0)
#   pt       — plaintext, pt_len bytes (may be 0)
# Outputs:
#   ct_out   — ciphertext buffer, pt_len bytes (caller-allocated)
#   tag_out  — 16-byte authentication tag (caller-allocated)
# Returns 0 on success, non-zero on input-validation failure.
#
# Security: round-key buffer and H are zeroized before free.

# _gcm_compute_j0 — the GCM pre-counter block J0 (NIST SP 800-38D §7.1).
# For a 96-bit (12-byte) IV the fast path is J0 = IV || 0^31 || 1; for any
# other length J0 = GHASH_H(IV || 0^s || (0^64 || [len(IV)]_64)), where the
# IV is zero-padded to a 128-bit boundary and a final block carries the
# 64-bit big-endian IV bit length. `h` is the GHASH subkey AES_K(0^128).
# Writes 16 bytes to j0_out. (3.7.2 — was 96-bit-only before.)
fn _gcm_compute_j0(h, iv, iv_len, j0_out): i64 {
    if (iv_len == 12) {
        memcpy(j0_out, iv, 12);
        store8(j0_out + 12, 0);
        store8(j0_out + 13, 0);
        store8(j0_out + 14, 0);
        store8(j0_out + 15, 1);
        return 0;
    }
    # Arbitrary-length IV: GHASH the IV (zero-padded to a block by
    # _ghash_update) then the (0^64 || 64-bit-BE IV bit length) block.
    # y is derived through the secret subkey h — zeroed on scope exit.
    # Banked (3.9.6): function-scope statics (quirk #1) raced under
    # concurrent AES-GCM (arbitrary-length-IV path). Plain `var` +
    # per-lane wipe.
    var bk = cbank();
    var y[1024];    var yb    = &y    + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    var lenb[1024]; var lenbb = &lenb + bk * 16;
    memset(yb, 0, 16);
    _ghash_update(yb, h, iv, iv_len);
    memset(lenbb, 0, 16);
    _be64_store(lenbb + 8, iv_len * 8);
    _ghash_update(yb, h, lenbb, 16);
    memcpy(j0_out, yb, 16);
    memset(lenbb, 0, 16);
    memset(yb, 0, 16);
    return 0;
}

fn _aes_gcm_encrypt_impl(key, iv, iv_len, aad, aad_len, pt, pt_len, ct_out, tag_out, nr): i64 {
    if (iv_len <= 0) { return (0 - 1); }
    if (aad_len < 0) { return (0 - 1); }
    if (pt_len < 0) { return (0 - 1); }

    aes_gcm_global_init();

    # Banked (3.9.6 — concurrent-TLS-handshake fix): every 16-byte buffer
    # below was a function-scope static (quirk #1) shared across threads;
    # two concurrent AES-GCM ops (the encrypted TLS handshake flight + the
    # record path) raced them. Banked across `cbank()` lanes; plain `var`
    # + per-lane wipe (quirk #9 — h/y/s are key-derived secrets).
    var bk = cbank();
    var zero_block[1024]; var zbb = &zero_block + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    var h[1024];          var hb  = &h          + bk * 16;
    var j0[1024];         var j0b = &j0         + bk * 16;
    var counter[1024];    var cnb = &counter    + bk * 16;
    var y[1024];          var yb  = &y          + bk * 16;
    var len_block[1024];  var lbb = &len_block  + bk * 16;
    var s[1024];          var sb  = &s          + bk * 16;

    # Banked key schedule (3.9.6): was `fl_alloc(rk_size)`, but fl_alloc
    # is NOT thread-safe (quirk #7) — concurrent GCM ops raced the
    # freelist. Banked static buffer instead (no allocator). 240 B/lane
    # (AES-256: 16*15) is divisible by 16, so each lane keeps the
    # 16-byte alignment the AES-NI round-key loads require (quirk #6).
    var rk_size = 16 * (nr + 1);
    var rkbuf[15360];   var round_keys = &rkbuf + bk * 240;   # 240 * SIGIL_CRYPTO_BANKS
    _aes_keyexp(key, round_keys, nr);

    # H = AES_K(0^128). h is the GHASH subkey — key-derived secret.
    memset(zbb, 0, 16);
    _aes_block_enc(round_keys, zbb, hb, nr);

    # J0 (SP 800-38D §7.1): 96-bit IV fast path or GHASH-based for any
    # other IV length.
    _gcm_compute_j0(hb, iv, iv_len, j0b);

    # Counter starts at inc32(J0) — low 32 bits incremented.
    memcpy(cnb, j0b, 16);
    var ctr_val = _be32_load(cnb + 12);
    ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
    _be32_store(cnb + 12, ctr_val);

    # Encrypt plaintext via CTR mode
    if (pt_len > 0) {
        _aes_gcm_ctr_xor(round_keys, cnb, pt, ct_out, pt_len, nr);
    }

    # GHASH over AAD || pad || CT || pad || len(AAD)||len(CT) in bits BE.
    # y is the running GHASH accumulator — secret-derived.
    memset(yb, 0, 16);
    if (aad_len > 0) {
        _ghash_update(yb, hb, aad, aad_len);
    }
    if (pt_len > 0) {
        _ghash_update(yb, hb, ct_out, pt_len);
    }
    memset(lbb, 0, 16);
    _be64_store(lbb + 0, aad_len * 8);
    _be64_store(lbb + 8, pt_len * 8);
    _ghash_update(yb, hb, lbb, 16);

    # Tag = Y XOR AES_K(J0). s = AES_K(J0) — key-derived secret.
    _aes_block_enc(round_keys, j0b, sb, nr);
    var i = 0;
    while (i < 16) {
        store8(tag_out + i, (load8(yb + i) ^ load8(sb + i)) & 0xFF);
        i = i + 1;
    }

    # Per-lane wipe of the key schedule + every secret/derived buffer
    # (replaces the old fl_free + `secret var` zeroization).
    memset(round_keys, 0, rk_size);
    memset(hb, 0, 16);
    memset(yb, 0, 16);
    memset(sb, 0, 16);
    memset(cnb, 0, 16);
    memset(j0b, 0, 16);
    memset(zbb, 0, 16);
    memset(lbb, 0, 16);
    return 0;
}

# aes_gcm_encrypt — AES-256-GCM AEAD encrypt (FIPS 197 + NIST SP
# 800-38D). key is 32 bytes; iv is 12 bytes; aad/pt may be empty.
# Writes pt_len ciphertext bytes to ct_out and a 16-byte tag to
# tag_out. Returns 0 on success, non-zero on input-validation failure.
fn aes_gcm_encrypt(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    return _aes_gcm_encrypt_impl(key, iv, 12, aad, aad_len, pt, pt_len, ct_out, tag_out, 14);
}

# aes_gcm_encrypt_iv — AES-256-GCM encrypt with an arbitrary-length IV
# (NIST SP 800-38D §7.1; iv_len in bytes, must be > 0). For iv_len == 12
# this is identical to aes_gcm_encrypt; other lengths derive J0 via
# GHASH. Returns 0 on success, non-zero on input-validation failure.
fn aes_gcm_encrypt_iv(key, iv, iv_len, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    return _aes_gcm_encrypt_impl(key, iv, iv_len, aad, aad_len, pt, pt_len, ct_out, tag_out, 14);
}

# aes_128_gcm_encrypt — AES-128-GCM AEAD encrypt (FIPS 197 + NIST SP
# 800-38D). Identical contract to aes_gcm_encrypt but with a 16-byte
# key (10-round schedule). Drives the TLS 1.3 TLS_AES_128_GCM_SHA256
# (0x1301) ciphersuite and the TLS 1.2 *_WITH_AES_128_GCM_SHA256
# suites. Returns 0 on success, non-zero on input-validation failure.
fn aes_128_gcm_encrypt(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    return _aes_gcm_encrypt_impl(key, iv, 12, aad, aad_len, pt, pt_len, ct_out, tag_out, 10);
}

# aes_128_gcm_encrypt_iv — AES-128-GCM encrypt with an arbitrary-length
# IV (SP 800-38D §7.1; iv_len in bytes, > 0). 96-bit IVs match
# aes_128_gcm_encrypt; other lengths derive J0 via GHASH.
fn aes_128_gcm_encrypt_iv(key, iv, iv_len, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    return _aes_gcm_encrypt_impl(key, iv, iv_len, aad, aad_len, pt, pt_len, ct_out, tag_out, 10);
}

# ================================================================
# GCM AEAD decrypt with tag verification — shared driver
# ================================================================
# `nr` selects the cipher (14 = AES-256, 10 = AES-128); see the
# encrypt driver above. Public entry points aes_gcm_decrypt /
# aes_128_gcm_decrypt wrap this with the fixed nr.
#
# Inputs:
#   key      — 32 bytes (nr=14) or 16 bytes (nr=10)
#   iv       — 12 bytes
#   aad      — aad_len bytes
#   ct       — ciphertext, ct_len bytes
#   tag      — 16-byte received tag
# Output:
#   pt_out   — plaintext, ct_len bytes (caller-allocated)
# Returns:
#   SIGIL_ERR_NONE on success
#   SIGIL_ERR_INTEGRITY_MISMATCH on tag mismatch (pt_out NOT populated
#       with real plaintext — it is zeroed on failure).
#   SIGIL_ERR_INVALID_INPUT on length validation failure.
#
# AEAD contract: plaintext MUST NOT be released until the tag is
# verified. We compute & verify the tag first, then derive pt.

fn _aes_gcm_decrypt_impl(key, iv, iv_len, aad, aad_len, ct, ct_len, tag, pt_out, nr): i64 {
    if (iv_len <= 0) { return SIGIL_ERR_INVALID_INPUT; }
    if (aad_len < 0) { return SIGIL_ERR_INVALID_INPUT; }
    if (ct_len < 0) { return SIGIL_ERR_INVALID_INPUT; }

    aes_gcm_global_init();

    # Banked (3.9.6 — concurrent-TLS-handshake fix): every 16-byte buffer
    # below was a function-scope static (quirk #1) raced by concurrent
    # AES-GCM. Banked across `cbank()` lanes; plain `var` + per-lane wipe
    # (quirk #9 — h/y/s/expected_tag are key-derived secrets).
    var bk = cbank();
    var zero_block[1024];   var zbb = &zero_block   + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    var h[1024];            var hb  = &h            + bk * 16;
    var j0[1024];           var j0b = &j0           + bk * 16;
    var y[1024];            var yb  = &y            + bk * 16;
    var len_block[1024];    var lbb = &len_block    + bk * 16;
    var s[1024];            var sb  = &s            + bk * 16;
    var expected_tag[1024]; var etb = &expected_tag + bk * 16;
    var counter[1024];      var cnb = &counter      + bk * 16;

    # Banked key schedule (3.9.6): was `fl_alloc` (not thread-safe,
    # quirk #7). Banked static buffer; 240 B/lane keeps 16-byte
    # alignment for AES-NI round-key loads (quirk #6).
    var rk_size = 16 * (nr + 1);
    var rkbuf[15360];   var round_keys = &rkbuf + bk * 240;   # 240 * SIGIL_CRYPTO_BANKS
    _aes_keyexp(key, round_keys, nr);

    # H = AES_K(0). h is the GHASH subkey — key-derived secret.
    memset(zbb, 0, 16);
    _aes_block_enc(round_keys, zbb, hb, nr);

    # J0 (SP 800-38D §7.1): 96-bit IV fast path or GHASH-based otherwise.
    _gcm_compute_j0(hb, iv, iv_len, j0b);

    # Compute expected tag over received ciphertext BEFORE
    # touching pt_out. y is the running GHASH accumulator — secret.
    memset(yb, 0, 16);
    if (aad_len > 0) {
        _ghash_update(yb, hb, aad, aad_len);
    }
    if (ct_len > 0) {
        _ghash_update(yb, hb, ct, ct_len);
    }
    memset(lbb, 0, 16);
    _be64_store(lbb + 0, aad_len * 8);
    _be64_store(lbb + 8, ct_len * 8);
    _ghash_update(yb, hb, lbb, 16);

    # s = AES_K(J0); expected_tag = Y XOR s. Both key-derived.
    _aes_block_enc(round_keys, j0b, sb, nr);
    var i = 0;
    while (i < 16) {
        store8(etb + i, (load8(yb + i) ^ load8(sb + i)) & 0xFF);
        i = i + 1;
    }

    # Constant-time tag compare. ct_eq_bytes_lens loops the full
    # length even on first mismatch — no early exit on secret data.
    # Lengths equal-by-construction (both 16 = poly1305 tag); could
    # equivalently call ct_eq_bytes(_, _, 16) since the dual-length
    # form's mismatch-fast-path is unreachable here. Kept dual-length
    # for symmetry with the v5.9.20 sigil 3.0.2 migration shape.
    var ok = ct_eq_bytes_lens(etb, 16, tag, 16);

    # Decrypt via CTR starting at inc32(J0) — we perform the CTR
    # pass unconditionally to keep the work profile flat across
    # valid and forged tag paths. If the tag failed, pt_out is
    # zeroed *after* CTR so no real plaintext ever escapes.
    memcpy(cnb, j0b, 16);
    var ctr_val = _be32_load(cnb + 12);
    ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
    _be32_store(cnb + 12, ctr_val);

    if (ct_len > 0) {
        _aes_gcm_ctr_xor(round_keys, cnb, ct, pt_out, ct_len, nr);
    }

    var rc = SIGIL_ERR_NONE;
    if (ok != 1) {
        # Overwrite the computed plaintext so the caller never
        # observes pre-auth bytes. AEAD no-plaintext-leak contract.
        if (ct_len > 0) {
            memset(pt_out, 0, ct_len);
        }
        rc = SIGIL_ERR_INTEGRITY_MISMATCH;
    }

    # Per-lane wipe of the key schedule + every secret/derived buffer
    # (replaces the old fl_free + `secret var` zeroization).
    memset(round_keys, 0, rk_size);
    memset(hb, 0, 16);
    memset(yb, 0, 16);
    memset(sb, 0, 16);
    memset(etb, 0, 16);
    memset(cnb, 0, 16);
    memset(j0b, 0, 16);
    memset(zbb, 0, 16);
    memset(lbb, 0, 16);
    return rc;
}

# aes_gcm_decrypt — AES-256-GCM AEAD decrypt with tag verification.
# key is 32 bytes; iv is 12 bytes. Returns SIGIL_ERR_NONE on success,
# SIGIL_ERR_INTEGRITY_MISMATCH on tag mismatch (pt_out zeroed), or
# SIGIL_ERR_INVALID_INPUT on length-validation failure.
fn aes_gcm_decrypt(key, iv, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    return _aes_gcm_decrypt_impl(key, iv, 12, aad, aad_len, ct, ct_len, tag, pt_out, 14);
}

# aes_gcm_decrypt_iv — AES-256-GCM decrypt+verify with an arbitrary-length
# IV (SP 800-38D §7.1; iv_len in bytes, > 0). Same return contract as
# aes_gcm_decrypt (SIGIL_ERR_NONE / SIGIL_ERR_INTEGRITY_MISMATCH / SIGIL_ERR_INVALID_INPUT).
fn aes_gcm_decrypt_iv(key, iv, iv_len, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    return _aes_gcm_decrypt_impl(key, iv, iv_len, aad, aad_len, ct, ct_len, tag, pt_out, 14);
}

# aes_128_gcm_decrypt — AES-128-GCM AEAD decrypt with tag
# verification. Identical contract to aes_gcm_decrypt but with a
# 16-byte key (10-round schedule). Drives the TLS 1.3
# TLS_AES_128_GCM_SHA256 (0x1301) ciphersuite and the TLS 1.2
# *_WITH_AES_128_GCM_SHA256 suites.
fn aes_128_gcm_decrypt(key, iv, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    return _aes_gcm_decrypt_impl(key, iv, 12, aad, aad_len, ct, ct_len, tag, pt_out, 10);
}

# aes_128_gcm_decrypt_iv — AES-128-GCM decrypt+verify with an
# arbitrary-length IV (SP 800-38D §7.1; iv_len in bytes, > 0). Same
# return contract as aes_128_gcm_decrypt.
fn aes_128_gcm_decrypt_iv(key, iv, iv_len, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    return _aes_gcm_decrypt_impl(key, iv, iv_len, aad, aad_len, ct, ct_len, tag, pt_out, 10);
}
