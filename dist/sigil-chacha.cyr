# sigil.cyr -- bundled distribution
# Version: 3.11.0
# Profile: chacha
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- error.cyr ---

# error.cyr — sigil error codes and error construction
# Follows packed-struct pattern (like sakshi) for error objects.

# ================================================================
# Error codes
# ================================================================

enum SigilError {
    SIGIL_ERR_NONE = 0;
    SIGIL_ERR_KEY_NOT_FOUND = 1;
    SIGIL_ERR_SIGNATURE_INVALID = 2;
    SIGIL_ERR_REVOCATION = 3;
    SIGIL_ERR_INTEGRITY_MISMATCH = 4;
    SIGIL_ERR_INVALID_INPUT = 5;
    SIGIL_ERR_IO = 6;
    SIGIL_ERR_SERIALIZATION = 7;
    SIGIL_ERR_CRYPTO = 8;
}

# ================================================================
# Error predicates
# ================================================================

# Returns 1 if `code` is SIGIL_ERR_NONE (success), 0 otherwise.
fn sigil_is_ok(code): i64 {
    if (code == SIGIL_ERR_NONE) { return 1; }
    return 0;
}

# Returns 1 if `code` is any non-SIGIL_ERR_NONE error code, 0 otherwise.
fn sigil_is_err(code): i64 {
    if (code != SIGIL_ERR_NONE) { return 1; }
    return 0;
}

# ================================================================
# Error object (16 bytes)
# ================================================================
# Layout:
#   +0   code   (i64, ERR_* constant)
#   +8   msg    (C-string pointer)

# Allocates a 16-byte error object holding `code` and `msg` (a C-string
# pointer). Returns the object pointer; free with sigil_err_free.
fn sigil_err(code, msg): i64 {
    var e = fl_alloc(16);
    store64(e, code);
    store64(e + 8, msg);
    return e;
}

# Returns the ERR_* code stored in error object `e`.
fn sigil_err_code(e): i64 { return load64(e); }
# Returns the message C-string pointer stored in error object `e`.
fn sigil_err_msg(e): i64 { return load64(e + 8); }
# Frees an error object allocated by sigil_err. Returns 0.
fn sigil_err_free(e): i64 { fl_free(e); return 0; }

# --- crypto_scratch.cyr ---

# crypto_scratch.cyr — per-thread working-buffer bank selection for
# the parallel batch-verify path (sigil 3.6).
#
# WHY THIS EXISTS
# ---------------
# A `var X[N]` declared inside a function in cyrius is a STATIC
# function-scope global, not a per-call stack array (CLAUDE.md quirk
# #1; tests/tcyr/var_array_semantics.tcyr — re-confirmed under cycc
# 6.0.52 during the 3.6 open). The transient working arrays inside
# the crypto primitives (SHA-256/512 message schedules, the Ed25519
# field/group temporaries) are therefore shared across threads, which
# is exactly why `sv_verify_batch` had to serialise every artifact
# behind `_sigil_batch_mutex` (see the threading-safety contract in
# src/verify.cyr).
#
# THE 3.6 MECHANISM — per-thread BANKS
# ------------------------------------
# Each racing `var X[N]` is widened to `var X[N * SIGIL_CRYPTO_BANKS]`
# and the function operates on its own lane `&X + cbank()*N`. `cbank()`
# returns the calling thread's bank index, read from a thread-local
# slot (cyrius 6.0.52 `lib/thread_local.cyr`):
#   - the main thread / serial path uses bank 0 (a fresh TLS slot
#     reads 0);
#   - batch workers are assigned distinct banks 1..workers at spawn
#     (`crypto_bank_set`).
# Distinct concurrent banks ⇒ disjoint memory ⇒ no data race — with
# NO signature changes, NO caller changes, and NO cross-function
# offset map. Each function still owns its own array; a worker simply
# writes a different lane of it. Collisions are impossible by
# construction (every lane is owned by exactly one live thread).
#
# This is deliberately cheaper and far lower-risk than threading a
# caller-provided scratch pointer through every `fp_mul` / `ge_add` /
# `sha256_transform` signature (the shape the v3.6 roadmap sketched
# before cyrius shipped thread-local storage): no signature churn, and
# the bank arithmetic is local and self-evidently collision-free.
#
# TLS LIFECYCLE
# -------------
# Worker threads spawned via `thread_create` get a zeroed 4 KB TLS
# block installed automatically by CLONE_SETTLS (cyrius lib/thread.cyr),
# so they need no init — their slot reads 0 until `crypto_bank_set`
# overwrites it. The MAIN thread has no TLS block until one is
# installed, so `cbank()` self-installs one on first use (and the
# batch path pre-warms it on the main thread before fan-out). The
# `& (SIGIL_CRYPTO_BANKS-1)` mask makes an out-of-range slot value
# impossible to turn into an out-of-bounds lane — defence in depth.
#
# Requires: lib/thread_local.cyr (cyrius >= 6.0.52). Must be included
# before any banked crypto module (src/sha_ni.cyr onward).

# Number of concurrent crypto-scratch lanes. MUST be a power of two
# (the `cbank()` mask relies on it). Bank 0 is reserved for the
# main/serial path; banks 1..SIGIL_CRYPTO_BANKS-1 are handed to
# concurrent worker threads. 64 covers a 63-worker TLS termination
# pool (one worker per core on any realistic host) plus the main
# thread; widening only costs banked-array static scratch (each
# banked `var X[N]` is sized N*SIGIL_CRYPTO_BANKS bytes).
#
# 3.9.6 — concurrent-TLS-handshake fix: bumped 8 -> 64 and made
# `cbank()` AUTO-ASSIGN a private lane per thread (see below). Before
# 3.9.6 the only caller that ever set a non-zero bank was the
# batch-verify path (`crypto_bank_set`); every other concurrent caller
# — notably cyrius `tls_native` / sandhi TLS worker threads — collided
# on bank 0, racing the banked scratch (the concurrent-TLS-handshake
# crash). Auto-assignment removes the need for any per-worker
# cooperation: a worker's first `cbank()` claims the next free lane.
# See docs/development/issues/2026-06-28-concurrent-tls-handshake-
# global-scratch-race.md and ADR 0007.
var SIGIL_CRYPTO_BANKS = 64;
var _SIGIL_CBANK_MASK = 63;     # SIGIL_CRYPTO_BANKS - 1
# thread-local slot (cyrius thread_local_get/set namespace). Holds (bank+1):
# 0 = unassigned, v = bank (v-1).
#
# 3.9.9 (2026-07-01): MOVED 0 -> 8. cyrius's thread_local slot namespace is a
# small shared integer space (16 slots, no allocator), and slot 0 COLLIDED with
# patra's SQL-parse scratch (patra owns slots 0-4: TLS_PR/TLS_TOKS/TLS_NTOKS +
# TLS_SLAB_STACK=3/TLS_SLAB_TOP=4). In a server that links BOTH sigil + patra
# (e.g. a TLS termination pool serving a patra-backed API — SecureYeoman's
# yeo-cy-test), a patra query clobbered sigil's pinned bank in slot 0, so a later
# cbank() read patra's scratch value as the bank and indexed the WRONG lane of
# the process-global banked crypto buffers — corrupting an in-flight handshake's
# key schedule -> the client saw RECORD_LAYER_FAILURE (reproduced as "every 4th
# handshake fails" under a specific worker layout). Slot 8 is clear of patra
# (0-4) + the common consumer high slots (15). NOTE: the underlying fix is a
# slot ALLOCATOR in cyrius thread_local.cyr (filed) — until then, leaf crypto
# owns slot 8 by convention. See docs/development/issues/2026-06-28-concurrent-
# tls-handshake-global-scratch-race.md and cyrius issue multiworker-tls-record-
# layer-failure.
var _SIGIL_CBANK_SLOT = 8;
var _crypto_tls_inited = 0;
var _crypto_next_bank = 0;      # atomic counter; auto-assigned worker
                                # threads draw lanes 1..BANKS-1 from it.

# Install a TLS block on the calling (main) thread and claim bank 0
# for it so `cbank()` is well-defined on the serial path. Idempotent
# (a CAS guard makes concurrent first-callers init exactly once, so a
# worker that races here cannot double-`alloc` the TLS block — quirk
# #7: alloc is not thread-safe).
#
# MULTI-THREADED CONSUMER CONTRACT: a server that spawns crypto worker
# threads (e.g. a TLS termination pool) should call this once on the
# MAIN thread at startup, before spawning workers — it installs main's
# TLS block (main has none until installed; workers get a zeroed block
# via CLONE_SETTLS) and marks the subsystem inited so each worker's
# first `cbank()` only reads/auto-assigns and never races init. In
# practice any sigil crypto call on the main thread (e.g. parsing the
# server cert/key) triggers this via the lazy backstop in `cbank()`
# before workers start; the explicit call is belt-and-suspenders.
# Returns 0.
fn crypto_tls_main_init(): i64 {
    # CAS 0 -> 1: exactly one thread wins and runs the init.
    if (atomic_cas(&_crypto_tls_inited, 0, 1) == 0) { return 0; }
    thread_local_init();
    # Claim bank 0 for this (main) thread: slot = bank0 encoded = 1.
    thread_local_set(_SIGIL_CBANK_SLOT, 1);
    return 0;
}

# Explicitly assign the calling thread a bank index (legacy / batch
# path). Bank must be in 0 .. SIGIL_CRYPTO_BANKS-1. Stored as (bank+1)
# so a fresh (unassigned) slot reads 0. Most callers no longer need
# this — `cbank()` auto-assigns — but the batch-verify path keeps using
# it for deterministic lane fan-out. Returns 0.
fn crypto_bank_set(bank): i64 {
    thread_local_set(_SIGIL_CBANK_SLOT, bank + 1);
    return 0;
}

# Bank (lane) index for the calling thread. Bank 0 on the main/serial
# path; a distinct 1..BANKS-1 lane on each concurrent worker. On a
# thread whose slot is still unassigned (a fresh worker that never
# called crypto_bank_set), the FIRST call atomically claims the next
# lane from `_crypto_next_bank` (cycled into 1..BANKS-1 so bank 0 stays
# the exclusive main lane) and pins it in the thread-local slot for the
# life of the thread. This is what makes concurrent callers (TLS
# handshake workers) race-free with zero per-worker cooperation. The
# mask guarantees the result is always a valid lane index (defence in
# depth).
fn cbank(): i64 {
    if (_crypto_tls_inited == 0) { crypto_tls_main_init(); }
    var raw = thread_local_get(_SIGIL_CBANK_SLOT);
    if (raw == 0) {
        # Unassigned thread: claim the next lane. atomic_fetch_add
        # returns the prior counter value (0,1,2,...); map it onto
        # 1..BANKS-1 so we never alias the main thread's bank 0.
        var n = atomic_fetch_add(&_crypto_next_bank, 1);
        var bank = (n % (SIGIL_CRYPTO_BANKS - 1)) + 1;
        thread_local_set(_SIGIL_CBANK_SLOT, bank + 1);
        return bank & _SIGIL_CBANK_MASK;
    }
    return (raw - 1) & _SIGIL_CBANK_MASK;
}

# --- poly1305.cyr ---

# poly1305.cyr — Poly1305 one-time message authenticator (RFC 8439 §2.5)
#
# Poly1305 authenticates a message under a 32-byte ONE-TIME key:
#   tag = (((acc) * r) mod (2^130 - 5)) + s   mod 2^128
# where the key splits into r (clamped, bytes 0..15) and s
# (bytes 16..31). It is the MAC half of the ChaCha20-Poly1305 AEAD
# (RFC 8439 §2.8), but ships here standalone ahead of that arc — a
# MAC primitive has no dependency on ChaCha20 or TLS.
#
# === SECURITY CONTRACT: ONE-TIME KEY ===========================
# The 32-byte key MUST be unique per message. Authenticating two
# distinct messages under the same key lets an attacker recover r
# and forge tags (RFC 8439 §2.6). Unlike HMAC (src/hmac.cyr),
# Poly1305 is NOT a reusable-key MAC. For the AEAD, the one-time
# key is derived fresh from the ChaCha20 keystream (counter 0) per
# nonce.
# ===============================================================
#
# Implementation: the 26-bit-limb ("poly1305-donna") form. Five
# 26-bit limbs keep every intermediate product below 2^59, so the
# whole reduction runs in signed i64 with no 128-bit arithmetic
# path. The final freeze is constant-time (mask-select, no branch
# on the key-derived accumulator) per sigil's constant-time-on-
# secret-data rule (CLAUDE.md Key Principles).
#
# THREAD-SAFETY: `_p1305_block` scratch is a single-call buffer;
# `poly1305_mac` fully writes it before reading (CLAUDE.md quirk
# #1). Serial use is correct. Parallel-batch callers must follow
# the per-worker-scratch discipline coming in the v3.6 cycle —
# until then this MAC is not on a multi-threaded path.
#
# Citation: RFC 8439 §2.5 (algorithm), §2.5.2 (worked example),
# Appendix A.3 (test vectors). See docs/sources.md.

# ================================================================
# Little-endian 4-byte codec
# ================================================================

# Read 4 little-endian bytes at p as an i64 in [0, 2^32).
fn _p1305_u8to32(p): i64 {
    return (load8(p) & 0xFF)
         | ((load8(p + 1) & 0xFF) << 8)
         | ((load8(p + 2) & 0xFF) << 16)
         | ((load8(p + 3) & 0xFF) << 24);
}

# Write the low 32 bits of v as 4 little-endian bytes at p.
fn _p1305_u32to8(p, v): i64 {
    store8(p,     v & 0xFF);
    store8(p + 1, (v >> 8) & 0xFF);
    store8(p + 2, (v >> 16) & 0xFF);
    store8(p + 3, (v >> 24) & 0xFF);
    return 0;
}

# ================================================================
# poly1305_mac — one-shot tag computation
#   key      — 32 bytes (r || s), one-time
#   msg      — message bytes
#   msg_len  — message length in bytes (any length, incl. 0)
#   out      — 16-byte tag buffer (caller-allocated)
# Returns 0.
# ================================================================
fn poly1305_mac(key, msg, msg_len, out): i64 {
    # ---- Load + clamp r (bytes 0..15), split into 5×26-bit limbs.
    # The masks fold RFC 8439's r-clamp
    # (0x0ffffffc0ffffffc0ffffffc0fffffff) into the limb split.
    var t0 = _p1305_u8to32(key);
    var t1 = _p1305_u8to32(key + 4);
    var t2 = _p1305_u8to32(key + 8);
    var t3 = _p1305_u8to32(key + 12);

    var r0 = t0 & 0x3ffffff;
    var r1 = ((t0 >> 26) | (t1 << 6)) & 0x3ffff03;
    var r2 = ((t1 >> 20) | (t2 << 12)) & 0x3ffc0ff;
    var r3 = ((t2 >> 14) | (t3 << 18)) & 0x3f03fff;
    var r4 = (t3 >> 8) & 0x00fffff;

    # Precompute 5*r_i for the wrap-around terms (2^130 ≡ 5 mod p).
    var s1 = r1 * 5;
    var s2 = r2 * 5;
    var s3 = r3 * 5;
    var s4 = r4 * 5;

    # ---- s (pad, bytes 16..31) as four 32-bit words.
    var pad0 = _p1305_u8to32(key + 16);
    var pad1 = _p1305_u8to32(key + 20);
    var pad2 = _p1305_u8to32(key + 24);
    var pad3 = _p1305_u8to32(key + 28);

    # ---- Accumulator (5×26-bit limbs), starts at 0.
    var h0 = 0; var h1 = 0; var h2 = 0; var h3 = 0; var h4 = 0;

    # Scratch for the final partial block. Banked (3.9.6): was a
    # function-scope static (quirk #1) raced under concurrent
    # ChaCha20-Poly1305 (the TLS_CHACHA20_POLY1305_SHA256 suite — the
    # issue confirmed both AEAD suites crash). Plain `var` + per-lane
    # wipe (it transiently holds message bytes).
    var bk = cbank();
    var block[1024];   var blockb = &block + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS

    var done = 0;
    while (done < msg_len) {
        var remaining = msg_len - done;
        var mp = msg + done;
        # Full block: implicit high bit via hibit = 2^128 (1<<24 in
        # limb 4). Partial block: pad to 16 with an explicit 0x01
        # after the data and hibit = 0.
        var hibit = 1 << 24;
        if (remaining < 16) {
            memset(blockb, 0, 16);
            memcpy(blockb, msg + done, remaining);
            store8(blockb + remaining, 1);
            mp = blockb;
            hibit = 0;
        }

        # h += block (read overlapping 32-bit windows into limbs)
        h0 = h0 + (_p1305_u8to32(mp) & 0x3ffffff);
        h1 = h1 + ((_p1305_u8to32(mp + 3) >> 2) & 0x3ffffff);
        h2 = h2 + ((_p1305_u8to32(mp + 6) >> 4) & 0x3ffffff);
        h3 = h3 + ((_p1305_u8to32(mp + 9) >> 6) & 0x3ffffff);
        h4 = h4 + ((_p1305_u8to32(mp + 12) >> 8) | hibit);

        # h *= r  (schoolbook with 2^130 ≡ 5 wrap; products < 2^59)
        var d0 = h0 * r0 + h1 * s4 + h2 * s3 + h3 * s2 + h4 * s1;
        var d1 = h0 * r1 + h1 * r0 + h2 * s4 + h3 * s3 + h4 * s2;
        var d2 = h0 * r2 + h1 * r1 + h2 * r0 + h3 * s4 + h4 * s3;
        var d3 = h0 * r3 + h1 * r2 + h2 * r1 + h3 * r0 + h4 * s4;
        var d4 = h0 * r4 + h1 * r3 + h2 * r2 + h3 * r1 + h4 * r0;

        # Carry-propagate back into 26-bit limbs.
        var c = d0 >> 26; h0 = d0 & 0x3ffffff;
        d1 = d1 + c; c = d1 >> 26; h1 = d1 & 0x3ffffff;
        d2 = d2 + c; c = d2 >> 26; h2 = d2 & 0x3ffffff;
        d3 = d3 + c; c = d3 >> 26; h3 = d3 & 0x3ffffff;
        d4 = d4 + c; c = d4 >> 26; h4 = d4 & 0x3ffffff;
        h0 = h0 + c * 5; c = h0 >> 26; h0 = h0 & 0x3ffffff;
        h1 = h1 + c;

        done = done + 16;
    }

    # ---- Fully carry h (h0 already < 2^26 from the last block).
    var c = h1 >> 26; h1 = h1 & 0x3ffffff;
    h2 = h2 + c; c = h2 >> 26; h2 = h2 & 0x3ffffff;
    h3 = h3 + c; c = h3 >> 26; h3 = h3 & 0x3ffffff;
    h4 = h4 + c; c = h4 >> 26; h4 = h4 & 0x3ffffff;
    h0 = h0 + c * 5; c = h0 >> 26; h0 = h0 & 0x3ffffff;
    h1 = h1 + c;

    # ---- Compute g = h + 5 (then subtract 2^130 from the top
    # limb). If h >= p the top borrow stays clear (g4 >= 0); if
    # h < p the subtraction underflows (g4 < 0). Constant-time
    # select between h and g with no branch on the accumulator.
    var g0 = h0 + 5; c = g0 >> 26; g0 = g0 & 0x3ffffff;
    var g1 = h1 + c; c = g1 >> 26; g1 = g1 & 0x3ffffff;
    var g2 = h2 + c; c = g2 >> 26; g2 = g2 & 0x3ffffff;
    var g3 = h3 + c; c = g3 >> 26; g3 = g3 & 0x3ffffff;
    var g4 = h4 + c - (1 << 26);

    # sign = 1 ⟺ g4 negative ⟺ h < p (keep h); 0 ⟺ h >= p (take g).
    # Isolate the sign bit with &1 so the result is independent of
    # whether `>>` is arithmetic or logical.
    var sign = (g4 >> 63) & 1;
    var mask_g = sign - 1;   # all-ones when h >= p
    var mask_h = 0 - sign;   # all-ones when h <  p
    h0 = (h0 & mask_h) | (g0 & mask_g);
    h1 = (h1 & mask_h) | (g1 & mask_g);
    h2 = (h2 & mask_h) | (g2 & mask_g);
    h3 = (h3 & mask_h) | (g3 & mask_g);
    h4 = (h4 & mask_h) | (g4 & mask_g);

    # ---- Collapse 5×26-bit limbs into 4×32-bit words.
    h0 = (h0 | (h1 << 26)) & 0xffffffff;
    h1 = ((h1 >> 6) | (h2 << 20)) & 0xffffffff;
    h2 = ((h2 >> 12) | (h3 << 14)) & 0xffffffff;
    h3 = ((h3 >> 18) | (h4 << 8)) & 0xffffffff;

    # ---- tag = (h + s) mod 2^128, little-endian.
    var f = h0 + pad0;             h0 = f & 0xffffffff;
    f = h1 + pad1 + (f >> 32);     h1 = f & 0xffffffff;
    f = h2 + pad2 + (f >> 32);     h2 = f & 0xffffffff;
    f = h3 + pad3 + (f >> 32);     h3 = f & 0xffffffff;

    _p1305_u32to8(out,      h0);
    _p1305_u32to8(out + 4,  h1);
    _p1305_u32to8(out + 8,  h2);
    _p1305_u32to8(out + 12, h3);

    # Best-effort scrub of key-derived scalars. (Cyrius `secret var`
    # guarantees zeroization for stack arrays only; scalar locals
    # rely on these explicit clears — same stance as the mldsa
    # module-global workspace buffers.)
    r0 = 0; r1 = 0; r2 = 0; r3 = 0; r4 = 0;
    s1 = 0; s2 = 0; s3 = 0; s4 = 0;
    pad0 = 0; pad1 = 0; pad2 = 0; pad3 = 0;
    t0 = 0; t1 = 0; t2 = 0; t3 = 0;
    memset(blockb, 0, 16);   # wipe this worker's lane (was `secret var`)
    return 0;
}

# ================================================================
# poly1305_verify — constant-time tag check
#   Returns 1 if the recomputed tag matches `tag`, 0 otherwise.
#   Compares via the stdlib constant-time `ct_eq_bytes` so a
#   forgery attempt learns nothing from comparison timing.
# ================================================================
fn poly1305_verify(key, msg, msg_len, tag): i64 {
    # Banked (3.9.6): was a function-scope static (quirk #1) raced under
    # concurrent ChaCha20-Poly1305. Plain `var` + per-lane wipe.
    var bk = cbank();
    var computed[1024];   var computedb = &computed + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    poly1305_mac(key, msg, msg_len, computedb);
    var ok = ct_eq_bytes(computedb, tag, 16);
    memset(computedb, 0, 16);
    return ok;
}

# ================================================================
# Streaming Poly1305 — init / update* / finalize (3.9.7)
# ================================================================
# The AEAD tag (RFC 8439 §2.8) is computed over
#   AAD || pad16(AAD) || ct || pad16(ct) || le64(aad_len) || le64(ct_len)
# which `_cp_tag` (src/chacha20poly1305.cyr) previously assembled into a
# per-call `fl_alloc`'d concat buffer — the last concurrent-path heap
# allocation on the AEAD record path. This streaming API absorbs those
# segments in place (init → update per segment → finalize) so the tag is
# produced WITHOUT materializing the concat, removing the fl_alloc.
#
# The one-shot `poly1305_mac` above is UNCHANGED (registers-resident,
# benched hot path); streaming uses a per-lane banked state buffer so the
# limb accumulator persists across update() calls. The arithmetic is the
# SAME poly1305-donna 26-bit-limb form — `_p1305_absorb` mirrors the
# one-shot's per-block body exactly (the streaming-equivalence test in
# poly1305.tcyr pins them together across arbitrary chunk splits).
#
# THREAD-SAFETY / quirk #9: the state holds key-derived secret scalars
# (r/s/h) plus buffered message bytes, so it is a PLAIN banked `var` +
# per-lane `memset` in finalize — NEVER `secret var` (a whole-array wipe
# would clobber a concurrent worker's lane — the 3.8.0 banking bug; see
# ADR 0004). `cbank()` auto-assigns the lane.
#
# State layout (per lane, 168 bytes): h0..h4 (i64 @0,8,16,24,32),
# r0..r4 (@40,48,56,64,72), s1..s4=5·r (@80,88,96,104),
# pad0..pad3 (@112,120,128,136), buf_len (@144), partial buf[16] (@152).
var _p1305_state[10752];   # 168 * SIGIL_CRYPTO_BANKS (64)

# Base of the calling thread's 168-byte state lane.
fn _p1305_lane(): i64 { return &_p1305_state + cbank() * 168; }

# Absorb one full 16-byte block at `mp` into the lane's accumulator.
# `hibit` is 1<<24 for a real 16-byte block, 0 for the padded final
# block (caller supplies the explicit 0x01). Loads h/r/s from `st`,
# runs the schoolbook multiply with 2^130≡5 wrap, stores h back —
# byte-identical to the one-shot loop body above.
fn _p1305_absorb(st, mp, hibit): i64 {
    var h0 = load64(st + 0);
    var h1 = load64(st + 8);
    var h2 = load64(st + 16);
    var h3 = load64(st + 24);
    var h4 = load64(st + 32);
    var r0 = load64(st + 40);
    var r1 = load64(st + 48);
    var r2 = load64(st + 56);
    var r3 = load64(st + 64);
    var r4 = load64(st + 72);
    var s1 = load64(st + 80);
    var s2 = load64(st + 88);
    var s3 = load64(st + 96);
    var s4 = load64(st + 104);

    h0 = h0 + (_p1305_u8to32(mp) & 0x3ffffff);
    h1 = h1 + ((_p1305_u8to32(mp + 3) >> 2) & 0x3ffffff);
    h2 = h2 + ((_p1305_u8to32(mp + 6) >> 4) & 0x3ffffff);
    h3 = h3 + ((_p1305_u8to32(mp + 9) >> 6) & 0x3ffffff);
    h4 = h4 + ((_p1305_u8to32(mp + 12) >> 8) | hibit);

    var d0 = h0 * r0 + h1 * s4 + h2 * s3 + h3 * s2 + h4 * s1;
    var d1 = h0 * r1 + h1 * r0 + h2 * s4 + h3 * s3 + h4 * s2;
    var d2 = h0 * r2 + h1 * r1 + h2 * r0 + h3 * s4 + h4 * s3;
    var d3 = h0 * r3 + h1 * r2 + h2 * r1 + h3 * r0 + h4 * s4;
    var d4 = h0 * r4 + h1 * r3 + h2 * r2 + h3 * r1 + h4 * r0;

    var c = d0 >> 26; h0 = d0 & 0x3ffffff;
    d1 = d1 + c; c = d1 >> 26; h1 = d1 & 0x3ffffff;
    d2 = d2 + c; c = d2 >> 26; h2 = d2 & 0x3ffffff;
    d3 = d3 + c; c = d3 >> 26; h3 = d3 & 0x3ffffff;
    d4 = d4 + c; c = d4 >> 26; h4 = d4 & 0x3ffffff;
    h0 = h0 + c * 5; c = h0 >> 26; h0 = h0 & 0x3ffffff;
    h1 = h1 + c;

    store64(st + 0, h0);
    store64(st + 8, h1);
    store64(st + 16, h2);
    store64(st + 24, h3);
    store64(st + 32, h4);
    return 0;
}

# poly1305_init — load+clamp r, precompute 5·r, split s (pad), zero the
# accumulator and partial buffer. `key` is the 32-byte one-time key.
fn poly1305_init(key): i64 {
    var st = _p1305_lane();
    var t0 = _p1305_u8to32(key);
    var t1 = _p1305_u8to32(key + 4);
    var t2 = _p1305_u8to32(key + 8);
    var t3 = _p1305_u8to32(key + 12);

    var r0 = t0 & 0x3ffffff;
    var r1 = ((t0 >> 26) | (t1 << 6)) & 0x3ffff03;
    var r2 = ((t1 >> 20) | (t2 << 12)) & 0x3ffc0ff;
    var r3 = ((t2 >> 14) | (t3 << 18)) & 0x3f03fff;
    var r4 = (t3 >> 8) & 0x00fffff;
    store64(st + 40, r0); store64(st + 48, r1); store64(st + 56, r2);
    store64(st + 64, r3); store64(st + 72, r4);
    store64(st + 80, r1 * 5); store64(st + 88, r2 * 5);
    store64(st + 96, r3 * 5); store64(st + 104, r4 * 5);

    store64(st + 112, _p1305_u8to32(key + 16));
    store64(st + 120, _p1305_u8to32(key + 20));
    store64(st + 128, _p1305_u8to32(key + 24));
    store64(st + 136, _p1305_u8to32(key + 28));

    store64(st + 0, 0); store64(st + 8, 0); store64(st + 16, 0);
    store64(st + 24, 0); store64(st + 32, 0);
    store64(st + 144, 0);   # buf_len
    return 0;
}

# poly1305_update — absorb `len` bytes at `ptr`. Buffers any sub-16-byte
# remainder across calls (so segment boundaries need not be 16-aligned);
# the 0x01 partial-pad is applied only at finalize, never at a boundary.
fn poly1305_update(ptr, len): i64 {
    if (len <= 0) { return 0; }
    var st = _p1305_lane();
    var buf_len = load64(st + 144);
    var buf = st + 152;
    var pos = 0;

    # Top up a pending partial block first; absorb it once full.
    if (buf_len > 0) {
        while (buf_len < 16 && pos < len) {
            store8(buf + buf_len, load8(ptr + pos) & 0xFF);
            buf_len = buf_len + 1;
            pos = pos + 1;
        }
        if (buf_len == 16) {
            _p1305_absorb(st, buf, 1 << 24);
            buf_len = 0;
        }
    }

    # Absorb full blocks straight from the caller's buffer.
    while (len - pos >= 16) {
        _p1305_absorb(st, ptr + pos, 1 << 24);
        pos = pos + 16;
    }

    # Stash the trailing remainder for the next update / finalize.
    while (pos < len) {
        store8(buf + buf_len, load8(ptr + pos) & 0xFF);
        buf_len = buf_len + 1;
        pos = pos + 1;
    }

    store64(st + 144, buf_len);
    return 0;
}

# poly1305_finalize — pad+absorb any buffered remainder, then freeze the
# accumulator (constant-time, no branch on the secret h) and add s,
# writing the 16-byte tag to `out`. Scrubs the calling lane (secret r/s/h
# + buffered bytes) before return — per-lane only (quirk #9).
fn poly1305_finalize(out): i64 {
    var st = _p1305_lane();
    var buf_len = load64(st + 144);
    var buf = st + 152;
    if (buf_len > 0) {
        store8(buf + buf_len, 1);            # explicit high bit for partial
        var i = buf_len + 1;
        while (i < 16) { store8(buf + i, 0); i = i + 1; }
        _p1305_absorb(st, buf, 0);
    }

    var h0 = load64(st + 0);
    var h1 = load64(st + 8);
    var h2 = load64(st + 16);
    var h3 = load64(st + 24);
    var h4 = load64(st + 32);

    # ---- Fully carry h.
    var c = h1 >> 26; h1 = h1 & 0x3ffffff;
    h2 = h2 + c; c = h2 >> 26; h2 = h2 & 0x3ffffff;
    h3 = h3 + c; c = h3 >> 26; h3 = h3 & 0x3ffffff;
    h4 = h4 + c; c = h4 >> 26; h4 = h4 & 0x3ffffff;
    h0 = h0 + c * 5; c = h0 >> 26; h0 = h0 & 0x3ffffff;
    h1 = h1 + c;

    # ---- g = h + 5 (minus 2^130 in the top limb); CT-select h vs g.
    var g0 = h0 + 5; c = g0 >> 26; g0 = g0 & 0x3ffffff;
    var g1 = h1 + c; c = g1 >> 26; g1 = g1 & 0x3ffffff;
    var g2 = h2 + c; c = g2 >> 26; g2 = g2 & 0x3ffffff;
    var g3 = h3 + c; c = g3 >> 26; g3 = g3 & 0x3ffffff;
    var g4 = h4 + c - (1 << 26);

    var sign = (g4 >> 63) & 1;
    var mask_g = sign - 1;
    var mask_h = 0 - sign;
    h0 = (h0 & mask_h) | (g0 & mask_g);
    h1 = (h1 & mask_h) | (g1 & mask_g);
    h2 = (h2 & mask_h) | (g2 & mask_g);
    h3 = (h3 & mask_h) | (g3 & mask_g);
    h4 = (h4 & mask_h) | (g4 & mask_g);

    # ---- Collapse 5×26-bit limbs into 4×32-bit words.
    h0 = (h0 | (h1 << 26)) & 0xffffffff;
    h1 = ((h1 >> 6) | (h2 << 20)) & 0xffffffff;
    h2 = ((h2 >> 12) | (h3 << 14)) & 0xffffffff;
    h3 = ((h3 >> 18) | (h4 << 8)) & 0xffffffff;

    # ---- tag = (h + s) mod 2^128, little-endian.
    var pad0 = load64(st + 112);
    var pad1 = load64(st + 120);
    var pad2 = load64(st + 128);
    var pad3 = load64(st + 136);
    var f = h0 + pad0;             h0 = f & 0xffffffff;
    f = h1 + pad1 + (f >> 32);     h1 = f & 0xffffffff;
    f = h2 + pad2 + (f >> 32);     h2 = f & 0xffffffff;
    f = h3 + pad3 + (f >> 32);     h3 = f & 0xffffffff;

    _p1305_u32to8(out,      h0);
    _p1305_u32to8(out + 4,  h1);
    _p1305_u32to8(out + 8,  h2);
    _p1305_u32to8(out + 12, h3);

    memset(st, 0, 168);   # scrub THIS lane's secret state (quirk #9)
    return 0;
}

# --- chacha20.cyr ---

# chacha20.cyr — ChaCha20 stream cipher (RFC 8439 §2.3 / §2.4)
#
# ChaCha20 is D. J. Bernstein's 256-bit stream cipher. It keys a
# 4x4 matrix of 32-bit words — 4 constant words ("expand 32-byte
# k"), 8 key words, a 32-bit block counter, and a 96-bit nonce —
# then applies 20 rounds (10 column/diagonal double-rounds) of the
# ARX quarter-round and adds the original state back to produce a
# 64-byte keystream block. Encryption XORs the keystream into the
# plaintext; decryption is the identical XOR.
#
# It is the cipher half of the ChaCha20-Poly1305 AEAD (RFC 8439
# §2.8) — TLS 1.3's `TLS_CHACHA20_POLY1305_SHA256` suite — and the
# source of the Poly1305 one-time key (block at counter 0).
#
# THREAD-SAFETY: the `chacha20_block` / `chacha20_xor` working state
# lives in function-scope `var` arrays (Cyrius static globals, quirk #1).
# As of 3.8.0 these are **per-worker banked** (`cbank()` lane slices, the
# v3.6 `src/crypto_scratch.cyr` mechanism), so concurrent callers operate
# on disjoint lanes and cannot race — `st` / `ws` / `ks` are each widened
# to `SIGIL_CRYPTO_BANKS` lanes and indexed by `cbank()`. Serial callers
# use bank 0. (Defensive: no in-tree concurrent caller exists yet.)
#
# Citation: RFC 8439 §2.1 (quarter round), §2.3 (block function),
# §2.3.2 / §2.4.2 (test vectors). See docs/sources.md.

# ================================================================
# Little-endian 4-byte codec
# ================================================================

fn _chacha_u8to32le(p): i64 {
    return (load8(p) & 0xFF)
         | ((load8(p + 1) & 0xFF) << 8)
         | ((load8(p + 2) & 0xFF) << 16)
         | ((load8(p + 3) & 0xFF) << 24);
}

fn _chacha_u32to8le(p, v): i64 {
    store8(p,     v & 0xFF);
    store8(p + 1, (v >> 8) & 0xFF);
    store8(p + 2, (v >> 16) & 0xFF);
    store8(p + 3, (v >> 24) & 0xFF);
    return 0;
}

# 32-bit left rotation. v is held in [0, 2^32); mask after the
# shift-or so the result stays a clean 32-bit word.
fn _chacha_rotl32(v, n): i64 {
    return ((v << n) | (v >> (32 - n))) & 0xffffffff;
}

# ================================================================
# Quarter round (RFC 8439 §2.1) over four words of the working
# state array `ws` (16 i64 slots, one 32-bit word each).
# ================================================================
fn _chacha_qr(ws, a, b, c, d): i64 {
    var va = load64(ws + a * 8);
    var vb = load64(ws + b * 8);
    var vc = load64(ws + c * 8);
    var vd = load64(ws + d * 8);

    va = (va + vb) & 0xffffffff; vd = _chacha_rotl32(vd ^ va, 16);
    vc = (vc + vd) & 0xffffffff; vb = _chacha_rotl32(vb ^ vc, 12);
    va = (va + vb) & 0xffffffff; vd = _chacha_rotl32(vd ^ va, 8);
    vc = (vc + vd) & 0xffffffff; vb = _chacha_rotl32(vb ^ vc, 7);

    store64(ws + a * 8, va);
    store64(ws + b * 8, vb);
    store64(ws + c * 8, vc);
    store64(ws + d * 8, vd);
    return 0;
}

# ================================================================
# chacha20_block — one 64-byte keystream block
#   key      — 32 bytes
#   nonce    — 12 bytes (96-bit)
#   counter  — 32-bit block counter
#   out      — 64-byte keystream buffer (caller-allocated)
# Returns 0.
# ================================================================
fn chacha20_block(key, nonce, counter, out): i64 {
    # Per-worker bank (3.8.0): st/ws are static function-scope globals
    # (quirk #1), so concurrent callers would race; each operates on its
    # own `cbank()` lane. Bank 0 on the serial path.
    var bk = cbank();
    var st[8192];   # 16 words × SIGIL_CRYPTO_BANKS lanes (per-lane zeroized below)
    var stb = &st + bk * 128;
    var ws[8192];   # 16 words × SIGIL_CRYPTO_BANKS lanes
    var wsb = &ws + bk * 128;

    # Constants — little-endian words of "expand 32-byte k".
    store64(stb + 0,  0x61707865);
    store64(stb + 8,  0x3320646e);
    store64(stb + 16, 0x79622d32);
    store64(stb + 24, 0x6b206574);

    # Key words 4..11.
    var i = 0;
    while (i < 8) {
        store64(stb + (4 + i) * 8, _chacha_u8to32le(key + i * 4));
        i = i + 1;
    }

    # Block counter — word 12.
    store64(stb + 12 * 8, counter & 0xffffffff);

    # Nonce words 13..15.
    i = 0;
    while (i < 3) {
        store64(stb + (13 + i) * 8, _chacha_u8to32le(nonce + i * 4));
        i = i + 1;
    }

    # Working copy.
    memcpy(wsb, stb, 128);

    # 20 rounds = 10 column+diagonal double-rounds.
    var r = 0;
    while (r < 10) {
        _chacha_qr(wsb, 0, 4, 8, 12);
        _chacha_qr(wsb, 1, 5, 9, 13);
        _chacha_qr(wsb, 2, 6, 10, 14);
        _chacha_qr(wsb, 3, 7, 11, 15);
        _chacha_qr(wsb, 0, 5, 10, 15);
        _chacha_qr(wsb, 1, 6, 11, 12);
        _chacha_qr(wsb, 2, 7, 8, 13);
        _chacha_qr(wsb, 3, 4, 9, 14);
        r = r + 1;
    }

    # Add the original state and serialize little-endian.
    i = 0;
    while (i < 16) {
        var v = (load64(wsb + i * 8) + load64(stb + i * 8)) & 0xffffffff;
        _chacha_u32to8le(out + i * 4, v);
        i = i + 1;
    }
    # Zeroize only THIS worker's lane. A `secret var` would zero the whole
    # array (all banks) on scope exit and clobber a concurrent worker's
    # in-flight lane — so we use plain `var` + this explicit per-lane wipe.
    memset(stb, 0, 128);
    memset(wsb, 0, 128);
    return 0;
}

# ================================================================
# chacha20_xor — encrypt/decrypt `in_len` bytes
#   Generates keystream from `counter` upward, one 64-byte block at
#   a time, XORing into the input. Decryption calls this with the
#   ciphertext (XOR is involutive). The counter increments per
#   block mod 2^32.
#   key/nonce/counter as chacha20_block; input/out are in_len bytes.
# Returns 0.
#
# USAGE LIMIT: the 32-bit counter wraps after 2^32 blocks, so a
# single (key, nonce) pair must encrypt at most 2^32 * 64 B = 256
# GiB (RFC 8439 §2.4). Beyond that the keystream repeats. Far above
# any sigil payload, but a hard cap the caller must respect — never
# reuse a (key, nonce) across messages totalling more than that.
# ================================================================
fn chacha20_xor(key, nonce, counter, input, in_len, out): i64 {
    var bk = cbank();
    var ks[4096];   # 64-byte keystream block × SIGIL_CRYPTO_BANKS lanes
    var ksb = &ks + bk * 64;
    var done = 0;
    var ctr = counter & 0xffffffff;
    while (done < in_len) {
        chacha20_block(key, nonce, ctr, ksb);
        var n = in_len - done;
        if (n > 64) { n = 64; }
        var j = 0;
        while (j < n) {
            store8(out + done + j,
                   (load8(input + done + j) ^ load8(ksb + j)) & 0xFF);
            j = j + 1;
        }
        ctr = (ctr + 1) & 0xffffffff;
        done = done + 64;
    }
    memset(ksb, 0, 64);   # wipe only this worker's keystream lane
    return 0;
}

# --- chacha20poly1305.cyr ---

# chacha20poly1305.cyr — ChaCha20-Poly1305 AEAD (RFC 8439 §2.8)
#
# The IETF AEAD construction: ChaCha20 (src/chacha20.cyr) for
# confidentiality, Poly1305 (src/poly1305.cyr) for authenticity.
# This is TLS 1.3's `TLS_CHACHA20_POLY1305_SHA256` suite and the
# pure-Cyrius alternative to AES-256-GCM (src/aes_gcm.cyr) for the
# native-TLS arc.
#
# Construction (RFC 8439 §2.8):
#   1. one-time Poly1305 key = first 32 bytes of the ChaCha20
#      keystream block at counter 0 (key, nonce).
#   2. ciphertext = ChaCha20(key, nonce, counter=1, plaintext).
#   3. mac_data = AAD || pad16(AAD) || ct || pad16(ct)
#                 || le64(len AAD) || le64(len ct).
#   4. tag = Poly1305(one-time key, mac_data).
# Decryption recomputes and verifies the tag in constant time
# BEFORE releasing plaintext (AEAD contract — matches aes_gcm).
#
# The per-message Poly1305 key is fresh per (key, nonce), so the
# one-time-key contract of src/poly1305.cyr is satisfied by
# construction — the caller must still never reuse a nonce under
# one key (standard AEAD requirement).
#
# Citation: RFC 8439 §2.8 (AEAD), §2.8.2 (test vector). See
# docs/sources.md.

# Bytes of zero-padding needed to round `n` up to a 16-byte
# multiple (0 when already aligned).
fn _cp_pad16len(n): i64 {
    var rem = n % 16;
    if (rem == 0) { return 0; }
    return 16 - rem;
}

# Store `v` as 8 little-endian bytes at p (mac-data length field).
fn _cp_store_le64(p, v): i64 {
    var i = 0;
    while (i < 8) {
        store8(p + i, (v >> (i * 8)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# Derive the one-time Poly1305 key: first 32 bytes of the ChaCha20
# keystream block at counter 0.
fn _cp_keygen(key, nonce, otk_out): i64 {
    # Banked (3.9.6): function-scope static (quirk #1) raced under
    # concurrent ChaCha20-Poly1305. Plain `var` + per-lane wipe.
    var bk = cbank();
    var block[4096];   var blockb = &block + bk * 64;   # 64 * SIGIL_CRYPTO_BANKS
    chacha20_block(key, nonce, 0, blockb);
    memcpy(otk_out, blockb, 32);
    memset(blockb, 0, 64);
    return 0;
}

# Compute the Poly1305 tag over the RFC 8439 §2.8 mac_data layout.
# 3.9.7: streams the segments — AAD || pad16(AAD) || ct || pad16(ct)
# || le64(aad_len) || le64(ct_len) — through the streaming Poly1305 API
# (src/poly1305.cyr) IN PLACE, so the tag is computed WITHOUT the
# per-call `fl_alloc`'d concat buffer that used to assemble mac_data
# (the last concurrent-path heap allocation on the AEAD record path).
# The two pad16 regions feed zero bytes; the trailing 16-byte length
# block is one full block, so mac_data is always a multiple of 16 (no
# partial). The zero-pad + length scratch hold only PUBLIC data (banked
# per lane for race-freedom; no secret, so no wipe).
fn _cp_tag(otk, aad, aad_len, ct, ct_len, tag_out): i64 {
    var aad_pad = _cp_pad16len(aad_len);
    var ct_pad = _cp_pad16len(ct_len);

    var bk = cbank();
    var zero16[1024];   var zb = &zero16 + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS (zero pad source)
    var lenblk[1024];   var lb = &lenblk + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS (public lengths)
    memset(zb, 0, 16);
    _cp_store_le64(lb, aad_len);
    _cp_store_le64(lb + 8, ct_len);

    poly1305_init(otk);
    poly1305_update(aad, aad_len);
    poly1305_update(zb, aad_pad);
    poly1305_update(ct, ct_len);
    poly1305_update(zb, ct_pad);
    poly1305_update(lb, 16);
    poly1305_finalize(tag_out);
    return 0;
}

# ================================================================
# chacha20poly1305_encrypt
#   key      — 32 bytes
#   nonce    — 12 bytes (96-bit)
#   aad      — aad_len bytes of additional authenticated data
#   pt       — plaintext, pt_len bytes
#   ct_out   — ciphertext, pt_len bytes (caller-allocated)
#   tag_out  — 16-byte tag (caller-allocated)
# Returns SIGIL_ERR_NONE, or SIGIL_ERR_INVALID_INPUT on a negative length.
# ================================================================
fn chacha20poly1305_encrypt(key, nonce, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    if (aad_len < 0) { return SIGIL_ERR_INVALID_INPUT; }
    if (pt_len < 0) { return SIGIL_ERR_INVALID_INPUT; }

    # Banked (3.9.6): function-scope static (quirk #1) raced under
    # concurrent ChaCha20-Poly1305. Plain `var` + per-lane wipe.
    var bk = cbank();
    var otk[2048];   var otkb = &otk + bk * 32;   # 32 * SIGIL_CRYPTO_BANKS
    _cp_keygen(key, nonce, otkb);

    chacha20_xor(key, nonce, 1, pt, pt_len, ct_out);
    _cp_tag(otkb, aad, aad_len, ct_out, pt_len, tag_out);
    memset(otkb, 0, 32);
    return SIGIL_ERR_NONE;
}

# ================================================================
# chacha20poly1305_decrypt
#   key/nonce/aad as above; ct/ct_len the received ciphertext;
#   tag the received 16-byte tag; pt_out the recovered plaintext
#   (caller-allocated, ct_len bytes).
# Returns:
#   SIGIL_ERR_NONE on success (pt_out populated).
#   SIGIL_ERR_INTEGRITY_MISMATCH on tag mismatch (pt_out zeroed, plaintext
#       NOT released — AEAD contract).
#   SIGIL_ERR_INVALID_INPUT on a negative length.
# ================================================================
fn chacha20poly1305_decrypt(key, nonce, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    if (aad_len < 0) { return SIGIL_ERR_INVALID_INPUT; }
    if (ct_len < 0) { return SIGIL_ERR_INVALID_INPUT; }

    # Banked (3.9.6): function-scope statics (quirk #1) raced under
    # concurrent ChaCha20-Poly1305. Plain `var` + per-lane wipe.
    var bk = cbank();
    var otk[2048];      var otkb      = &otk      + bk * 32;   # 32 * SIGIL_CRYPTO_BANKS
    var expected[1024]; var expectedb = &expected + bk * 16;   # 16 * SIGIL_CRYPTO_BANKS
    _cp_keygen(key, nonce, otkb);

    # Verify the tag over the received ciphertext BEFORE deriving
    # plaintext. Constant-time compare via the stdlib ct_eq_bytes.
    _cp_tag(otkb, aad, aad_len, ct, ct_len, expectedb);
    if (ct_eq_bytes(expectedb, tag, 16) == 0) {
        memset(pt_out, 0, ct_len);
        memset(otkb, 0, 32);
        memset(expectedb, 0, 16);
        return SIGIL_ERR_INTEGRITY_MISMATCH;
    }

    chacha20_xor(key, nonce, 1, ct, ct_len, pt_out);
    memset(otkb, 0, 32);
    memset(expectedb, 0, 16);
    return SIGIL_ERR_NONE;
}
