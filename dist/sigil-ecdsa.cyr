# --- crypto_scratch.cyr ---

# crypto_scratch.cyr — per-thread working-buffer bank selection for
# the parallel batch-verify path (sigil 3.6).
#
# WHY THIS EXISTS
# ---------------
# A `var X[N]` declared inside a function in cyrius is a STATIC
# function-scope global, not a per-call stack array (CLAUDE.md quirk
# #1; tests/tcyr/var_array_semantics.tcyr — re-confirmed under cycc
# 6.0.52 during the 3.6 open). The transient working arrays inside
# the crypto primitives (SHA-256/512 message schedules, the Ed25519
# field/group temporaries) are therefore shared across threads, which
# is exactly why `sv_verify_batch` had to serialise every artifact
# behind `_sigil_batch_mutex` (see the threading-safety contract in
# src/verify.cyr).
#
# THE 3.6 MECHANISM — per-thread BANKS
# ------------------------------------
# Each racing `var X[N]` is widened to `var X[N * SIGIL_CRYPTO_BANKS]`
# and the function operates on its own lane `&X + cbank()*N`. `cbank()`
# returns the calling thread's bank index, read from a thread-local
# slot (cyrius 6.0.52 `lib/thread_local.cyr`):
#   - the main thread / serial path uses bank 0 (a fresh TLS slot
#     reads 0);
#   - batch workers are assigned distinct banks 1..workers at spawn
#     (`crypto_bank_set`).
# Distinct concurrent banks ⇒ disjoint memory ⇒ no data race — with
# NO signature changes, NO caller changes, and NO cross-function
# offset map. Each function still owns its own array; a worker simply
# writes a different lane of it. Collisions are impossible by
# construction (every lane is owned by exactly one live thread).
#
# This is deliberately cheaper and far lower-risk than threading a
# caller-provided scratch pointer through every `fp_mul` / `ge_add` /
# `sha256_transform` signature (the shape the v3.6 roadmap sketched
# before cyrius shipped thread-local storage): no signature churn, and
# the bank arithmetic is local and self-evidently collision-free.
#
# TLS LIFECYCLE
# -------------
# Worker threads spawned via `thread_create` get a zeroed 4 KB TLS
# block installed automatically by CLONE_SETTLS (cyrius lib/thread.cyr),
# so they need no init — their slot reads 0 until `crypto_bank_set`
# overwrites it. The MAIN thread has no TLS block until one is
# installed, so `cbank()` self-installs one on first use (and the
# batch path pre-warms it on the main thread before fan-out). The
# `& (SIGIL_CRYPTO_BANKS-1)` mask makes an out-of-range slot value
# impossible to turn into an out-of-bounds lane — defence in depth.
#
# Requires: lib/thread_local.cyr (cyrius >= 6.0.52). Must be included
# before any banked crypto module (src/sha_ni.cyr onward).

# Number of concurrent crypto-scratch lanes. MUST be a power of two
# (the `cbank()` mask relies on it). Bank 0 is reserved for the
# main/serial path; banks 1..SIGIL_CRYPTO_BANKS-1 are handed to
# concurrent worker threads. 64 covers a 63-worker TLS termination
# pool (one worker per core on any realistic host) plus the main
# thread; widening only costs banked-array static scratch (each
# banked `var X[N]` is sized N*SIGIL_CRYPTO_BANKS bytes).
#
# 3.9.6 — concurrent-TLS-handshake fix: bumped 8 -> 64 and made
# `cbank()` AUTO-ASSIGN a private lane per thread (see below). Before
# 3.9.6 the only caller that ever set a non-zero bank was the
# batch-verify path (`crypto_bank_set`); every other concurrent caller
# — notably cyrius `tls_native` / sandhi TLS worker threads — collided
# on bank 0, racing the banked scratch (the concurrent-TLS-handshake
# crash). Auto-assignment removes the need for any per-worker
# cooperation: a worker's first `cbank()` claims the next free lane.
# See docs/development/issues/2026-06-28-concurrent-tls-handshake-
# global-scratch-race.md and ADR 0007.
var SIGIL_CRYPTO_BANKS = 64;
var _SIGIL_CBANK_MASK = 63;     # SIGIL_CRYPTO_BANKS - 1
# thread-local slot (cyrius thread_local_get/set namespace). Holds (bank+1):
# 0 = unassigned, v = bank (v-1).
#
# 3.9.9 (2026-07-01): MOVED 0 -> 8. cyrius's thread_local slot namespace is a
# small shared integer space (16 slots, no allocator), and slot 0 COLLIDED with
# patra's SQL-parse scratch (patra owns slots 0-4: TLS_PR/TLS_TOKS/TLS_NTOKS +
# TLS_SLAB_STACK=3/TLS_SLAB_TOP=4). In a server that links BOTH sigil + patra
# (e.g. a TLS termination pool serving a patra-backed API — SecureYeoman's
# yeo-cy-test), a patra query clobbered sigil's pinned bank in slot 0, so a later
# cbank() read patra's scratch value as the bank and indexed the WRONG lane of
# the process-global banked crypto buffers — corrupting an in-flight handshake's
# key schedule -> the client saw RECORD_LAYER_FAILURE (reproduced as "every 4th
# handshake fails" under a specific worker layout). Slot 8 is clear of patra
# (0-4) + the common consumer high slots (15). NOTE: the underlying fix is a
# slot ALLOCATOR in cyrius thread_local.cyr (filed) — until then, leaf crypto
# owns slot 8 by convention. See docs/development/issues/2026-06-28-concurrent-
# tls-handshake-global-scratch-race.md and cyrius issue multiworker-tls-record-
# layer-failure.
var _SIGIL_CBANK_SLOT = 8;
var _crypto_tls_inited = 0;
var _crypto_next_bank = 0;      # atomic counter; auto-assigned worker
                                # threads draw lanes 1..BANKS-1 from it.

# Install a TLS block on the calling (main) thread and claim bank 0
# for it so `cbank()` is well-defined on the serial path. Idempotent
# (a CAS guard makes concurrent first-callers init exactly once, so a
# worker that races here cannot double-`alloc` the TLS block — quirk
# #7: alloc is not thread-safe).
#
# MULTI-THREADED CONSUMER CONTRACT: a server that spawns crypto worker
# threads (e.g. a TLS termination pool) should call this once on the
# MAIN thread at startup, before spawning workers — it installs main's
# TLS block (main has none until installed; workers get a zeroed block
# via CLONE_SETTLS) and marks the subsystem inited so each worker's
# first `cbank()` only reads/auto-assigns and never races init. In
# practice any sigil crypto call on the main thread (e.g. parsing the
# server cert/key) triggers this via the lazy backstop in `cbank()`
# before workers start; the explicit call is belt-and-suspenders.
# Returns 0.
fn crypto_tls_main_init(): i64 {
    # CAS 0 -> 1: exactly one thread wins and runs the init.
    if (atomic_cas(&_crypto_tls_inited, 0, 1) == 0) { return 0; }
    thread_local_init();
    # Claim bank 0 for this (main) thread: slot = bank0 encoded = 1.
    thread_local_set(_SIGIL_CBANK_SLOT, 1);
    return 0;
}

# Explicitly assign the calling thread a bank index (legacy / batch
# path). Bank must be in 0 .. SIGIL_CRYPTO_BANKS-1. Stored as (bank+1)
# so a fresh (unassigned) slot reads 0. Most callers no longer need
# this — `cbank()` auto-assigns — but the batch-verify path keeps using
# it for deterministic lane fan-out. Returns 0.
fn crypto_bank_set(bank): i64 {
    thread_local_set(_SIGIL_CBANK_SLOT, bank + 1);
    return 0;
}

# Bank (lane) index for the calling thread. Bank 0 on the main/serial
# path; a distinct 1..BANKS-1 lane on each concurrent worker. On a
# thread whose slot is still unassigned (a fresh worker that never
# called crypto_bank_set), the FIRST call atomically claims the next
# lane from `_crypto_next_bank` (cycled into 1..BANKS-1 so bank 0 stays
# the exclusive main lane) and pins it in the thread-local slot for the
# life of the thread. This is what makes concurrent callers (TLS
# handshake workers) race-free with zero per-worker cooperation. The
# mask guarantees the result is always a valid lane index (defence in
# depth).
fn cbank(): i64 {
    if (_crypto_tls_inited == 0) { crypto_tls_main_init(); }
    var raw = thread_local_get(_SIGIL_CBANK_SLOT);
    if (raw == 0) {
        # Unassigned thread: claim the next lane. atomic_fetch_add
        # returns the prior counter value (0,1,2,...); map it onto
        # 1..BANKS-1 so we never alias the main thread's bank 0.
        var n = atomic_fetch_add(&_crypto_next_bank, 1);
        var bank = (n % (SIGIL_CRYPTO_BANKS - 1)) + 1;
        thread_local_set(_SIGIL_CBANK_SLOT, bank + 1);
        return bank & _SIGIL_CBANK_MASK;
    }
    return (raw - 1) & _SIGIL_CBANK_MASK;
}

# --- sha_ni.cyr ---

# sha_ni.cyr — SHA-NI hardware-acceleration dispatch.
#
# Include-guard marker: single-file consumers pull this in via the
# `#ifndef`-guarded `include "src/sha_ni.cyr"` in sha256.cyr / aes_gcm.cyr /
# lib.cyr, but the dist bundle (dist/sigil.cyr) already inlines this module —
# so the bundle's redundant include must NOT re-fire (the file is absent in the
# fold, and cyrius hard-errors on a missing include since v6.1.35). This marker
# makes those guarded includes self-skip once this module is present.
#define _SIGIL_SHA_NI_INCLUDED
#
# Lays the CPUID-probe + dispatch infrastructure for the Intel SHA
# extensions (SHA256RNDS2 / SHA256MSG1 / SHA256MSG2) and ships a
# byte-encoded single-block SHA-256 compress that `sha256_transform`
# (in src/sha256.cyr) routes to when `sha_ni_available()` returns 1.
#
# History:
#   2.9.2 — probe live, compress was a -1 stub.
#   2.9.3 — compress shipped; cross-path tested against the FIPS
#           180-4 software path on every input the test suite
#           exercises (empty, "abc", 56-byte two-block vector,
#           1KB, 64KB).
#
# Design and sourcing notes live in
# `docs/development/issues/archive/2026-04-25-sha-ni-compress-design.md`.
# The compress sequence below is byte-for-byte derived from the
# Linux kernel's arch/x86/crypto/sha256_ni_asm.S (Intel
# Corporation, dual BSD/GPLv2 — Sigil is GPL-3.0 so the GPL leg
# applies). State-pack/unpack at the function boundaries adapts
# the kernel's 4-dword digest layout to sigil's 8-byte-per-h_i
# context layout (see design doc §"State-layout impedance").
#
# Detection reference (Intel SDM Vol 2A §3.2):
#   CPUID leaf 7, sub-leaf 0 → EBX bit 29 = SHA extensions
#
# SHA-NI opcode reference (Intel SDM Vol 2A §3.2, §5):
#   SHA256RNDS2 xmm1, xmm2/m128, <XMM0>     0F 38 CB /r
#       Two SHA-256 rounds. K+W in implicit XMM0.
#       xmm1=CDGH input; xmm2=ABEF input; xmm1=new ABEF output.
#   SHA256MSG1  xmm1, xmm2/m128             0F 38 CC /r
#       xmm1 = xmm1 + sigma0(window from xmm1[1..3] || xmm2[0]).
#   SHA256MSG2  xmm1, xmm2/m128             0F 38 CD /r
#       xmm1 = xmm1 + sigma1(window built from xmm1 + xmm2).

# _sha_ni_cache: 2 = uncached, 0 = unavailable, 1 = available.
# Same sentinel discipline as _aes_ni_cache; one CPUID probe
# per process. The "available" gate requires BOTH the CPUID bit
# AND the FIPS 180-4 "abc" self-test passing. The parameter loads
# inside `_sha_ni_compress_one` now use the prologue-drift-proof
# `param_load` pseudo (3.7.8), so the primary SIGILL re-break class
# is fixed at the source; the self-test stays as defense-in-depth
# against any future wrong-output asm regression.
var _sha_ni_cache = 2;
var _sha_ni_probe_out = 0;      # 8-byte scratch for the probe's *out param
var _sha_ni_probe_lock = 0;     # CAS guard: serializes the one-time self-test (3.9.6)

# Self-test scratch — module-level so the 144-byte ctx and the
# expected-digest slots live in BSS rather than on the stack. ctx
# is touched by `_sha_ni_compress_one` via `movdqu` loads/stores
# only (no alignment requirement on ctx itself), but keeping the
# buffer at module scope avoids per-call zeroization cost in the
# happy path.
var _sha_ni_st_ctx[144];

# Runtime SHA-NI capability gate. Returns 1 if the CPU advertises the
# SHA extensions (CPUID leaf 7 EBX bit 29) AND the hardware compress
# reproduces the FIPS 180-4 "abc" digest; 0 otherwise. Result is
# cached after the first probe (one CPUID + self-test per process).
fn sha_ni_available(): i64 {
    if (_sha_ni_cache != 2) { return _sha_ni_cache; }
    # First-probe serialization (3.9.6): the self-test drives the
    # module-global `_sha_ni_st_ctx` scratch; CAS so exactly one thread
    # runs it and the rest spin for the published result (x86-only path,
    # x86-TSO visibility). Matches `aes_ni_available`.
    if (atomic_cas(&_sha_ni_probe_lock, 0, 1) == 0) {
        while (_sha_ni_cache == 2) { }
        return _sha_ni_cache;
    }
    if (_sha_ni_probe_out == 0) { _sha_ni_probe_out = alloc(8); }
    store64(_sha_ni_probe_out, 0);
    _sha_ni_cpuid_probe(_sha_ni_probe_out);
    var ebx = load64(_sha_ni_probe_out);
    # EBX bit 29 = SHA (Intel SDM Vol 2A §3.2 CPUID leaf 7 sub-leaf 0).
    if ((ebx & (1 << 29)) == 0) {
        _sha_ni_cache = 0;
        # Release the one-shot latch AFTER publishing the cache, so a
        # later re-probe (cache reset to the `2` sentinel — tests/benches
        # force a specific path that way) re-acquires the probe instead
        # of dead-spinning on a permanently-held lock (the 3.9.6 bench
        # hang). Production never resets the cache, so the self-test
        # still runs exactly once there and the concurrency guarantee
        # (one thread probes, the rest spin until publish) is unchanged.
        _sha_ni_probe_lock = 0;
        return 0;
    }
    # Defense-in-depth: confirm the NI compress produces the FIPS
    # 180-4 §B.1 single-block "abc" digest before going live. The
    # `[rbp-N]` parameter-load coupling that caused the original
    # SIGILL re-break is now removed (param_load, 3.7.8); this self-
    # test remains to downgrade to software on any *wrong-output* asm
    # regression the compiler change could still introduce. See
    # docs/development/issues/2026-05-10-cyrius-510-asm-stack-frame-
    # drift-breaks-ni-paths.md and the 2026-06-09 re-break issue.
    if (_sha_ni_self_test() == 0) {
        _sha_ni_cache = 1;
    } else {
        _sha_ni_cache = 0;
    }
    _sha_ni_probe_lock = 0;   # release the one-shot latch (see note above)
    return _sha_ni_cache;
}

# _sha_ni_cpuid_probe — write CPUID leaf 7 sub-leaf 0 EBX to *out.
# Caller-supplied pointer keeps the CPUID-clobbered registers'
# lifetime confined to the asm block; reload via load64 after.
fn _sha_ni_cpuid_probe(out): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Param out -> rdi via the prologue-drift-proof param_load
        # pseudo (cyrius 6.0.67+): the slot offset is resolved at emit
        # time, so it cannot read garbage if the prologue layout drifts.
        param_load(rdi, 0);            # out
        0x53;                          # push rbx (callee-saved; CPUID clobbers it)
        0xB8; 0x07; 0x00; 0x00; 0x00;  # mov eax, 7   (leaf 7)
        0x31; 0xC9;                    # xor ecx, ecx (sub-leaf 0)
        0x0F; 0xA2;                    # cpuid
        0x48; 0x89; 0x1F;              # mov [rdi], rbx  ; *out = ebx
        0x5B;                          # pop rbx
    }
    #endif
    return 0;
}

# ================================================================
# Read-only shared globals (lazy init on first transform).
#
#   _sha_ni_K          — 256 bytes: 64 packed dwords of the K constants
#   _sha_ni_bswap_src  — 16 bytes:  PSHUFFLE_BYTE_FLIP_MASK template
#                                   (memcpy'd into per-call buf+64)
#
# 3.3: the pre-3.3 design used a single module-global 80-byte
# `_sha_ni_buf` that held the packed-state in/out + ABEF/CDGH
# saves + bswap mask. That made the SHA-NI compress non-
# reentrant — concurrent batch-verify workers (3.3 dropped the
# serialising mutex) stomped each other's state every block.
#
# Splitting the bswap mask (read-only) out of the working area
# lets the working area become a per-call stack buffer.
# `_sha_ni_compress_one` keeps its 3-parameter signature (the
# safe cc5/cc6 prologue-spill shape).
#
# alloc() is 8-byte aligned but PSHUFB / PADDD with an m128
# operand both require the memory address to be 16-aligned or
# they raise #GP. Each buffer is over-allocated by 16 bytes and
# aligned via `_sha_ni_align16`.
# ================================================================

var _sha_ni_K = 0;
var _sha_ni_bswap_src = 0;

# _sha_ni_pack_k_word — write K[i] as 4 little-endian bytes at dst+0..3.
fn _sha_ni_pack_k_word(dst, k): i64 {
    store8(dst + 0, k & 0xFF);
    store8(dst + 1, (k >> 8) & 0xFF);
    store8(dst + 2, (k >> 16) & 0xFF);
    store8(dst + 3, (k >> 24) & 0xFF);
    return 0;
}

# _sha_ni_align16 — round addr up to a 16-byte boundary. The bump
# allocator is 8-byte aligned, but PSHUFB / PADDD with an m128
# operand both require the memory address to be 16-aligned or
# they raise #GP. Caller over-allocates by 16 bytes and aligns
# the returned base.
fn _sha_ni_align16(addr): i64 {
    var off = addr & 15;
    if (off == 0) { return addr; }
    return addr + (16 - off);
}

fn _sha_ni_init(): i64 {
    if (_sha_ni_K != 0) { return 0; }

    _sha_ni_bswap_src = _sha_ni_align16(alloc(16 + 16));
    _sha_ni_K         = _sha_ni_align16(alloc(256 + 16));

    # PSHUFFLE_BYTE_FLIP_MASK — reverses bytes within each 32-bit
    # dword. Matches the kernel constant
    # 0x0c0d0e0f08090a0b0405060700010203. Read-only after init;
    # memcpy'd into per-call bufs at the top of each transform.
    store8(_sha_ni_bswap_src + 0,  0x03); store8(_sha_ni_bswap_src + 1,  0x02);
    store8(_sha_ni_bswap_src + 2,  0x01); store8(_sha_ni_bswap_src + 3,  0x00);
    store8(_sha_ni_bswap_src + 4,  0x07); store8(_sha_ni_bswap_src + 5,  0x06);
    store8(_sha_ni_bswap_src + 6,  0x05); store8(_sha_ni_bswap_src + 7,  0x04);
    store8(_sha_ni_bswap_src + 8,  0x0B); store8(_sha_ni_bswap_src + 9,  0x0A);
    store8(_sha_ni_bswap_src + 10, 0x09); store8(_sha_ni_bswap_src + 11, 0x08);
    store8(_sha_ni_bswap_src + 12, 0x0F); store8(_sha_ni_bswap_src + 13, 0x0E);
    store8(_sha_ni_bswap_src + 14, 0x0D); store8(_sha_ni_bswap_src + 15, 0x0C);

    # K constants from FIPS 180-4 §4.2.2 — packed 64×4-byte LE dwords.
    # Embedded directly rather than read from sha256.cyr's _sha256_K
    # so this module has no init-order dependency on sha256.cyr.
    _sha_ni_pack_k_word(_sha_ni_K + 0,   0x428a2f98);
    _sha_ni_pack_k_word(_sha_ni_K + 4,   0x71374491);
    _sha_ni_pack_k_word(_sha_ni_K + 8,   0xb5c0fbcf);
    _sha_ni_pack_k_word(_sha_ni_K + 12,  0xe9b5dba5);
    _sha_ni_pack_k_word(_sha_ni_K + 16,  0x3956c25b);
    _sha_ni_pack_k_word(_sha_ni_K + 20,  0x59f111f1);
    _sha_ni_pack_k_word(_sha_ni_K + 24,  0x923f82a4);
    _sha_ni_pack_k_word(_sha_ni_K + 28,  0xab1c5ed5);
    _sha_ni_pack_k_word(_sha_ni_K + 32,  0xd807aa98);
    _sha_ni_pack_k_word(_sha_ni_K + 36,  0x12835b01);
    _sha_ni_pack_k_word(_sha_ni_K + 40,  0x243185be);
    _sha_ni_pack_k_word(_sha_ni_K + 44,  0x550c7dc3);
    _sha_ni_pack_k_word(_sha_ni_K + 48,  0x72be5d74);
    _sha_ni_pack_k_word(_sha_ni_K + 52,  0x80deb1fe);
    _sha_ni_pack_k_word(_sha_ni_K + 56,  0x9bdc06a7);
    _sha_ni_pack_k_word(_sha_ni_K + 60,  0xc19bf174);
    _sha_ni_pack_k_word(_sha_ni_K + 64,  0xe49b69c1);
    _sha_ni_pack_k_word(_sha_ni_K + 68,  0xefbe4786);
    _sha_ni_pack_k_word(_sha_ni_K + 72,  0x0fc19dc6);
    _sha_ni_pack_k_word(_sha_ni_K + 76,  0x240ca1cc);
    _sha_ni_pack_k_word(_sha_ni_K + 80,  0x2de92c6f);
    _sha_ni_pack_k_word(_sha_ni_K + 84,  0x4a7484aa);
    _sha_ni_pack_k_word(_sha_ni_K + 88,  0x5cb0a9dc);
    _sha_ni_pack_k_word(_sha_ni_K + 92,  0x76f988da);
    _sha_ni_pack_k_word(_sha_ni_K + 96,  0x983e5152);
    _sha_ni_pack_k_word(_sha_ni_K + 100, 0xa831c66d);
    _sha_ni_pack_k_word(_sha_ni_K + 104, 0xb00327c8);
    _sha_ni_pack_k_word(_sha_ni_K + 108, 0xbf597fc7);
    _sha_ni_pack_k_word(_sha_ni_K + 112, 0xc6e00bf3);
    _sha_ni_pack_k_word(_sha_ni_K + 116, 0xd5a79147);
    _sha_ni_pack_k_word(_sha_ni_K + 120, 0x06ca6351);
    _sha_ni_pack_k_word(_sha_ni_K + 124, 0x14292967);
    _sha_ni_pack_k_word(_sha_ni_K + 128, 0x27b70a85);
    _sha_ni_pack_k_word(_sha_ni_K + 132, 0x2e1b2138);
    _sha_ni_pack_k_word(_sha_ni_K + 136, 0x4d2c6dfc);
    _sha_ni_pack_k_word(_sha_ni_K + 140, 0x53380d13);
    _sha_ni_pack_k_word(_sha_ni_K + 144, 0x650a7354);
    _sha_ni_pack_k_word(_sha_ni_K + 148, 0x766a0abb);
    _sha_ni_pack_k_word(_sha_ni_K + 152, 0x81c2c92e);
    _sha_ni_pack_k_word(_sha_ni_K + 156, 0x92722c85);
    _sha_ni_pack_k_word(_sha_ni_K + 160, 0xa2bfe8a1);
    _sha_ni_pack_k_word(_sha_ni_K + 164, 0xa81a664b);
    _sha_ni_pack_k_word(_sha_ni_K + 168, 0xc24b8b70);
    _sha_ni_pack_k_word(_sha_ni_K + 172, 0xc76c51a3);
    _sha_ni_pack_k_word(_sha_ni_K + 176, 0xd192e819);
    _sha_ni_pack_k_word(_sha_ni_K + 180, 0xd6990624);
    _sha_ni_pack_k_word(_sha_ni_K + 184, 0xf40e3585);
    _sha_ni_pack_k_word(_sha_ni_K + 188, 0x106aa070);
    _sha_ni_pack_k_word(_sha_ni_K + 192, 0x19a4c116);
    _sha_ni_pack_k_word(_sha_ni_K + 196, 0x1e376c08);
    _sha_ni_pack_k_word(_sha_ni_K + 200, 0x2748774c);
    _sha_ni_pack_k_word(_sha_ni_K + 204, 0x34b0bcb5);
    _sha_ni_pack_k_word(_sha_ni_K + 208, 0x391c0cb3);
    _sha_ni_pack_k_word(_sha_ni_K + 212, 0x4ed8aa4a);
    _sha_ni_pack_k_word(_sha_ni_K + 216, 0x5b9cca4f);
    _sha_ni_pack_k_word(_sha_ni_K + 220, 0x682e6ff3);
    _sha_ni_pack_k_word(_sha_ni_K + 224, 0x748f82ee);
    _sha_ni_pack_k_word(_sha_ni_K + 228, 0x78a5636f);
    _sha_ni_pack_k_word(_sha_ni_K + 232, 0x84c87814);
    _sha_ni_pack_k_word(_sha_ni_K + 236, 0x8cc70208);
    _sha_ni_pack_k_word(_sha_ni_K + 240, 0x90befffa);
    _sha_ni_pack_k_word(_sha_ni_K + 244, 0xa4506ceb);
    _sha_ni_pack_k_word(_sha_ni_K + 248, 0xbef9a3f7);
    _sha_ni_pack_k_word(_sha_ni_K + 252, 0xc67178f2);
    return 0;
}

# ================================================================
# _sha_ni_compress_one — single-block SHA-NI compress.
#
# Parameters (loaded via the prologue-drift-proof `param_load`
# pseudo, cyrius 6.0.67+ — slots resolved at emit time):
#   idx 0  ctx     — 144-byte SHA-256 context (h0..h7 at +0,
#                     block buffer at +64)            -> rdi
#   idx 1  buf     — 80-byte per-call working area. Layout:
#                        +0..31  packed state in/out
#                        +32..47 ABEF_save
#                        +48..63 CDGH_save
#                        +64..79 PSHUFFLE_BYTE_FLIP_MASK  -> rsi
#   idx 2  kbuf    — 256-byte packed K table            -> rcx
#
# Pre-3.7.8 these were hand-emitted `mov r__, [rbp-N]` byte
# literals, which coupled to the cyrius prologue layout and
# SIGILL-re-broke when 6.1.20 shifted the param spill slots (see
# docs/development/issues/2026-06-09-cyrius-6120-rebreaks-ni-paths-
# sigill.md). `param_load` resolves each slot at emit time, so the
# loads track the prologue automatically.
#
# Register usage inside the asm block:
#   rdi = ctx, rsi = buf, rcx = kbuf, rdx = scalar tmp
#   xmm0 = MSG, xmm1 = STATE0 (ABEF), xmm2 = STATE1 (CDGH),
#   xmm3 = MSGTMP0, xmm4 = MSGTMP1, xmm5 = MSGTMP2, xmm6 = MSGTMP3,
#   xmm7 = MSGTMP4 (palignr scratch)
#
# All XMM registers are caller-saved in System V x86-64 — clobber
# is safe because the asm block is straight-line with no calls
# and Cyrius does not expect XMM state across the block.
# ================================================================
fn _sha_ni_compress_one(ctx, buf, kbuf): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # -- Param loads (prologue-drift-proof param_load, cyrius 6.0.67+) --
        #    The pseudo resolves each param's spill slot at emit time,
        #    so a future cyrius prologue change cannot shift these reads
        #    onto the wrong slot (the SIGILL re-break class, see header).
        param_load(rdi, 0);        # ctx
        param_load(rsi, 1);        # buf
        param_load(rcx, 2);        # kbuf

        # ── Pack ctx h0..h7 (8 sparse 64-bit slots, low 32 bits each)
        #    into scratch[0..31] (8 packed little-endian dwords).
        #    Each pair is `mov edx, [rdi+8i]` + `mov [rsi+4i], edx`.
        0x8B; 0x57; 0x00; 0x89; 0x56; 0x00;
        0x8B; 0x57; 0x08; 0x89; 0x56; 0x04;
        0x8B; 0x57; 0x10; 0x89; 0x56; 0x08;
        0x8B; 0x57; 0x18; 0x89; 0x56; 0x0C;
        0x8B; 0x57; 0x20; 0x89; 0x56; 0x10;
        0x8B; 0x57; 0x28; 0x89; 0x56; 0x14;
        0x8B; 0x57; 0x30; 0x89; 0x56; 0x18;
        0x8B; 0x57; 0x38; 0x89; 0x56; 0x1C;

        # ── State setup: load packed ABCD/EFGH, permute to ABEF/CDGH ─
        0xF3; 0x0F; 0x6F; 0x4E; 0x00;          # movdqu xmm1, [rsi+0]   STATE0=ABCD
        0xF3; 0x0F; 0x6F; 0x56; 0x10;          # movdqu xmm2, [rsi+16]  STATE1=EFGH
        0x66; 0x0F; 0x70; 0xC9; 0xB1;          # pshufd xmm1, xmm1, 0xB1   →[b,a,d,c]
        0x66; 0x0F; 0x70; 0xD2; 0x1B;          # pshufd xmm2, xmm2, 0x1B   →[h,g,f,e]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1     save pre-palignr
        0x66; 0x0F; 0x3A; 0x0F; 0xCA; 0x08;    # palignr xmm1, xmm2, 8 STATE0=ABEF=[f,e,b,a]
        0x66; 0x0F; 0x3A; 0x0E; 0xD7; 0xF0;    # pblendw xmm2, xmm7,F0 STATE1=CDGH=[h,g,d,c]

        # ── Save ABEF/CDGH for the post-loop add ──────────────────
        0xF3; 0x0F; 0x7F; 0x4E; 0x20;          # movdqu [rsi+32], xmm1  (ABEF_save)
        0xF3; 0x0F; 0x7F; 0x56; 0x30;          # movdqu [rsi+48], xmm2  (CDGH_save)

        # ── Iter 0 — Rounds 0..3 — load MSGTMP0 = W[0..3] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x40;          # movdqu xmm0, [rdi+64]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xD8;                # movdqa xmm3, xmm0      MSGTMP0
        0x66; 0x0F; 0xFE; 0x41; 0x00;          # paddd  xmm0, [rcx+0]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2

        # ── Iter 1 — Rounds 4..7 — load MSGTMP1 = W[4..7] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x50;          # movdqu xmm0, [rdi+80]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE0;                # movdqa xmm4, xmm0      MSGTMP1
        0x66; 0x0F; 0xFE; 0x41; 0x10;          # paddd  xmm0, [rcx+16]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4   MSGTMP0+=σ0

        # ── Iter 2 — Rounds 8..11 — load MSGTMP2 = W[8..11] ───────
        0xF3; 0x0F; 0x6F; 0x47; 0x60;          # movdqu xmm0, [rdi+96]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE8;                # movdqa xmm5, xmm0      MSGTMP2
        0x66; 0x0F; 0xFE; 0x41; 0x20;          # paddd  xmm0, [rcx+32]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5   MSGTMP1+=σ0

        # ── Iter 3 — Rounds 12..15 — load MSGTMP3 = W[12..15];
        #    also compute MSGTMP0 = W[16..19] for iter 4. ──────────
        0xF3; 0x0F; 0x6F; 0x47; 0x70;          # movdqu xmm0, [rdi+112]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xF0;                # movdqa xmm6, xmm0      MSGTMP3
        0x66; 0x0F; 0xFE; 0x41; 0x30;          # paddd  xmm0, [rcx+48]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6      tmp ← MSGTMP3
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4  W[9..12]
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7      MSGTMP0 += W[9..12]
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6  MSGTMP0 = W[16..19]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6   MSGTMP2+=σ0

        # ── Iter 4 — Rounds 16..19 — MSGTMP0 already W[16..19];
        #    compute MSGTMP1 = W[20..23]
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x41; 0x40;          # paddd  xmm0, [rcx+64]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3   MSGTMP1=W[20..23]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # ── Iter 5 — Rounds 20..23 — compute MSGTMP2 = W[24..27] ──
        0x66; 0x0F; 0x6F; 0xC4;                # movdqa xmm0, xmm4
        0x66; 0x0F; 0xFE; 0x41; 0x50;          # paddd  xmm0, [rcx+80]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;                # movdqa xmm7, xmm4
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;    # palignr xmm7, xmm3, 4
        0x66; 0x0F; 0xFE; 0xEF;                # paddd  xmm5, xmm7
        0x0F; 0x38; 0xCD; 0xEC;                # sha256msg2 xmm5, xmm4
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4

        # ── Iter 6 — Rounds 24..27 — compute MSGTMP3 = W[28..31] ──
        0x66; 0x0F; 0x6F; 0xC5;                # movdqa xmm0, xmm5
        0x66; 0x0F; 0xFE; 0x41; 0x60;          # paddd  xmm0, [rcx+96]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;                # movdqa xmm7, xmm5
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;    # palignr xmm7, xmm4, 4
        0x66; 0x0F; 0xFE; 0xF7;                # paddd  xmm6, xmm7
        0x0F; 0x38; 0xCD; 0xF5;                # sha256msg2 xmm6, xmm5
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5

        # ── Iter 7 — Rounds 28..31 — compute MSGTMP0 = W[32..35] ──
        0x66; 0x0F; 0x6F; 0xC6;                # movdqa xmm0, xmm6
        0x66; 0x0F; 0xFE; 0x41; 0x70;          # paddd  xmm0, [rcx+112]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6

        # ── Iter 8 — Rounds 32..35 — disp32 K offset 128 onward ──
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x81; 0x80; 0x00; 0x00; 0x00;  # paddd xmm0, [rcx+128]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # -- Iter 9 -- Rounds 36..39 --
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0x90; 0x00; 0x00; 0x00;  # [rcx+144]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;

        # -- Iter 10 -- Rounds 40..43 --
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xA0; 0x00; 0x00; 0x00;  # [rcx+160]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;

        # -- Iter 11 -- Rounds 44..47 --
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xB0; 0x00; 0x00; 0x00;  # [rcx+176]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;
        0x66; 0x0F; 0xFE; 0xDF;
        0x0F; 0x38; 0xCD; 0xDE;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;

        # -- Iter 12 -- Rounds 48..51 --
        0x66; 0x0F; 0x6F; 0xC3;
        0x66; 0x0F; 0xFE; 0x81; 0xC0; 0x00; 0x00; 0x00;  # [rcx+192]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;
        0x66; 0x0F; 0xFE; 0xE7;
        0x0F; 0x38; 0xCD; 0xE3;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;

        # ── Iter 13 — Rounds 52..55 — drop sha256msg1 (no longer
        #    needed: msg1 precomputes for iter+3 = 16, out of range) ─
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0xD0; 0x00; 0x00; 0x00;  # [rcx+208]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # -- Iter 14 -- Rounds 56..59 --
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xE0; 0x00; 0x00; 0x00;  # [rcx+224]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Iter 15 — Rounds 60..63 — drop ALL schedule work ───
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xF0; 0x00; 0x00; 0x00;  # [rcx+240]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Final add: STATE0 += ABEF_save; STATE1 += CDGH_save ──
        0x66; 0x0F; 0xFE; 0x4E; 0x20;          # paddd xmm1, [rsi+32]
        0x66; 0x0F; 0xFE; 0x56; 0x30;          # paddd xmm2, [rsi+48]

        # ── Reverse state setup: ABEF/CDGH → ABCD/EFGH packed ───
        0x66; 0x0F; 0x70; 0xC9; 0x1B;          # pshufd xmm1, xmm1, 0x1B → [A,B,E,F]
        0x66; 0x0F; 0x70; 0xD2; 0xB1;          # pshufd xmm2, xmm2, 0xB1 → [G,H,C,D]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1
        0x66; 0x0F; 0x3A; 0x0E; 0xCA; 0xF0;    # pblendw xmm1, xmm2, 0xF0 → [A,B,C,D]
        0x66; 0x0F; 0x3A; 0x0F; 0xD7; 0x08;    # palignr xmm2, xmm7, 8   → [E,F,G,H]
        0xF3; 0x0F; 0x7F; 0x4E; 0x00;          # movdqu [rsi+0],  xmm1
        0xF3; 0x0F; 0x7F; 0x56; 0x10;          # movdqu [rsi+16], xmm2

        # ── Unpack scratch packed dwords back to ctx h0..h7 with
        #    zero-extending 64-bit stores so the high 32 bits of
        #    each ctx slot stay zero (sha256.cyr's invariant). ────
        0x8B; 0x56; 0x00; 0x48; 0x89; 0x57; 0x00;
        0x8B; 0x56; 0x04; 0x48; 0x89; 0x57; 0x08;
        0x8B; 0x56; 0x08; 0x48; 0x89; 0x57; 0x10;
        0x8B; 0x56; 0x0C; 0x48; 0x89; 0x57; 0x18;
        0x8B; 0x56; 0x10; 0x48; 0x89; 0x57; 0x20;
        0x8B; 0x56; 0x14; 0x48; 0x89; 0x57; 0x28;
        0x8B; 0x56; 0x18; 0x48; 0x89; 0x57; 0x30;
        0x8B; 0x56; 0x1C; 0x48; 0x89; 0x57; 0x38;
    }
    #endif
    return 0;
}

# sha256_transform_ni — SHA-NI single-block compression (live in 2.9.3).
#
# Caller contract:
#   - ctx points to a 144-byte SHA-256 context (h0..h7 at +0,
#     buf at +64)
#   - returns 0 on success (compressed in hardware)
#
# `sha256_transform`'s dispatcher in src/sha256.cyr falls through
# to the FIPS 180-4 software path on hosts where the CPUID probe
# returns 0; this entry point is only invoked when SHA-NI is live.
fn sha256_transform_ni(ctx): i64 {
    if (_sha_ni_K == 0) { _sha_ni_init(); }
    # Per-call working area. 80 bytes needed; over-allocate by 16
    # so we can align the base to a 16-byte boundary (PSHUFB / PADDD
    # m128 reads of buf+0/+16/+64 require alignment). Banked per
    # thread (3.6): each batch worker writes its own 96-byte lane so
    # concurrent compresses never stomp this shared static scratch
    # (CLAUDE.md quirk #1). 96 is a multiple of 16, so each lane stays
    # 16-aligned and `_sha_ni_align16` is a no-op within it.
    var raw[6144];   # 96 * SIGIL_CRYPTO_BANKS
    var buf = _sha_ni_align16(&raw + cbank() * 96);
    memcpy(buf + 64, _sha_ni_bswap_src, 16);
    _sha_ni_compress_one(ctx, buf, _sha_ni_K);
    return 0;
}

# _sha_ni_self_test — run SHA-NI against the FIPS 180-4 §B.1 single-
# block "abc" example and compare the resulting state to the spec's
# published digest. Returns 0 on match (NI safe to enable), non-zero
# on mismatch (downgrade to software). Constant-time compare (OR-
# accumulating, no early exit).
#
# Calls `_sha_ni_compress_one` directly rather than going through
# `sha256_transform`'s dispatcher (which would call back into
# `sha_ni_available` → infinite recursion through this very fn).
# `_sha_ni_init` is idempotent so the K-table + bswap-mask setup
# costs nothing on the second-and-later probe.
#
# FIPS 180-4 §B.1 SHA-256 example:
#   Msg:     "abc"                        (3 bytes, single block)
#   Digest:  BA7816BF 8F01CFEA 414140DE 5DAE2223
#            B00361A3 96177A9C B410FF61 F20015AD
#
# Ctx layout (per src/sha256.cyr): h0..h7 at +0..+63 (8 slots × 8B,
# low 32 bits hold the dword), block buf at +64..+127, buf_len at
# +128, total_len at +136.
fn _sha_ni_self_test(): i64 {
    if (_sha_ni_K == 0) { _sha_ni_init(); }

    # Zero ctx slots.
    var i = 0;
    while (i < 144) { store8(&_sha_ni_st_ctx + i, 0); i = i + 1; }

    # FIPS 180-4 §5.3.3 initial hash values for SHA-256.
    store64(&_sha_ni_st_ctx +  0, 0x6a09e667);
    store64(&_sha_ni_st_ctx +  8, 0xbb67ae85);
    store64(&_sha_ni_st_ctx + 16, 0x3c6ef372);
    store64(&_sha_ni_st_ctx + 24, 0xa54ff53a);
    store64(&_sha_ni_st_ctx + 32, 0x510e527f);
    store64(&_sha_ni_st_ctx + 40, 0x9b05688c);
    store64(&_sha_ni_st_ctx + 48, 0x1f83d9ab);
    store64(&_sha_ni_st_ctx + 56, 0x5be0cd19);

    # Padded "abc" block at +64..+127:
    #   bytes 0..2 = 'a','b','c'
    #   byte 3     = 0x80 (padding terminator per FIPS 180-4 §5.1.1)
    #   bytes 4..62 = zeros
    #   bytes 56..63 = length-in-bits big-endian (3 * 8 = 24 = 0x18)
    store8(&_sha_ni_st_ctx + 64, 0x61);
    store8(&_sha_ni_st_ctx + 65, 0x62);
    store8(&_sha_ni_st_ctx + 66, 0x63);
    store8(&_sha_ni_st_ctx + 67, 0x80);
    store8(&_sha_ni_st_ctx + 127, 0x18);

    var raw[96];
    var buf = _sha_ni_align16(&raw);
    memcpy(buf + 64, _sha_ni_bswap_src, 16);
    _sha_ni_compress_one(&_sha_ni_st_ctx, buf, _sha_ni_K);

    # Compare h0..h7 to FIPS 180-4 §B.1 expected digest. The high 32
    # bits of each 64-bit slot are guaranteed zero by the asm's
    # zero-extending 64-bit stores at unpack time (see line 472 of
    # this file), so a `& 0xFFFFFFFF` mask is sufficient for the
    # XOR-accumulate compare.
    var diff = 0;
    diff = diff | ((load64(&_sha_ni_st_ctx +  0) ^ 0xba7816bf) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx +  8) ^ 0x8f01cfea) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 16) ^ 0x414140de) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 24) ^ 0x5dae2223) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 32) ^ 0xb00361a3) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 40) ^ 0x96177a9c) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 48) ^ 0xb410ff61) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 56) ^ 0xf20015ad) & 0xFFFFFFFF);
    return diff;
}

# --- sha256.cyr ---

# sha256.cyr — FIPS 180-4 SHA-256 implementation
# All arithmetic masked to 32 bits. Working state is per-call
# (function-local) so concurrent workers don't race; the round
# constants K[0..63] are read-only after init and remain shared.
#
# Historical note: 2.x and 3.0–3.2 lifted the round state into
# module globals as a cycc 3 local-clobbering workaround
# (CLAUDE.md quirk #1). 3.3's empirical probe
# (tests/tcyr/sha256_locals_probe.tcyr) confirmed cycc 6.0.1
# preserves locals across the helper calls, unblocking the
# refactor and the mutex-drop on the parallel-verify path.
#
# `sha256_transform` dispatches to the SHA-NI hardware path via
# `sha_ni_available()` / `sha256_transform_ni()`; pull the dispatch
# infrastructure in so single-file consumers (test harnesses that
# include only `src/sha256.cyr`) link cleanly.

#ifndef _SIGIL_SHA_NI_INCLUDED
#endif

var MASK32 = 0xFFFFFFFF;

# ================================================================
# Bitwise helpers (32-bit)
# ================================================================

# 32-bit circular right rotation of `x` by `n` bits (result masked
# to 32 bits). FIPS 180-4 §3.2 ROTR^n.
fn rotr32(x, n): i64 {
    return ((x >> n) | ((x << (32 - n)) & MASK32)) & MASK32;
}

# 32-bit logical right shift of `x` by `n` bits. FIPS 180-4 §3.2 SHR^n.
fn shr32(x, n): i64 {
    return (x >> n) & MASK32;
}

# ================================================================
# SHA-256 sub-functions
# ================================================================

# SHA-256 Ch(x,y,z) choice function (FIPS 180-4 §4.1.2).
fn sha256_ch(x, y, z): i64 {
    return ((x & y) ^ ((x ^ MASK32) & z)) & MASK32;
}

# SHA-256 Maj(x,y,z) majority function (FIPS 180-4 §4.1.2).
fn sha256_maj(x, y, z): i64 {
    return ((x & y) ^ (x & z) ^ (y & z)) & MASK32;
}

# SHA-256 big-sigma-0 (Σ0) of `x` (FIPS 180-4 §4.1.2).
fn sha256_bsig0(x): i64 {
    return (rotr32(x, 2) ^ rotr32(x, 13) ^ rotr32(x, 22)) & MASK32;
}

# SHA-256 big-sigma-1 (Σ1) of `x` (FIPS 180-4 §4.1.2).
fn sha256_bsig1(x): i64 {
    return (rotr32(x, 6) ^ rotr32(x, 11) ^ rotr32(x, 25)) & MASK32;
}

# SHA-256 small-sigma-0 (σ0) of `x` (FIPS 180-4 §4.1.2).
fn sha256_ssig0(x): i64 {
    return (rotr32(x, 7) ^ rotr32(x, 18) ^ shr32(x, 3)) & MASK32;
}

# SHA-256 small-sigma-1 (σ1) of `x` (FIPS 180-4 §4.1.2).
fn sha256_ssig1(x): i64 {
    return (rotr32(x, 17) ^ rotr32(x, 19) ^ shr32(x, 10)) & MASK32;
}

# ================================================================
# Round constants K[0..63] and initialization
# ================================================================

var _sha256_K = 0;
var _sha256_inited = 0;

# Lazily allocates and fills the 64-entry SHA-256 round-constant table
# K[0..63] (FIPS 180-4 §4.2.2). Idempotent — runs the fill once per
# process; subsequent calls return immediately. Returns 0.
fn sha256_global_init(): i64 {
    if (_sha256_inited == 1) { return 0; }

    _sha256_K = alloc(512);
    store64(_sha256_K + 0, 0x428a2f98);
    store64(_sha256_K + 8, 0x71374491);
    store64(_sha256_K + 16, 0xb5c0fbcf);
    store64(_sha256_K + 24, 0xe9b5dba5);
    store64(_sha256_K + 32, 0x3956c25b);
    store64(_sha256_K + 40, 0x59f111f1);
    store64(_sha256_K + 48, 0x923f82a4);
    store64(_sha256_K + 56, 0xab1c5ed5);
    store64(_sha256_K + 64, 0xd807aa98);
    store64(_sha256_K + 72, 0x12835b01);
    store64(_sha256_K + 80, 0x243185be);
    store64(_sha256_K + 88, 0x550c7dc3);
    store64(_sha256_K + 96, 0x72be5d74);
    store64(_sha256_K + 104, 0x80deb1fe);
    store64(_sha256_K + 112, 0x9bdc06a7);
    store64(_sha256_K + 120, 0xc19bf174);
    store64(_sha256_K + 128, 0xe49b69c1);
    store64(_sha256_K + 136, 0xefbe4786);
    store64(_sha256_K + 144, 0x0fc19dc6);
    store64(_sha256_K + 152, 0x240ca1cc);
    store64(_sha256_K + 160, 0x2de92c6f);
    store64(_sha256_K + 168, 0x4a7484aa);
    store64(_sha256_K + 176, 0x5cb0a9dc);
    store64(_sha256_K + 184, 0x76f988da);
    store64(_sha256_K + 192, 0x983e5152);
    store64(_sha256_K + 200, 0xa831c66d);
    store64(_sha256_K + 208, 0xb00327c8);
    store64(_sha256_K + 216, 0xbf597fc7);
    store64(_sha256_K + 224, 0xc6e00bf3);
    store64(_sha256_K + 232, 0xd5a79147);
    store64(_sha256_K + 240, 0x06ca6351);
    store64(_sha256_K + 248, 0x14292967);
    store64(_sha256_K + 256, 0x27b70a85);
    store64(_sha256_K + 264, 0x2e1b2138);
    store64(_sha256_K + 272, 0x4d2c6dfc);
    store64(_sha256_K + 280, 0x53380d13);
    store64(_sha256_K + 288, 0x650a7354);
    store64(_sha256_K + 296, 0x766a0abb);
    store64(_sha256_K + 304, 0x81c2c92e);
    store64(_sha256_K + 312, 0x92722c85);
    store64(_sha256_K + 320, 0xa2bfe8a1);
    store64(_sha256_K + 328, 0xa81a664b);
    store64(_sha256_K + 336, 0xc24b8b70);
    store64(_sha256_K + 344, 0xc76c51a3);
    store64(_sha256_K + 352, 0xd192e819);
    store64(_sha256_K + 360, 0xd6990624);
    store64(_sha256_K + 368, 0xf40e3585);
    store64(_sha256_K + 376, 0x106aa070);
    store64(_sha256_K + 384, 0x19a4c116);
    store64(_sha256_K + 392, 0x1e376c08);
    store64(_sha256_K + 400, 0x2748774c);
    store64(_sha256_K + 408, 0x34b0bcb5);
    store64(_sha256_K + 416, 0x391c0cb3);
    store64(_sha256_K + 424, 0x4ed8aa4a);
    store64(_sha256_K + 432, 0x5b9cca4f);
    store64(_sha256_K + 440, 0x682e6ff3);
    store64(_sha256_K + 448, 0x748f82ee);
    store64(_sha256_K + 456, 0x78a5636f);
    store64(_sha256_K + 464, 0x84c87814);
    store64(_sha256_K + 472, 0x8cc70208);
    store64(_sha256_K + 480, 0x90befffa);
    store64(_sha256_K + 488, 0xa4506ceb);
    store64(_sha256_K + 496, 0xbef9a3f7);
    store64(_sha256_K + 504, 0xc67178f2);

    _sha256_inited = 1;
    return 0;
}

# ================================================================
# SHA-256 context
# ================================================================
# Layout (144 bytes):
#   +0   h0..h7   (8 x 8 = 64 bytes) hash state words
#   +64  buf      (64 bytes) partial block buffer
#   +128 buf_len  (8 bytes)
#   +136 total_len (8 bytes)

# Allocates a 144-byte SHA-256 context from the freelist and seeds it
# with the FIPS 180-4 initial hash values. Returns the context pointer;
# free with fl_free after sha256_finalize.
fn sha256_init(): i64 {
    var ctx = fl_alloc(144);
    return sha256_init_into(ctx);
}

# Alloc-free variant of sha256_init (3.2.0). Initialises an
# existing 144-byte context buffer with the FIPS 180-4 §5.3.3
# initial hash values and zeroes the block buffer + counters.
# Caller MUST size `ctx` to at least 144 bytes.
#
# Used by `hash_file_into` and the parallel-batch worker scratch
# so a SHA-256 streaming hash can run without touching the
# freelist allocator — `fl_alloc` mutates shared state and is
# unsafe under concurrent fan-out (CLAUDE.md quirk #7).
fn sha256_init_into(ctx): i64 {
    sha256_global_init();
    store64(ctx, 0x6a09e667);
    store64(ctx + 8, 0xbb67ae85);
    store64(ctx + 16, 0x3c6ef372);
    store64(ctx + 24, 0xa54ff53a);
    store64(ctx + 32, 0x510e527f);
    store64(ctx + 40, 0x9b05688c);
    store64(ctx + 48, 0x1f83d9ab);
    store64(ctx + 56, 0x5be0cd19);
    memset(ctx + 64, 0, 64);
    store64(ctx + 128, 0);
    store64(ctx + 136, 0);
    return ctx;
}

# ================================================================
# Compression function — per-call working state (3.3 refactor)
# ================================================================
# All working state (a..hv, t1, t2, i, W) lives in function-local
# variables. The pre-3.3 module-global pattern was a cycc 3
# local-clobbering workaround that the cycc 6.0.1 codegen no
# longer needs; verified by tests/tcyr/sha256_locals_probe.tcyr
# against published FIPS 180-2 vectors and multi-block cross-
# check against the reference path.
#
# Concurrency consequence: this function is now race-free across
# threads, which unblocks dropping the _sigil_batch_mutex on the
# parallel-verify hot path. Read-only globals (_sha256_K) remain
# shared and safe under concurrent read.

# Compresses one 64-byte message block held in `ctx`'s block buffer
# into the running hash state (FIPS 180-4 §6.2.2). Dispatches to the
# SHA-NI hardware path when available, else the software round loop.
# Returns 0.
fn sha256_transform(ctx): i64 {
    # SHA-NI dispatch wire-point (2.9.2 foundation).
    # When sha256_transform_ni returns 0 it has fully transformed
    # the block and we return early. The 2.9.2 stub returns -1 so
    # this falls through to the software path on every host; 2.9.3
    # replaces the stub body with a byte-encoded SHA-NI compress.
    if (sha_ni_available() == 1) {
        if (sha256_transform_ni(ctx) == 0) { return 0; }
    }

    # Message schedule, banked per thread (3.6): `var W[N]` is a
    # static function-scope global (CLAUDE.md quirk #1), so concurrent
    # batch workers must each use their own lane to avoid stomping the
    # schedule mid-compress. `Wb` is this thread's 512-byte lane.
    var W[32768];          # 64 words × 8 bytes × SIGIL_CRYPTO_BANKS
    var Wb = &W + cbank() * 512;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian).
    var i = 0;
    while (i < 16) {
        var off = i * 4;
        var w = ((load8(buf + off) & 0xFF) << 24)
        | ((load8(buf + off + 1) & 0xFF) << 16)
        | ((load8(buf + off + 2) & 0xFF) << 8)
        | (load8(buf + off + 3) & 0xFF);
        store64(Wb + i * 8, w & MASK32);
        i = i + 1;
    }

    # Extend W[16..63].
    i = 16;
    while (i < 64) {
        var w16 = load64(Wb + (i - 16) * 8);
        var w15 = load64(Wb + (i - 15) * 8);
        var w7 = load64(Wb + (i - 7) * 8);
        var w2 = load64(Wb + (i - 2) * 8);
        var s0 = sha256_ssig0(w15);
        var s1 = sha256_ssig1(w2);
        store64(Wb + i * 8, (w16 + s0 + w7 + s1) & MASK32);
        i = i + 1;
    }

    # Initialize working variables.
    var a = load64(ctx);
    var b = load64(ctx + 8);
    var c = load64(ctx + 16);
    var d = load64(ctx + 24);
    var e = load64(ctx + 32);
    var f = load64(ctx + 40);
    var g = load64(ctx + 48);
    var hv = load64(ctx + 56);

    # 64 rounds.
    i = 0;
    while (i < 64) {
        var t1 = hv;
        t1 = (t1 + sha256_bsig1(e)) & MASK32;
        t1 = (t1 + sha256_ch(e, f, g)) & MASK32;
        t1 = (t1 + load64(_sha256_K + i * 8)) & MASK32;
        t1 = (t1 + load64(Wb + i * 8)) & MASK32;

        var t2 = sha256_bsig0(a);
        t2 = (t2 + sha256_maj(a, b, c)) & MASK32;

        hv = g;
        g = f;
        f = e;
        e = (d + t1) & MASK32;
        d = c;
        c = b;
        b = a;
        a = (t1 + t2) & MASK32;
        i = i + 1;
    }

    # Add compressed chunk to current hash value.
    store64(ctx, (load64(ctx) + a) & MASK32);
    store64(ctx + 8, (load64(ctx + 8) + b) & MASK32);
    store64(ctx + 16, (load64(ctx + 16) + c) & MASK32);
    store64(ctx + 24, (load64(ctx + 24) + d) & MASK32);
    store64(ctx + 32, (load64(ctx + 32) + e) & MASK32);
    store64(ctx + 40, (load64(ctx + 40) + f) & MASK32);
    store64(ctx + 48, (load64(ctx + 48) + g) & MASK32);
    store64(ctx + 56, (load64(ctx + 56) + hv) & MASK32);
    return 0;
}

# ================================================================
# Update — feed data into the hash context
# ================================================================

# Feeds `len` bytes at `data` into the streaming hash context `ctx`,
# buffering any partial trailing block and compressing full 64-byte
# blocks as they accumulate. May be called repeatedly. Returns 0.
fn sha256_update(ctx, data, len): i64 {
    var buf_len = load64(ctx + 128);
    var total = load64(ctx + 136);
    total = total + len;
    store64(ctx + 136, total);

    var pos = 0;

    # Fill partial buffer first
    if (buf_len > 0) {
        var need = 64 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 128, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha256_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    # Process full 64-byte blocks
    while (pos + 64 <= len) {
        memcpy(ctx + 64, data + pos, 64);
        sha256_transform(ctx);
        pos = pos + 64;
    }

    # Buffer remaining bytes
    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 128, remaining);
    return 0;
}

# ================================================================
# Finalize — pad and produce 32-byte digest
# ================================================================

# Applies FIPS 180-4 §5.1.1 padding (0x80, zero fill, 64-bit big-endian
# length), runs the final compression, and writes the 32-byte digest to
# `out` in big-endian order. Consumes `ctx` (caller frees it). Returns 0.
fn sha256_finalize(ctx, out): i64 {
    var buf_len = load64(ctx + 128);
    var total_bits = load64(ctx + 136) * 8;

    # Append 0x80 byte
    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    # If buffer > 56 bytes, pad and process extra block
    if (buf_len > 56) {
        memset(ctx + 64 + buf_len, 0, 64 - buf_len);
        sha256_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 56 - buf_len);

    # Append total length as 64-bit big-endian at bytes 56-63
    store8(ctx + 64 + 56, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 57, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 58, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 59, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 60, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 61, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 62, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 63, total_bits & 0xFF);

    sha256_transform(ctx);

    # Write 32-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 4, (word >> 24) & 0xFF);
        store8(out + di * 4 + 1, (word >> 16) & 0xFF);
        store8(out + di * 4 + 2, (word >> 8) & 0xFF);
        store8(out + di * 4 + 3, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

# One-shot SHA-256: hashes `len` bytes at `data` and writes the 32-byte
# digest to `out`. Allocates, drives, and frees a context internally.
# Returns 0.
fn sha256(data, len, out): i64 {
    # Banked one-shot (3.9.6): the ctx was `fl_alloc`'d, but `fl_alloc`
    # is NOT thread-safe (quirk #7), so concurrent one-shot hashes (TLS
    # transcript / HKDF / HMAC long-key) raced the freelist — a
    # concurrent-TLS-handshake crash site. Use a per-worker banked
    # static ctx + the `_into` variant; no allocator touched.
    var bk = cbank();
    var ctx[9216];   var ctxb = &ctx + bk * 144;   # 144 * SIGIL_CRYPTO_BANKS
    sha256_init_into(ctxb);
    sha256_update(ctxb, data, len);
    sha256_finalize(ctxb, out);
    return 0;
}

# --- hmac.cyr ---

# hmac.cyr — HMAC-SHA256 (RFC 2104)
# Proper ipad/opad construction, not simplified SHA-256(key||msg).
#
# Status in 3.0: sigil-internal primitive. Public consumers should
# call `hkdf_*` (src/hkdf.cyr) rather than `hmac_sha256` directly
# — HMAC's hot-path role in sigil is as the HKDF extract/expand
# building block, and exposing it as a top-level API would
# encourage miscomposition (consumers rolling their own KDFs when
# HKDF already covers the use case correctly). The 2.x roadmap
# entry proposing a full drop of this module is retired: the
# 2.9.0 HKDF landing pulled `hmac_sha256` into sigil's internal
# call graph, so it stays. `tests/tcyr/crypto.tcyr` and
# `tests/tcyr/security.tcyr` retain hmac-level test vectors as
# unit coverage of the primitive.
#
# HMAC(K, m) = H((K' xor opad) || H((K' xor ipad) || m))
# where:
#   K' = H(K) if len(K) > 64, else K padded to 64 bytes
#   ipad = 0x36 repeated 64 times
#   opad = 0x5c repeated 64 times

# ================================================================
# HMAC-SHA256
# ================================================================

# Computes HMAC-SHA256 (RFC 2104) over `msg` under `key`, writing the
# 32-byte MAC to `out`. Keys longer than the 64-byte block are first
# SHA-256-hashed per the spec; shorter keys are zero-padded. The K'
# / ipad / opad scratch buffers are `secret var` and zeroized on
# return. Returns 0.
fn hmac_sha256(key, key_len, msg, msg_len, out): i64 {
    # Per-worker banked scratch (3.9.6 — concurrent-TLS-handshake fix).
    # kprime/ipad/opad/inner_hash were function-scope `secret var`s, i.e.
    # STATIC globals (quirk #1), and the two SHA-256 ctxs were `fl_alloc`'d
    # — both raced under concurrent TLS handshakes (HMAC is the HKDF
    # building block driven on every TLS 1.3 key-schedule step). Banked
    # across `cbank()` lanes; the secret K'/ipad/opad lanes are plain
    # `var` + per-lane `memset` on exit (quirk #9 — a `secret var`
    # whole-array wipe would clobber a sibling worker's live lane), and
    # the streaming ctx uses a banked `_into` buffer (no fl_alloc).
    var bk = cbank();
    var kprime[4096];     var kprimeb     = &kprime     + bk * 64;   # 64 * SIGIL_CRYPTO_BANKS
    var ipad[4096];       var ipadb       = &ipad       + bk * 64;
    var opad[4096];       var opadb       = &opad       + bk * 64;
    var inner_hash[2048]; var inner_hashb = &inner_hash + bk * 32;   # 32 * SIGIL_CRYPTO_BANKS
    var hctx[9216];       var hctxb       = &hctx       + bk * 144;  # 144 * SIGIL_CRYPTO_BANKS (reused)

    # Step 1: Derive K' (64 bytes). The init memset is retained for
    # correctness — the key_len < 64 branch relies on the upper bytes
    # being zero.
    memset(kprimeb, 0, 64);
    if (key_len > 64) {
        # Key too long — hash it. kprime is then 32 B hash + 32 B zeros.
        sha256(key, key_len, kprimeb);
    } else {
        memcpy(kprimeb, key, key_len);
        # Rest already zeroed
    }

    # Step 2: inner = SHA-256((K' xor ipad) || message)
    var i = 0;
    while (i < 64) {
        store8(ipadb + i, (load8(kprimeb + i) & 0xFF) ^ 0x36);
        i = i + 1;
    }
    sha256_init_into(hctxb);
    sha256_update(hctxb, ipadb, 64);
    sha256_update(hctxb, msg, msg_len);
    sha256_finalize(hctxb, inner_hashb);

    # Step 3: outer = SHA-256((K' xor opad) || inner)  (reuse the ctx)
    i = 0;
    while (i < 64) {
        store8(opadb + i, (load8(kprimeb + i) & 0xFF) ^ 0x5c);
        i = i + 1;
    }
    sha256_init_into(hctxb);
    sha256_update(hctxb, opadb, 64);
    sha256_update(hctxb, inner_hashb, 32);
    sha256_finalize(hctxb, out);

    # Per-lane secret zeroization (replaces the lost `secret var`
    # guarantee; wipes only THIS worker's lane). inner_hash is a public
    # digest — left as-is.
    memset(kprimeb, 0, 64);
    memset(ipadb, 0, 64);
    memset(opadb, 0, 64);
    return 0;
}

# --- sha512.cyr ---

# sha512.cyr — FIPS 180-4 SHA-512 implementation
# Required by Ed25519 (RFC 8032) for key expansion and signing.
# All arithmetic uses 64-bit words (native Cyrius i64).

# ================================================================
# SHA-512 round constants K[0..79]
# ================================================================

var _sha512_K = 0;
var _sha512_inited = 0;

fn _sha512_rotr(x, n): i64 {
    return (x >> n) | (x << (64 - n));
}

fn sha512_ch(x, y, z): i64 {
    return (x & y) ^ ((x ^ 0xFFFFFFFFFFFFFFFF) & z);
}

fn sha512_maj(x, y, z): i64 {
    return (x & y) ^ (x & z) ^ (y & z);
}

fn sha512_bsig0(x): i64 {
    return _sha512_rotr(x, 28) ^ _sha512_rotr(x, 34) ^ _sha512_rotr(x, 39);
}

fn sha512_bsig1(x): i64 {
    return _sha512_rotr(x, 14) ^ _sha512_rotr(x, 18) ^ _sha512_rotr(x, 41);
}

fn sha512_ssig0(x): i64 {
    return _sha512_rotr(x, 1) ^ _sha512_rotr(x, 8) ^ (x >> 7);
}

fn sha512_ssig1(x): i64 {
    return _sha512_rotr(x, 19) ^ _sha512_rotr(x, 61) ^ (x >> 6);
}

fn sha512_global_init(): i64 {
    if (_sha512_inited == 1) { return 0; }

    _sha512_K = alloc(640);
    store64(_sha512_K + 0, 0x428a2f98d728ae22);
    store64(_sha512_K + 8, 0x7137449123ef65cd);
    store64(_sha512_K + 16, 0xb5c0fbcfec4d3b2f);
    store64(_sha512_K + 24, 0xe9b5dba58189dbbc);
    store64(_sha512_K + 32, 0x3956c25bf348b538);
    store64(_sha512_K + 40, 0x59f111f1b605d019);
    store64(_sha512_K + 48, 0x923f82a4af194f9b);
    store64(_sha512_K + 56, 0xab1c5ed5da6d8118);
    store64(_sha512_K + 64, 0xd807aa98a3030242);
    store64(_sha512_K + 72, 0x12835b0145706fbe);
    store64(_sha512_K + 80, 0x243185be4ee4b28c);
    store64(_sha512_K + 88, 0x550c7dc3d5ffb4e2);
    store64(_sha512_K + 96, 0x72be5d74f27b896f);
    store64(_sha512_K + 104, 0x80deb1fe3b1696b1);
    store64(_sha512_K + 112, 0x9bdc06a725c71235);
    store64(_sha512_K + 120, 0xc19bf174cf692694);
    store64(_sha512_K + 128, 0xe49b69c19ef14ad2);
    store64(_sha512_K + 136, 0xefbe4786384f25e3);
    store64(_sha512_K + 144, 0x0fc19dc68b8cd5b5);
    store64(_sha512_K + 152, 0x240ca1cc77ac9c65);
    store64(_sha512_K + 160, 0x2de92c6f592b0275);
    store64(_sha512_K + 168, 0x4a7484aa6ea6e483);
    store64(_sha512_K + 176, 0x5cb0a9dcbd41fbd4);
    store64(_sha512_K + 184, 0x76f988da831153b5);
    store64(_sha512_K + 192, 0x983e5152ee66dfab);
    store64(_sha512_K + 200, 0xa831c66d2db43210);
    store64(_sha512_K + 208, 0xb00327c898fb213f);
    store64(_sha512_K + 216, 0xbf597fc7beef0ee4);
    store64(_sha512_K + 224, 0xc6e00bf33da88fc2);
    store64(_sha512_K + 232, 0xd5a79147930aa725);
    store64(_sha512_K + 240, 0x06ca6351e003826f);
    store64(_sha512_K + 248, 0x142929670a0e6e70);
    store64(_sha512_K + 256, 0x27b70a8546d22ffc);
    store64(_sha512_K + 264, 0x2e1b21385c26c926);
    store64(_sha512_K + 272, 0x4d2c6dfc5ac42aed);
    store64(_sha512_K + 280, 0x53380d139d95b3df);
    store64(_sha512_K + 288, 0x650a73548baf63de);
    store64(_sha512_K + 296, 0x766a0abb3c77b2a8);
    store64(_sha512_K + 304, 0x81c2c92e47edaee6);
    store64(_sha512_K + 312, 0x92722c851482353b);
    store64(_sha512_K + 320, 0xa2bfe8a14cf10364);
    store64(_sha512_K + 328, 0xa81a664bbc423001);
    store64(_sha512_K + 336, 0xc24b8b70d0f89791);
    store64(_sha512_K + 344, 0xc76c51a30654be30);
    store64(_sha512_K + 352, 0xd192e819d6ef5218);
    store64(_sha512_K + 360, 0xd69906245565a910);
    store64(_sha512_K + 368, 0xf40e35855771202a);
    store64(_sha512_K + 376, 0x106aa07032bbd1b8);
    store64(_sha512_K + 384, 0x19a4c116b8d2d0c8);
    store64(_sha512_K + 392, 0x1e376c085141ab53);
    store64(_sha512_K + 400, 0x2748774cdf8eeb99);
    store64(_sha512_K + 408, 0x34b0bcb5e19b48a8);
    store64(_sha512_K + 416, 0x391c0cb3c5c95a63);
    store64(_sha512_K + 424, 0x4ed8aa4ae3418acb);
    store64(_sha512_K + 432, 0x5b9cca4f7763e373);
    store64(_sha512_K + 440, 0x682e6ff3d6b2b8a3);
    store64(_sha512_K + 448, 0x748f82ee5defb2fc);
    store64(_sha512_K + 456, 0x78a5636f43172f60);
    store64(_sha512_K + 464, 0x84c87814a1f0ab72);
    store64(_sha512_K + 472, 0x8cc702081a6439ec);
    store64(_sha512_K + 480, 0x90befffa23631e28);
    store64(_sha512_K + 488, 0xa4506cebde82bde9);
    store64(_sha512_K + 496, 0xbef9a3f7b2c67915);
    store64(_sha512_K + 504, 0xc67178f2e372532b);
    store64(_sha512_K + 512, 0xca273eceea26619c);
    store64(_sha512_K + 520, 0xd186b8c721c0c207);
    store64(_sha512_K + 528, 0xeada7dd6cde0eb1e);
    store64(_sha512_K + 536, 0xf57d4f7fee6ed178);
    store64(_sha512_K + 544, 0x06f067aa72176fba);
    store64(_sha512_K + 552, 0x0a637dc5a2c898a6);
    store64(_sha512_K + 560, 0x113f9804bef90dae);
    store64(_sha512_K + 568, 0x1b710b35131c471b);
    store64(_sha512_K + 576, 0x28db77f523047d84);
    store64(_sha512_K + 584, 0x32caab7b40c72493);
    store64(_sha512_K + 592, 0x3c9ebe0a15c9bebc);
    store64(_sha512_K + 600, 0x431d67c49c100d4c);
    store64(_sha512_K + 608, 0x4cc5d4becb3e42b6);
    store64(_sha512_K + 616, 0x597f299cfc657e2a);
    store64(_sha512_K + 624, 0x5fcb6fab3ad6faec);
    store64(_sha512_K + 632, 0x6c44198c4a475817);

    _sha512_inited = 1;
    return 0;
}

# ================================================================
# SHA-512 context (272 bytes)
# ================================================================
# Layout:
#   +0    h0..h7 (8 x 8 = 64 bytes) hash state
#   +64   buf    (128 bytes) partial block buffer
#   +192  buf_len (8 bytes)
#   +200  total_len (8 bytes)

fn sha512_init(): i64 {
    var ctx = fl_alloc(208);
    return sha512_init_into(ctx);
}

# Alloc-free variant of sha512_init. Initialises an existing
# 208-byte context buffer with the FIPS 180-4 §5.3.5 initial
# hash values and zeroes the block buffer + counters. Caller
# MUST size `ctx` to at least 208 bytes.
#
# Used by `ed25519_verify` and other parallel-friendly callers
# so a streaming SHA-512 hash can run without touching the
# freelist allocator (CLAUDE.md quirk #7: `fl_alloc` is not
# thread-safe).
fn sha512_init_into(ctx): i64 {
    sha512_global_init();
    store64(ctx, 0x6a09e667f3bcc908);
    store64(ctx + 8, 0xbb67ae8584caa73b);
    store64(ctx + 16, 0x3c6ef372fe94f82b);
    store64(ctx + 24, 0xa54ff53a5f1d36f1);
    store64(ctx + 32, 0x510e527fade682d1);
    store64(ctx + 40, 0x9b05688c2b3e6c1f);
    store64(ctx + 48, 0x1f83d9abfb41bd6b);
    store64(ctx + 56, 0x5be0cd19137e2179);
    memset(ctx + 64, 0, 128);
    store64(ctx + 192, 0);
    store64(ctx + 200, 0);
    return ctx;
}

# ================================================================
# SHA-512 transform — per-call working state (3.3 refactor)
# ================================================================
# Mirror of sha256.cyr's 3.3 refactor: working state (a..hv,
# t1, t2, i, W) lives in function locals. Round constants K
# remain read-only-after-init and shared across threads.

fn sha512_transform(ctx): i64 {
    # Message schedule, banked per thread (3.6): `var W[N]` is a
    # static function-scope global (CLAUDE.md quirk #1); each batch
    # worker uses its own 640-byte lane so concurrent compresses on
    # the Ed25519 HRAM hash never race. `Wb` is this thread's lane.
    var W[40960];          # 80 words × 8 bytes × SIGIL_CRYPTO_BANKS
    var Wb = &W + cbank() * 640;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian 64-bit words)
    var i = 0;
    while (i < 16) {
        var off = i * 8;
        var w = ((load8(buf + off) & 0xFF) << 56)
        | ((load8(buf + off + 1) & 0xFF) << 48)
        | ((load8(buf + off + 2) & 0xFF) << 40)
        | ((load8(buf + off + 3) & 0xFF) << 32)
        | ((load8(buf + off + 4) & 0xFF) << 24)
        | ((load8(buf + off + 5) & 0xFF) << 16)
        | ((load8(buf + off + 6) & 0xFF) << 8)
        | (load8(buf + off + 7) & 0xFF);
        store64(Wb + i * 8, w);
        i = i + 1;
    }

    # Extend W[16..79]
    i = 16;
    while (i < 80) {
        var w16 = load64(Wb + (i - 16) * 8);
        var w15 = load64(Wb + (i - 15) * 8);
        var w7 = load64(Wb + (i - 7) * 8);
        var w2 = load64(Wb + (i - 2) * 8);
        var s0 = sha512_ssig0(w15);
        var s1 = sha512_ssig1(w2);
        store64(Wb + i * 8, w16 + s0 + w7 + s1);
        i = i + 1;
    }

    # Initialize working variables
    var a = load64(ctx);
    var b = load64(ctx + 8);
    var c = load64(ctx + 16);
    var d = load64(ctx + 24);
    var e = load64(ctx + 32);
    var f = load64(ctx + 40);
    var g = load64(ctx + 48);
    var hv = load64(ctx + 56);

    # 80 rounds
    i = 0;
    while (i < 80) {
        var t1 = hv + sha512_bsig1(e) + sha512_ch(e, f, g);
        t1 = t1 + load64(_sha512_K + i * 8) + load64(Wb + i * 8);
        var t2 = sha512_bsig0(a) + sha512_maj(a, b, c);

        hv = g;
        g = f;
        f = e;
        e = d + t1;
        d = c;
        c = b;
        b = a;
        a = t1 + t2;
        i = i + 1;
    }

    # Add compressed chunk to current hash value
    store64(ctx, load64(ctx) + a);
    store64(ctx + 8, load64(ctx + 8) + b);
    store64(ctx + 16, load64(ctx + 16) + c);
    store64(ctx + 24, load64(ctx + 24) + d);
    store64(ctx + 32, load64(ctx + 32) + e);
    store64(ctx + 40, load64(ctx + 40) + f);
    store64(ctx + 48, load64(ctx + 48) + g);
    store64(ctx + 56, load64(ctx + 56) + hv);
    return 0;
}

# ================================================================
# SHA-512 update
# ================================================================

fn sha512_update(ctx, data, len): i64 {
    var buf_len = load64(ctx + 192);
    var total = load64(ctx + 200);
    total = total + len;
    store64(ctx + 200, total);

    var pos = 0;

    if (buf_len > 0) {
        var need = 128 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 192, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha512_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    while (pos + 128 <= len) {
        memcpy(ctx + 64, data + pos, 128);
        sha512_transform(ctx);
        pos = pos + 128;
    }

    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 192, remaining);
    return 0;
}

# ================================================================
# SHA-512 finalize — produce 64-byte digest
# ================================================================

fn sha512_finalize(ctx, out): i64 {
    var buf_len = load64(ctx + 192);
    var total_bits = load64(ctx + 200) * 8;

    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    if (buf_len > 112) {
        memset(ctx + 64 + buf_len, 0, 128 - buf_len);
        sha512_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 112 - buf_len);

    # Append total length as 128-bit big-endian (high 64 bits = 0 for < 2^64 bits)
    memset(ctx + 64 + 112, 0, 8);
    store8(ctx + 64 + 120, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 121, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 122, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 123, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 124, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 125, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 126, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 127, total_bits & 0xFF);

    sha512_transform(ctx);

    # Write 64-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 8, (word >> 56) & 0xFF);
        store8(out + di * 8 + 1, (word >> 48) & 0xFF);
        store8(out + di * 8 + 2, (word >> 40) & 0xFF);
        store8(out + di * 8 + 3, (word >> 32) & 0xFF);
        store8(out + di * 8 + 4, (word >> 24) & 0xFF);
        store8(out + di * 8 + 5, (word >> 16) & 0xFF);
        store8(out + di * 8 + 6, (word >> 8) & 0xFF);
        store8(out + di * 8 + 7, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

fn sha512(data, len, out): i64 {
    # Banked one-shot (3.9.6): the ctx was `fl_alloc`'d, but `fl_alloc`
    # is NOT thread-safe (quirk #7), so concurrent one-shot hashes (TLS
    # transcript / HKDF / HMAC long-key) raced the freelist — a
    # concurrent-TLS-handshake crash site. Use a per-worker banked
    # static ctx + the `_into` variant; no allocator touched.
    var bk = cbank();
    var ctx[13312];   var ctxb = &ctx + bk * 208;   # 208 * SIGIL_CRYPTO_BANKS
    sha512_init_into(ctxb);
    sha512_update(ctxb, data, len);
    sha512_finalize(ctxb, out);
    return 0;
}

# --- sha384.cyr ---

# sha384.cyr — FIPS 180-4 SHA-384.
#
# SHA-384 reuses SHA-512's compression core (`src/sha512.cyr`) with
# two changes per FIPS 180-4 §5.3.4 / §6.5:
#   1. Different initial hash value (IV).
#   2. Output is the leftmost 48 bytes of the final 64-byte state.
#
# Used by:
#   • SEV-SNP attestation reports — measurement field is a SHA-384
#     digest of the guest's launch state (per AMD's spec).
#   • Future ECDSA P-384 signature workflows where the message
#     representative is SHA-384(msg).
#
# Wrapper-style implementation — the heavy lifting stays in
# `sha512_transform` / `sha512_update` / `sha512_finalize`. Sigil
# 2.x's `sha256.cyr` / `sha512.cyr` / `hkdf.cyr` separation
# pattern is preserved.

# SHA-384 initial hash (FIPS 180-4 §5.3.4)
# Initialize a SHA-384 hash context into a CALLER-PROVIDED 208-byte buffer (no
# allocation) — the arena-aware sibling of sha384_init, mirroring
# sha256_init_into. Lets a consumer (e.g. cyrius tls_native's per-connection TLS
# arena) draw the transcript hash context from its own arena instead of the
# freelist, so a long-running server stays flat-RSS. Returns 0.
fn sha384_init_into(ctx): i64 {
    sha512_global_init();
    store64(ctx +  0, 0xcbbb9d5dc1059ed8);
    store64(ctx +  8, 0x629a292a367cd507);
    store64(ctx + 16, 0x9159015a3070dd17);
    store64(ctx + 24, 0x152fecd8f70e5939);
    store64(ctx + 32, 0x67332667ffc00b31);
    store64(ctx + 40, 0x8eb44a8768581511);
    store64(ctx + 48, 0xdb0c2e0d64f98fa7);
    store64(ctx + 56, 0x47b5481dbefa4fa4);
    memset(ctx + 64, 0, 128);
    store64(ctx + 192, 0);
    store64(ctx + 200, 0);
    return 0;
}

fn sha384_init(): i64 {
    var ctx = fl_alloc(208);
    sha384_init_into(ctx);
    return ctx;
}

# Update — identical streaming behaviour to SHA-512 (same block size).
fn sha384_update(ctx, data, len): i64 {
    return sha512_update(ctx, data, len);
}

# Finalize — run the SHA-512 finaliser into a 64-byte scratch, then
# truncate to the leftmost 48 bytes.
fn sha384_finalize(ctx, out): i64 {
    # Banked (3.9.6): `var tmp[64]` is a function-scope static global
    # (quirk #1) — two concurrent SHA-384 finalizes (the TLS-SHA384
    # transcript / HKDF-SHA384 path) raced it. (SHA-256's finalize
    # writes straight to `out`, so it has no analogous buffer — which is
    # why only the SHA-384 path showed the race.) Per-`cbank()` lane;
    # public digest, no wipe needed.
    var bk = cbank();
    var tmp[4096];   var tmpb = &tmp + bk * 64;   # 64 * SIGIL_CRYPTO_BANKS
    sha512_finalize(ctx, tmpb);
    memcpy(out, tmpb, 48);
    return 0;
}

# Convenience — hash `data` (len bytes) into `out` (48 bytes).
fn sha384(data, len, out): i64 {
    # Banked one-shot (3.9.6): `fl_alloc` is not thread-safe (quirk #7),
    # so concurrent SHA-384 one-shots (the TLS_AES_256_GCM_SHA384
    # transcript / HKDF-SHA384 key schedule) raced the freelist. Use a
    # per-worker banked static ctx + the `_into` variant.
    var bk = cbank();
    var ctx[13312];   var ctxb = &ctx + bk * 208;   # 208 * SIGIL_CRYPTO_BANKS
    sha384_init_into(ctxb);
    sha384_update(ctxb, data, len);
    sha384_finalize(ctxb, out);
    return 0;
}

# --- hmac_sha384.cyr ---

# hmac_sha384.cyr — HMAC-SHA384 (FIPS 198-1 / RFC 4231 §3)
#
# Companion to `src/hmac.cyr`'s HMAC-SHA256. Split into its own
# module because it depends on `src/sha384.cyr`, which is included
# AFTER `src/hmac.cyr` / `src/hkdf.cyr` in the dependency order
# (`src/lib.cyr`) — sha384 layers on sha512's compression core. This
# module therefore lives after sha384 in the include chain.
#
# Added at 3.5.6 for the cyrius native TLS 1.3 arc: the
# `TLS_AES_256_GCM_SHA384` (0x1302) ciphersuite drives its RFC 8446
# §7.1 key schedule off HKDF-SHA384, whose extract/expand primitive
# is HMAC-SHA384. See `docs/development/issues/2026-05-28-cyrius-tls-
# native-needs-hkdf-sha384.md`.
#
# HMAC(K, m) = H((K' xor opad) || H((K' xor ipad) || m))
# where:
#   K' = H(K) if len(K) > B, else K padded to B bytes
#   ipad = 0x36 repeated B times
#   opad = 0x5c repeated B times
#
# THE WRINKLE: SHA-384's block size B is **128 bytes**, not 64 like
# SHA-256. The digest is **48 bytes**, not 32. Copying the SHA-256
# variant and only swapping the hash function produces wrong output
# — every block/digest constant below cascades from B=128 / L=48.

# ================================================================
# HMAC-SHA384
# ================================================================

# Computes HMAC-SHA384 (FIPS 198-1 / RFC 4231 §3) over `msg` under
# `key`, writing the 48-byte MAC to `out48`. Keys longer than the
# 128-byte block are first SHA-384-hashed per the spec (yielding 48
# bytes, zero-padded to 128); shorter keys are zero-padded. The K' /
# ipad / opad scratch buffers are `secret var` and zeroized on
# return. Returns 0.
fn hmac_sha384(key, key_len, msg, msg_len, out48): i64 {
    # Per-worker banked scratch (3.9.6 — concurrent-TLS-handshake fix).
    # kprime384/ipad384/opad384/inner_hash384 were function-scope
    # `secret var`s (static globals, quirk #1) and the two SHA-384 ctxs
    # were `fl_alloc`'d — both raced under concurrent handshakes
    # (HMAC-SHA384 is the HKDF-SHA384 primitive driving the
    # TLS_AES_256_GCM_SHA384 key schedule on every handshake). Banked
    # across `cbank()` lanes; secret lanes are plain `var` + per-lane
    # `memset` on exit (quirk #9); streaming ctx uses a banked `_into`
    # buffer (no fl_alloc). Block size B = 128, digest L = 48.
    var bk = cbank();
    var kprime384[8192];    var kprime384b    = &kprime384    + bk * 128;  # 128 * SIGIL_CRYPTO_BANKS
    var ipad384[8192];      var ipad384b      = &ipad384      + bk * 128;
    var opad384[8192];      var opad384b      = &opad384      + bk * 128;
    var inner_hash384[3072]; var inner_hash384b = &inner_hash384 + bk * 48;  # 48 * SIGIL_CRYPTO_BANKS
    var hctx[13312];        var hctxb         = &hctx         + bk * 208;  # 208 * SIGIL_CRYPTO_BANKS (reused)

    # Step 1: Derive K' (128 bytes — the SHA-384 block size). The init
    # memset is retained because the key_len <= 128 branch relies on the
    # upper bytes being zero.
    memset(kprime384b, 0, 128);
    if (key_len > 128) {
        # Key longer than block — replace with its 48-byte hash
        # (48 B hash + 80 B zeros).
        sha384(key, key_len, kprime384b);
    } else {
        memcpy(kprime384b, key, key_len);
        # Rest already zeroed.
    }

    # Step 2: inner = SHA-384((K' xor ipad) || message)
    var i = 0;
    while (i < 128) {
        store8(ipad384b + i, (load8(kprime384b + i) & 0xFF) ^ 0x36);
        i = i + 1;
    }
    sha384_init_into(hctxb);
    sha384_update(hctxb, ipad384b, 128);
    sha384_update(hctxb, msg, msg_len);
    sha384_finalize(hctxb, inner_hash384b);

    # Step 3: outer = SHA-384((K' xor opad) || inner)  (reuse the ctx)
    i = 0;
    while (i < 128) {
        store8(opad384b + i, (load8(kprime384b + i) & 0xFF) ^ 0x5c);
        i = i + 1;
    }
    sha384_init_into(hctxb);
    sha384_update(hctxb, opad384b, 128);
    sha384_update(hctxb, inner_hash384b, 48);
    sha384_finalize(hctxb, out48);

    # Per-lane secret zeroization (replaces the lost `secret var`
    # guarantee; wipes only THIS worker's lane). inner_hash384 is a
    # public digest — left as-is.
    memset(kprime384b, 0, 128);
    memset(ipad384b, 0, 128);
    memset(opad384b, 0, 128);
    return 0;
}

# --- bigint_ext.cyr ---

# bigint_ext.cyr — extended 256-bit arithmetic for Ed25519
# Adds: full 512-bit multiply, modular reduction for p=2^255-19,
# modular inversion, modular exponentiation, LE byte codec.
# Builds on lib/bigint.cyr

# ================================================================
# u256 <-> little-endian byte codec
# Previously inlined at 7 sites (5 decode + 2 encode loops, ~11 lines
# each) across ed25519.cyr. Safe to factor out: no nested function
# calls inside the loop body, so locals survive despite Cyrius'
# parameter-clobber rule.
# ================================================================

# Load 32 little-endian bytes from src into dst as four i64 limbs.
fn u256_load_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        store64(dst + i * 8,
        (load8(src + i*8) & 0xFF)
        | ((load8(src + i*8 + 1) & 0xFF) << 8)
        | ((load8(src + i*8 + 2) & 0xFF) << 16)
        | ((load8(src + i*8 + 3) & 0xFF) << 24)
        | ((load8(src + i*8 + 4) & 0xFF) << 32)
        | ((load8(src + i*8 + 5) & 0xFF) << 40)
        | ((load8(src + i*8 + 6) & 0xFF) << 48)
        | ((load8(src + i*8 + 7) & 0xFF) << 56));
        i = i + 1;
    }
    return 0;
}

# Store src (four i64 limbs) as 32 little-endian bytes at dst.
fn u256_store_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        var v = load64(src + i * 8);
        store8(dst + i*8, v & 0xFF);
        store8(dst + i*8 + 1, (v >> 8) & 0xFF);
        store8(dst + i*8 + 2, (v >> 16) & 0xFF);
        store8(dst + i*8 + 3, (v >> 24) & 0xFF);
        store8(dst + i*8 + 4, (v >> 32) & 0xFF);
        store8(dst + i*8 + 5, (v >> 40) & 0xFF);
        store8(dst + i*8 + 6, (v >> 48) & 0xFF);
        store8(dst + i*8 + 7, (v >> 56) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Full 256×256 → 512-bit multiply
# out: 64 bytes (8 limbs)
# ================================================================
# 3.3: per-call working state. The pre-3.3 module-globals were a
# cycc 3 local-clobbering workaround that cycc 6.0.1 no longer
# needs. `_mul64_full` is inlined here — it was its only caller
# and returning two values via globals (`_m64_lo` / `_m64_hi`)
# had no clean local equivalent.

# Schoolbook 256×256→512 multiply. RETAINED AS THE KAT ORACLE / REFERENCE
# for the Karatsuba `u256_mul_full` below (differential KAT in bigint.tcyr).
# Thread-safe: scalar locals + caller's `out` only, no static scratch (it
# runs on the Ed25519 parallel batch-verify path).
fn _u256_mul_full_schoolbook(out, a, b): i64 {
    memset(out, 0, 64);
    var sbit = 1 << 63;
    var mask32 = 0xFFFFFFFF;
    var i = 0;
    while (i < 4) {
        var carry = 0;
        var j = 0;
        while (j < 4) {
            # Inlined 64×64 → 128-bit multiply.
            var av = load64(a + i * 8);
            var bv = load64(b + j * 8);
            var aL = av & mask32;
            var aH = (av >> 32) & mask32;
            var bL = bv & mask32;
            var bH = (bv >> 32) & mask32;
            var ll = aL * bL;
            var lh = aL * bH;
            var hl = aH * bL;
            var hh = aH * bH;
            var mid = lh + hl;
            var mid_carry = 0;
            if ((mid ^ sbit) < (lh ^ sbit)) { mid_carry = 1; }
            var m_lo = ll + (mid << 32);
            var lo_carry = 0;
            if ((m_lo ^ sbit) < (ll ^ sbit)) { lo_carry = 1; }
            var m_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;

            var k = i + j;
            var prev = load64(out + k * 8);

            # s1 = prev + m_lo; c1 = overflow
            var s1 = prev + m_lo;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }

            # s2 = s1 + carry; c2 = overflow
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }

            store64(out + k * 8, s2);
            carry = m_hi + c1 + c2;
            j = j + 1;
        }
        if (i + 4 < 8) {
            store64(out + (i + 4) * 8, load64(out + (i + 4) * 8) + carry);
        }
        i = i + 1;
    }
    return 0;
}

# Thread-safe 128×128→256 schoolbook (2×2 limbs). `out` is 4 limbs (32 B);
# `a`, `b` are 2 limbs (16 B) each. Scalar locals only — no static scratch.
fn _u256k_mul128(out, a, b): i64 {
    memset(out, 0, 32);
    var sbit = 1 << 63;
    var mask32 = 0xFFFFFFFF;
    var i = 0;
    while (i < 2) {
        var carry = 0;
        var j = 0;
        while (j < 2) {
            var av = load64(a + i * 8);
            var bv = load64(b + j * 8);
            var aL = av & mask32; var aH = (av >> 32) & mask32;
            var bL = bv & mask32; var bH = (bv >> 32) & mask32;
            var ll = aL * bL; var lh = aL * bH; var hl = aH * bL; var hh = aH * bH;
            var mid = lh + hl;
            var mid_carry = 0;
            if ((mid ^ sbit) < (lh ^ sbit)) { mid_carry = 1; }
            var m_lo = ll + (mid << 32);
            var lo_carry = 0;
            if ((m_lo ^ sbit) < (ll ^ sbit)) { lo_carry = 1; }
            var m_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;
            var k = i + j;
            var prev = load64(out + k * 8);
            var s1 = prev + m_lo;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
            store64(out + k * 8, s2);
            carry = m_hi + c1 + c2;
            j = j + 1;
        }
        store64(out + (i + 2) * 8, load64(out + (i + 2) * 8) + carry);
        i = i + 1;
    }
    return 0;
}

# Karatsuba 256×256→512. a = aL + aH·2^128, b = bL + bH·2^128 (each half
# 2 limbs). z0 = aL·bL, z2 = aH·bH, z1 = (aL+aH)(bL+bH) − z0 − z2 (= aL·bH
# + aH·bL); out = z0 + z1·2^128 + z2·2^256. 12 × 64×64 muls vs the
# schoolbook's 16. THREAD-SAFE (scalar locals + caller's `out` + the
# stateless _u256k_mul128 helper — no static scratch, so it is safe on the
# Ed25519 parallel batch-verify path). KAT-gated byte-for-byte against
# `_u256_mul_full_schoolbook` (bigint.tcyr).
fn u256_mul_full(out, a, b): i64 {
    var sbit = 1 << 63;
    var mask32 = 0xFFFFFFFF;

    # z0 = aL·bL → out[0..3];  z2 = aH·bH → out[4..7].
    # (out now holds z0 + z2·2^256 — the result minus the middle term.)
    _u256k_mul128(out, a, b);
    _u256k_mul128(out + 32, a + 16, b + 16);

    var a0 = load64(a + 0);  var a1 = load64(a + 8);
    var a2 = load64(a + 16); var a3 = load64(a + 24);
    var b0 = load64(b + 0);  var b1 = load64(b + 8);
    var b2 = load64(b + 16); var b3 = load64(b + 24);

    # sL = aL + aH = (sl0, sl1) + cs·2^128   (cs ∈ {0,1})
    var sl0 = a0 + a2;
    var sc = 0; if ((sl0 ^ sbit) < (a0 ^ sbit)) { sc = 1; }
    var sl1 = a1 + a3;
    var cs = 0; if ((sl1 ^ sbit) < (a1 ^ sbit)) { cs = 1; }
    var sl1c = sl1 + sc; if ((sl1c ^ sbit) < (sl1 ^ sbit)) { cs = cs + 1; }
    sl1 = sl1c;

    # tL = bL + bH = (tl0, tl1) + ct·2^128
    var tl0 = b0 + b2;
    var tc = 0; if ((tl0 ^ sbit) < (b0 ^ sbit)) { tc = 1; }
    var tl1 = b1 + b3;
    var ct = 0; if ((tl1 ^ sbit) < (b1 ^ sbit)) { ct = 1; }
    var tl1c = tl1 + tc; if ((tl1c ^ sbit) < (tl1 ^ sbit)) { ct = ct + 1; }
    tl1 = tl1c;

    # m = (sl0,sl1) × (tl0,tl1) → m0..m3 (2×2 schoolbook, inline).
    var vL = sl0 & mask32; var vH = (sl0 >> 32) & mask32;
    var wL = tl0 & mask32; var wH = (tl0 >> 32) & mask32;
    var ll = vL * wL; var lh = vL * wH; var hl = vH * wL; var hh = vH * wH;
    var md = lh + hl; var mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p00lo = ll + (md << 32); var lc = 0; if ((p00lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p00hi = hh + (md >> 32) + (mc << 32) + lc;

    vL = sl0 & mask32; vH = (sl0 >> 32) & mask32; wL = tl1 & mask32; wH = (tl1 >> 32) & mask32;
    ll = vL * wL; lh = vL * wH; hl = vH * wL; hh = vH * wH;
    md = lh + hl; mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p01lo = ll + (md << 32); lc = 0; if ((p01lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p01hi = hh + (md >> 32) + (mc << 32) + lc;

    vL = sl1 & mask32; vH = (sl1 >> 32) & mask32; wL = tl0 & mask32; wH = (tl0 >> 32) & mask32;
    ll = vL * wL; lh = vL * wH; hl = vH * wL; hh = vH * wH;
    md = lh + hl; mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p10lo = ll + (md << 32); lc = 0; if ((p10lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p10hi = hh + (md >> 32) + (mc << 32) + lc;

    vL = sl1 & mask32; vH = (sl1 >> 32) & mask32; wL = tl1 & mask32; wH = (tl1 >> 32) & mask32;
    ll = vL * wL; lh = vL * wH; hl = vH * wL; hh = vH * wH;
    md = lh + hl; mc = 0; if ((md ^ sbit) < (lh ^ sbit)) { mc = 1; }
    var p11lo = ll + (md << 32); lc = 0; if ((p11lo ^ sbit) < (ll ^ sbit)) { lc = 1; }
    var p11hi = hh + (md >> 32) + (mc << 32) + lc;

    var m0 = p00lo;
    var t = p00hi + p01lo; var cm = 0; if ((t ^ sbit) < (p00hi ^ sbit)) { cm = 1; }
    var m1 = t + p10lo; if ((m1 ^ sbit) < (t ^ sbit)) { cm = cm + 1; }
    var u = p01hi + p10hi; var cm2 = 0; if ((u ^ sbit) < (p01hi ^ sbit)) { cm2 = 1; }
    var u2 = u + p11lo; if ((u2 ^ sbit) < (u ^ sbit)) { cm2 = cm2 + 1; }
    var m2 = u2 + cm; if ((m2 ^ sbit) < (u2 ^ sbit)) { cm2 = cm2 + 1; }
    var m3 = p11hi + cm2;
    var m4 = 0; if ((m3 ^ sbit) < (p11hi ^ sbit)) { m4 = 1; }

    # corrections: m += cs·(tl0,tl1)·2^128 + ct·(sl0,sl1)·2^128 + (cs·ct)·2^256
    if (cs == 1) {
        var n0 = m2 + tl0; var nc = 0; if ((n0 ^ sbit) < (m2 ^ sbit)) { nc = 1; } m2 = n0;
        var n1 = m3 + tl1; if ((n1 ^ sbit) < (m3 ^ sbit)) { m4 = m4 + 1; }
        m3 = n1 + nc; if ((m3 ^ sbit) < (n1 ^ sbit)) { m4 = m4 + 1; }
    }
    if (ct == 1) {
        var o0 = m2 + sl0; var oc = 0; if ((o0 ^ sbit) < (m2 ^ sbit)) { oc = 1; } m2 = o0;
        var o1 = m3 + sl1; if ((o1 ^ sbit) < (m3 ^ sbit)) { m4 = m4 + 1; }
        m3 = o1 + oc; if ((m3 ^ sbit) < (o1 ^ sbit)) { m4 = m4 + 1; }
    }
    if (cs == 1) { if (ct == 1) { m4 = m4 + 1; } }

    # z1 = m − z0 − z2  (z0 = out[0..3], z2 = out[4..7]; result ≥ 0).
    var z00 = load64(out + 0);  var z01 = load64(out + 8);
    var z02 = load64(out + 16); var z03 = load64(out + 24);
    var z20 = load64(out + 32); var z21 = load64(out + 40);
    var z22 = load64(out + 48); var z23 = load64(out + 56);
    var br = 0; var dq = 0; var dq2 = 0; var nb = 0;
    dq = m0 - z00; br = 0; if ((m0 ^ sbit) < (z00 ^ sbit)) { br = 1; } m0 = dq;
    dq = m1 - z01; nb = 0; if ((m1 ^ sbit) < (z01 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m1 = dq2; br = nb;
    dq = m2 - z02; nb = 0; if ((m2 ^ sbit) < (z02 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m2 = dq2; br = nb;
    dq = m3 - z03; nb = 0; if ((m3 ^ sbit) < (z03 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m3 = dq2; br = nb;
    m4 = m4 - br;
    dq = m0 - z20; br = 0; if ((m0 ^ sbit) < (z20 ^ sbit)) { br = 1; } m0 = dq;
    dq = m1 - z21; nb = 0; if ((m1 ^ sbit) < (z21 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m1 = dq2; br = nb;
    dq = m2 - z22; nb = 0; if ((m2 ^ sbit) < (z22 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m2 = dq2; br = nb;
    dq = m3 - z23; nb = 0; if ((m3 ^ sbit) < (z23 ^ sbit)) { nb = 1; }
    dq2 = dq - br; if ((dq ^ sbit) < (br ^ sbit)) { nb = nb + 1; } m3 = dq2; br = nb;
    m4 = m4 - br;

    # out += z1·2^128  (add m0..m4 into out[2..6], carry to out[7]).
    var oc2 = 0; var p = 0; var p2 = 0; var nc2 = 0;
    p = load64(out + 16) + m0; if ((p ^ sbit) < (m0 ^ sbit)) { oc2 = 1; } store64(out + 16, p);
    p = load64(out + 24) + m1; nc2 = 0; if ((p ^ sbit) < (m1 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 24, p2); oc2 = nc2;
    p = load64(out + 32) + m2; nc2 = 0; if ((p ^ sbit) < (m2 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 32, p2); oc2 = nc2;
    p = load64(out + 40) + m3; nc2 = 0; if ((p ^ sbit) < (m3 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 40, p2); oc2 = nc2;
    p = load64(out + 48) + m4; nc2 = 0; if ((p ^ sbit) < (m4 ^ sbit)) { nc2 = 1; }
    p2 = p + oc2; if ((p2 ^ sbit) < (p ^ sbit)) { nc2 = nc2 + 1; } store64(out + 48, p2); oc2 = nc2;
    store64(out + 56, load64(out + 56) + oc2);
    return 0;
}

# ================================================================
# Reduction mod p = 2^255 - 19
# Uses: 2^256 ≡ 38 (mod p), so for 512-bit val = aH*2^256 + aL:
#   val mod p ≡ aL + 38*aH (mod p)
# May need 1-2 further subtractions.
# ================================================================

# Read-only-after-init: curve modulus p = 2^255 - 19 and the
# Solinas constant 38 (= 2 · 19) used in 2^256 ≡ 38 (mod p).
var _ed_p = 0;
var _ed_p_inited = 0;
var _mod_38 = 0;

fn _init_ed_p(): i64 {
    if (_ed_p_inited == 1) { return 0; }
    _ed_p = u256_from_hex("7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffed");
    _mod_38 = u256_from(38);
    _ed_p_inited = 1;
    return 0;
}

fn u512_mod_p(out, val): i64 {
    _init_ed_p();

    # Per-thread banked scratch (3.6): every `var X[N]` here is a
    # static function-scope global (CLAUDE.md quirk #1), so each
    # batch-verify worker carves its own lane. One `cbank()` read per
    # call; all lanes derive from the same bank index.
    var bk = cbank();
    var aH[2048];   var aHb = &aH + bk * 32;     # 32 * SIGIL_CRYPTO_BANKS
    var aL[2048];   var aLb = &aL + bk * 32;
    var prod[4096]; var prodb = &prod + bk * 64; # 64 * SIGIL_CRYPTO_BANKS
    var lowp[2048]; var lowpb = &lowp + bk * 32;
    var r[2048];    var rb = &r + bk * 32;
    var extra[2048];var extrab = &extra + bk * 32;

    store64(aHb, load64(val + 32));
    store64(aHb + 8, load64(val + 40));
    store64(aHb + 16, load64(val + 48));
    store64(aHb + 24, load64(val + 56));

    store64(aLb, load64(val));
    store64(aLb + 8, load64(val + 8));
    store64(aLb + 16, load64(val + 16));
    store64(aLb + 24, load64(val + 24));

    u256_mul_full(prodb, aHb, _mod_38);

    store64(lowpb, load64(prodb));
    store64(lowpb + 8, load64(prodb + 8));
    store64(lowpb + 16, load64(prodb + 16));
    store64(lowpb + 24, load64(prodb + 24));

    var carry = u256_add(rb, aLb, lowpb);
    var overflow = carry + load64(prodb + 32);

    while (overflow > 0) {
        store64(extrab, overflow * 38);
        store64(extrab + 8, 0);
        store64(extrab + 16, 0);
        store64(extrab + 24, 0);
        overflow = u256_add(rb, rb, extrab);
    }

    while (u256_cmp(rb, _ed_p) >= 0) {
        u256_sub(rb, rb, _ed_p);
    }

    u256_copy(out, rb);
    return 0;
}

# ================================================================
# Field arithmetic mod p
# ================================================================

fn fp_add(r, a, b): i64 {
    _init_ed_p();
    u256_add(r, a, b);
    if (u256_cmp(r, _ed_p) >= 0) { u256_sub(r, r, _ed_p); }
    return 0;
}

fn fp_sub(r, a, b): i64 {
    _init_ed_p();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _ed_p); }
    return 0;
}

fn fp_neg(r, a): i64 {
    _init_ed_p();
    if (u256_is_zero(a) == 1) {
        u256_copy(r, a);
        return 0;
    }
    u256_sub(r, _ed_p, a);
    return 0;
}

fn fp_mul(r, a, b): i64 {
    # Per-thread banked scratch (3.6): `var prod[N]` is a static
    # function-scope global (CLAUDE.md quirk #1). Each batch-verify
    # worker uses its own 64-byte lane so concurrent field
    # multiplies on the [h]A / [S]B ladders never collide.
    var prod[4096];                       # 64 * SIGIL_CRYPTO_BANKS
    var prodb = &prod + cbank() * 64;
    u256_mul_full(prodb, a, b);
    u512_mod_p(r, prodb);
    return 0;
}

fn fp_sq(r, a): i64 {
    return fp_mul(r, a, a);
}

# ================================================================
# Modular exponentiation: r = base^exp mod p
# ================================================================

fn fp_pow(r, base, exp): i64 {
    _init_ed_p();
    # Per-thread banked scratch (3.6) — see fp_mul / u512_mod_p.
    var bk = cbank();
    var tmp[2048];      var tmpb = &tmp + bk * 32;       # 32 * SIGIL_CRYPTO_BANKS
    var result[2048];   var resultb = &result + bk * 32;
    var base_buf[2048]; var base_bufb = &base_buf + bk * 32;
    store64(resultb, 1);
    store64(resultb + 8, 0);
    store64(resultb + 16, 0);
    store64(resultb + 24, 0);
    u256_copy(base_bufb, base);
    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx = i % 64;
        var bit = (load64(exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_mul(tmpb, resultb, base_bufb);
            u256_copy(resultb, tmpb);
        }
        fp_mul(tmpb, base_bufb, base_bufb);
        u256_copy(base_bufb, tmpb);
        i = i + 1;
    }
    u256_copy(r, resultb);
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p for p = 2^255 - 19
# Bernstein's addition chain from the curve25519 reference:
# 254 squarings + 11 multiplies = 265 fp_mul calls
# (vs the generic fp_pow(p-2): ~512 fp_mul calls).
# ================================================================

fn _fpi_sq_n(buf, n): i64 {
    # In-place square `buf` n times.
    var i = 0;
    while (i < n) {
        fp_sq(buf, buf);
        i = i + 1;
    }
    return 0;
}

fn fp_inv(r, a): i64 {
    _init_ed_p();
    # Per-thread banked scratch (3.6): these 8 chain temporaries are
    # static function-scope globals (CLAUDE.md quirk #1) and fp_inv is
    # on the parallel verify path (ge_to_bytes → fp_inv), so each
    # worker inverts into its own lane. One `cbank()` read per call.
    var bk = cbank();
    var t0[2048];    var t0b = &t0 + bk * 32;       # 32 * SIGIL_CRYPTO_BANKS
    var z9[2048];    var z9b = &z9 + bk * 32;
    var z11[2048];   var z11b = &z11 + bk * 32;
    var z5[2048];    var z5b = &z5 + bk * 32;
    var z10[2048];   var z10b = &z10 + bk * 32;
    var z50[2048];   var z50b = &z50 + bk * 32;
    var z100[2048];  var z100b = &z100 + bk * 32;
    var a_buf[2048]; var a_bufb = &a_buf + bk * 32;
    u256_copy(a_bufb, a);

    # z2 in t0: t0 = a^2
    fp_sq(t0b, a_bufb);
    # z9 = t0^4 * a   = a^9
    fp_sq(z9b, t0b);
    fp_sq(z9b, z9b);
    fp_mul(z9b, z9b, a_bufb);
    # z11 = z9 * z2(=t0) = a^11
    fp_mul(z11b, z9b, t0b);
    # z5 = z11^2 * z9  = a^(2^5 - 1) = a^31
    fp_sq(z5b, z11b);
    fp_mul(z5b, z5b, z9b);

    # z10 = z5^(2^5) * z5 = a^(2^10 - 1)
    fp_sq(z10b, z5b);
    _fpi_sq_n(z10b, 4);
    fp_mul(z10b, z10b, z5b);

    # t0 = z10^(2^10) * z10 = a^(2^20 - 1)
    fp_sq(t0b, z10b);
    _fpi_sq_n(t0b, 9);
    fp_mul(t0b, t0b, z10b);

    # t0 = t0^(2^20) * t0 = a^(2^40 - 1)
    # Save current t0 into z9 (which is dead after this point —
    # the last use was building z11).
    u256_copy(z9b, t0b);
    _fpi_sq_n(t0b, 20);
    fp_mul(t0b, t0b, z9b);

    # t0 = t0^(2^10) * z10 = a^(2^50 - 1)
    _fpi_sq_n(t0b, 10);
    fp_mul(z50b, t0b, z10b);

    # t0 = z50^(2^50) * z50 = a^(2^100 - 1)
    fp_sq(t0b, z50b);
    _fpi_sq_n(t0b, 49);
    fp_mul(z100b, t0b, z50b);

    # t0 = z100^(2^100) * z100 = a^(2^200 - 1)
    fp_sq(t0b, z100b);
    _fpi_sq_n(t0b, 99);
    fp_mul(t0b, t0b, z100b);

    # t0 = t0^(2^50) * z50 = a^(2^250 - 1)
    _fpi_sq_n(t0b, 50);
    fp_mul(t0b, t0b, z50b);

    # r = t0^(2^5) * z11 = a^(2^255 - 21) = a^(p - 2)
    _fpi_sq_n(t0b, 5);
    fp_mul(r, t0b, z11b);
    return 0;
}

# --- ecdsa_p256.cyr ---

# ecdsa_p256.cyr — ECDSA verify on NIST P-256 (secp256r1)
#
# Surface (Sigil 3.2.1):
#   fn ecdsa_p256_verify(pk, msg, msg_len, sig): i64
#   fn ecdsa_p256_verify_der(pk, msg, msg_len, sig_der, sig_der_len): i64
#
# Inputs (big-endian byte strings, per SEC 1 v2.0 §2.3):
#   pk:  64 bytes — Qx || Qy uncompressed affine public key
#   sig: 64 bytes — r || s, both big-endian
#
# Implementation references:
#   • FIPS 186-5 §6 — ECDSA algorithm
#   • SEC 1 v2.0 §4.1.4 — verifying operation
#   • FIPS 186-4 D.1.2.3 / SP 800-186 — P-256 curve parameters
#
# Constant-time discipline:
#   • Verify takes only public inputs (msg, pk, sig). No secret-data
#     branches exist on this path. The Montgomery-ladder scalar
#     multiplication is still used because (a) it's the same shape a
#     future sign path would need and (b) defense in depth — any
#     future caller composing internal sign / DH against the same
#     point-mul primitive inherits constant-time behaviour for free.
#   • Final r comparison uses OR-accumulation (`ct_eq_bytes_lens`
#     from `lib/ct.cyr`), matching the pattern in `ed25519.cyr`.
#
# All working state lives in module globals because Cyrius'
# single-pass compiler can clobber locals across nested call chains
# (CLAUDE.md quirk #1). Same pattern as `bigint_ext.cyr` and
# `ed25519.cyr`.

# ================================================================
# Curve constants — initialised on first call via `_p256_init`.
# ================================================================

# Field prime p = 2^256 - 2^224 + 2^192 + 2^96 - 1
#   = 0xFFFFFFFF00000001 0000000000000000 00000000FFFFFFFF FFFFFFFFFFFFFFFF
var _p256_p = 0;

# Group order n =
#   0xFFFFFFFF00000000 FFFFFFFFFFFFFFFF BCE6FAADA7179E84 F3B9CAC2FC632551
var _p256_n = 0;

# Curve coefficient b for y^2 = x^3 - 3x + b:
#   b = 0x5AC635D8AA3A93E7 B3EBBD55769886BC 651D06B0CC53B0F6 3BCE3C3E27D2604B
var _p256_b = 0;

# Base point G (affine) — Gx, Gy
var _p256_gx = 0;
var _p256_gy = 0;

# Long-lived scratch (one allocation each, reused per call)
var _p256_prod = 0;        # 512-bit (64 B) full-product scratch
var _p256_tmp1 = 0;        # 32 B scratch
var _p256_tmp2 = 0;        # 32 B scratch
var _p256_one  = 0;        # constant 1 (256-bit)

var _p256_inited = 0;

fn _p256_init(): i64 {
    if (_p256_inited == 1) { return 0; }
    _p256_p  = u256_from_hex("ffffffff00000001000000000000000000000000ffffffffffffffffffffffff");
    _p256_n  = u256_from_hex("ffffffff00000000ffffffffffffffffbce6faada7179e84f3b9cac2fc632551");
    _p256_b  = u256_from_hex("5ac635d8aa3a93e7b3ebbd55769886bc651d06b0cc53b0f63bce3c3e27d2604b");
    _p256_gx = u256_from_hex("6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296");
    _p256_gy = u256_from_hex("4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5");
    _p256_prod = alloc(64 * SIGIL_CRYPTO_BANKS);
    _p256_tmp1 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_tmp2 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_one  = u256_from(1);
    _p256_inited = 1;
    return 0;
}

# ================================================================
# Big-endian byte ⇄ u256 codec
#
# SEC 1 §2.3.5: integers are encoded most-significant-byte-first.
# This differs from Ed25519 (RFC 8032 little-endian) so we cannot
# reuse `u256_load_le` from `bigint_ext.cyr` — the byte order
# inverts. Defined here local to the P-256 module.
# ================================================================

# Load 32 big-endian bytes from src into dst as four LE i64 limbs.
fn u256_load_be(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        # limb[i] (low → high) holds bytes [src + (3-i)*8 .. src + (3-i)*8 + 7]
        # where byte 0 of that range is the MSB of the limb.
        var off = (3 - i) * 8;
        store64(dst + i * 8,
        ((load8(src + off + 0) & 0xFF) << 56)
        | ((load8(src + off + 1) & 0xFF) << 48)
        | ((load8(src + off + 2) & 0xFF) << 40)
        | ((load8(src + off + 3) & 0xFF) << 32)
        | ((load8(src + off + 4) & 0xFF) << 24)
        | ((load8(src + off + 5) & 0xFF) << 16)
        | ((load8(src + off + 6) & 0xFF) << 8)
        | (load8(src + off + 7) & 0xFF));
        i = i + 1;
    }
    return 0;
}

# Store src (four LE i64 limbs) as 32 big-endian bytes at dst.
fn u256_store_be(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        var off = (3 - i) * 8;
        var v = load64(src + i * 8);
        store8(dst + off + 0, (v >> 56) & 0xFF);
        store8(dst + off + 1, (v >> 48) & 0xFF);
        store8(dst + off + 2, (v >> 40) & 0xFF);
        store8(dst + off + 3, (v >> 32) & 0xFF);
        store8(dst + off + 4, (v >> 24) & 0xFF);
        store8(dst + off + 5, (v >> 16) & 0xFF);
        store8(dst + off + 6, (v >> 8) & 0xFF);
        store8(dst + off + 7, v & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Modular reduction mod p256 (or any 256-bit prime)
#
# Algorithm: textbook long-division.
#   R = 0
#   For each bit of val from bit 511 down to bit 0:
#       R = (R << 1) | bit
#       if R >= p, R -= p
#   Return R
#
# Each iteration runs on 256-bit values plus a single carry bit; the
# 257-bit transient (R = 2·prev_R + bit, which may exceed 2^256) is
# folded back via the identity:
#   (2^256 + R')  mod p  =  R' - p  mod 2^256     when R' < p
# i.e. when the carry bit is set, an unconditional `R -= p` realises
# the correct residue because the 256-bit unsigned wraparound supplies
# the missing +2^256 implicitly. After the conditional subtract,
# R < p again, restoring the loop invariant.
#
# 256 iterations × ~12 limb ops per iteration — slow but trivially
# correct. The Solinas word-level reduction that superseded this on the
# hot path shipped in 3.7.0 (`_p256_solinas_reduce`); this long-division
# form is retained as the differential-KAT reference.
# ================================================================

# Process bits 255 .. 0 of `lo` into accumulator R (mod p),
# given an initial R that is already in [0, p). Used by both p256_reduce
# (val high half pre-loaded) and modular ops that need it directly.
var _p256_R = 0;

fn _p256_long_div_reduce(R, lo): i64 {
    var i = 255;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u256_shl1(R, R);
        store64(R, load64(R) | bit);

        # Single conditional subtract covers both branches:
        #   • carry == 1 → V ∈ [2^256, 2p), V - p ∈ [2^256 - p, p), always valid
        #   • carry == 0, R >= p → standard reduce
        # When carry == 1 the unsigned wraparound of R - p gives the correct
        # residue because the implied +2^256 cancels.
        if (carry == 1) {
            u256_sub(R, R, _p256_p);
        } else {
            if (u256_cmp(R, _p256_p) >= 0) { u256_sub(R, R, _p256_p); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod p256 (val is 512-bit, r is 256-bit) — textbook long
# division. Retained as the correctness reference for the Solinas
# differential KAT (tests/tcyr/ecdsa_p256.tcyr); `p256_reduce` itself
# now uses the fast Solinas path below (3.7.0).
fn _p256_reduce_longdiv(out, val): i64 {
    _p256_init();
    if (_p256_R == 0) { _p256_R = alloc(32 * SIGIL_CRYPTO_BANKS); }
    var _p256_Rb = _p256_R + cbank() * 32;

    # Initialise R = high half of val, pre-reduce if R >= p.
    store64(_p256_Rb + 0, load64(val + 32));
    store64(_p256_Rb + 8, load64(val + 40));
    store64(_p256_Rb + 16, load64(val + 48));
    store64(_p256_Rb + 24, load64(val + 56));
    if (u256_cmp(_p256_Rb, _p256_p) >= 0) { u256_sub(_p256_Rb, _p256_Rb, _p256_p); }

    _p256_long_div_reduce(_p256_Rb, val);
    u256_copy(out, _p256_Rb);
    return 0;
}

# ================================================================
# Solinas fast reduction mod p256 (3.7.0)
#
# p256 = 2^256 − 2^224 + 2^192 + 2^96 − 1 is a Solinas (generalized
# Mersenne) prime, so a 512-bit product reduces via a fixed permutation
# of its sixteen 32-bit words c0..c15 (c0 = least significant) into nine
# 256-bit terms, combined as (FIPS 186-4 App. D.2 / GECC Alg. 2.29):
#
#   r = s1 + 2·s2 + 2·s3 + s4 + s5 − s6 − s7 − s8 − s9  (mod p256)
#
# Each term is < 2^256 (one conditional subtract reduces it into [0,p)),
# then combined with the audited constant-time-free fp_p256_add /
# fp_p256_sub (operands in [0,p), result stays in [0,p)). This replaces
# the 256-iteration bit-by-bit long division — ~20-50× fewer limb ops.
# Validated byte-for-byte against `_p256_reduce_longdiv` over random and
# edge inputs in ecdsa_p256.tcyr.
# ================================================================
var _p256_sol_t = 0;        # single 256-bit term scratch

# Read 32-bit word `idx` (0..15, little-endian) from a 64-byte product.
fn _p256_wd(prod, idx): i64 {
    var limb = load64(prod + (idx / 2) * 8);
    if ((idx & 1) == 0) { return limb & 0xFFFFFFFF; }
    return (limb >> 32) & 0xFFFFFFFF;
}

# Assemble a 256-bit value (32 bytes, little-endian) from eight 32-bit
# words w0 (low) .. w7 (high).
fn _p256_mk(out, w0, w1, w2, w3, w4, w5, w6, w7): i64 {
    store64(out + 0,  (w0 & 0xFFFFFFFF) | (w1 << 32));
    store64(out + 8,  (w2 & 0xFFFFFFFF) | (w3 << 32));
    store64(out + 16, (w4 & 0xFFFFFFFF) | (w5 << 32));
    store64(out + 24, (w6 & 0xFFFFFFFF) | (w7 << 32));
    return 0;
}

# Reduce a single term in [0, 2^256) into [0, p256): one conditional
# subtract (a term < 2^256 < 2·p256).
fn _p256_sol_red1(t): i64 {
    if (u256_cmp(t, _p256_p) >= 0) { u256_sub(t, t, _p256_p); }
    return 0;
}

fn _p256_solinas_reduce(out, val): i64 {
    _p256_init();
    if (_p256_sol_t == 0) { _p256_sol_t = alloc(32 * SIGIL_CRYPTO_BANKS); }
    var T = _p256_sol_t + cbank() * 32;

    var c0 = _p256_wd(val, 0);   var c1 = _p256_wd(val, 1);
    var c2 = _p256_wd(val, 2);   var c3 = _p256_wd(val, 3);
    var c4 = _p256_wd(val, 4);   var c5 = _p256_wd(val, 5);
    var c6 = _p256_wd(val, 6);   var c7 = _p256_wd(val, 7);
    var c8 = _p256_wd(val, 8);   var c9 = _p256_wd(val, 9);
    var c10 = _p256_wd(val, 10); var c11 = _p256_wd(val, 11);
    var c12 = _p256_wd(val, 12); var c13 = _p256_wd(val, 13);
    var c14 = _p256_wd(val, 14); var c15 = _p256_wd(val, 15);

    # s1 = (c7 c6 c5 c4 c3 c2 c1 c0)
    _p256_mk(out, c0, c1, c2, c3, c4, c5, c6, c7);
    _p256_sol_red1(out);

    # + 2·s2 ; s2 = (c15 c14 c13 c12 c11 0 0 0)
    _p256_mk(T, 0, 0, 0, c11, c12, c13, c14, c15); _p256_sol_red1(T);
    fp_p256_add(out, out, T); fp_p256_add(out, out, T);

    # + 2·s3 ; s3 = (0 c15 c14 c13 c12 0 0 0)
    _p256_mk(T, 0, 0, 0, c12, c13, c14, c15, 0); _p256_sol_red1(T);
    fp_p256_add(out, out, T); fp_p256_add(out, out, T);

    # + s4 ; s4 = (c15 c14 0 0 0 c10 c9 c8)
    _p256_mk(T, c8, c9, c10, 0, 0, 0, c14, c15); _p256_sol_red1(T);
    fp_p256_add(out, out, T);

    # + s5 ; s5 = (c8 c13 c15 c14 c13 c11 c10 c9)
    _p256_mk(T, c9, c10, c11, c13, c14, c15, c13, c8); _p256_sol_red1(T);
    fp_p256_add(out, out, T);

    # − s6 ; s6 = (c10 c8 0 0 0 c13 c12 c11)
    _p256_mk(T, c11, c12, c13, 0, 0, 0, c8, c10); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    # − s7 ; s7 = (c11 c9 0 0 c15 c14 c13 c12)
    _p256_mk(T, c12, c13, c14, c15, 0, 0, c9, c11); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    # − s8 ; s8 = (c12 0 c10 c9 c8 c15 c14 c13)
    _p256_mk(T, c13, c14, c15, c8, c9, c10, 0, c12); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    # − s9 ; s9 = (c13 0 c11 c10 c9 0 c15 c14)
    _p256_mk(T, c14, c15, 0, c9, c10, c11, 0, c13); _p256_sol_red1(T);
    fp_p256_sub(out, out, T);

    return 0;
}

# r = val mod p256 (val is 512-bit, r is 256-bit) — Solinas fast path.
fn p256_reduce(out, val): i64 {
    _p256_solinas_reduce(out, val);
    return 0;
}

# ================================================================
# Field arithmetic mod p256
# ================================================================

# r = (a + b) mod p
fn fp_p256_add(r, a, b): i64 {
    _p256_init();
    var carry = u256_add(r, a, b);
    # If a 257-bit carry occurred, treat as (R + 2^256) and subtract p
    # (same trick as the long-division reduce: u256_sub wraparound
    # supplies the implicit +2^256). After: r < 2^256 always.
    if (carry == 1) {
        u256_sub(r, r, _p256_p);
    }
    if (u256_cmp(r, _p256_p) >= 0) { u256_sub(r, r, _p256_p); }
    return 0;
}

# r = (a - b) mod p (handles underflow by adding p)
fn fp_p256_sub(r, a, b): i64 {
    _p256_init();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _p256_p); }
    return 0;
}

# r = (-a) mod p
fn fp_p256_neg(r, a): i64 {
    _p256_init();
    if (u256_is_zero(a) == 1) { u256_copy(r, a); return 0; }
    u256_sub(r, _p256_p, a);
    return 0;
}

# r = (a * b) mod p
fn fp_p256_mul(r, a, b): i64 {
    _p256_init();
    var _p256_prodb = _p256_prod + cbank() * 64;
    u256_mul_full(_p256_prodb, a, b);
    p256_reduce(r, _p256_prodb);
    return 0;
}

# r = a^2 mod p
fn fp_p256_sq(r, a): i64 {
    return fp_p256_mul(r, a, a);
}

# ================================================================
# Affine public-key validation — closes audit 2026-05-21 LOW-1.
#
# Verify that (x, y) satisfies the P-256 curve equation:
#     y^2 ≡ x^3 - 3*x + b  (mod p)
# and that both coordinates are in the field [0, p). Rejects the
# point at infinity ((0, 0) treated as such here per SEC 1 §3.2.2),
# off-curve points (invalid-curve attack, Bos et al. 2014), and
# coordinates outside the canonical range.
#
# Returns 1 if (x, y) is a valid affine point on P-256, 0 otherwise.
# x and y are 32-byte LE u256 limb buffers (the post-load_be form).
# ================================================================

var _onc_lhs = 0;
var _onc_rhs = 0;
var _onc_tmp = 0;
var _onc_three_x = 0;
var _onc_inited = 0;

fn _onc_init(): i64 {
    if (_onc_inited == 1) { return 0; }
    _p256_init();
    _onc_lhs = alloc(32 * SIGIL_CRYPTO_BANKS);
    _onc_rhs = alloc(32 * SIGIL_CRYPTO_BANKS);
    _onc_tmp = alloc(32 * SIGIL_CRYPTO_BANKS);
    _onc_three_x = alloc(32 * SIGIL_CRYPTO_BANKS);
    _onc_inited = 1;
    return 0;
}

fn pt_is_on_curve(x, y): i64 {
    _onc_init();
    var bk = cbank();
    var _onc_lhsb = _onc_lhs + bk * 32;
    var _onc_rhsb = _onc_rhs + bk * 32;
    var _onc_tmpb = _onc_tmp + bk * 32;
    var _onc_three_xb = _onc_three_x + bk * 32;
    # Range check: 0 ≤ x < p and 0 ≤ y < p.
    if (u256_cmp(x, _p256_p) >= 0) { return 0; }
    if (u256_cmp(y, _p256_p) >= 0) { return 0; }
    # Reject point at infinity (encoded as (0, 0) in affine).
    if (u256_is_zero(x) == 1) {
        if (u256_is_zero(y) == 1) { return 0; }
    }
    # lhs = y^2
    fp_p256_sq(_onc_lhsb, y);
    # rhs = x^3 - 3x + b
    fp_p256_sq(_onc_tmpb, x);
    fp_p256_mul(_onc_rhsb, _onc_tmpb, x);
    fp_p256_add(_onc_tmpb, x, x);
    fp_p256_add(_onc_three_xb, _onc_tmpb, x);
    fp_p256_sub(_onc_rhsb, _onc_rhsb, _onc_three_xb);
    fp_p256_add(_onc_rhsb, _onc_rhsb, _p256_b);
    if (u256_eq(_onc_lhsb, _onc_rhsb) == 1) { return 1; }
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p (Fermat's little theorem)
#
# Generic square-and-multiply over the 256-bit exponent p-2.
# Cost: 256 squarings + ~128 multiplies (Hamming weight of p-2 ≈ 128).
# An addition-chain optimisation (à la `fp_inv` in `bigint_ext.cyr`)
# can drop this to ~265 muls — tracked as the "scalar-inversion
# addition-chain" backlog item in docs/development/roadmap.md.
# ================================================================

var _p256_inv_tmp = 0;
var _p256_inv_res = 0;
var _p256_inv_base = 0;
var _p256_inv_exp = 0;     # p-2, precomputed
var _p256_inv_inited = 0;

fn _p256_inv_init(): i64 {
    if (_p256_inv_inited == 1) { return 0; }
    _p256_init();
    _p256_inv_tmp  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_inv_res  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_inv_base = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_inv_exp  = u256_clone(_p256_p);
    # exp = p - 2
    store64(_p256_inv_exp, load64(_p256_inv_exp) - 2);
    _p256_inv_inited = 1;
    return 0;
}

# r = a^(-1) mod p, generic binary square-and-multiply (Fermat a^(p-2)).
# RETAINED AS THE KAT ORACLE / REFERENCE for the fixed addition-chain
# `fp_p256_inv` below (differential KAT in ecdsa_p256.tcyr). Not on the
# hot path anymore. If a == 0 the result is 0 (caller gates on s != 0).
fn _fp_p256_inv_generic(r, a): i64 {
    _p256_inv_init();
    var bk = cbank();
    var _p256_inv_tmpb  = _p256_inv_tmp + bk * 32;
    var _p256_inv_resb  = _p256_inv_res + bk * 32;
    var _p256_inv_baseb = _p256_inv_base + bk * 32;
    # res = 1
    store64(_p256_inv_resb + 0, 1);
    store64(_p256_inv_resb + 8, 0);
    store64(_p256_inv_resb + 16, 0);
    store64(_p256_inv_resb + 24, 0);
    u256_copy(_p256_inv_baseb, a);

    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p256_inv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_p256_mul(_p256_inv_tmpb, _p256_inv_resb, _p256_inv_baseb);
            u256_copy(_p256_inv_resb, _p256_inv_tmpb);
        }
        fp_p256_sq(_p256_inv_tmpb, _p256_inv_baseb);
        u256_copy(_p256_inv_baseb, _p256_inv_tmpb);
        i = i + 1;
    }
    u256_copy(r, _p256_inv_resb);
    return 0;
}

# ----------------------------------------------------------------
# Fixed addition-chain field inverse a^(p-2) mod p  (3.7.x perf)
#
# p = 2^256 - 2^224 + 2^192 + 2^96 - 1, so p-2 has bit-runs (MSB->LSB):
#   [255:224]=1^32, [223:193]=0^31, [192]=1, [191:96]=0^96,
#   [95:32]=1^64, [31:2]=1^30, [1]=0, [0]=1.
# Built from 2^k-1 blocks (à la `fp_inv` in bigint_ext.cyr) in
# ~255 squarings + 12 multiplications, vs the generic loop's 256 sq +
# ~128 mul. The exponent (p-2) is a PUBLIC constant, so this is not a
# secret-dependent path — no CT concern. KAT-gated against
# `_fp_p256_inv_generic` (ecdsa_p256.tcyr differential test).
# ----------------------------------------------------------------
var _p256fi_t1 = 0;  var _p256fi_t2 = 0;  var _p256fi_t3 = 0;
var _p256fi_t6 = 0;  var _p256fi_t12 = 0; var _p256fi_t15 = 0;
var _p256fi_t30 = 0; var _p256fi_t32 = 0; var _p256fi_acc = 0;
var _p256fi_inited = 0;

fn _p256fi_init(): i64 {
    if (_p256fi_inited == 1) { return 0; }
    _p256_init();
    _p256fi_t1  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_t2  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_t3  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_t6  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_t12 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_t15 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_t30 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_t32 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_acc = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256fi_inited = 1;
    return 0;
}

# In-place square `buf` n times (field, mod p). fp_p256_mul reads both
# operands into _p256_prod before writing r, so r==a is alias-safe.
fn _fp_p256_sq_n(buf, n): i64 {
    var i = 0;
    while (i < n) {
        fp_p256_sq(buf, buf);
        i = i + 1;
    }
    return 0;
}

# r = a^(-1) mod p via the fixed addition chain. a == 0 → 0.
fn fp_p256_inv(r, a): i64 {
    _p256fi_init();
    var bk = cbank();
    var _p256fi_t1b  = _p256fi_t1  + bk * 32;
    var _p256fi_t2b  = _p256fi_t2  + bk * 32;
    var _p256fi_t3b  = _p256fi_t3  + bk * 32;
    var _p256fi_t6b  = _p256fi_t6  + bk * 32;
    var _p256fi_t12b = _p256fi_t12 + bk * 32;
    var _p256fi_t15b = _p256fi_t15 + bk * 32;
    var _p256fi_t30b = _p256fi_t30 + bk * 32;
    var _p256fi_t32b = _p256fi_t32 + bk * 32;
    var _p256fi_accb = _p256fi_acc + bk * 32;
    # --- 2^k-1 blocks ---
    u256_copy(_p256fi_t1b, a);                            # t1  = a^(2^1-1)
    fp_p256_sq(_p256fi_t2b, _p256fi_t1b);                 #       a^2
    fp_p256_mul(_p256fi_t2b, _p256fi_t2b, _p256fi_t1b);   # t2  = a^(2^2-1)
    fp_p256_sq(_p256fi_t3b, _p256fi_t2b);                 #       a^6
    fp_p256_mul(_p256fi_t3b, _p256fi_t3b, _p256fi_t1b);   # t3  = a^(2^3-1)
    u256_copy(_p256fi_t6b, _p256fi_t3b);
    _fp_p256_sq_n(_p256fi_t6b, 3);
    fp_p256_mul(_p256fi_t6b, _p256fi_t6b, _p256fi_t3b);   # t6  = a^(2^6-1)
    u256_copy(_p256fi_t12b, _p256fi_t6b);
    _fp_p256_sq_n(_p256fi_t12b, 6);
    fp_p256_mul(_p256fi_t12b, _p256fi_t12b, _p256fi_t6b); # t12 = a^(2^12-1)
    u256_copy(_p256fi_t15b, _p256fi_t12b);
    _fp_p256_sq_n(_p256fi_t15b, 3);
    fp_p256_mul(_p256fi_t15b, _p256fi_t15b, _p256fi_t3b); # t15 = a^(2^15-1)
    u256_copy(_p256fi_t30b, _p256fi_t15b);
    _fp_p256_sq_n(_p256fi_t30b, 15);
    fp_p256_mul(_p256fi_t30b, _p256fi_t30b, _p256fi_t15b);# t30 = a^(2^30-1)
    u256_copy(_p256fi_t32b, _p256fi_t30b);
    _fp_p256_sq_n(_p256fi_t32b, 2);
    fp_p256_mul(_p256fi_t32b, _p256fi_t32b, _p256fi_t2b); # t32 = a^(2^32-1)
    # --- assemble a^(p-2) ---
    u256_copy(_p256fi_accb, _p256fi_t32b);               # [255:224] 1^32
    _fp_p256_sq_n(_p256fi_accb, 31);                     # [223:193] 0^31
    fp_p256_sq(_p256fi_accb, _p256fi_accb);              # [192] 1
    fp_p256_mul(_p256fi_accb, _p256fi_accb, _p256fi_t1b);
    _fp_p256_sq_n(_p256fi_accb, 96);                     # [191:96] 0^96
    _fp_p256_sq_n(_p256fi_accb, 32);                     # [95:64] 1^32
    fp_p256_mul(_p256fi_accb, _p256fi_accb, _p256fi_t32b);
    _fp_p256_sq_n(_p256fi_accb, 32);                     # [63:32] 1^32
    fp_p256_mul(_p256fi_accb, _p256fi_accb, _p256fi_t32b);
    _fp_p256_sq_n(_p256fi_accb, 30);                     # [31:2] 1^30
    fp_p256_mul(_p256fi_accb, _p256fi_accb, _p256fi_t30b);
    fp_p256_sq(_p256fi_accb, _p256fi_accb);              # [1] 0
    fp_p256_sq(_p256fi_accb, _p256fi_accb);              # [0] 1
    fp_p256_mul(r, _p256fi_accb, _p256fi_t1b);
    return 0;
}

# ================================================================
# Scalar field arithmetic mod n (group order)
#
# Same long-division reduction as the field, but parameterised on
# `_p256_n` instead of `_p256_p`. ECDSA verify needs:
#   • reduce e (the SHA-256 message digest) mod n
#   • r, s ∈ [1, n-1] range checks (no reduction needed)
#   • s^(-1) mod n
#   • u1 = e * s^(-1) mod n, u2 = r * s^(-1) mod n
# ================================================================

var _p256_n_R = 0;

fn _p256_long_div_reduce_n(R, lo): i64 {
    var i = 255;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u256_shl1(R, R);
        store64(R, load64(R) | bit);

        if (carry == 1) {
            u256_sub(R, R, _p256_n);
        } else {
            if (u256_cmp(R, _p256_n) >= 0) { u256_sub(R, R, _p256_n); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod n (val is 512-bit, r is 256-bit)
fn n_reduce(out, val): i64 {
    _p256_init();
    if (_p256_n_R == 0) { _p256_n_R = alloc(32 * SIGIL_CRYPTO_BANKS); }
    var _p256_n_Rb = _p256_n_R + cbank() * 32;
    store64(_p256_n_Rb + 0, load64(val + 32));
    store64(_p256_n_Rb + 8, load64(val + 40));
    store64(_p256_n_Rb + 16, load64(val + 48));
    store64(_p256_n_Rb + 24, load64(val + 56));
    if (u256_cmp(_p256_n_Rb, _p256_n) >= 0) { u256_sub(_p256_n_Rb, _p256_n_Rb, _p256_n); }
    _p256_long_div_reduce_n(_p256_n_Rb, val);
    u256_copy(out, _p256_n_Rb);
    return 0;
}

# r = a mod n for a 256-bit `a` (avoid full 512-bit reduce when not needed).
fn fn_p256_reduce256(out, a): i64 {
    _p256_init();
    u256_copy(out, a);
    if (u256_cmp(out, _p256_n) >= 0) { u256_sub(out, out, _p256_n); }
    return 0;
}

# r = (a * b) mod n
var _p256_n_prod = 0;

fn fn_p256_mul(r, a, b): i64 {
    _p256_init();
    if (_p256_n_prod == 0) { _p256_n_prod = alloc(64 * SIGIL_CRYPTO_BANKS); }
    var _p256_n_prodb = _p256_n_prod + cbank() * 64;
    u256_mul_full(_p256_n_prodb, a, b);
    n_reduce(r, _p256_n_prodb);
    return 0;
}

# r = a^(-1) mod n (Fermat: a^(n-2) mod n).
var _p256_ninv_tmp = 0;
var _p256_ninv_res = 0;
var _p256_ninv_base = 0;
var _p256_ninv_exp = 0;
var _p256_ninv_inited = 0;

fn _p256_ninv_init(): i64 {
    if (_p256_ninv_inited == 1) { return 0; }
    _p256_init();
    _p256_ninv_tmp  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_ninv_res  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_ninv_base = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256_ninv_exp  = u256_clone(_p256_n);
    store64(_p256_ninv_exp, load64(_p256_ninv_exp) - 2);
    _p256_ninv_inited = 1;
    return 0;
}

# Generic binary square-and-multiply scalar inverse (Fermat a^(n-2)).
# RETAINED AS THE KAT ORACLE / REFERENCE for the windowed `fn_p256_inv`
# below. Each fn_p256_mul here is expensive (u256_mul_full + 256-iter
# long-division n_reduce), so the window's mul-count reduction is the
# real win on this path.
fn _fn_p256_inv_generic(r, a): i64 {
    _p256_ninv_init();
    var bk = cbank();
    var _p256_ninv_tmpb  = _p256_ninv_tmp  + bk * 32;
    var _p256_ninv_resb  = _p256_ninv_res  + bk * 32;
    var _p256_ninv_baseb = _p256_ninv_base + bk * 32;
    store64(_p256_ninv_resb + 0, 1);
    store64(_p256_ninv_resb + 8, 0);
    store64(_p256_ninv_resb + 16, 0);
    store64(_p256_ninv_resb + 24, 0);
    u256_copy(_p256_ninv_baseb, a);

    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p256_ninv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fn_p256_mul(_p256_ninv_tmpb, _p256_ninv_resb, _p256_ninv_baseb);
            u256_copy(_p256_ninv_resb, _p256_ninv_tmpb);
        }
        fn_p256_mul(_p256_ninv_tmpb, _p256_ninv_baseb, _p256_ninv_baseb);
        u256_copy(_p256_ninv_baseb, _p256_ninv_tmpb);
        i = i + 1;
    }
    u256_copy(r, _p256_ninv_resb);
    return 0;
}

# ----------------------------------------------------------------
# Windowed scalar inverse a^(n-2) mod n  (3.7.x perf)
#
# n-2's low 128 bits are irregular (no clean 2^k-1 decomposition like
# the field prime), so instead of a hand-derived optimal addition chain
# this uses a fixed 4-bit window: precompute a^1..a^15, then process the
# 64 nibbles of n-2 MSB->LSB (4 squarings + one table-mul per non-zero
# nibble). ~14 + 256 + ~55 = ~325 `fn_p256_mul` calls vs the generic
# 256 + ~128 = ~384 — and every saved mul avoids a 256-iteration
# long-division n_reduce, which is where this path's cost lives. The
# exponent (n-2) is a PUBLIC constant → no CT concern. `fn_p256_mul`
# writes r only after consuming a,b into _p256_n_prod, so r==a==b
# (in-place squaring) is alias-safe. KAT-gated vs the generic above.
# ----------------------------------------------------------------
var _p256si_tbl = 0;     # 16 × 32 B table; table[i] = a^i at +i*32
var _p256si_acc = 0;
var _p256si_inited = 0;

fn _p256si_init(): i64 {
    if (_p256si_inited == 1) { return 0; }
    _p256_ninv_init();           # ensures _p256_ninv_exp = n - 2
    _p256si_tbl = alloc(512 * SIGIL_CRYPTO_BANKS);
    _p256si_acc = alloc(32 * SIGIL_CRYPTO_BANKS);
    _p256si_inited = 1;
    return 0;
}

fn fn_p256_inv(r, a): i64 {
    _p256si_init();
    var bk = cbank();
    var _p256si_tblb = _p256si_tbl + bk * 512;
    var _p256si_accb = _p256si_acc + bk * 32;
    # table[1] = a; table[i] = table[i-1] * a  (i = 2..15)
    u256_copy(_p256si_tblb + 32, a);
    var ti = 2;
    while (ti < 16) {
        fn_p256_mul(_p256si_tblb + ti * 32, _p256si_tblb + (ti - 1) * 32, a);
        ti = ti + 1;
    }
    # acc = 1
    store64(_p256si_accb + 0, 1);
    store64(_p256si_accb + 8, 0);
    store64(_p256si_accb + 16, 0);
    store64(_p256si_accb + 24, 0);
    # process nibbles of (n-2) from MSB (nibble 63) to LSB (nibble 0)
    var ni = 63;
    while (ni >= 0) {
        fn_p256_mul(_p256si_accb, _p256si_accb, _p256si_accb);   # ^2
        fn_p256_mul(_p256si_accb, _p256si_accb, _p256si_accb);   # ^4
        fn_p256_mul(_p256si_accb, _p256si_accb, _p256si_accb);   # ^8
        fn_p256_mul(_p256si_accb, _p256si_accb, _p256si_accb);   # ^16
        var limb = load64(_p256_ninv_exp + (ni / 16) * 8);
        var nib = (limb >> ((ni & 15) * 4)) & 15;
        if (nib != 0) {
            fn_p256_mul(_p256si_accb, _p256si_accb, _p256si_tblb + nib * 32);
        }
        ni = ni - 1;
    }
    u256_copy(r, _p256si_accb);
    return 0;
}

# ================================================================
# Jacobian point arithmetic on P-256
#
# Representation: 96 bytes per point — concatenation of X, Y, Z (each
# 32 B, little-endian limbs). Affine (x, y) = (X/Z^2, Y/Z^3) for Z≠0;
# Z == 0 represents the point at infinity (identity element).
#
# Formulas: explicit-formulas-database "dbl-2001-b" (for a=-3) and
# "add-2007-bl" (general affine + Jacobian add). 4M+4S for double,
# 12M+4S for add — matches openssl/ec/ecp_nistz256.c reference.
# ================================================================

# Field offsets within a 96-byte point.
fn _pt_x(p): i64 { return p; }
fn _pt_y(p): i64 { return p + 32; }
fn _pt_z(p): i64 { return p + 64; }

# Allocate a fresh point (zeroed; represents point at infinity).
fn pt_alloc(): i64 {
    var p = alloc(96);
    memset(p, 0, 96);
    return p;
}

fn pt_set_infinity(p): i64 {
    memset(p, 0, 96);
    return 0;
}

fn pt_is_infinity(p): i64 {
    if (u256_is_zero(_pt_z(p)) == 1) { return 1; }
    return 0;
}

fn pt_copy(dst, src): i64 {
    memcpy(dst, src, 96);
    return 0;
}

# Constant-time conditional swap of two 96-byte points.
#   if swap == 1: a <-> b
#   if swap == 0: no change
# No branches on point data. (swap itself is treated as public — it
# is derived from the public scalar bits during Montgomery-ladder
# scalar multiplication.)
fn pt_cswap(swap, a, b): i64 {
    var mask = 0 - swap;     # 0 or 0xFF..FF
    var i = 0;
    while (i < 12) {         # 12 × 8 bytes = 96
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var t  = mask & (av ^ bv);
        store64(a + i * 8, av ^ t);
        store64(b + i * 8, bv ^ t);
        i = i + 1;
    }
    return 0;
}

# Load an affine point (x, y) into Jacobian (x, y, 1).
fn pt_from_affine(p, x, y): i64 {
    u256_copy(_pt_x(p), x);
    u256_copy(_pt_y(p), y);
    store64(_pt_z(p) + 0, 1);
    store64(_pt_z(p) + 8, 0);
    store64(_pt_z(p) + 16, 0);
    store64(_pt_z(p) + 24, 0);
    return 0;
}

# Convert Jacobian → affine. Out_x, out_y receive the affine coords.
# Returns 0 if p is the point at infinity (no inverse), 1 otherwise.
var _pt_aff_zinv  = 0;
var _pt_aff_zinv2 = 0;
var _pt_aff_zinv3 = 0;

fn pt_to_affine(out_x, out_y, p): i64 {
    if (pt_is_infinity(p) == 1) { return 0; }
    if (_pt_aff_zinv  == 0) { _pt_aff_zinv  = alloc(32 * SIGIL_CRYPTO_BANKS); }
    if (_pt_aff_zinv2 == 0) { _pt_aff_zinv2 = alloc(32 * SIGIL_CRYPTO_BANKS); }
    if (_pt_aff_zinv3 == 0) { _pt_aff_zinv3 = alloc(32 * SIGIL_CRYPTO_BANKS); }
    var bk = cbank();
    var _pt_aff_zinvb  = _pt_aff_zinv  + bk * 32;
    var _pt_aff_zinv2b = _pt_aff_zinv2 + bk * 32;
    var _pt_aff_zinv3b = _pt_aff_zinv3 + bk * 32;

    fp_p256_inv(_pt_aff_zinvb, _pt_z(p));
    fp_p256_sq(_pt_aff_zinv2b, _pt_aff_zinvb);
    fp_p256_mul(_pt_aff_zinv3b, _pt_aff_zinv2b, _pt_aff_zinvb);
    fp_p256_mul(out_x, _pt_x(p), _pt_aff_zinv2b);
    fp_p256_mul(out_y, _pt_y(p), _pt_aff_zinv3b);
    return 1;
}

# ----------------------------------------------------------------
# Point doubling — Jacobian, a = -3
# Source: explicit-formulas-database dbl-2001-b
#   delta = Z^2
#   gamma = Y^2
#   beta  = X * gamma
#   alpha = 3 * (X - delta) * (X + delta)         (uses a = -3)
#   X3 = alpha^2 - 8*beta
#   Z3 = (Y + Z)^2 - gamma - delta
#   Y3 = alpha * (4*beta - X3) - 8 * gamma^2
# ----------------------------------------------------------------

var _ptd_delta = 0;
var _ptd_gamma = 0;
var _ptd_beta  = 0;
var _ptd_alpha = 0;
var _ptd_t1    = 0;
var _ptd_t2    = 0;
var _ptd_x3    = 0;
var _ptd_y3    = 0;
var _ptd_z3    = 0;
var _ptd_inited = 0;

fn _ptd_init(): i64 {
    if (_ptd_inited == 1) { return 0; }
    _ptd_delta = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_gamma = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_beta  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_alpha = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_t1    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_t2    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_x3    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_y3    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_z3    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ptd_inited = 1;
    return 0;
}

fn pt_double(out, p): i64 {
    _p256_init();
    _ptd_init();
    if (pt_is_infinity(p) == 1) { pt_set_infinity(out); return 0; }
    var bk = cbank();
    var _ptd_deltab = _ptd_delta + bk * 32;
    var _ptd_gammab = _ptd_gamma + bk * 32;
    var _ptd_betab  = _ptd_beta  + bk * 32;
    var _ptd_alphab = _ptd_alpha + bk * 32;
    var _ptd_t1b    = _ptd_t1    + bk * 32;
    var _ptd_t2b    = _ptd_t2    + bk * 32;
    var _ptd_x3b    = _ptd_x3    + bk * 32;
    var _ptd_y3b    = _ptd_y3    + bk * 32;
    var _ptd_z3b    = _ptd_z3    + bk * 32;

    # delta = Z^2
    fp_p256_sq(_ptd_deltab, _pt_z(p));
    # gamma = Y^2
    fp_p256_sq(_ptd_gammab, _pt_y(p));
    # beta = X * gamma
    fp_p256_mul(_ptd_betab, _pt_x(p), _ptd_gammab);

    # alpha = 3 * (X - delta) * (X + delta)
    fp_p256_sub(_ptd_t1b, _pt_x(p), _ptd_deltab);
    fp_p256_add(_ptd_t2b, _pt_x(p), _ptd_deltab);
    fp_p256_mul(_ptd_alphab, _ptd_t1b, _ptd_t2b);
    # alpha = 3*alpha
    fp_p256_add(_ptd_t1b, _ptd_alphab, _ptd_alphab);
    fp_p256_add(_ptd_alphab, _ptd_t1b, _ptd_alphab);

    # X3 = alpha^2 - 8*beta
    fp_p256_sq(_ptd_x3b, _ptd_alphab);
    # 8*beta
    fp_p256_add(_ptd_t1b, _ptd_betab, _ptd_betab);   # 2*beta
    fp_p256_add(_ptd_t1b, _ptd_t1b, _ptd_t1b);       # 4*beta
    fp_p256_add(_ptd_t2b, _ptd_t1b, _ptd_t1b);       # 8*beta
    fp_p256_sub(_ptd_x3b, _ptd_x3b, _ptd_t2b);

    # Z3 = (Y + Z)^2 - gamma - delta
    fp_p256_add(_ptd_t1b, _pt_y(p), _pt_z(p));
    fp_p256_sq(_ptd_z3b, _ptd_t1b);
    fp_p256_sub(_ptd_z3b, _ptd_z3b, _ptd_gammab);
    fp_p256_sub(_ptd_z3b, _ptd_z3b, _ptd_deltab);

    # Y3 = alpha * (4*beta - X3) - 8 * gamma^2
    fp_p256_add(_ptd_t1b, _ptd_betab, _ptd_betab);   # 2*beta
    fp_p256_add(_ptd_t1b, _ptd_t1b, _ptd_t1b);       # 4*beta
    fp_p256_sub(_ptd_t1b, _ptd_t1b, _ptd_x3b);       # 4*beta - X3
    fp_p256_mul(_ptd_y3b, _ptd_alphab, _ptd_t1b);
    fp_p256_sq(_ptd_t2b, _ptd_gammab);               # gamma^2
    fp_p256_add(_ptd_t1b, _ptd_t2b, _ptd_t2b);       # 2*gamma^2
    fp_p256_add(_ptd_t1b, _ptd_t1b, _ptd_t1b);       # 4*gamma^2
    fp_p256_add(_ptd_t1b, _ptd_t1b, _ptd_t1b);       # 8*gamma^2
    fp_p256_sub(_ptd_y3b, _ptd_y3b, _ptd_t1b);

    u256_copy(_pt_x(out), _ptd_x3b);
    u256_copy(_pt_y(out), _ptd_y3b);
    u256_copy(_pt_z(out), _ptd_z3b);
    return 0;
}

# ----------------------------------------------------------------
# Point addition — Jacobian P + Q
# Source: explicit-formulas-database add-2007-bl
#   Z1Z1 = Z1^2,  Z2Z2 = Z2^2
#   U1 = X1 * Z2Z2,  U2 = X2 * Z1Z1
#   S1 = Y1 * Z2 * Z2Z2,  S2 = Y2 * Z1 * Z1Z1
#   H  = U2 - U1
#   I  = (2H)^2,  J = H * I
#   r  = 2*(S2 - S1)
#   V  = U1 * I
#   X3 = r^2 - J - 2V
#   Y3 = r * (V - X3) - 2 * S1 * J
#   Z3 = ((Z1 + Z2)^2 - Z1Z1 - Z2Z2) * H
#
# Handles all special cases: P=O → out=Q, Q=O → out=P, P=Q → double,
# P=-Q → infinity.
# ----------------------------------------------------------------

var _pta_z1z1 = 0;
var _pta_z2z2 = 0;
var _pta_u1   = 0;
var _pta_u2   = 0;
var _pta_s1   = 0;
var _pta_s2   = 0;
var _pta_h    = 0;
var _pta_i    = 0;
var _pta_j    = 0;
var _pta_r    = 0;
var _pta_v    = 0;
var _pta_t1   = 0;
var _pta_t2   = 0;
var _pta_x3   = 0;
var _pta_y3   = 0;
var _pta_z3   = 0;
var _pta_inited = 0;

fn _pta_init(): i64 {
    if (_pta_inited == 1) { return 0; }
    _pta_z1z1 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_z2z2 = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_u1   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_u2   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_s1   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_s2   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_h    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_i    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_j    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_r    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_v    = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_t1   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_t2   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_x3   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_y3   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_z3   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _pta_inited = 1;
    return 0;
}

fn pt_add(out, p, q): i64 {
    _p256_init();
    _pta_init();

    if (pt_is_infinity(p) == 1) { pt_copy(out, q); return 0; }
    if (pt_is_infinity(q) == 1) { pt_copy(out, p); return 0; }

    var bk = cbank();
    var _pta_z1z1b = _pta_z1z1 + bk * 32;
    var _pta_z2z2b = _pta_z2z2 + bk * 32;
    var _pta_u1b   = _pta_u1   + bk * 32;
    var _pta_u2b   = _pta_u2   + bk * 32;
    var _pta_s1b   = _pta_s1   + bk * 32;
    var _pta_s2b   = _pta_s2   + bk * 32;
    var _pta_hb    = _pta_h    + bk * 32;
    var _pta_ib    = _pta_i    + bk * 32;
    var _pta_jb    = _pta_j    + bk * 32;
    var _pta_rb    = _pta_r    + bk * 32;
    var _pta_vb    = _pta_v    + bk * 32;
    var _pta_t1b   = _pta_t1   + bk * 32;
    var _pta_t2b   = _pta_t2   + bk * 32;
    var _pta_x3b   = _pta_x3   + bk * 32;
    var _pta_y3b   = _pta_y3   + bk * 32;
    var _pta_z3b   = _pta_z3   + bk * 32;

    # Z1Z1, Z2Z2
    fp_p256_sq(_pta_z1z1b, _pt_z(p));
    fp_p256_sq(_pta_z2z2b, _pt_z(q));

    # U1 = X1 * Z2Z2; U2 = X2 * Z1Z1
    fp_p256_mul(_pta_u1b, _pt_x(p), _pta_z2z2b);
    fp_p256_mul(_pta_u2b, _pt_x(q), _pta_z1z1b);

    # S1 = Y1 * Z2 * Z2Z2; S2 = Y2 * Z1 * Z1Z1
    fp_p256_mul(_pta_t1b, _pt_z(q), _pta_z2z2b);
    fp_p256_mul(_pta_s1b, _pt_y(p), _pta_t1b);
    fp_p256_mul(_pta_t1b, _pt_z(p), _pta_z1z1b);
    fp_p256_mul(_pta_s2b, _pt_y(q), _pta_t1b);

    # H = U2 - U1
    fp_p256_sub(_pta_hb, _pta_u2b, _pta_u1b);

    # If H == 0: either P == Q (double) or P == -Q (infinity).
    if (u256_is_zero(_pta_hb) == 1) {
        if (u256_eq(_pta_s1b, _pta_s2b) == 1) {
            return pt_double(out, p);
        } else {
            pt_set_infinity(out);
            return 0;
        }
    }

    # I = (2H)^2
    fp_p256_add(_pta_t1b, _pta_hb, _pta_hb);          # 2H
    fp_p256_sq(_pta_ib, _pta_t1b);
    # J = H * I
    fp_p256_mul(_pta_jb, _pta_hb, _pta_ib);
    # r = 2 * (S2 - S1)
    fp_p256_sub(_pta_t1b, _pta_s2b, _pta_s1b);
    fp_p256_add(_pta_rb, _pta_t1b, _pta_t1b);
    # V = U1 * I
    fp_p256_mul(_pta_vb, _pta_u1b, _pta_ib);

    # X3 = r^2 - J - 2V
    fp_p256_sq(_pta_x3b, _pta_rb);
    fp_p256_sub(_pta_x3b, _pta_x3b, _pta_jb);
    fp_p256_add(_pta_t1b, _pta_vb, _pta_vb);          # 2V
    fp_p256_sub(_pta_x3b, _pta_x3b, _pta_t1b);

    # Y3 = r * (V - X3) - 2 * S1 * J
    fp_p256_sub(_pta_t1b, _pta_vb, _pta_x3b);
    fp_p256_mul(_pta_y3b, _pta_rb, _pta_t1b);
    fp_p256_mul(_pta_t1b, _pta_s1b, _pta_jb);
    fp_p256_add(_pta_t2b, _pta_t1b, _pta_t1b);        # 2*S1*J
    fp_p256_sub(_pta_y3b, _pta_y3b, _pta_t2b);

    # Z3 = ((Z1 + Z2)^2 - Z1Z1 - Z2Z2) * H
    fp_p256_add(_pta_t1b, _pt_z(p), _pt_z(q));
    fp_p256_sq(_pta_t2b, _pta_t1b);
    fp_p256_sub(_pta_t2b, _pta_t2b, _pta_z1z1b);
    fp_p256_sub(_pta_t2b, _pta_t2b, _pta_z2z2b);
    fp_p256_mul(_pta_z3b, _pta_t2b, _pta_hb);

    u256_copy(_pt_x(out), _pta_x3b);
    u256_copy(_pt_y(out), _pta_y3b);
    u256_copy(_pt_z(out), _pta_z3b);
    return 0;
}

# ----------------------------------------------------------------
# Mixed addition: Jacobian P + affine Q (Z2 == 1 implicit).  (3.7.x perf)
#
# Formula "madd-2007-bl" (explicit-formulas-database). With Z2=1 the
# Z2Z2 / U1=X1*Z2Z2 / S1=Y1*Z2*Z2Z2 multiplies vanish, dropping the cost
# to ~7M+4S vs the general add's ~11M+5S — ~4 muls saved per add. Used
# on the verify-only comb-G path (affine fixed-base table), where every
# table entry is affine. PUBLIC data only (same non-CT caveat as pt_add
# on the comb path). `out` may alias `p`: every coord of `p` is read
# before any coord of `out` is written. q is given as separate qx, qy
# 32-byte limb buffers (never the point at infinity here — the comb
# skips the nibble==0 / identity entry).
fn pt_add_mixed(out, p, qx, qy): i64 {
    _p256_init();
    _pta_init();

    if (pt_is_infinity(p) == 1) {
        u256_copy(_pt_x(out), qx);
        u256_copy(_pt_y(out), qy);
        store64(_pt_z(out) + 0, 1);
        store64(_pt_z(out) + 8, 0);
        store64(_pt_z(out) + 16, 0);
        store64(_pt_z(out) + 24, 0);
        return 0;
    }

    var bk = cbank();
    var _pta_z1z1b = _pta_z1z1 + bk * 32;
    var _pta_u2b   = _pta_u2   + bk * 32;
    var _pta_s2b   = _pta_s2   + bk * 32;
    var _pta_hb    = _pta_h    + bk * 32;
    var _pta_ib    = _pta_i    + bk * 32;
    var _pta_jb    = _pta_j    + bk * 32;
    var _pta_rb    = _pta_r    + bk * 32;
    var _pta_vb    = _pta_v    + bk * 32;
    var _pta_t1b   = _pta_t1   + bk * 32;
    var _pta_t2b   = _pta_t2   + bk * 32;
    var _pta_x3b   = _pta_x3   + bk * 32;
    var _pta_y3b   = _pta_y3   + bk * 32;
    var _pta_z3b   = _pta_z3   + bk * 32;

    # Z1Z1 = Z1^2
    fp_p256_sq(_pta_z1z1b, _pt_z(p));
    # U2 = X2 * Z1Z1   (U1 = X1 since Z2 = 1)
    fp_p256_mul(_pta_u2b, qx, _pta_z1z1b);
    # S2 = Y2 * Z1 * Z1Z1   (S1 = Y1)
    fp_p256_mul(_pta_t1b, _pt_z(p), _pta_z1z1b);
    fp_p256_mul(_pta_s2b, qy, _pta_t1b);
    # H = U2 - X1
    fp_p256_sub(_pta_hb, _pta_u2b, _pt_x(p));

    # H == 0: P == Q (double) or P == -Q (infinity).
    if (u256_is_zero(_pta_hb) == 1) {
        if (u256_eq(_pt_y(p), _pta_s2b) == 1) {
            return pt_double(out, p);
        } else {
            pt_set_infinity(out);
            return 0;
        }
    }

    # HH = H^2  (kept in _pta_i for Z3)
    fp_p256_sq(_pta_ib, _pta_hb);
    # I = 4*HH   (in _pta_t1)
    fp_p256_add(_pta_t1b, _pta_ib, _pta_ib);
    fp_p256_add(_pta_t1b, _pta_t1b, _pta_t1b);
    # J = H * I
    fp_p256_mul(_pta_jb, _pta_hb, _pta_t1b);
    # r = 2*(S2 - Y1)
    fp_p256_sub(_pta_t2b, _pta_s2b, _pt_y(p));
    fp_p256_add(_pta_rb, _pta_t2b, _pta_t2b);
    # V = X1 * I
    fp_p256_mul(_pta_vb, _pt_x(p), _pta_t1b);

    # X3 = r^2 - J - 2V
    fp_p256_sq(_pta_x3b, _pta_rb);
    fp_p256_sub(_pta_x3b, _pta_x3b, _pta_jb);
    fp_p256_add(_pta_t2b, _pta_vb, _pta_vb);
    fp_p256_sub(_pta_x3b, _pta_x3b, _pta_t2b);

    # Y3 = r*(V - X3) - 2*Y1*J
    fp_p256_sub(_pta_t2b, _pta_vb, _pta_x3b);
    fp_p256_mul(_pta_y3b, _pta_rb, _pta_t2b);
    fp_p256_mul(_pta_t2b, _pt_y(p), _pta_jb);
    fp_p256_add(_pta_t1b, _pta_t2b, _pta_t2b);        # 2*Y1*J
    fp_p256_sub(_pta_y3b, _pta_y3b, _pta_t1b);

    # Z3 = (Z1 + H)^2 - Z1Z1 - HH
    fp_p256_add(_pta_t1b, _pt_z(p), _pta_hb);
    fp_p256_sq(_pta_z3b, _pta_t1b);
    fp_p256_sub(_pta_z3b, _pta_z3b, _pta_z1z1b);
    fp_p256_sub(_pta_z3b, _pta_z3b, _pta_ib);

    u256_copy(_pt_x(out), _pta_x3b);
    u256_copy(_pt_y(out), _pta_y3b);
    u256_copy(_pt_z(out), _pta_z3b);
    return 0;
}

# ----------------------------------------------------------------
# Constant-time scalar multiplication via Montgomery ladder.
#   R0 = O, R1 = P, prev = 0
#   for i = 255 .. 0:
#       bit = scalar bit i
#       cswap(R0, R1, prev XOR bit)   # bring "double target" to R0
#       R1 = R0 + R1
#       R0 = 2 * R0
#       prev = bit
#   cswap(R0, R1, prev)               # final unswap
#   return R0
#
# Branches only on public swap masks; field/point ops always run in
# fixed sequence. Defense-in-depth: ECDSA verify inputs are public,
# but any future sign / DH path through this primitive inherits the
# constant-time behaviour for free.
# ----------------------------------------------------------------

var _ptm_r0 = 0;
var _ptm_r1 = 0;
var _ptm_sum = 0;
var _ptm_dbl = 0;
var _ptm_inited = 0;

fn _ptm_init(): i64 {
    if (_ptm_inited == 1) { return 0; }
    _ptm_r0 = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ptm_r1 = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ptm_sum = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ptm_dbl = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ptm_inited = 1;
    return 0;
}

# out = k * P, where k is a 256-bit scalar (LE limbs) and P is Jacobian.
fn pt_scalarmul(out, k, P): i64 {
    _p256_init();
    _ptm_init();
    var bk = cbank();
    var _ptm_r0b  = _ptm_r0  + bk * 96;
    var _ptm_r1b  = _ptm_r1  + bk * 96;
    var _ptm_sumb = _ptm_sum + bk * 96;
    var _ptm_dblb = _ptm_dbl + bk * 96;

    pt_set_infinity(_ptm_r0b);
    pt_copy(_ptm_r1b, P);

    var scalar = k;
    var prev = 0;
    var i = 255;
    while (i >= 0) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(scalar + limb_idx * 8) >> bit_idx) & 1;
        var swap = prev ^ bit;
        pt_cswap(swap, _ptm_r0b, _ptm_r1b);

        pt_add(_ptm_sumb, _ptm_r0b, _ptm_r1b);
        pt_double(_ptm_dblb, _ptm_r0b);
        pt_copy(_ptm_r1b, _ptm_sumb);
        pt_copy(_ptm_r0b, _ptm_dblb);

        prev = bit;
        i = i - 1;
    }
    pt_cswap(prev, _ptm_r0b, _ptm_r1b);
    pt_copy(out, _ptm_r0b);
    return 0;
}

# ================================================================
# Fixed-base comb for the generator G (verify-only, NON-constant-time)
#
# G is a public constant, and `ecdsa_p256_verify` consumes only public
# data (digest, signature, public key), so the `u1·G` term can use a
# fast table-indexed comb instead of the constant-time Montgomery ladder
# (`pt_scalarmul`). **This must never be used on a secret scalar** — the
# table index leaks the scalar nibble via cache timing. The signing path
# (`ecdsa_sign.cyr`, secret nonce k·G) deliberately stays on
# `pt_scalarmul`; only the verify `u1·G` site calls this.
#
# 4-bit windowed comb (the same shape ed25519 uses for its base point):
#   table[i][k] = k · 16^i · G   for window i ∈ [0,64), digit k ∈ [0,16)
#   k·G = Σ_i table[i][ nibble_i(k) ]
# Cost: 64 table reads + 64 Jacobian adds, zero doublings on the hot
# path (the 4 doublings per window happen once, at table-build time).
# Table: 64 × 16 × 96 B = 98304 B, built once on the main thread (ECDSA
# verify is not on the parallel batch path, so no banking is needed).
# ================================================================

# Affine comb table (3.7.x): table[i][k] = k · 16^i · G stored as affine
# x||y (64 B each) so the comb hot path uses the cheaper mixed add. The
# [i][0] entry (= O, identity) is unused — the main loop skips nibble 0.
var _p256_G_table_aff = 0;  # 64*16 affine points (64 B each)
var _p256_Gt_inited   = 0;
var _p256_gt_tmp      = 0;  # scratch point for the 4× doubling at build time
var _p256_gt_row      = 0;  # 16-Jacobian-point scratch row (1536 B), reused per i

# Build table[i][k] = k · 16^i · G in affine form. Runs once; the ~960
# one-time `pt_to_affine` inversions are amortized over the process.
fn _build_p256_G_table(): i64 {
    if (_p256_Gt_inited == 1) { return 0; }
    _p256_init();
    _ptm_init();
    _p256_G_table_aff = alloc(65536);             # 64 * 16 * 64
    if (_p256_gt_tmp == 0) { _p256_gt_tmp = pt_alloc(); }
    if (_p256_gt_row == 0) { _p256_gt_row = alloc(1536); }   # 16 * 96

    # basept walks Bi = 16^i · G, starting at B0 = G.
    var basept = pt_alloc();
    pt_from_affine(basept, _p256_gx, _p256_gy);

    var i = 0;
    while (i < 64) {
        # Build the Jacobian row in scratch: row[1] = Bi, row[k] = row[k-1] + Bi.
        pt_copy(_p256_gt_row + 96, basept);       # row[1] = Bi
        var k = 2;
        while (k < 16) {
            pt_add(_p256_gt_row + k * 96, _p256_gt_row + (k - 1) * 96, basept);
            k = k + 1;
        }
        # Convert row[1..15] to affine into table[i][1..15]; [i][0] left unused.
        var arow = _p256_G_table_aff + i * 16 * 64;
        var kk = 1;
        while (kk < 16) {
            pt_to_affine(arow + kk * 64, arow + kk * 64 + 32, _p256_gt_row + kk * 96);
            kk = kk + 1;
        }
        if (i < 63) {                             # Bi+1 = 16·Bi (four doublings)
            pt_double(_p256_gt_tmp, basept);      # 2Bi
            pt_double(basept, _p256_gt_tmp);      # 4Bi
            pt_double(_p256_gt_tmp, basept);      # 8Bi
            pt_double(basept, _p256_gt_tmp);      # 16Bi
        }
        i = i + 1;
    }
    _p256_Gt_inited = 1;
    return 0;
}

# out = k · G via the fixed-base comb. PUBLIC scalar only (non-CT).
# k is 256-bit LE limbs (4 × i64); nibble i = bits [4i, 4i+3]. nibble 0
# is the identity (skipped); other nibbles use the mixed add against the
# affine table.
fn p256_scalarmul_base(out, k): i64 {
    if (_p256_Gt_inited == 0) { _build_p256_G_table(); }
    pt_set_infinity(out);
    var i = 0;
    while (i < 64) {
        var limb = load64(k + (i / 16) * 8);
        var nib  = (limb >> ((i % 16) * 4)) & 0xF;
        if (nib != 0) {
            var ent = _p256_G_table_aff + (i * 16 + nib) * 64;
            pt_add_mixed(out, out, ent, ent + 32);
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Windowed scalar mul for a VARIABLE point Q (verify-only, NON-CT).
#
# Q (the public key) changes every verify, so a fixed-base comb does
# not apply — but the scalar (u2) and Q are still public, so we replace
# the constant-time Montgomery ladder (`pt_scalarmul`, 256 adds + 256
# doubles) with a 4-bit left-to-right windowed double-and-add:
#   precompute Qtab[k] = k·Q for k ∈ [0,16)   (15 adds, once per call)
#   acc = O; for nibble i = 63..0: acc = 16·acc + Qtab[nibble_i]
# Cost: 256 doubles + 64 adds + 15 precompute ≈ 1.5× fewer point ops
# than the ladder. **Public data only** (table index leaks the nibble);
# the secret-nonce signing path stays on `pt_scalarmul`.
# ================================================================

var _ecq_tab    = 0;    # 16 Jacobian multiples k·Q (96 B each), build scratch
var _ecq_aff    = 0;    # 16 affine multiples (64 B: x‖y); [0] unused (3.7.17)
var _ecq_acc    = 0;    # accumulator
var _ecq_zp     = 0;    # 16 running Z-products (32 B; idx 1..15 used)
var _ecq_zinv   = 0;    # batch-inversion running inverse (32 B)
var _ecq_ct1    = 0;    # affine-conversion scratch (32 B)
var _ecq_ct2    = 0;    # affine-conversion scratch (32 B)
var _ecq_inited = 0;

fn _ecq_init(): i64 {
    if (_ecq_inited == 1) { return 0; }
    _ecq_tab  = alloc(1536 * SIGIL_CRYPTO_BANKS);    # 16 * 96
    _ecq_aff  = alloc(1024 * SIGIL_CRYPTO_BANKS);    # 16 * 64
    _ecq_acc  = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ecq_zp   = alloc(512 * SIGIL_CRYPTO_BANKS);     # 16 * 32
    _ecq_zinv = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecq_ct1  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecq_ct2  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecq_inited = 1;
    return 0;
}

# out = k · Q for a VARIABLE affine point Q = (qx, qy), verify-only / non-CT
# (the secret-nonce signing path stays on the CT ladder pt_scalarmul).
#
# 4-bit window: build Qtab[1..15] = k·Q (mixed adds, Q affine), batch-invert
# their 15 Z-coordinates with Montgomery's trick (1 field inversion + ~3·14
# muls) so the whole window table goes affine, then run the 64-window
# double-and-add with the cheaper `pt_add_mixed`. 256 doublings + ≤64 mixed
# adds + 15 mixed build-adds + 1 inversion, vs the prior 256 doublings + ~79
# general adds. (3.7.17 lever 2b.)
fn p256_scalarmul_var(out, k, qx, qy): i64 {
    _p256_init();
    _ecq_init();
    var bk = cbank();
    var _ecq_tabb  = _ecq_tab  + bk * 1536;
    var _ecq_affb  = _ecq_aff  + bk * 1024;
    var _ecq_accb  = _ecq_acc  + bk * 96;
    var _ecq_zpb   = _ecq_zp   + bk * 512;
    var _ecq_zinvb = _ecq_zinv + bk * 32;
    var _ecq_ct1b  = _ecq_ct1  + bk * 32;
    var _ecq_ct2b  = _ecq_ct2  + bk * 32;

    # Build Qtab[1..15] in Jacobian via mixed adds. Qtab[1] = Q (Z = 1);
    # Qtab[k] = Qtab[k-1] + Q. (Qtab[2] hits pt_add_mixed's P==Q → 2P path.)
    pt_from_affine(_ecq_tabb + 96, qx, qy);
    var j = 2;
    while (j < 16) {
        pt_add_mixed(_ecq_tabb + j * 96, _ecq_tabb + (j - 1) * 96, qx, qy);
        j = j + 1;
    }

    # Montgomery batch inversion of the 15 Z's. zp[k] = Z_1·…·Z_k.
    # (k·Q ≠ O for 1 ≤ k < 16 on a prime-order curve, so every Z_k ≠ 0.)
    u256_copy(_ecq_zpb + 32, _pt_z(_ecq_tabb + 96));   # zp[1] = Z_1
    var m = 2;
    while (m < 16) {
        fp_p256_mul(_ecq_zpb + m * 32, _ecq_zpb + (m - 1) * 32, _pt_z(_ecq_tabb + m * 96));
        m = m + 1;
    }
    fp_p256_inv(_ecq_zinvb, _ecq_zpb + 15 * 32);       # zinv = 1 / zp[15]

    # Back-substitute: for kk = 15..1, Zinv_kk = zinv · zp[kk-1] (zp[0]=1),
    # then zinv *= Z_kk; convert Qtab[kk] to affine into _ecq_aff[kk].
    var kk = 15;
    while (kk >= 1) {
        if (kk == 1) {
            u256_copy(_ecq_ct1b, _ecq_zinvb);                              # Zinv_1 = zinv
        } else {
            fp_p256_mul(_ecq_ct1b, _ecq_zinvb, _ecq_zpb + (kk - 1) * 32);  # Zinv_kk
        }
        fp_p256_mul(_ecq_zinvb, _ecq_zinvb, _pt_z(_ecq_tabb + kk * 96));   # zinv *= Z_kk
        # x = X · Zinv^2 ; y = Y · Zinv^3
        fp_p256_sq(_ecq_ct2b, _ecq_ct1b);
        fp_p256_mul(_ecq_affb + kk * 64, _pt_x(_ecq_tabb + kk * 96), _ecq_ct2b);
        fp_p256_mul(_ecq_ct2b, _ecq_ct2b, _ecq_ct1b);
        fp_p256_mul(_ecq_affb + kk * 64 + 32, _pt_y(_ecq_tabb + kk * 96), _ecq_ct2b);
        kk = kk - 1;
    }

    # acc = Σ nibble_i · 16^i · Q (MS→LS), mixed adds against the affine
    # table; nibble 0 (identity) is skipped. pt_double(O)=O covers the
    # leading no-op doublings.
    pt_set_infinity(_ecq_accb);
    var i = 63;
    while (i >= 0) {
        pt_double(_ecq_accb, _ecq_accb);
        pt_double(_ecq_accb, _ecq_accb);
        pt_double(_ecq_accb, _ecq_accb);
        pt_double(_ecq_accb, _ecq_accb);
        var limb = load64(k + (i / 16) * 8);
        var nib  = (limb >> ((i % 16) * 4)) & 0xF;
        if (nib != 0) {
            pt_add_mixed(_ecq_accb, _ecq_accb, _ecq_affb + nib * 64, _ecq_affb + nib * 64 + 32);
        }
        i = i - 1;
    }
    pt_copy(out, _ecq_accb);
    return 0;
}

# ================================================================
# ECDSA verify (SEC 1 v2.0 §4.1.4 / FIPS 186-5 §6.4.2)
#
# Inputs:
#   pk    — 64 bytes, Qx || Qy (big-endian)
#   msg   — raw message bytes (this entry hashes them internally)
#   sig   — 64 bytes, r || s   (big-endian)
#
# Algorithm:
#   1. Verify r, s ∈ [1, n-1].
#   2. e = leftmost 256 bits of SHA-256(msg) — for P-256 this is the
#      full digest; reduce mod n.
#   3. w = s^(-1) mod n
#   4. u1 = e*w mod n,  u2 = r*w mod n
#   5. R = u1*G + u2*Q  (Jacobian, then to affine)
#   6. If R is the point at infinity, reject.
#   7. v = Rx mod n. Accept iff v == r.
# ================================================================

var _ecv_e        = 0;
var _ecv_r        = 0;
var _ecv_s        = 0;
var _ecv_w        = 0;
var _ecv_u1       = 0;
var _ecv_u2       = 0;
var _ecv_qx       = 0;
var _ecv_qy       = 0;
var _ecv_digest   = 0;
var _ecv_digest_padded = 0;
var _ecv_P_u1G    = 0;
var _ecv_P_u2Q    = 0;
var _ecv_R        = 0;
var _ecv_Rx       = 0;
var _ecv_Ry       = 0;
var _ecv_Rx_modn  = 0;
var _ecv_Q        = 0;
var _ecv_inited   = 0;

fn _ecv_init(): i64 {
    if (_ecv_inited == 1) { return 0; }
    _p256_init();
    _ecv_e        = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_r        = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_s        = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_w        = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_u1       = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_u2       = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_qx       = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_qy       = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_digest   = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_digest_padded = alloc(64 * SIGIL_CRYPTO_BANKS);
    _ecv_P_u1G    = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ecv_P_u2Q    = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ecv_R        = alloc(96 * SIGIL_CRYPTO_BANKS);
    _ecv_Rx       = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_Ry       = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_Rx_modn  = alloc(32 * SIGIL_CRYPTO_BANKS);
    _ecv_Q        = alloc(96 * SIGIL_CRYPTO_BANKS);
    _build_p256_G_table();        # fixed-base comb for the u1·G term
    _ecv_inited = 1;
    return 0;
}

# Public entry. Returns 1 on valid, 0 on invalid. Hashes msg with
# SHA-256 internally, then defers to the digest-taking core. The 4-arg
# signature is preserved byte-for-byte for the sgx/tdx/snp/dist callers.
fn ecdsa_p256_verify(pk, msg, msg_len, sig): i64 {
    _ecv_init();
    var _ecv_digestb = _ecv_digest + cbank() * 32;
    sha256(msg, msg_len, _ecv_digestb);
    return _ecdsa_p256_verify_digest(pk, _ecv_digestb, 32, sig);
}

# Digest-taking core. Verifies a P-256 signature against a PRECOMPUTED
# digest of `digest_len` bytes — the hash is the caller's choice,
# DECOUPLED from the curve. This is what lets x509 verify an off-diagonal
# chain link (a P-256 issuer signing a SHA-384 child). The message
# representative e is the leftmost bitlen(n) = 256 bits of the digest
# (FIPS 186-4 §6.4 / SEC 1 §4.1.4 step 3): bitlen(n_p256) is exactly 256,
# so for a digest of >= 32 bytes that is its leftmost 32 bytes (the MSBs;
# e.g. the top 32 of a 48-byte SHA-384 digest); a shorter digest is used
# whole, left-zero-padded. e is then reduced mod n with a single
# conditional subtract (e < 2^256 < 2n, so one subtract is exact).
fn _ecdsa_p256_verify_digest(pk, digest, digest_len, sig): i64 {
    _ecv_init();
    var bk = cbank();
    var _ecv_eb        = _ecv_e        + bk * 32;
    var _ecv_rb        = _ecv_r        + bk * 32;
    var _ecv_sb        = _ecv_s        + bk * 32;
    var _ecv_wb        = _ecv_w        + bk * 32;
    var _ecv_u1b       = _ecv_u1       + bk * 32;
    var _ecv_u2b       = _ecv_u2       + bk * 32;
    var _ecv_qxb       = _ecv_qx       + bk * 32;
    var _ecv_qyb       = _ecv_qy       + bk * 32;
    var _ecv_digest_paddedb = _ecv_digest_padded + bk * 64;
    var _ecv_P_u1Gb    = _ecv_P_u1G    + bk * 96;
    var _ecv_P_u2Qb    = _ecv_P_u2Q    + bk * 96;
    var _ecv_Rb        = _ecv_R        + bk * 96;
    var _ecv_Rxb       = _ecv_Rx       + bk * 32;
    var _ecv_Ryb       = _ecv_Ry       + bk * 32;
    var _ecv_Rx_modnb  = _ecv_Rx_modn  + bk * 32;

    # 1. Decode r, s from sig (big-endian). Range check r, s ∈ [1, n-1].
    u256_load_be(_ecv_rb, sig);
    u256_load_be(_ecv_sb, sig + 32);
    if (u256_is_zero(_ecv_rb) == 1) { return 0; }
    if (u256_is_zero(_ecv_sb) == 1) { return 0; }
    if (u256_cmp(_ecv_rb, _p256_n) >= 0) { return 0; }
    if (u256_cmp(_ecv_sb, _p256_n) >= 0) { return 0; }

    # 2. Decode Q from pk and validate it is on the curve.
    # Closes audit 2026-05-21 LOW-1 (invalid-curve attack — Bos et al.
    # 2014). pt_is_on_curve also rejects (0,0) and out-of-range
    # coordinates so the prior explicit checks are subsumed.
    u256_load_be(_ecv_qxb, pk);
    u256_load_be(_ecv_qyb, pk + 32);
    if (pt_is_on_curve(_ecv_qxb, _ecv_qyb) == 0) { return 0; }

    # 3. e = leftmost 256 bits of digest, mod n (FIPS 186-4 §6.4).
    #    Assemble the 32 scalar bytes big-endian: leftmost 32 of the
    #    digest when it is >= 32 bytes (pad == 0); whole digest left-
    #    zero-padded otherwise. (_ecv_digest_padded is 64-byte scratch.)
    var take = 32;
    if (digest_len < 32) { take = digest_len; }
    var pad = 32 - take;
    memset(_ecv_digest_paddedb, 0, 32);
    var i = 0;
    while (i < take) {
        store8(_ecv_digest_paddedb + pad + i, load8(digest + i) & 0xFF);
        i = i + 1;
    }
    u256_load_be(_ecv_eb, _ecv_digest_paddedb);
    if (u256_cmp(_ecv_eb, _p256_n) >= 0) { u256_sub(_ecv_eb, _ecv_eb, _p256_n); }

    # 4. w = s^-1 mod n
    fn_p256_inv(_ecv_wb, _ecv_sb);

    # 5. u1 = e*w mod n, u2 = r*w mod n
    fn_p256_mul(_ecv_u1b, _ecv_eb, _ecv_wb);
    fn_p256_mul(_ecv_u2b, _ecv_rb, _ecv_wb);

    # 6. R = u1*G + u2*Q. u1·G via the fixed-base affine comb; u2·Q via the
    #    4-bit window over an affine (batch-inverted) Q-table — both with the
    #    mixed add. Inputs are public, so the non-CT table indices are fine.
    p256_scalarmul_base(_ecv_P_u1Gb, _ecv_u1b);
    p256_scalarmul_var(_ecv_P_u2Qb, _ecv_u2b, _ecv_qxb, _ecv_qyb);
    pt_add(_ecv_Rb, _ecv_P_u1Gb, _ecv_P_u2Qb);

    if (pt_is_infinity(_ecv_Rb) == 1) { return 0; }

    # 7. v = Rx mod n; accept iff v == r.
    pt_to_affine(_ecv_Rxb, _ecv_Ryb, _ecv_Rb);
    fn_p256_reduce256(_ecv_Rx_modnb, _ecv_Rxb);
    if (u256_eq(_ecv_Rx_modnb, _ecv_rb) == 1) { return 1; }
    return 0;
}

# ================================================================
# DER signature decode wrapper
#
# X.509 / DER-encoded ECDSA signature shape:
#   SEQUENCE { INTEGER r, INTEGER s }
# Tag bytes: 0x30 (SEQUENCE), 0x02 (INTEGER).
# Each INTEGER may be 32 or 33 bytes (leading 0x00 if the MSB would
# otherwise set the sign bit). Short ints (< 32 bytes) are 0-padded
# on the left to 32 bytes for raw verify.
# ================================================================

# Decode one DER INTEGER starting at off into a big-endian destination
# of field width `fw` bytes (32 for P-256, 48 for P-384). Returns the
# next offset on success, or -1 on any malformed input. `dst` must be
# `fw` bytes; on success, contents are the big-endian r/s value
# zero-padded on the left.
fn _ecdsa_der_int_w(src, off, src_len, dst, fw): i64 {
    if (off + 2 > src_len) { return 0 - 1; }
    if ((load8(src + off) & 0xFF) != 0x02) { return 0 - 1; }
    var raw_len = load8(src + off + 1) & 0xFF;
    if (raw_len > fw + 1) { return 0 - 1; }      # too long for this field
    if (off + 2 + raw_len > src_len) { return 0 - 1; }

    var int_off = off + 2;
    var int_len = raw_len;
    # Strip a single leading 0x00 sign byte, if any. (DER requires it
    # when the next byte's high bit is set; we tolerate either.)
    if (raw_len == fw + 1) {
        if ((load8(src + int_off) & 0xFF) != 0x00) { return 0 - 1; }
        int_off = int_off + 1;
        int_len = int_len - 1;
    }
    if (int_len > fw) { return 0 - 1; }

    # Left-pad with zeros into the `fw`-byte big-endian destination.
    memset(dst, 0, fw);
    var pad = fw - int_len;
    var i = 0;
    while (i < int_len) {
        store8(dst + pad + i, load8(src + int_off + i) & 0xFF);
        i = i + 1;
    }
    return off + 2 + raw_len;   # consume the original encoded length
}

# P-256 (32-byte field) wrapper — preserves the original contract.
fn _ecdsa_der_int(src, off, src_len, dst): i64 {
    return _ecdsa_der_int_w(src, off, src_len, dst, 32);
}

fn ecdsa_p256_verify_der(pk, msg, msg_len, sig_der, sig_der_len): i64 {
    if (sig_der_len < 8) { return 0; }
    if ((load8(sig_der) & 0xFF) != 0x30) { return 0; }
    var seq_len = load8(sig_der + 1) & 0xFF;
    if (seq_len >= 0x80) { return 0; }   # short-form length only (always under 71 bytes for P-256)
    if (2 + seq_len > sig_der_len) { return 0; }

    # Banked (3.9.7) raw (r||s) scratch — consumed by ecdsa_p256_verify
    # before return. Was `secret var raw_sig[64]`: the v6.2.25 "arena fix"
    # stopped the per-call alloc(64) bump-heap leak (mTLS CertificateVerify
    # on a long-running server), but `secret var` arrays are still
    # function-scope STATICS (quirk #1, confirmed by a 2-thread probe), so
    # concurrent verify_der callers raced this buffer. Plain banked `var` +
    # per-lane wipe (quirk #9); r||s is public, so the wipe is hygiene.
    var bk = cbank();
    var raw_sig[4096];   var rsb = &raw_sig + bk * 64;   # 64 * SIGIL_CRYPTO_BANKS
    var off = _ecdsa_der_int(sig_der, 2, sig_der_len, rsb);
    if (off < 0) { memset(rsb, 0, 64); return 0; }
    off = _ecdsa_der_int(sig_der, off, sig_der_len, rsb + 32);
    if (off < 0) { memset(rsb, 0, 64); return 0; }

    var rc = ecdsa_p256_verify(pk, msg, msg_len, rsb);
    memset(rsb, 0, 64);
    return rc;
}

# --- ecdsa_p384.cyr ---

# ecdsa_p384.cyr — ECDSA verify on NIST P-384 (secp384r1)
#
# Sigil 3.2.4 — bite 4 of the TEE attestation arc. Mirrors
# `src/ecdsa_p256.cyr` (3.2.1) at 384 bits. The structural shape is
# identical (constants → BE codec → reduction → field arithmetic →
# scalar field → Jacobian point ops → Montgomery-ladder scalar mul
# → verify); the only differences are the 6-limb (48-byte) value
# width and the curve constants.
#
# Surface:
#   fn ecdsa_p384_verify(pk, msg, msg_len, sig): i64
#       — pk: 96 bytes (Qx || Qy big-endian)
#       — sig: 96 bytes (r || s big-endian)
#       — msg-rep: SHA-384(msg), per FIPS 186-5 §6.4.2 step 3
#         with hash output L = field width
#   fn pt_p384_is_on_curve(x, y): i64
#       — affine curve-equation + in-field-range gate; same shape
#         as `pt_is_on_curve` for P-256.
#
# Implementation references:
#   • FIPS 186-5 §6 — ECDSA algorithm
#   • SEC 1 v2.0 §4.1.4 — verifying operation
#   • FIPS 186-4 D.1.2.4 / SP 800-186 — P-384 curve params
#
# All u384 helpers are private to this module. If 3.2.5 (TDX) or a
# future consumer needs P-384 arithmetic outside ECDSA, lift them
# into `lib/bigint.cyr` as `u384_*` analogues at that point.

# ================================================================
# Curve constants — initialised on first call via `_p384_init`.
# ================================================================

# Field prime p384 = 2^384 - 2^128 - 2^96 + 2^32 - 1
#   = FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEFFFFFFFF0000000000000000FFFFFFFF
var _p384_p = 0;

# Group order n384
var _p384_n = 0;

# Curve coefficient b for y² = x³ - 3x + b
var _p384_b = 0;

# Base point G affine
var _p384_gx = 0;
var _p384_gy = 0;

# Long-lived scratch (init-time alloc, reused)
var _p384_prod = 0;        # 96-byte (768-bit) full-product
var _p384_tmp1 = 0;        # 48-byte
var _p384_tmp2 = 0;        # 48-byte
var _p384_one  = 0;

var _p384_inited = 0;

# ----------------------------------------------------------------
# u384 helpers — 6 × 64-bit LE limbs = 48 bytes
# ----------------------------------------------------------------

fn u384_zero(): i64 {
    var r = alloc(48);
    memset(r, 0, 48);
    return r;
}

fn u384_from(val): i64 {
    var r = alloc(48);
    memset(r, 0, 48);
    store64(r, val);
    return r;
}

fn u384_copy(dst, src): i64 {
    memcpy(dst, src, 48);
    return 0;
}

fn u384_clone(a): i64 {
    var r = alloc(48);
    memcpy(r, a, 48);
    return r;
}

fn u384_is_zero(a): i64 {
    var i = 0;
    while (i < 6) {
        if (load64(a + i * 8) != 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn u384_eq(a, b): i64 {
    var i = 0;
    while (i < 6) {
        if (load64(a + i * 8) != load64(b + i * 8)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Returns 1 if a > b, -1 if a < b, 0 if equal (unsigned).
fn u384_cmp(a, b): i64 {
    var sbit = 1 << 63;
    var i = 5;
    while (i >= 0) {
        var al = load64(a + i * 8);
        var bl = load64(b + i * 8);
        var ax = al ^ sbit;
        var bx = bl ^ sbit;
        if (ax > bx) { return 1; }
        if (ax < bx) { return 0 - 1; }
        i = i - 1;
    }
    return 0;
}

# r = a + b mod 2^384; returns carry-out (0 or 1).
fn u384_add(r, a, b): i64 {
    var sbit = 1 << 63;
    var carry = 0;
    var i = 0;
    while (i < 6) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var s1 = av + bv;
        var c1 = 0;
        if ((s1 ^ sbit) < (av ^ sbit)) { c1 = 1; }
        var s2 = s1 + carry;
        var c2 = 0;
        if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
        store64(r + i * 8, s2);
        carry = c1 + c2;
        i = i + 1;
    }
    return carry;
}

# r = a - b mod 2^384; returns borrow-out (0 or 1).
fn u384_sub(r, a, b): i64 {
    var sbit = 1 << 63;
    var borrow = 0;
    var i = 0;
    while (i < 6) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var nb = 0;
        if (borrow > 0) {
            if (bv == (0 - 1)) {
                nb = 1;
                store64(r + i * 8, av);
            } else {
                var bv2 = bv + 1;
                if ((bv2 ^ sbit) > (av ^ sbit)) { nb = 1; }
                store64(r + i * 8, av - bv2);
            }
        } else {
            if ((bv ^ sbit) > (av ^ sbit)) { nb = 1; }
            store64(r + i * 8, av - bv);
        }
        borrow = nb;
        i = i + 1;
    }
    return borrow;
}

# r = a << 1; returns MSB-out.
fn u384_shl1(r, a): i64 {
    var carry = 0;
    var i = 0;
    while (i < 6) {
        var v = load64(a + i * 8);
        store64(r + i * 8, (v << 1) | carry);
        carry = (v >> 63) & 1;
        i = i + 1;
    }
    return carry;
}

# 64×64 → 128 bit multiply (lo/hi via 32-bit halves). The 128-bit
# product is returned via a CALLER-PROVIDED 16-byte out buffer
# (out[0..7] = lo, out[8..15] = hi) rather than module-global scalars:
# the old `_p384_m64_lo/_hi` globals were read immediately after the
# call inside `u384_mul_full`'s tight inner loop, so under concurrency a
# sibling worker's call could clobber them between write and read (a
# read-modify-write race that can't be lane-banked as a scalar — quirk
# #9 / ADR 0004). The caller hands in a per-lane banked 16-byte slot.
fn _p384_mul64(a, b, out): i64 {
    var mask32 = 0xFFFFFFFF;
    var aL = a & mask32;
    var aH = (a >> 32) & mask32;
    var bL = b & mask32;
    var bH = (b >> 32) & mask32;
    var ll = aL * bL;
    var lh = aL * bH;
    var hl = aH * bL;
    var hh = aH * bH;
    var mid = lh + hl;
    var mid_carry = 0;
    if ((mid ^ (1 << 63)) < (lh ^ (1 << 63))) { mid_carry = 1; }
    var lo = ll + (mid << 32);
    var lo_carry = 0;
    if ((lo ^ (1 << 63)) < (ll ^ (1 << 63))) { lo_carry = 1; }
    store64(out, lo);
    store64(out + 8, hh + (mid >> 32) + (mid_carry << 32) + lo_carry);
    return 0;
}

# Per-lane 16-byte slot for _p384_mul64's lo/hi product (quirk #9 / ADR
# 0004). Module-global (banked) so the sign-path scrub in ecdsa_sign.cyr
# can wipe it by name: it holds intermediate products of secret operands
# on the sign path, so it is plain `alloc` + a per-lane scrub (NEVER
# `secret var` — a whole-array wipe would clobber a sibling worker's
# live lane). Lazily allocated on first u384_mul_full call.
var _p384_m64 = 0;

# Schoolbook 384×384 → 768-bit multiply.
# out: 96 bytes (12 limbs)
fn u384_mul_full(out, a, b): i64 {
    memset(out, 0, 96);
    if (_p384_m64 == 0) { _p384_m64 = alloc(16 * SIGIL_CRYPTO_BANKS); }
    var m64b = _p384_m64 + cbank() * 16;
    var sbit = 1 << 63;
    var i = 0;
    while (i < 6) {
        var carry = 0;
        var j = 0;
        while (j < 6) {
            _p384_mul64(load64(a + i * 8), load64(b + j * 8), m64b);
            var m64_lo = load64(m64b);
            var m64_hi = load64(m64b + 8);
            var k = i + j;
            var prev = load64(out + k * 8);
            var s1 = prev + m64_lo;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
            store64(out + k * 8, s2);
            carry = m64_hi + c1 + c2;
            j = j + 1;
        }
        if (i + 6 < 12) {
            store64(out + (i + 6) * 8, load64(out + (i + 6) * 8) + carry);
        }
        i = i + 1;
    }
    return 0;
}

# Parse a 96-char big-endian hex string into a 48-byte LE-limb buffer.
fn u384_from_hex(s): i64 {
    var r = u384_zero();
    var len = strlen(s);
    if (len > 96) { len = 96; }
    var i = 0;
    while (i < len) {
        # Shift left by 4 bits.
        var carry = 0;
        var li = 0;
        while (li < 6) {
            var v = load64(r + li * 8);
            store64(r + li * 8, (v << 4) | carry);
            carry = (v >> 60) & 0xF;
            li = li + 1;
        }
        var c = load8(s + i);
        var d = 0;
        if (c >= 48) { if (c <= 57) { d = c - 48; } }
        if (c >= 97) { if (c <= 102) { d = c - 87; } }
        if (c >= 65) { if (c <= 70) { d = c - 55; } }
        store64(r, load64(r) | d);
        i = i + 1;
    }
    return r;
}

# 48 BE bytes → 6 LE limbs.
fn u384_load_be(dst, src): i64 {
    var i = 0;
    while (i < 6) {
        var off = (5 - i) * 8;
        store64(dst + i * 8,
        ((load8(src + off + 0) & 0xFF) << 56)
        | ((load8(src + off + 1) & 0xFF) << 48)
        | ((load8(src + off + 2) & 0xFF) << 40)
        | ((load8(src + off + 3) & 0xFF) << 32)
        | ((load8(src + off + 4) & 0xFF) << 24)
        | ((load8(src + off + 5) & 0xFF) << 16)
        | ((load8(src + off + 6) & 0xFF) << 8)
        | (load8(src + off + 7) & 0xFF));
        i = i + 1;
    }
    return 0;
}

# 6 LE limbs → 48 BE bytes.
fn u384_store_be(dst, src): i64 {
    var i = 0;
    while (i < 6) {
        var off = (5 - i) * 8;
        var v = load64(src + i * 8);
        store8(dst + off + 0, (v >> 56) & 0xFF);
        store8(dst + off + 1, (v >> 48) & 0xFF);
        store8(dst + off + 2, (v >> 40) & 0xFF);
        store8(dst + off + 3, (v >> 32) & 0xFF);
        store8(dst + off + 4, (v >> 24) & 0xFF);
        store8(dst + off + 5, (v >> 16) & 0xFF);
        store8(dst + off + 6, (v >> 8) & 0xFF);
        store8(dst + off + 7, v & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ----------------------------------------------------------------
# Initialisation
# ----------------------------------------------------------------

fn _p384_init(): i64 {
    if (_p384_inited == 1) { return 0; }
    _p384_p  = u384_from_hex(
        "fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffeffffffff0000000000000000ffffffff");
    _p384_n  = u384_from_hex(
        "ffffffffffffffffffffffffffffffffffffffffffffffffc7634d81f4372ddf581a0db248b0a77aecec196accc52973");
    _p384_b  = u384_from_hex(
        "b3312fa7e23ee7e4988e056be3f82d19181d9c6efe8141120314088f5013875ac656398d8a2ed19d2a85c8edd3ec2aef");
    _p384_gx = u384_from_hex(
        "aa87ca22be8b05378eb1c71ef320ad746e1d3b628ba79b9859f741e082542a385502f25dbf55296c3a545e3872760ab7");
    _p384_gy = u384_from_hex(
        "3617de4a96262c6f5d9e98bf9292dc29f8f41dbd289a147ce9da3113b5f0b8c00a60b1ce1d7e819d7a431d7c90ea0e5f");
    _p384_prod = alloc(96 * SIGIL_CRYPTO_BANKS);
    _p384_tmp1 = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_tmp2 = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_one  = u384_from(1);
    _p384_inited = 1;
    return 0;
}

# ================================================================
# Reduction mod p384 — textbook long-division (384 iterations of
# shl1 + conditional subtract). Same shape as `p256_reduce`; the
# carry-bit invariant analysis carries over (V = 2·R + bit < 2p,
# so one conditional subtract per iteration suffices). Slow but
# correct and easy to audit; the Solinas word-level reduction that
# superseded this on the hot path shipped in 3.7.1
# (`_p384_solinas_reduce`); this long-division form is the retained
# differential-KAT reference.
# ================================================================

var _p384_R = 0;

fn _p384_long_div_reduce(R, lo): i64 {
    var i = 383;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u384_shl1(R, R);
        store64(R, load64(R) | bit);

        if (carry == 1) {
            u384_sub(R, R, _p384_p);
        } else {
            if (u384_cmp(R, _p384_p) >= 0) { u384_sub(R, R, _p384_p); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod p384 (val is 768-bit, r is 384-bit) — textbook long
# division. Retained as the correctness reference for the Solinas
# differential KAT (tests/tcyr/ecdsa_p384.tcyr); `p384_reduce` itself
# now uses the fast Solinas path below (3.7.1).
fn _p384_reduce_longdiv(out, val): i64 {
    _p384_init();
    if (_p384_R == 0) { _p384_R = alloc(48 * SIGIL_CRYPTO_BANKS); }
    var _p384_Rb = _p384_R + cbank() * 48;
    # R = high half of val
    memcpy(_p384_Rb, val + 48, 48);
    if (u384_cmp(_p384_Rb, _p384_p) >= 0) { u384_sub(_p384_Rb, _p384_Rb, _p384_p); }
    _p384_long_div_reduce(_p384_Rb, val);
    u384_copy(out, _p384_Rb);
    return 0;
}

# ================================================================
# Solinas fast reduction mod p384 (3.7.1)
#
# p384 = 2^384 − 2^128 − 2^96 + 2^32 − 1 is a Solinas (generalized
# Mersenne) prime, so a 768-bit product reduces via a fixed permutation
# of its twenty-four 32-bit words c0..c23 (c0 = least significant) into
# ten 384-bit terms, combined as (FIPS 186-4 App. D.2 / GECC Alg. 2.30):
#
#   r = s1 + 2·s2 + s3 + s4 + s5 + s6 + s7 − s8 − s9 − s10  (mod p384)
#
# Each term is < 2^384 (one conditional subtract reduces it into [0,p)),
# then combined with the audited fp_p384_add / fp_p384_sub. Replaces the
# 384-iteration long division. Validated byte-for-byte against
# `_p384_reduce_longdiv` over random + edge inputs in ecdsa_p384.tcyr.
# ================================================================
var _p384_sol_t = 0;        # single 384-bit term scratch

# Read 32-bit word `idx` (0..23, little-endian) from a 96-byte product.
fn _p384_wd(prod, idx): i64 {
    var limb = load64(prod + (idx / 2) * 8);
    if ((idx & 1) == 0) { return limb & 0xFFFFFFFF; }
    return (limb >> 32) & 0xFFFFFFFF;
}

# Assemble a 384-bit value (48 bytes, little-endian) from twelve 32-bit
# words w0 (low) .. w11 (high).
fn _p384_mk(out, w0, w1, w2, w3, w4, w5, w6, w7, w8, w9, w10, w11): i64 {
    store64(out + 0,  (w0 & 0xFFFFFFFF)  | (w1 << 32));
    store64(out + 8,  (w2 & 0xFFFFFFFF)  | (w3 << 32));
    store64(out + 16, (w4 & 0xFFFFFFFF)  | (w5 << 32));
    store64(out + 24, (w6 & 0xFFFFFFFF)  | (w7 << 32));
    store64(out + 32, (w8 & 0xFFFFFFFF)  | (w9 << 32));
    store64(out + 40, (w10 & 0xFFFFFFFF) | (w11 << 32));
    return 0;
}

# Reduce a single term in [0, 2^384) into [0, p384): one conditional
# subtract (a term < 2^384 < 2·p384).
fn _p384_sol_red1(t): i64 {
    if (u384_cmp(t, _p384_p) >= 0) { u384_sub(t, t, _p384_p); }
    return 0;
}

fn _p384_solinas_reduce(out, val): i64 {
    _p384_init();
    if (_p384_sol_t == 0) { _p384_sol_t = alloc(48 * SIGIL_CRYPTO_BANKS); }
    var T = _p384_sol_t + cbank() * 48;

    var c0 = _p384_wd(val, 0);   var c1 = _p384_wd(val, 1);
    var c2 = _p384_wd(val, 2);   var c3 = _p384_wd(val, 3);
    var c4 = _p384_wd(val, 4);   var c5 = _p384_wd(val, 5);
    var c6 = _p384_wd(val, 6);   var c7 = _p384_wd(val, 7);
    var c8 = _p384_wd(val, 8);   var c9 = _p384_wd(val, 9);
    var c10 = _p384_wd(val, 10); var c11 = _p384_wd(val, 11);
    var c12 = _p384_wd(val, 12); var c13 = _p384_wd(val, 13);
    var c14 = _p384_wd(val, 14); var c15 = _p384_wd(val, 15);
    var c16 = _p384_wd(val, 16); var c17 = _p384_wd(val, 17);
    var c18 = _p384_wd(val, 18); var c19 = _p384_wd(val, 19);
    var c20 = _p384_wd(val, 20); var c21 = _p384_wd(val, 21);
    var c22 = _p384_wd(val, 22); var c23 = _p384_wd(val, 23);

    # Reduction terms derived (and verified, 5000/5000 vs `x mod p`) from
    # the folding relation 2^384 ≡ 2^128 + 2^96 − 2^32 + 1 (mod p384).
    # Each term is a 12-word [t0..t11] value (t0 = least significant);
    # combined as P1 + P2 + P3 + P4 + P5 + 2·P6 + P8 − N1 − N2 − N3.

    # P1 = (c0..c11)  — the low half.
    _p384_mk(out, c0, c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11);
    _p384_sol_red1(out);

    # + P2
    _p384_mk(T, c12, c13, c14, c12, c12, c13, c14, c15, c16, c17, c18, c19); _p384_sol_red1(T);
    fp_p384_add(out, out, T);

    # + P3
    _p384_mk(T, c20, c22, c23, c15, c13, c14, c15, c16, c17, c18, c19, c20); _p384_sol_red1(T);
    fp_p384_add(out, out, T);

    # + P4
    _p384_mk(T, c21, c23, 0, c20, c16, c17, c18, c19, c20, c21, c22, c23); _p384_sol_red1(T);
    fp_p384_add(out, out, T);

    # + P5
    _p384_mk(T, 0, 0, 0, c21, c20, c21, c22, c23, 0, 0, 0, 0); _p384_sol_red1(T);
    fp_p384_add(out, out, T);

    # + 2·P6 (the two identical coeff-2 columns: c21@t4, c22@t5, c23@t6)
    _p384_mk(T, 0, 0, 0, 0, c21, c22, c23, 0, 0, 0, 0, 0); _p384_sol_red1(T);
    fp_p384_add(out, out, T); fp_p384_add(out, out, T);

    # + P8
    _p384_mk(T, 0, 0, 0, 0, c22, c23, 0, 0, 0, 0, 0, 0); _p384_sol_red1(T);
    fp_p384_add(out, out, T);

    # − N1 = (c23 c12 c13 c14 c15 c16 c17 c18 c19 c20 c21 c22)
    _p384_mk(T, c23, c12, c13, c14, c15, c16, c17, c18, c19, c20, c21, c22); _p384_sol_red1(T);
    fp_p384_sub(out, out, T);

    # − N2
    _p384_mk(T, 0, c20, c21, c22, c23, 0, 0, 0, 0, 0, 0, 0); _p384_sol_red1(T);
    fp_p384_sub(out, out, T);

    # − N3
    _p384_mk(T, 0, 0, 0, c23, c23, 0, 0, 0, 0, 0, 0, 0); _p384_sol_red1(T);
    fp_p384_sub(out, out, T);

    return 0;
}

# r = val mod p384 (val is 768-bit, r is 384-bit) — Solinas fast path.
fn p384_reduce(out, val): i64 {
    _p384_solinas_reduce(out, val);
    return 0;
}

# ================================================================
# Field arithmetic mod p384
# ================================================================

fn fp_p384_add(r, a, b): i64 {
    _p384_init();
    var carry = u384_add(r, a, b);
    if (carry == 1) { u384_sub(r, r, _p384_p); }
    if (u384_cmp(r, _p384_p) >= 0) { u384_sub(r, r, _p384_p); }
    return 0;
}

fn fp_p384_sub(r, a, b): i64 {
    _p384_init();
    var borrow = u384_sub(r, a, b);
    if (borrow > 0) { u384_add(r, r, _p384_p); }
    return 0;
}

fn fp_p384_neg(r, a): i64 {
    _p384_init();
    if (u384_is_zero(a) == 1) { u384_copy(r, a); return 0; }
    u384_sub(r, _p384_p, a);
    return 0;
}

fn fp_p384_mul(r, a, b): i64 {
    _p384_init();
    var _p384_prodb = _p384_prod + cbank() * 96;
    u384_mul_full(_p384_prodb, a, b);
    p384_reduce(r, _p384_prodb);
    return 0;
}

fn fp_p384_sq(r, a): i64 {
    return fp_p384_mul(r, a, a);
}

# Modular inversion via Fermat: a^(p-2) mod p.
var _p384_inv_tmp = 0;
var _p384_inv_res = 0;
var _p384_inv_base = 0;
var _p384_inv_exp = 0;
var _p384_inv_inited = 0;

fn _p384_inv_init(): i64 {
    if (_p384_inv_inited == 1) { return 0; }
    _p384_init();
    _p384_inv_tmp  = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_inv_res  = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_inv_base = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_inv_exp  = u384_clone(_p384_p);
    store64(_p384_inv_exp, load64(_p384_inv_exp) - 2);
    _p384_inv_inited = 1;
    return 0;
}

fn fp_p384_inv(r, a): i64 {
    _p384_inv_init();
    var bk = cbank();
    var _p384_inv_tmpb  = _p384_inv_tmp  + bk * 48;
    var _p384_inv_resb  = _p384_inv_res  + bk * 48;
    var _p384_inv_baseb = _p384_inv_base + bk * 48;
    memset(_p384_inv_resb, 0, 48);
    store64(_p384_inv_resb, 1);
    u384_copy(_p384_inv_baseb, a);

    var i = 0;
    while (i < 384) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p384_inv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_p384_mul(_p384_inv_tmpb, _p384_inv_resb, _p384_inv_baseb);
            u384_copy(_p384_inv_resb, _p384_inv_tmpb);
        }
        fp_p384_sq(_p384_inv_tmpb, _p384_inv_baseb);
        u384_copy(_p384_inv_baseb, _p384_inv_tmpb);
        i = i + 1;
    }
    u384_copy(r, _p384_inv_resb);
    return 0;
}

# ================================================================
# Scalar field arithmetic mod n384
# ================================================================

var _p384_n_R = 0;

fn _p384_long_div_reduce_n(R, lo): i64 {
    var i = 383;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;
        var carry = u384_shl1(R, R);
        store64(R, load64(R) | bit);
        if (carry == 1) {
            u384_sub(R, R, _p384_n);
        } else {
            if (u384_cmp(R, _p384_n) >= 0) { u384_sub(R, R, _p384_n); }
        }
        i = i - 1;
    }
    return 0;
}

fn n384_reduce(out, val): i64 {
    _p384_init();
    if (_p384_n_R == 0) { _p384_n_R = alloc(48 * SIGIL_CRYPTO_BANKS); }
    var _p384_n_Rb = _p384_n_R + cbank() * 48;
    memcpy(_p384_n_Rb, val + 48, 48);
    if (u384_cmp(_p384_n_Rb, _p384_n) >= 0) { u384_sub(_p384_n_Rb, _p384_n_Rb, _p384_n); }
    _p384_long_div_reduce_n(_p384_n_Rb, val);
    u384_copy(out, _p384_n_Rb);
    return 0;
}

fn fn_p384_reduce384(out, a): i64 {
    _p384_init();
    u384_copy(out, a);
    if (u384_cmp(out, _p384_n) >= 0) { u384_sub(out, out, _p384_n); }
    return 0;
}

var _p384_n_prod = 0;

fn fn_p384_mul(r, a, b): i64 {
    _p384_init();
    if (_p384_n_prod == 0) { _p384_n_prod = alloc(96 * SIGIL_CRYPTO_BANKS); }
    var _p384_n_prodb = _p384_n_prod + cbank() * 96;
    u384_mul_full(_p384_n_prodb, a, b);
    n384_reduce(r, _p384_n_prodb);
    return 0;
}

# r = a^-1 mod n via Fermat (a^(n-2) mod n).
var _p384_ninv_tmp = 0;
var _p384_ninv_res = 0;
var _p384_ninv_base = 0;
var _p384_ninv_exp = 0;
var _p384_ninv_inited = 0;

fn _p384_ninv_init(): i64 {
    if (_p384_ninv_inited == 1) { return 0; }
    _p384_init();
    _p384_ninv_tmp  = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_ninv_res  = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_ninv_base = alloc(48 * SIGIL_CRYPTO_BANKS);
    _p384_ninv_exp  = u384_clone(_p384_n);
    store64(_p384_ninv_exp, load64(_p384_ninv_exp) - 2);
    _p384_ninv_inited = 1;
    return 0;
}

fn fn_p384_inv(r, a): i64 {
    _p384_ninv_init();
    var bk = cbank();
    var _p384_ninv_tmpb  = _p384_ninv_tmp  + bk * 48;
    var _p384_ninv_resb  = _p384_ninv_res  + bk * 48;
    var _p384_ninv_baseb = _p384_ninv_base + bk * 48;
    memset(_p384_ninv_resb, 0, 48);
    store64(_p384_ninv_resb, 1);
    u384_copy(_p384_ninv_baseb, a);
    var i = 0;
    while (i < 384) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p384_ninv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fn_p384_mul(_p384_ninv_tmpb, _p384_ninv_resb, _p384_ninv_baseb);
            u384_copy(_p384_ninv_resb, _p384_ninv_tmpb);
        }
        fn_p384_mul(_p384_ninv_tmpb, _p384_ninv_baseb, _p384_ninv_baseb);
        u384_copy(_p384_ninv_baseb, _p384_ninv_tmpb);
        i = i + 1;
    }
    u384_copy(r, _p384_ninv_resb);
    return 0;
}

# ================================================================
# On-curve check
# ================================================================

var _onc384_lhs = 0;
var _onc384_rhs = 0;
var _onc384_tmp = 0;
var _onc384_three_x = 0;
var _onc384_inited = 0;

fn _onc384_init(): i64 {
    if (_onc384_inited == 1) { return 0; }
    _p384_init();
    _onc384_lhs = alloc(48 * SIGIL_CRYPTO_BANKS);
    _onc384_rhs = alloc(48 * SIGIL_CRYPTO_BANKS);
    _onc384_tmp = alloc(48 * SIGIL_CRYPTO_BANKS);
    _onc384_three_x = alloc(48 * SIGIL_CRYPTO_BANKS);
    _onc384_inited = 1;
    return 0;
}

fn pt_p384_is_on_curve(x, y): i64 {
    _onc384_init();
    var bk = cbank();
    var _onc384_lhsb = _onc384_lhs + bk * 48;
    var _onc384_rhsb = _onc384_rhs + bk * 48;
    var _onc384_tmpb = _onc384_tmp + bk * 48;
    var _onc384_three_xb = _onc384_three_x + bk * 48;
    if (u384_cmp(x, _p384_p) >= 0) { return 0; }
    if (u384_cmp(y, _p384_p) >= 0) { return 0; }
    if (u384_is_zero(x) == 1) {
        if (u384_is_zero(y) == 1) { return 0; }
    }
    fp_p384_sq(_onc384_lhsb, y);
    fp_p384_sq(_onc384_tmpb, x);
    fp_p384_mul(_onc384_rhsb, _onc384_tmpb, x);
    fp_p384_add(_onc384_tmpb, x, x);
    fp_p384_add(_onc384_three_xb, _onc384_tmpb, x);
    fp_p384_sub(_onc384_rhsb, _onc384_rhsb, _onc384_three_xb);
    fp_p384_add(_onc384_rhsb, _onc384_rhsb, _p384_b);
    if (u384_eq(_onc384_lhsb, _onc384_rhsb) == 1) { return 1; }
    return 0;
}

# ================================================================
# Jacobian point arithmetic on P-384
#
# Point representation: 144 bytes (X 48 || Y 48 || Z 48 of LE limbs).
# Z == 0 represents the point at infinity.
# Formulas: same EFD references as P-256 (dbl-2001-b for a=-3,
# add-2007-bl for general add).
# ================================================================

fn _pt384_x(p): i64 { return p; }
fn _pt384_y(p): i64 { return p + 48; }
fn _pt384_z(p): i64 { return p + 96; }

fn pt384_alloc(): i64 {
    var p = alloc(144);
    memset(p, 0, 144);
    return p;
}

fn pt384_set_infinity(p): i64 {
    memset(p, 0, 144);
    return 0;
}

fn pt384_is_infinity(p): i64 {
    if (u384_is_zero(_pt384_z(p)) == 1) { return 1; }
    return 0;
}

fn pt384_copy(dst, src): i64 {
    memcpy(dst, src, 144);
    return 0;
}

fn pt384_cswap(swap, a, b): i64 {
    var mask = 0 - swap;
    var i = 0;
    while (i < 18) {       # 18 × 8 bytes = 144
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var t  = mask & (av ^ bv);
        store64(a + i * 8, av ^ t);
        store64(b + i * 8, bv ^ t);
        i = i + 1;
    }
    return 0;
}

fn pt384_from_affine(p, x, y): i64 {
    u384_copy(_pt384_x(p), x);
    u384_copy(_pt384_y(p), y);
    memset(_pt384_z(p), 0, 48);
    store64(_pt384_z(p), 1);
    return 0;
}

var _pt384_aff_zinv  = 0;
var _pt384_aff_zinv2 = 0;
var _pt384_aff_zinv3 = 0;

fn pt384_to_affine(out_x, out_y, p): i64 {
    if (pt384_is_infinity(p) == 1) { return 0; }
    if (_pt384_aff_zinv  == 0) { _pt384_aff_zinv  = alloc(48 * SIGIL_CRYPTO_BANKS); }
    if (_pt384_aff_zinv2 == 0) { _pt384_aff_zinv2 = alloc(48 * SIGIL_CRYPTO_BANKS); }
    if (_pt384_aff_zinv3 == 0) { _pt384_aff_zinv3 = alloc(48 * SIGIL_CRYPTO_BANKS); }
    var bk = cbank();
    var _pt384_aff_zinvb  = _pt384_aff_zinv  + bk * 48;
    var _pt384_aff_zinv2b = _pt384_aff_zinv2 + bk * 48;
    var _pt384_aff_zinv3b = _pt384_aff_zinv3 + bk * 48;
    fp_p384_inv(_pt384_aff_zinvb, _pt384_z(p));
    fp_p384_sq(_pt384_aff_zinv2b, _pt384_aff_zinvb);
    fp_p384_mul(_pt384_aff_zinv3b, _pt384_aff_zinv2b, _pt384_aff_zinvb);
    fp_p384_mul(out_x, _pt384_x(p), _pt384_aff_zinv2b);
    fp_p384_mul(out_y, _pt384_y(p), _pt384_aff_zinv3b);
    return 1;
}

# Point doubling (EFD dbl-2001-b, a = -3).
var _ptd384_delta = 0;
var _ptd384_gamma = 0;
var _ptd384_beta  = 0;
var _ptd384_alpha = 0;
var _ptd384_t1    = 0;
var _ptd384_t2    = 0;
var _ptd384_x3    = 0;
var _ptd384_y3    = 0;
var _ptd384_z3    = 0;
var _ptd384_inited = 0;

fn _ptd384_init(): i64 {
    if (_ptd384_inited == 1) { return 0; }
    _ptd384_delta = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_gamma = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_beta  = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_alpha = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_t1    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_t2    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_x3    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_y3    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_z3    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ptd384_inited = 1;
    return 0;
}

fn pt384_double(out, p): i64 {
    _p384_init();
    _ptd384_init();
    if (pt384_is_infinity(p) == 1) { pt384_set_infinity(out); return 0; }
    var bk = cbank();
    var _ptd384_deltab = _ptd384_delta + bk * 48;
    var _ptd384_gammab = _ptd384_gamma + bk * 48;
    var _ptd384_betab  = _ptd384_beta  + bk * 48;
    var _ptd384_alphab = _ptd384_alpha + bk * 48;
    var _ptd384_t1b    = _ptd384_t1    + bk * 48;
    var _ptd384_t2b    = _ptd384_t2    + bk * 48;
    var _ptd384_x3b    = _ptd384_x3    + bk * 48;
    var _ptd384_y3b    = _ptd384_y3    + bk * 48;
    var _ptd384_z3b    = _ptd384_z3    + bk * 48;

    fp_p384_sq(_ptd384_deltab, _pt384_z(p));
    fp_p384_sq(_ptd384_gammab, _pt384_y(p));
    fp_p384_mul(_ptd384_betab, _pt384_x(p), _ptd384_gammab);

    fp_p384_sub(_ptd384_t1b, _pt384_x(p), _ptd384_deltab);
    fp_p384_add(_ptd384_t2b, _pt384_x(p), _ptd384_deltab);
    fp_p384_mul(_ptd384_alphab, _ptd384_t1b, _ptd384_t2b);
    fp_p384_add(_ptd384_t1b, _ptd384_alphab, _ptd384_alphab);
    fp_p384_add(_ptd384_alphab, _ptd384_t1b, _ptd384_alphab);

    fp_p384_sq(_ptd384_x3b, _ptd384_alphab);
    fp_p384_add(_ptd384_t1b, _ptd384_betab, _ptd384_betab);
    fp_p384_add(_ptd384_t1b, _ptd384_t1b, _ptd384_t1b);
    fp_p384_add(_ptd384_t2b, _ptd384_t1b, _ptd384_t1b);
    fp_p384_sub(_ptd384_x3b, _ptd384_x3b, _ptd384_t2b);

    fp_p384_add(_ptd384_t1b, _pt384_y(p), _pt384_z(p));
    fp_p384_sq(_ptd384_z3b, _ptd384_t1b);
    fp_p384_sub(_ptd384_z3b, _ptd384_z3b, _ptd384_gammab);
    fp_p384_sub(_ptd384_z3b, _ptd384_z3b, _ptd384_deltab);

    fp_p384_add(_ptd384_t1b, _ptd384_betab, _ptd384_betab);
    fp_p384_add(_ptd384_t1b, _ptd384_t1b, _ptd384_t1b);
    fp_p384_sub(_ptd384_t1b, _ptd384_t1b, _ptd384_x3b);
    fp_p384_mul(_ptd384_y3b, _ptd384_alphab, _ptd384_t1b);
    fp_p384_sq(_ptd384_t2b, _ptd384_gammab);
    fp_p384_add(_ptd384_t1b, _ptd384_t2b, _ptd384_t2b);
    fp_p384_add(_ptd384_t1b, _ptd384_t1b, _ptd384_t1b);
    fp_p384_add(_ptd384_t1b, _ptd384_t1b, _ptd384_t1b);
    fp_p384_sub(_ptd384_y3b, _ptd384_y3b, _ptd384_t1b);

    u384_copy(_pt384_x(out), _ptd384_x3b);
    u384_copy(_pt384_y(out), _ptd384_y3b);
    u384_copy(_pt384_z(out), _ptd384_z3b);
    return 0;
}

# Point addition (EFD add-2007-bl).
var _pta384_z1z1 = 0;
var _pta384_z2z2 = 0;
var _pta384_u1   = 0;
var _pta384_u2   = 0;
var _pta384_s1   = 0;
var _pta384_s2   = 0;
var _pta384_h    = 0;
var _pta384_i    = 0;
var _pta384_j    = 0;
var _pta384_r    = 0;
var _pta384_v    = 0;
var _pta384_t1   = 0;
var _pta384_t2   = 0;
var _pta384_x3   = 0;
var _pta384_y3   = 0;
var _pta384_z3   = 0;
var _pta384_inited = 0;

fn _pta384_init(): i64 {
    if (_pta384_inited == 1) { return 0; }
    _pta384_z1z1 = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_z2z2 = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_u1   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_u2   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_s1   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_s2   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_h    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_i    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_j    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_r    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_v    = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_t1   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_t2   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_x3   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_y3   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_z3   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _pta384_inited = 1;
    return 0;
}

fn pt384_add(out, p, q): i64 {
    _p384_init();
    _pta384_init();

    if (pt384_is_infinity(p) == 1) { pt384_copy(out, q); return 0; }
    if (pt384_is_infinity(q) == 1) { pt384_copy(out, p); return 0; }

    var bk = cbank();
    var _pta384_z1z1b = _pta384_z1z1 + bk * 48;
    var _pta384_z2z2b = _pta384_z2z2 + bk * 48;
    var _pta384_u1b   = _pta384_u1   + bk * 48;
    var _pta384_u2b   = _pta384_u2   + bk * 48;
    var _pta384_s1b   = _pta384_s1   + bk * 48;
    var _pta384_s2b   = _pta384_s2   + bk * 48;
    var _pta384_hb    = _pta384_h    + bk * 48;
    var _pta384_ib    = _pta384_i    + bk * 48;
    var _pta384_jb    = _pta384_j    + bk * 48;
    var _pta384_rb    = _pta384_r    + bk * 48;
    var _pta384_vb    = _pta384_v    + bk * 48;
    var _pta384_t1b   = _pta384_t1   + bk * 48;
    var _pta384_t2b   = _pta384_t2   + bk * 48;
    var _pta384_x3b   = _pta384_x3   + bk * 48;
    var _pta384_y3b   = _pta384_y3   + bk * 48;
    var _pta384_z3b   = _pta384_z3   + bk * 48;

    fp_p384_sq(_pta384_z1z1b, _pt384_z(p));
    fp_p384_sq(_pta384_z2z2b, _pt384_z(q));

    fp_p384_mul(_pta384_u1b, _pt384_x(p), _pta384_z2z2b);
    fp_p384_mul(_pta384_u2b, _pt384_x(q), _pta384_z1z1b);

    fp_p384_mul(_pta384_t1b, _pt384_z(q), _pta384_z2z2b);
    fp_p384_mul(_pta384_s1b, _pt384_y(p), _pta384_t1b);
    fp_p384_mul(_pta384_t1b, _pt384_z(p), _pta384_z1z1b);
    fp_p384_mul(_pta384_s2b, _pt384_y(q), _pta384_t1b);

    fp_p384_sub(_pta384_hb, _pta384_u2b, _pta384_u1b);

    if (u384_is_zero(_pta384_hb) == 1) {
        if (u384_eq(_pta384_s1b, _pta384_s2b) == 1) {
            return pt384_double(out, p);
        } else {
            pt384_set_infinity(out);
            return 0;
        }
    }

    fp_p384_add(_pta384_t1b, _pta384_hb, _pta384_hb);
    fp_p384_sq(_pta384_ib, _pta384_t1b);
    fp_p384_mul(_pta384_jb, _pta384_hb, _pta384_ib);
    fp_p384_sub(_pta384_t1b, _pta384_s2b, _pta384_s1b);
    fp_p384_add(_pta384_rb, _pta384_t1b, _pta384_t1b);
    fp_p384_mul(_pta384_vb, _pta384_u1b, _pta384_ib);

    fp_p384_sq(_pta384_x3b, _pta384_rb);
    fp_p384_sub(_pta384_x3b, _pta384_x3b, _pta384_jb);
    fp_p384_add(_pta384_t1b, _pta384_vb, _pta384_vb);
    fp_p384_sub(_pta384_x3b, _pta384_x3b, _pta384_t1b);

    fp_p384_sub(_pta384_t1b, _pta384_vb, _pta384_x3b);
    fp_p384_mul(_pta384_y3b, _pta384_rb, _pta384_t1b);
    fp_p384_mul(_pta384_t1b, _pta384_s1b, _pta384_jb);
    fp_p384_add(_pta384_t2b, _pta384_t1b, _pta384_t1b);
    fp_p384_sub(_pta384_y3b, _pta384_y3b, _pta384_t2b);

    fp_p384_add(_pta384_t1b, _pt384_z(p), _pt384_z(q));
    fp_p384_sq(_pta384_t2b, _pta384_t1b);
    fp_p384_sub(_pta384_t2b, _pta384_t2b, _pta384_z1z1b);
    fp_p384_sub(_pta384_t2b, _pta384_t2b, _pta384_z2z2b);
    fp_p384_mul(_pta384_z3b, _pta384_t2b, _pta384_hb);

    u384_copy(_pt384_x(out), _pta384_x3b);
    u384_copy(_pt384_y(out), _pta384_y3b);
    u384_copy(_pt384_z(out), _pta384_z3b);
    return 0;
}

# Montgomery-ladder scalar multiplication.
var _ptm384_r0 = 0;
var _ptm384_r1 = 0;
var _ptm384_sum = 0;
var _ptm384_dbl = 0;
var _ptm384_inited = 0;

fn _ptm384_init(): i64 {
    if (_ptm384_inited == 1) { return 0; }
    _ptm384_r0  = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ptm384_r1  = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ptm384_sum = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ptm384_dbl = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ptm384_inited = 1;
    return 0;
}

fn pt384_scalarmul(out, k, P): i64 {
    _p384_init();
    _ptm384_init();
    var bk = cbank();
    var _ptm384_r0b  = _ptm384_r0  + bk * 144;
    var _ptm384_r1b  = _ptm384_r1  + bk * 144;
    var _ptm384_sumb = _ptm384_sum + bk * 144;
    var _ptm384_dblb = _ptm384_dbl + bk * 144;

    pt384_set_infinity(_ptm384_r0b);
    pt384_copy(_ptm384_r1b, P);
    var scalar = k;
    var prev = 0;
    var i = 383;
    while (i >= 0) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(scalar + limb_idx * 8) >> bit_idx) & 1;
        var swap = prev ^ bit;
        pt384_cswap(swap, _ptm384_r0b, _ptm384_r1b);
        pt384_add(_ptm384_sumb, _ptm384_r0b, _ptm384_r1b);
        pt384_double(_ptm384_dblb, _ptm384_r0b);
        pt384_copy(_ptm384_r1b, _ptm384_sumb);
        pt384_copy(_ptm384_r0b, _ptm384_dblb);
        prev = bit;
        i = i - 1;
    }
    pt384_cswap(prev, _ptm384_r0b, _ptm384_r1b);
    pt384_copy(out, _ptm384_r0b);
    return 0;
}

# ================================================================
# Fixed-base comb (G) + windowed variable mul (Q) — verify-only, NON-CT.
# Direct mirror of the P-256 comb/window (see src/ecdsa_p256.cyr for the
# full rationale). Both verify inputs are public, so the non-CT table
# index is acceptable; the secret-nonce signing path stays on
# `pt384_scalarmul`. P-384: 144 B points, 96 four-bit windows (384/4).
# G table: 96 × 16 × 144 B = 221184 B, built once on the main thread
# (P-384 verify is not on the parallel batch path).
# ================================================================

var _p384_G_table   = 0;
var _p384_Gt_inited = 0;
var _p384_gt_tmp    = 0;

fn _build_p384_G_table(): i64 {
    if (_p384_Gt_inited == 1) { return 0; }
    _p384_init();
    _ptm384_init();
    _p384_G_table = alloc(221184);                # 96 * 16 * 144
    if (_p384_gt_tmp == 0) { _p384_gt_tmp = pt384_alloc(); }

    var basept = pt384_alloc();
    pt384_from_affine(basept, _p384_gx, _p384_gy);

    var i = 0;
    while (i < 96) {
        var row = _p384_G_table + i * 16 * 144;
        pt384_set_infinity(row);                  # table[i][0] = O
        pt384_copy(row + 144, basept);            # table[i][1] = Bi
        var k = 2;
        while (k < 16) {
            pt384_add(row + k * 144, row + (k - 1) * 144, basept);
            k = k + 1;
        }
        if (i < 95) {                             # Bi+1 = 16·Bi
            pt384_double(_p384_gt_tmp, basept);
            pt384_double(basept, _p384_gt_tmp);
            pt384_double(_p384_gt_tmp, basept);
            pt384_double(basept, _p384_gt_tmp);
        }
        i = i + 1;
    }
    _p384_Gt_inited = 1;
    return 0;
}

# out = k · G via the fixed-base comb. PUBLIC scalar only (non-CT).
# k is 384-bit LE limbs (6 × i64); nibble i = bits [4i, 4i+3], i ∈ [0,96).
fn p384_scalarmul_base(out, k): i64 {
    if (_p384_Gt_inited == 0) { _build_p384_G_table(); }
    pt384_set_infinity(out);
    var i = 0;
    while (i < 96) {
        var limb = load64(k + (i / 16) * 8);
        var nib  = (limb >> ((i % 16) * 4)) & 0xF;
        pt384_add(out, out, _p384_G_table + (i * 16 + nib) * 144);
        i = i + 1;
    }
    return 0;
}

# Windowed scalar mul for the VARIABLE point Q. PUBLIC scalar/point only.
var _ecq384_tab    = 0;    # 16 multiples k·Q (144 B each)
var _ecq384_acc    = 0;
var _ecq384_inited = 0;

fn _ecq384_init(): i64 {
    if (_ecq384_inited == 1) { return 0; }
    _ecq384_tab = alloc(2304 * SIGIL_CRYPTO_BANKS);     # 16 * 144
    _ecq384_acc = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ecq384_inited = 1;
    return 0;
}

fn p384_scalarmul_var(out, k, Q): i64 {
    _p384_init();
    _ecq384_init();
    var bk = cbank();
    var _ecq384_tabb = _ecq384_tab + bk * 2304;
    var _ecq384_accb = _ecq384_acc + bk * 144;

    pt384_set_infinity(_ecq384_tabb);
    pt384_copy(_ecq384_tabb + 144, Q);
    var j = 2;
    while (j < 16) {
        pt384_add(_ecq384_tabb + j * 144, _ecq384_tabb + (j - 1) * 144, Q);
        j = j + 1;
    }

    pt384_set_infinity(_ecq384_accb);
    var i = 95;
    while (i >= 0) {
        pt384_double(_ecq384_accb, _ecq384_accb);
        pt384_double(_ecq384_accb, _ecq384_accb);
        pt384_double(_ecq384_accb, _ecq384_accb);
        pt384_double(_ecq384_accb, _ecq384_accb);
        var limb = load64(k + (i / 16) * 8);
        var nib  = (limb >> ((i % 16) * 4)) & 0xF;
        pt384_add(_ecq384_accb, _ecq384_accb, _ecq384_tabb + nib * 144);
        i = i - 1;
    }
    pt384_copy(out, _ecq384_accb);
    return 0;
}

# ================================================================
# ECDSA P-384 verify (SEC 1 v2.0 §4.1.4)
#
# Inputs:
#   pk    — 96 bytes, Qx || Qy (big-endian)
#   sig   — 96 bytes, r || s   (big-endian)
#   msg   — message bytes; SHA-384(msg) is the message representative
# ================================================================

var _ecv384_e        = 0;
var _ecv384_r        = 0;
var _ecv384_s        = 0;
var _ecv384_w        = 0;
var _ecv384_u1       = 0;
var _ecv384_u2       = 0;
var _ecv384_qx       = 0;
var _ecv384_qy       = 0;
var _ecv384_digest   = 0;
var _ecv384_eb       = 0;
var _ecv384_P_u1G    = 0;
var _ecv384_P_u2Q    = 0;
var _ecv384_R        = 0;
var _ecv384_Rx       = 0;
var _ecv384_Ry       = 0;
var _ecv384_Rx_modn  = 0;
var _ecv384_Q        = 0;
var _ecv384_inited   = 0;

fn _ecv384_init(): i64 {
    if (_ecv384_inited == 1) { return 0; }
    _p384_init();
    _ecv384_e        = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_r        = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_s        = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_w        = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_u1       = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_u2       = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_qx       = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_qy       = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_digest   = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_eb       = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_P_u1G    = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ecv384_P_u2Q    = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ecv384_R        = alloc(144 * SIGIL_CRYPTO_BANKS);
    _ecv384_Rx       = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_Ry       = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_Rx_modn  = alloc(48 * SIGIL_CRYPTO_BANKS);
    _ecv384_Q        = alloc(144 * SIGIL_CRYPTO_BANKS);
    _build_p384_G_table();        # fixed-base comb for the u1·G term
    _ecv384_inited = 1;
    return 0;
}

# Public entry. Hashes msg with SHA-384 internally, then defers to the
# digest-taking core. The 4-arg signature is preserved byte-for-byte for
# the sgx/tdx/snp/dist callers.
fn ecdsa_p384_verify(pk, msg, msg_len, sig): i64 {
    _ecv384_init();
    var _ecv384_digestb = _ecv384_digest + cbank() * 48;
    sha384(msg, msg_len, _ecv384_digestb);
    return _ecdsa_p384_verify_digest(pk, _ecv384_digestb, 48, sig);
}

# Digest-taking core — the P-384 mirror of _ecdsa_p256_verify_digest.
# e = leftmost bitlen(n) = 384 bits of the digest (FIPS 186-4 §6.4):
# a digest of >= 48 bytes contributes its leftmost 48 bytes (the diagonal
# SHA-384 case uses the whole 48-byte digest); a SHORTER digest (the
# off-diagonal case — a P-384 issuer signing a SHA-256 child) is used
# whole, left-zero-padded into 48 bytes. Since a sub-384-bit value is
# already < n, the conditional reduce is then a no-op.
fn _ecdsa_p384_verify_digest(pk, digest, digest_len, sig): i64 {
    _ecv384_init();
    var bk = cbank();
    var _ecv384_eb_      = _ecv384_e       + bk * 48;
    var _ecv384_rb       = _ecv384_r       + bk * 48;
    var _ecv384_sb       = _ecv384_s       + bk * 48;
    var _ecv384_wb       = _ecv384_w       + bk * 48;
    var _ecv384_u1b      = _ecv384_u1      + bk * 48;
    var _ecv384_u2b      = _ecv384_u2      + bk * 48;
    var _ecv384_qxb      = _ecv384_qx      + bk * 48;
    var _ecv384_qyb      = _ecv384_qy      + bk * 48;
    var _ecv384_ebufb    = _ecv384_eb      + bk * 48;
    var _ecv384_P_u1Gb   = _ecv384_P_u1G   + bk * 144;
    var _ecv384_P_u2Qb   = _ecv384_P_u2Q   + bk * 144;
    var _ecv384_Rb       = _ecv384_R       + bk * 144;
    var _ecv384_Rxb      = _ecv384_Rx      + bk * 48;
    var _ecv384_Ryb      = _ecv384_Ry      + bk * 48;
    var _ecv384_Rx_modnb = _ecv384_Rx_modn + bk * 48;
    var _ecv384_Qb       = _ecv384_Q       + bk * 144;

    # 1. Decode r, s; range check ∈ [1, n-1].
    u384_load_be(_ecv384_rb, sig);
    u384_load_be(_ecv384_sb, sig + 48);
    if (u384_is_zero(_ecv384_rb) == 1) { return 0; }
    if (u384_is_zero(_ecv384_sb) == 1) { return 0; }
    if (u384_cmp(_ecv384_rb, _p384_n) >= 0) { return 0; }
    if (u384_cmp(_ecv384_sb, _p384_n) >= 0) { return 0; }

    # 2. Decode + validate Q (on-curve).
    u384_load_be(_ecv384_qxb, pk);
    u384_load_be(_ecv384_qyb, pk + 48);
    if (pt_p384_is_on_curve(_ecv384_qxb, _ecv384_qyb) == 0) { return 0; }
    pt384_from_affine(_ecv384_Qb, _ecv384_qxb, _ecv384_qyb);

    # 3. e = leftmost 384 bits of digest, mod n (FIPS 186-4 §6.4).
    var take = 48;
    if (digest_len < 48) { take = digest_len; }
    var pad = 48 - take;
    memset(_ecv384_ebufb, 0, 48);
    var i = 0;
    while (i < take) {
        store8(_ecv384_ebufb + pad + i, load8(digest + i) & 0xFF);
        i = i + 1;
    }
    u384_load_be(_ecv384_eb_, _ecv384_ebufb);
    if (u384_cmp(_ecv384_eb_, _p384_n) >= 0) { u384_sub(_ecv384_eb_, _ecv384_eb_, _p384_n); }

    # 4. w = s^-1 mod n
    fn_p384_inv(_ecv384_wb, _ecv384_sb);

    # 5. u1 = e*w mod n, u2 = r*w mod n
    fn_p384_mul(_ecv384_u1b, _ecv384_eb_, _ecv384_wb);
    fn_p384_mul(_ecv384_u2b, _ecv384_rb, _ecv384_wb);

    # 6. R = u1*G + u2*Q. u1·G via the fixed-base comb (public scalar);
    #    u2·Q via the 4-bit windowed mul. Both inputs public → non-CT OK.
    p384_scalarmul_base(_ecv384_P_u1Gb, _ecv384_u1b);
    p384_scalarmul_var(_ecv384_P_u2Qb, _ecv384_u2b, _ecv384_Qb);
    pt384_add(_ecv384_Rb, _ecv384_P_u1Gb, _ecv384_P_u2Qb);

    if (pt384_is_infinity(_ecv384_Rb) == 1) { return 0; }

    # 7. v = Rx mod n; accept iff v == r
    pt384_to_affine(_ecv384_Rxb, _ecv384_Ryb, _ecv384_Rb);
    fn_p384_reduce384(_ecv384_Rx_modnb, _ecv384_Rxb);
    if (u384_eq(_ecv384_Rx_modnb, _ecv384_rb) == 1) { return 1; }
    return 0;
}

# --- ecdsa_sign.cyr ---

# ecdsa_sign.cyr — ECDSA P-256 / P-384 signing with RFC 6979
# deterministic nonces. Issue line item 3 of the cyrius native-TLS
# arc (3.5.9). Pairs with the existing ecdsa_p256_verify /
# ecdsa_p384_verify and consumes the private scalars parsed by
# src/privkey.cyr (3.5.8).
#
# Construction (SEC 1 §4.1.3 + RFC 6979 §3.2):
#   e   = leftmost qlen bits of H(m), reduced mod n
#   k   = RFC 6979 deterministic nonce (HMAC_DRBG over the curve hash)
#   R   = k·G ; r = R.x mod n
#   s   = k^(-1) · (e + r·d) mod n
#   sig = r || s  (raw, big-endian, fixed length) or DER SEQUENCE.
#
# Determinism (RFC 6979) removes the catastrophic dependence on a
# per-signature random nonce — a repeated or biased k leaks the
# private key (PS3 / Sony 2010). The nonce is derived from (d, H(m))
# via HMAC_DRBG keyed on the curve's hash (SHA-256 for P-256,
# SHA-384 for P-384), so signing is a pure function of key + message.
#
# Security floor (CLAUDE.md § Security Hardening):
#   - The nonce k, the HMAC_DRBG state (K, V), the private scalar, and
#     every (e + r·d) / k^(-1) intermediate live in `secret var` stack
#     buffers, zeroized on scope exit. r and s are public outputs.
#   - Scalar inversion / multiply reuse the curve's existing mod-n
#     primitives (fn_p256_inv / fn_p256_mul, etc.).
#   - add-mod-n is carry-correct (the lib `u256_addmod` drops the
#     2^256 carry, which is wrong for the P-256/P-384 scalar field
#     where n ≈ 2^256 and a+b can exceed 2^256 — see _ecs_addmod_*).

# ================================================================
# Carry-correct scalar add mod n
# ================================================================
# r = (a + b) mod n, for a, b < n (n < 2^256). a+b can be up to
# 2n-2 > 2^256, so the 2^256 carry from u256_add MUST be honored.
# When carry == 1 the true sum is 2^256 + low; since a,b < n the low
# limbs are < n, so a single `u256_sub(r, r, n)` (which borrows and
# wraps, adding 2^256-n) yields the correct residue in [0, n).
fn _ecs_addmod_n_p256(r, a, b): i64 {
    var carry = u256_add(r, a, b);
    if (carry == 1) {
        u256_sub(r, r, _p256_n);
    } else {
        if (u256_cmp(r, _p256_n) >= 0) { u256_sub(r, r, _p256_n); }
    }
    return 0;
}

fn _ecs_addmod_n_p384(r, a, b): i64 {
    var carry = u384_add(r, a, b);
    if (carry == 1) {
        u384_sub(r, r, _p384_n);
    } else {
        if (u384_cmp(r, _p384_n) >= 0) { u384_sub(r, r, _p384_n); }
    }
    return 0;
}

# ================================================================
# RFC 6979 §3.2 — deterministic nonce (P-256 / HMAC-SHA256)
# ================================================================
# d_be:  32-byte big-endian private scalar (int2octets(x)).
# h1oct: 32-byte big-endian bits2octets(H(m)) = int2octets(e mod n).
# k_out: 32-byte big-endian nonce in [1, n-1].
# Returns 0 on success, -1 if no valid nonce within the retry bound.
#
# qlen == hlen == 256 for this curve/hash pair, so each HMAC round
# yields exactly one qlen block (T = V), and bits2int(T) = T.

# data = V(32) || sep(1) || d(32) || h1(32)  →  97 bytes
fn _rfc6979_build_p256(data, V, sep, d, h1): i64 {
    memcpy(data, V, 32);
    store8(data + 32, sep & 0xFF);
    memcpy(data + 33, d, 32);
    memcpy(data + 65, h1, 32);
    return 0;
}

# Per-lane secret zeroization of this function's banked HMAC_DRBG scratch
# (quirk #9 / ADR 0004). The V/K/Kt/Vt/data/d1/kint arrays are
# function-scope `var X[N]`, i.e. STATIC globals (quirk #1) — shared
# across concurrent signers, so they are banked across `cbank()` lanes
# (the concurrent-signers race in ecdsa_concurrent.tcyr). They carry the
# secret nonce / DRBG state, so they are plain `var` + a per-lane wipe
# (NEVER `secret var`: a whole-array wipe would clobber a sibling lane).
# Wipes ONLY the calling worker's lane.
fn _rfc6979_scrub_p256_lanes(V, K, Kt, Vt, data, d1, kint): i64 {
    memset(V, 0, 32);
    memset(K, 0, 32);
    memset(Kt, 0, 32);
    memset(Vt, 0, 32);
    memset(data, 0, 97);
    memset(d1, 0, 33);
    memset(kint, 0, 32);
    return 0;
}

fn _rfc6979_k_p256(d_be, h1oct, k_out): i64 {
    var bk = cbank();
    var V[2048];    var Vb    = &V    + bk * 32;   # 32 * SIGIL_CRYPTO_BANKS
    var K[2048];    var Kb    = &K    + bk * 32;
    var Kt[2048];   var Ktb   = &Kt   + bk * 32;
    var Vt[2048];   var Vtb   = &Vt   + bk * 32;
    var data[6208]; var datab = &data + bk * 97;   # 97 * SIGIL_CRYPTO_BANKS
    var d1[2112];   var d1b   = &d1   + bk * 33;    # 33 * SIGIL_CRYPTO_BANKS
    var kint[2048]; var kintb = &kint + bk * 32;

    var i = 0;
    while (i < 32) { store8(Vb + i, 0x01); store8(Kb + i, 0x00); i = i + 1; }

    # K = HMAC_K(V || 0x00 || int2octets(x) || bits2octets(h1))
    _rfc6979_build_p256(datab, Vb, 0x00, d_be, h1oct);
    hmac_sha256(Kb, 32, datab, 97, Ktb);
    memcpy(Kb, Ktb, 32);
    # V = HMAC_K(V)
    hmac_sha256(Kb, 32, Vb, 32, Vtb);
    memcpy(Vb, Vtb, 32);
    # K = HMAC_K(V || 0x01 || int2octets(x) || bits2octets(h1))
    _rfc6979_build_p256(datab, Vb, 0x01, d_be, h1oct);
    hmac_sha256(Kb, 32, datab, 97, Ktb);
    memcpy(Kb, Ktb, 32);
    # V = HMAC_K(V)
    hmac_sha256(Kb, 32, Vb, 32, Vtb);
    memcpy(Vb, Vtb, 32);

    var tries = 0;
    while (tries < 256) {
        # T = HMAC_K(V) (one block = qlen)
        hmac_sha256(Kb, 32, Vb, 32, Vtb);
        memcpy(Vb, Vtb, 32);
        # k = bits2int(T); accept iff 1 <= k <= n-1.
        u256_load_be(kintb, Vb);
        if (u256_is_zero(kintb) == 0) {
            if (u256_cmp(kintb, _p256_n) < 0) {
                u256_store_be(k_out, kintb);
                _rfc6979_scrub_p256_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
                return 0;
            }
        }
        # Reject: K = HMAC_K(V || 0x00); V = HMAC_K(V).
        memcpy(d1b, Vb, 32);
        store8(d1b + 32, 0x00);
        hmac_sha256(Kb, 32, d1b, 33, Ktb);
        memcpy(Kb, Ktb, 32);
        hmac_sha256(Kb, 32, Vb, 32, Vtb);
        memcpy(Vb, Vtb, 32);
        tries = tries + 1;
    }
    _rfc6979_scrub_p256_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
    return 0 - 1;
}

# ================================================================
# RFC 6979 §3.2 — deterministic nonce (P-384 / HMAC-SHA384)
# ================================================================
# 48-byte HMAC-SHA384 blocks; qlen == hlen == 384.

# data = V(48) || sep(1) || d(48) || h1(48)  →  145 bytes
fn _rfc6979_build_p384(data, V, sep, d, h1): i64 {
    memcpy(data, V, 48);
    store8(data + 48, sep & 0xFF);
    memcpy(data + 49, d, 48);
    memcpy(data + 97, h1, 48);
    return 0;
}

# Per-lane secret zeroization of this function's banked HMAC_DRBG scratch
# (quirk #9 / ADR 0004) — the P-384 mirror of _rfc6979_scrub_p256_lanes.
# The V/K/Kt/Vt/data/d1/kint arrays are function-scope `var X[N]`, i.e.
# STATIC globals (quirk #1) shared across concurrent signers, so they are
# banked across `cbank()` lanes (the concurrent-signers race in
# ecdsa_concurrent.tcyr). They carry the secret nonce / DRBG state, so they
# are plain `var` + a per-lane wipe (NEVER `secret var`: a whole-array wipe
# would clobber a sibling lane). Wipes ONLY the calling worker's lane.
fn _rfc6979_scrub_p384_lanes(V, K, Kt, Vt, data, d1, kint): i64 {
    memset(V, 0, 48);
    memset(K, 0, 48);
    memset(Kt, 0, 48);
    memset(Vt, 0, 48);
    memset(data, 0, 145);
    memset(d1, 0, 49);
    memset(kint, 0, 48);
    return 0;
}

fn _rfc6979_k_p384(d_be, h1oct, k_out): i64 {
    var bk = cbank();
    var V[3072];    var Vb    = &V    + bk * 48;    # 48 * SIGIL_CRYPTO_BANKS
    var K[3072];    var Kb    = &K    + bk * 48;
    var Kt[3072];   var Ktb   = &Kt   + bk * 48;
    var Vt[3072];   var Vtb   = &Vt   + bk * 48;
    var data[9280]; var datab = &data + bk * 145;   # 145 * SIGIL_CRYPTO_BANKS
    var d1[3136];   var d1b   = &d1   + bk * 49;     # 49 * SIGIL_CRYPTO_BANKS
    var kint[3072]; var kintb = &kint + bk * 48;

    var i = 0;
    while (i < 48) { store8(Vb + i, 0x01); store8(Kb + i, 0x00); i = i + 1; }

    _rfc6979_build_p384(datab, Vb, 0x00, d_be, h1oct);
    hmac_sha384(Kb, 48, datab, 145, Ktb);
    memcpy(Kb, Ktb, 48);
    hmac_sha384(Kb, 48, Vb, 48, Vtb);
    memcpy(Vb, Vtb, 48);
    _rfc6979_build_p384(datab, Vb, 0x01, d_be, h1oct);
    hmac_sha384(Kb, 48, datab, 145, Ktb);
    memcpy(Kb, Ktb, 48);
    hmac_sha384(Kb, 48, Vb, 48, Vtb);
    memcpy(Vb, Vtb, 48);

    var tries = 0;
    while (tries < 256) {
        hmac_sha384(Kb, 48, Vb, 48, Vtb);
        memcpy(Vb, Vtb, 48);
        u384_load_be(kintb, Vb);
        if (u384_is_zero(kintb) == 0) {
            if (u384_cmp(kintb, _p384_n) < 0) {
                u384_store_be(k_out, kintb);
                _rfc6979_scrub_p384_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
                return 0;
            }
        }
        memcpy(d1b, Vb, 48);
        store8(d1b + 48, 0x00);
        hmac_sha384(Kb, 48, d1b, 49, Ktb);
        memcpy(Kb, Ktb, 48);
        hmac_sha384(Kb, 48, Vb, 48, Vtb);
        memcpy(Vb, Vtb, 48);
        tries = tries + 1;
    }
    _rfc6979_scrub_p384_lanes(Vb, Kb, Ktb, Vtb, datab, d1b, kintb);
    return 0 - 1;
}

# ================================================================
# Point scratch (allocated once; G and R are public data)
# ================================================================
var _ecs256_inited = 0;
var _ecs256_G = 0;
var _ecs256_R = 0;

fn _ecs256_init(): i64 {
    if (_ecs256_inited == 1) { return 0; }
    _p256_init();
    _ecs256_G = pt_alloc();                      # generator, set once, read-only — unbanked
    _ecs256_R = alloc(96 * SIGIL_CRYPTO_BANKS);  # per-sign k·G output point — lane-banked
    pt_from_affine(_ecs256_G, _p256_gx, _p256_gy);
    _ecs256_inited = 1;
    return 0;
}

# Per-lane zeroization of every secret-tainted P-256 scratch buffer
# (CLAUDE.md quirk #9 / ADR 0004). The banked field/scalar/point scratch
# in ecdsa_p256.cyr is plain `var`/`alloc` (never `secret var`), so a
# whole-array wipe would clobber a concurrent worker's live lane. This
# scrubs ONLY the calling thread's lane (`cbank()`), preserving per-call
# secret zeroization on the sign path. Called on every return of
# ecdsa_p256_sign. Each buffer is guarded against the not-yet-allocated
# (lazy `_init`) case. NOTE: only the secret-carrying buffers (nonce k,
# k·G, private scalar d, and their intermediates) are scrubbed; the
# verify-only buffers (_ecv_*, _ecq_*, _onc_*, _p256fi_*, _p256_inv_*,
# _p256_R, _p256_sol_t, _p256_ninv_*) hold public data and are left
# alone (they are banked for race-freedom but need no wipe).
fn _p256_scrub_secret_lanes(): i64 {
    var bk = cbank();
    # Montgomery-ladder point set (k·G with secret k) — 96 B each.
    if (_ptm_r0  != 0) { memset(_ptm_r0  + bk * 96, 0, 96); }
    if (_ptm_r1  != 0) { memset(_ptm_r1  + bk * 96, 0, 96); }
    if (_ptm_sum != 0) { memset(_ptm_sum + bk * 96, 0, 96); }
    if (_ptm_dbl != 0) { memset(_ptm_dbl + bk * 96, 0, 96); }
    # pt_double temps — 9 × 32 B.
    if (_ptd_delta != 0) { memset(_ptd_delta + bk * 32, 0, 32); }
    if (_ptd_gamma != 0) { memset(_ptd_gamma + bk * 32, 0, 32); }
    if (_ptd_beta  != 0) { memset(_ptd_beta  + bk * 32, 0, 32); }
    if (_ptd_alpha != 0) { memset(_ptd_alpha + bk * 32, 0, 32); }
    if (_ptd_t1    != 0) { memset(_ptd_t1    + bk * 32, 0, 32); }
    if (_ptd_t2    != 0) { memset(_ptd_t2    + bk * 32, 0, 32); }
    if (_ptd_x3    != 0) { memset(_ptd_x3    + bk * 32, 0, 32); }
    if (_ptd_y3    != 0) { memset(_ptd_y3    + bk * 32, 0, 32); }
    if (_ptd_z3    != 0) { memset(_ptd_z3    + bk * 32, 0, 32); }
    # pt_add / pt_add_mixed temps — 16 × 32 B.
    if (_pta_z1z1 != 0) { memset(_pta_z1z1 + bk * 32, 0, 32); }
    if (_pta_z2z2 != 0) { memset(_pta_z2z2 + bk * 32, 0, 32); }
    if (_pta_u1   != 0) { memset(_pta_u1   + bk * 32, 0, 32); }
    if (_pta_u2   != 0) { memset(_pta_u2   + bk * 32, 0, 32); }
    if (_pta_s1   != 0) { memset(_pta_s1   + bk * 32, 0, 32); }
    if (_pta_s2   != 0) { memset(_pta_s2   + bk * 32, 0, 32); }
    if (_pta_h    != 0) { memset(_pta_h    + bk * 32, 0, 32); }
    if (_pta_i    != 0) { memset(_pta_i    + bk * 32, 0, 32); }
    if (_pta_j    != 0) { memset(_pta_j    + bk * 32, 0, 32); }
    if (_pta_r    != 0) { memset(_pta_r    + bk * 32, 0, 32); }
    if (_pta_v    != 0) { memset(_pta_v    + bk * 32, 0, 32); }
    if (_pta_t1   != 0) { memset(_pta_t1   + bk * 32, 0, 32); }
    if (_pta_t2   != 0) { memset(_pta_t2   + bk * 32, 0, 32); }
    if (_pta_x3   != 0) { memset(_pta_x3   + bk * 32, 0, 32); }
    if (_pta_y3   != 0) { memset(_pta_y3   + bk * 32, 0, 32); }
    if (_pta_z3   != 0) { memset(_pta_z3   + bk * 32, 0, 32); }
    # pt_to_affine z-inverse temps — 3 × 32 B.
    if (_pt_aff_zinv  != 0) { memset(_pt_aff_zinv  + bk * 32, 0, 32); }
    if (_pt_aff_zinv2 != 0) { memset(_pt_aff_zinv2 + bk * 32, 0, 32); }
    if (_pt_aff_zinv3 != 0) { memset(_pt_aff_zinv3 + bk * 32, 0, 32); }
    # scalar-inverse window (k^-1 / s^-1) — 512 B table + 32 B acc.
    if (_p256si_tbl != 0) { memset(_p256si_tbl + bk * 512, 0, 512); }
    if (_p256si_acc != 0) { memset(_p256si_acc + bk * 32, 0, 32); }
    # mod-n product / reduce scratch (carries r·d, k^-1·hpd) — 64 + 32 B.
    if (_p256_n_prod != 0) { memset(_p256_n_prod + bk * 64, 0, 64); }
    if (_p256_n_R    != 0) { memset(_p256_n_R    + bk * 32, 0, 32); }
    # field product / temps — 64 + 32 + 32 B.
    if (_p256_prod != 0) { memset(_p256_prod + bk * 64, 0, 64); }
    if (_p256_tmp1 != 0) { memset(_p256_tmp1 + bk * 32, 0, 32); }
    if (_p256_tmp2 != 0) { memset(_p256_tmp2 + bk * 32, 0, 32); }
    # per-sign k·G output point (ecdsa_sign.cyr) — 96 B.
    if (_ecs256_R != 0) { memset(_ecs256_R + bk * 96, 0, 96); }
    return 0;
}

var _ecs384_inited = 0;
var _ecs384_G = 0;
var _ecs384_R = 0;

fn _ecs384_init(): i64 {
    if (_ecs384_inited == 1) { return 0; }
    _p384_init();
    _ecs384_G = alloc(144);                       # generator, set once, read-only — unbanked
    _ecs384_R = alloc(144 * SIGIL_CRYPTO_BANKS);  # per-sign k·G output point — lane-banked
    pt384_from_affine(_ecs384_G, _p384_gx, _p384_gy);
    _ecs384_inited = 1;
    return 0;
}

# Per-lane zeroization of every secret-tainted P-384 scratch buffer
# (CLAUDE.md quirk #9 / ADR 0004) — the P-384 mirror of
# _p256_scrub_secret_lanes. The banked field/scalar/point scratch in
# ecdsa_p384.cyr is plain `var`/`alloc` (never `secret var`), so a
# whole-array wipe would clobber a concurrent worker's live lane. This
# scrubs ONLY the calling thread's lane (`cbank()`), preserving per-call
# secret zeroization on the sign path. Called on every return of
# ecdsa_p384_sign. Each buffer is guarded against the not-yet-allocated
# (lazy `_init`) case. Only secret-carrying buffers (nonce k, k·G,
# private scalar d, and their intermediates) are scrubbed; the verify-only
# buffers (_ecv384_*, _ecq384_*, _onc384_*, _p384_inv_*, _p384_ninv_*,
# _p384_R, _p384_sol_t) hold public data and are left alone (banked for
# race-freedom, no wipe needed).
fn _p384_scrub_secret_lanes(): i64 {
    var bk = cbank();
    # Montgomery-ladder point set (k·G with secret k) — 144 B each.
    if (_ptm384_r0  != 0) { memset(_ptm384_r0  + bk * 144, 0, 144); }
    if (_ptm384_r1  != 0) { memset(_ptm384_r1  + bk * 144, 0, 144); }
    if (_ptm384_sum != 0) { memset(_ptm384_sum + bk * 144, 0, 144); }
    if (_ptm384_dbl != 0) { memset(_ptm384_dbl + bk * 144, 0, 144); }
    # pt384_double temps — 9 × 48 B.
    if (_ptd384_delta != 0) { memset(_ptd384_delta + bk * 48, 0, 48); }
    if (_ptd384_gamma != 0) { memset(_ptd384_gamma + bk * 48, 0, 48); }
    if (_ptd384_beta  != 0) { memset(_ptd384_beta  + bk * 48, 0, 48); }
    if (_ptd384_alpha != 0) { memset(_ptd384_alpha + bk * 48, 0, 48); }
    if (_ptd384_t1    != 0) { memset(_ptd384_t1    + bk * 48, 0, 48); }
    if (_ptd384_t2    != 0) { memset(_ptd384_t2    + bk * 48, 0, 48); }
    if (_ptd384_x3    != 0) { memset(_ptd384_x3    + bk * 48, 0, 48); }
    if (_ptd384_y3    != 0) { memset(_ptd384_y3    + bk * 48, 0, 48); }
    if (_ptd384_z3    != 0) { memset(_ptd384_z3    + bk * 48, 0, 48); }
    # pt384_add temps — 16 × 48 B.
    if (_pta384_z1z1 != 0) { memset(_pta384_z1z1 + bk * 48, 0, 48); }
    if (_pta384_z2z2 != 0) { memset(_pta384_z2z2 + bk * 48, 0, 48); }
    if (_pta384_u1   != 0) { memset(_pta384_u1   + bk * 48, 0, 48); }
    if (_pta384_u2   != 0) { memset(_pta384_u2   + bk * 48, 0, 48); }
    if (_pta384_s1   != 0) { memset(_pta384_s1   + bk * 48, 0, 48); }
    if (_pta384_s2   != 0) { memset(_pta384_s2   + bk * 48, 0, 48); }
    if (_pta384_h    != 0) { memset(_pta384_h    + bk * 48, 0, 48); }
    if (_pta384_i    != 0) { memset(_pta384_i    + bk * 48, 0, 48); }
    if (_pta384_j    != 0) { memset(_pta384_j    + bk * 48, 0, 48); }
    if (_pta384_r    != 0) { memset(_pta384_r    + bk * 48, 0, 48); }
    if (_pta384_v    != 0) { memset(_pta384_v    + bk * 48, 0, 48); }
    if (_pta384_t1   != 0) { memset(_pta384_t1   + bk * 48, 0, 48); }
    if (_pta384_t2   != 0) { memset(_pta384_t2   + bk * 48, 0, 48); }
    if (_pta384_x3   != 0) { memset(_pta384_x3   + bk * 48, 0, 48); }
    if (_pta384_y3   != 0) { memset(_pta384_y3   + bk * 48, 0, 48); }
    if (_pta384_z3   != 0) { memset(_pta384_z3   + bk * 48, 0, 48); }
    # pt384_to_affine z-inverse temps — 3 × 48 B.
    if (_pt384_aff_zinv  != 0) { memset(_pt384_aff_zinv  + bk * 48, 0, 48); }
    if (_pt384_aff_zinv2 != 0) { memset(_pt384_aff_zinv2 + bk * 48, 0, 48); }
    if (_pt384_aff_zinv3 != 0) { memset(_pt384_aff_zinv3 + bk * 48, 0, 48); }
    # scalar-inverse working regs (k^-1 / s^-1) — 3 × 48 B.
    if (_p384_ninv_tmp  != 0) { memset(_p384_ninv_tmp  + bk * 48, 0, 48); }
    if (_p384_ninv_res  != 0) { memset(_p384_ninv_res  + bk * 48, 0, 48); }
    if (_p384_ninv_base != 0) { memset(_p384_ninv_base + bk * 48, 0, 48); }
    # mod-n product / reduce scratch (carries r·d, k^-1·hpd) — 96 + 48 B.
    if (_p384_n_prod != 0) { memset(_p384_n_prod + bk * 96, 0, 96); }
    if (_p384_n_R    != 0) { memset(_p384_n_R    + bk * 48, 0, 48); }
    # field product / temps — 96 + 48 + 48 B.
    if (_p384_prod != 0) { memset(_p384_prod + bk * 96, 0, 96); }
    if (_p384_tmp1 != 0) { memset(_p384_tmp1 + bk * 48, 0, 48); }
    if (_p384_tmp2 != 0) { memset(_p384_tmp2 + bk * 48, 0, 48); }
    # _p384_mul64 lo/hi product slot (intermediate secret products) — 16 B.
    if (_p384_m64 != 0) { memset(_p384_m64 + bk * 16, 0, 16); }
    # per-sign k·G output point (ecdsa_sign.cyr) — 144 B.
    if (_ecs384_R != 0) { memset(_ecs384_R + bk * 144, 0, 144); }
    return 0;
}

# ================================================================
# ecdsa_p256_sign — raw r||s (64 bytes, big-endian)
# ================================================================
# d_be: 32-byte big-endian private scalar in [1, n-1].
# Hashes msg with SHA-256 internally (matches ecdsa_p256_verify).
# Returns 0 on success, -1 on failure (degenerate r/s or no nonce).
fn ecdsa_p256_sign(d_be, msg, msg_len, sig_out): i64 {
    _ecs256_init();
    var bk = cbank();
    var _ecs256_Rb = _ecs256_R + bk * 96;

    # One secret scratch block; carve 13 × 32-byte slots by offset. This
    # `var sc[N]` is a function-scope STATIC global (quirk #1), shared
    # across concurrent signers, so it is banked across `cbank()` lanes
    # (the concurrent-signers race in ecdsa_concurrent.tcyr). It carries
    # key-derived / nonce material, so it is plain `var` + a per-lane wipe
    # before every return (quirk #9 / ADR 0004 — NEVER `secret var`, whose
    # whole-array wipe would clobber a sibling worker's live lane). Slots
    # are offset from the calling worker's lane base `scb`.
    var sc[26624];            # 416 * SIGIL_CRYPTO_BANKS
    var scb    = &sc + bk * 416;
    var digest = scb + 0;
    var e      = scb + 32;
    var h1oct  = scb + 64;
    var k      = scb + 96;
    var kint   = scb + 128;
    var kinv   = scb + 160;
    var dint   = scb + 192;
    var rint   = scb + 224;
    var sint   = scb + 256;
    var rd     = scb + 288;
    var hpd    = scb + 320;
    var Rx     = scb + 352;
    var Ry     = scb + 384;

    # e = SHA-256(msg) as BE int, reduced mod n.
    sha256(msg, msg_len, digest);
    u256_load_be(e, digest);
    if (u256_cmp(e, _p256_n) >= 0) { u256_sub(e, e, _p256_n); }
    # bits2octets(H(m)) = int2octets(e mod n)
    u256_store_be(h1oct, e);

    # k = RFC 6979 deterministic nonce.
    if (_rfc6979_k_p256(d_be, h1oct, k) != 0) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }
    u256_load_be(kint, k);

    # R = k·G ; r = R.x mod n.
    pt_scalarmul(_ecs256_Rb, kint, _ecs256_G);
    if (pt_is_infinity(_ecs256_Rb) == 1) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }
    pt_to_affine(Rx, Ry, _ecs256_Rb);
    fn_p256_reduce256(rint, Rx);
    if (u256_is_zero(rint) == 1) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }

    # s = k^(-1) · (e + r·d) mod n.
    u256_load_be(dint, d_be);
    fn_p256_mul(rd, rint, dint);
    _ecs_addmod_n_p256(hpd, e, rd);
    fn_p256_inv(kinv, kint);
    fn_p256_mul(sint, kinv, hpd);
    if (u256_is_zero(sint) == 1) { memset(scb, 0, 416); _p256_scrub_secret_lanes(); return 0 - 1; }

    u256_store_be(sig_out, rint);
    u256_store_be(sig_out + 32, sint);
    memset(scb, 0, 416);
    _p256_scrub_secret_lanes();
    return 0;
}

# ================================================================
# ecdsa_p256_warm — main-thread prewarm (ADR 0007)
# ================================================================
# The per-call P-256 scratch is lane-banked (3.9.7) for race-freedom, but
# the lazy `_init` allocations themselves use the NON-thread-safe bump
# allocator (quirk #7), so the FIRST touch of each must happen on a single
# thread. A server that fans ECDSA work out to worker threads MUST call
# this once on the MAIN thread at startup, before spawning workers — the
# same prewarm contract as `crypto_tls_main_init`. One sign + one verify
# exercises every sign- AND verify-path lazy alloc / table build (the
# verify-only inits `_ecv_init`/`_ecq_init` are not reached by signing, so
# both paths must run). Returns 0.
fn ecdsa_p256_warm(): i64 {
    var d[32]; memset(&d, 0, 32); store8(&d + 31, 7);   # any scalar in [1, n-1]
    var sig[64];
    ecdsa_p256_sign(&d, "warm", 4, &sig);               # sign-path inits
    var pk[64];
    u256_store_be(&pk, _p256_gx);
    u256_store_be(&pk + 32, _p256_gy);                  # pk = G (a valid point)
    ecdsa_p256_verify(&pk, "warm", 4, &sig);            # verify-path inits (result ignored)
    return 0;
}

# ================================================================
# ecdsa_p384_sign — raw r||s (96 bytes, big-endian)
# ================================================================
fn ecdsa_p384_sign(d_be, msg, msg_len, sig_out): i64 {
    _ecs384_init();
    var bk = cbank();
    var _ecs384_Rb = _ecs384_R + bk * 144;

    # One secret scratch block; carve 13 × 48-byte slots by offset. This
    # `var sc[N]` is a function-scope STATIC global (quirk #1), shared
    # across concurrent signers, so it is banked across `cbank()` lanes
    # (the concurrent-signers race in ecdsa_concurrent.tcyr). It carries
    # key-derived / nonce material, so it is plain `var` + a per-lane wipe
    # before every return (quirk #9 / ADR 0004 — NEVER `secret var`, whose
    # whole-array wipe would clobber a sibling worker's live lane). Slots
    # are offset from the calling worker's lane base `scb`.
    var sc[39936];            # 624 * SIGIL_CRYPTO_BANKS
    var scb    = &sc + bk * 624;
    var digest = scb + 0;
    var e      = scb + 48;
    var h1oct  = scb + 96;
    var k      = scb + 144;
    var kint   = scb + 192;
    var kinv   = scb + 240;
    var dint   = scb + 288;
    var rint   = scb + 336;
    var sint   = scb + 384;
    var rd     = scb + 432;
    var hpd    = scb + 480;
    var Rx     = scb + 528;
    var Ry     = scb + 576;

    sha384(msg, msg_len, digest);
    u384_load_be(e, digest);
    if (u384_cmp(e, _p384_n) >= 0) { u384_sub(e, e, _p384_n); }
    u384_store_be(h1oct, e);

    if (_rfc6979_k_p384(d_be, h1oct, k) != 0) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }
    u384_load_be(kint, k);

    pt384_scalarmul(_ecs384_Rb, kint, _ecs384_G);
    if (pt384_is_infinity(_ecs384_Rb) == 1) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }
    pt384_to_affine(Rx, Ry, _ecs384_Rb);
    fn_p384_reduce384(rint, Rx);
    if (u384_is_zero(rint) == 1) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }

    u384_load_be(dint, d_be);
    fn_p384_mul(rd, rint, dint);
    _ecs_addmod_n_p384(hpd, e, rd);
    fn_p384_inv(kinv, kint);
    fn_p384_mul(sint, kinv, hpd);
    if (u384_is_zero(sint) == 1) { memset(scb, 0, 624); _p384_scrub_secret_lanes(); return 0 - 1; }

    u384_store_be(sig_out, rint);
    u384_store_be(sig_out + 48, sint);
    memset(scb, 0, 624);
    _p384_scrub_secret_lanes();
    return 0;
}

# ================================================================
# ecdsa_p384_warm — main-thread prewarm (ADR 0007)
# ================================================================
# P-384 mirror of ecdsa_p256_warm. The per-call P-384 scratch is lane-
# banked for race-freedom, but the lazy `_init` allocations themselves use
# the NON-thread-safe bump allocator (quirk #7), so the FIRST touch of each
# must happen on a single thread. A server that fans P-384 ECDSA work out to
# worker threads MUST call this once on the MAIN thread at startup, before
# spawning workers. One sign + one verify exercises every sign- AND
# verify-path lazy alloc / table build (the verify-only inits _ecv384_init /
# _ecq384_init / _onc384_init are not reached by signing, so both paths must
# run). Returns 0.
fn ecdsa_p384_warm(): i64 {
    var d[48]; memset(&d, 0, 48); store8(&d + 47, 7);   # any scalar in [1, n-1]
    var sig[96];
    ecdsa_p384_sign(&d, "warm", 4, &sig);               # sign-path inits
    var pk[96];
    u384_store_be(&pk, _p384_gx);
    u384_store_be(&pk + 48, _p384_gy);                  # pk = G (a valid point)
    ecdsa_p384_verify(&pk, "warm", 4, &sig);            # verify-path inits (result ignored)
    return 0;
}

# ================================================================
# DER encoding — SEQUENCE { INTEGER r, INTEGER s }
# ================================================================
# Emit one minimal DER INTEGER from a `len`-byte big-endian value:
# strip leading zero bytes (keep at least one), prepend 0x00 when the
# top bit of the leading byte is set. Returns bytes written.
fn _ecs_der_emit_int(out, val, len): i64 {
    var start = 0;
    var done = 0;
    while (done == 0) {
        if (start >= len - 1) { done = 1; }
        else {
            if ((load8(val + start) & 0xFF) != 0) { done = 1; }
            else { start = start + 1; }
        }
    }
    var vlen = len - start;
    var pad = 0;
    if ((load8(val + start) & 0xFF) >= 0x80) { pad = 1; }
    var p = 0;
    store8(out + p, 0x02); p = p + 1;
    store8(out + p, (vlen + pad) & 0xFF); p = p + 1;
    if (pad == 1) { store8(out + p, 0x00); p = p + 1; }
    var i = 0;
    while (i < vlen) {
        store8(out + p, load8(val + start + i) & 0xFF);
        p = p + 1;
        i = i + 1;
    }
    return p;
}

# Wrap a raw r||s signature (each `comp_len` BE bytes) as DER. Returns
# the DER byte length, or -1 if it would exceed `out_max`. For P-256
# /P-384 the total content is < 128 bytes, so the SEQUENCE length is
# always single-byte.
fn _ecs_der_from_raw(sig, comp_len, out, out_max): i64 {
    var body[110];
    var bp = 0;
    bp = bp + _ecs_der_emit_int(&body + bp, sig, comp_len);
    bp = bp + _ecs_der_emit_int(&body + bp, sig + comp_len, comp_len);
    var total = 2 + bp;
    if (total > out_max) { return 0 - 1; }
    store8(out + 0, 0x30);
    store8(out + 1, bp & 0xFF);
    memcpy(out + 2, &body, bp);
    return total;
}

# ecdsa_p256_sign_der — DER-encoded signature (TLS 1.3 CertificateVerify
# form, RFC 8446 §4.2.3 ecdsa_secp256r1_sha256). Returns the DER byte
# length, or -1 on failure / insufficient `out_max`.
fn ecdsa_p256_sign_der(d_be, msg, msg_len, out, out_max): i64 {
    # Banked (3.9.7): the raw r||s scratch was `secret var sig[64]`, a
    # function-scope STATIC (quirk #1) — `secret var` arrays are NOT
    # per-call (the v6.2.25 "arena fix" only stopped a bump-heap leak),
    # so concurrent CertificateVerify signers raced it. Plain banked `var`
    # + per-lane wipe (quirk #9); r||s is public, so the wipe is hygiene.
    var bk = cbank();
    var sig[4096];   var sigb = &sig + bk * 64;   # 64 * SIGIL_CRYPTO_BANKS
    if (ecdsa_p256_sign(d_be, msg, msg_len, sigb) != 0) { memset(sigb, 0, 64); return 0 - 1; }
    var rc = _ecs_der_from_raw(sigb, 32, out, out_max);
    memset(sigb, 0, 64);
    return rc;
}

# ecdsa_p384_sign_der — DER-encoded P-384 signature
# (ecdsa_secp384r1_sha384). Returns the DER byte length, or -1.
fn ecdsa_p384_sign_der(d_be, msg, msg_len, out, out_max): i64 {
    # Banked (3.9.7) — see ecdsa_p256_sign_der; was `secret var sig[96]`.
    var bk = cbank();
    var sig[6144];   var sigb = &sig + bk * 96;   # 96 * SIGIL_CRYPTO_BANKS
    if (ecdsa_p384_sign(d_be, msg, msg_len, sigb) != 0) { memset(sigb, 0, 96); return 0 - 1; }
    var rc = _ecs_der_from_raw(sigb, 48, out, out_max);
    memset(sigb, 0, 96);
    return rc;
}
