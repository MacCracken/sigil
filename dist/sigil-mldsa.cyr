# types.cyr — sigil type system
# Enums, structs, constructors, accessors for the trust verification module.

# ================================================================
# SignatureAlgorithm
# ================================================================

enum SignatureAlgorithm {
    SIG_ALG_ED25519 = 0;
    SIG_ALG_ML_DSA_65 = 1;
    SIG_ALG_HYBRID = 2;
}

# Returns a static display name C-string for a SignatureAlgorithm enum
# value ("Ed25519", "ML-DSA-65", "Hybrid(...)", or "unknown").
fn sig_alg_name(alg): i64 {
    if (alg == SIG_ALG_ED25519) { return "Ed25519"; }
    if (alg == SIG_ALG_ML_DSA_65) { return "ML-DSA-65"; }
    if (alg == SIG_ALG_HYBRID) { return "Hybrid(Ed25519+ML-DSA-65)"; }
    return "unknown";
}

# ================================================================
# HashAlgorithm
# ================================================================

enum HashAlgorithm {
    HASH_ALG_SHA256 = 0;
    HASH_ALG_SHA512 = 1;
}

# Returns a static display name C-string for a HashAlgorithm enum value
# ("SHA-256", "SHA-512", or "unknown").
fn hash_alg_name(alg): i64 {
    if (alg == HASH_ALG_SHA256) { return "SHA-256"; }
    if (alg == HASH_ALG_SHA512) { return "SHA-512"; }
    return "unknown";
}

# ================================================================
# TrustLevel
# ================================================================
# Ordered from highest trust to lowest conceptually.
# Rank: SystemCore(4) > Verified(3) > Unverified(1) > Revoked(0)
#
# 3.0 removed TRUST_COMMUNITY (value 2) — unused across all
# AGNOS consumers (post-3.0-branch audit). The numeric slot at
# value 2 is intentionally left unassigned rather than
# renumbered so that any persisted state carrying `level: 3`
# (Unverified) or `level: 4` (Revoked) decodes identically
# pre- and post-3.0. Old `level: 2` entries decode as
# "unknown" / rank 0 — safe degraded default for a deprecated
# level.

enum TrustLevel {
    TRUST_SYSTEM_CORE = 0;
    TRUST_VERIFIED = 1;
    TRUST_UNVERIFIED = 3;
    TRUST_REVOKED = 4;
}

# Maps a TrustLevel enum value to its comparable integer rank
# (SystemCore=4 > Verified=3 > Unverified=1 > Revoked=0).
fn trust_level_rank(level): i64 {
    if (level == TRUST_SYSTEM_CORE) { return 4; }
    if (level == TRUST_VERIFIED) { return 3; }
    if (level == TRUST_UNVERIFIED) { return 1; }
    if (level == TRUST_REVOKED) { return 0; }
    return 0;
}

# Returns 1 if trust level `a` ranks at least as high as `b`, else 0.
fn trust_level_ge(a, b): i64 {
    if (trust_level_rank(a) >= trust_level_rank(b)) { return 1; }
    return 0;
}

# Returns a static display name C-string for a TrustLevel enum value
# ("SystemCore", "Verified", "Unverified", "Revoked", or "unknown").
fn trust_level_name(level): i64 {
    if (level == TRUST_SYSTEM_CORE) { return "SystemCore"; }
    if (level == TRUST_VERIFIED) { return "Verified"; }
    if (level == TRUST_UNVERIFIED) { return "Unverified"; }
    if (level == TRUST_REVOKED) { return "Revoked"; }
    return "unknown";
}

# ================================================================
# TrustEnforcement
# ================================================================

enum TrustEnforcement {
    ENFORCE_STRICT = 0;
    ENFORCE_PERMISSIVE = 1;
    ENFORCE_AUDIT_ONLY = 2;
}

# Returns a static display name C-string for a TrustEnforcement enum
# value ("Strict", "Permissive", "AuditOnly", or "unknown").
fn enforcement_name(mode): i64 {
    if (mode == ENFORCE_STRICT) { return "Strict"; }
    if (mode == ENFORCE_PERMISSIVE) { return "Permissive"; }
    if (mode == ENFORCE_AUDIT_ONLY) { return "AuditOnly"; }
    return "unknown";
}

