# ================================================================
# TrustPolicy (72 bytes)
# ================================================================
# Layout:
#   +0   enforcement           (i64)
#   +8   minimum_trust_level   (i64)
#   +16  allow_unsigned        (i64, 0=false 1=true)
#   +24  verify_on_boot        (i64)
#   +32  verify_on_install     (i64)
#   +40  verify_on_execute     (i64)
#   +48  revocation_check      (i64)
#   +56  hash_algorithm        (i64)
#   +64  required_sig_alg      (i64, SignatureAlgorithm enum)
#
# required_sig_alg added in 2.10.0 alongside ML-DSA-65 landing.
# Default is SIG_ALG_ED25519 so legacy policies behave exactly as
# before. Consumers opting in to PQC set it to SIG_ALG_HYBRID
# (requires both Ed25519 and ML-DSA-65 signatures to verify) or
# SIG_ALG_ML_DSA_65 (PQC-only, future state).

# Allocates a 72-byte TrustPolicy with secure defaults: strict
# enforcement, minimum trust Verified, unsigned artifacts rejected,
# verify-on-boot/install/execute and revocation checks all on, SHA-256,
# and Ed25519 as the required signature algorithm. Returns the pointer.
fn trust_policy_new(): i64 {
    var p = fl_alloc(72);
    store64(p, ENFORCE_STRICT);
    store64(p + 8, TRUST_VERIFIED);
    store64(p + 16, 0);
    store64(p + 24, 1);
    store64(p + 32, 1);
    store64(p + 40, 1);
    store64(p + 48, 1);
    store64(p + 56, HASH_ALG_SHA256);
    store64(p + 64, SIG_ALG_ED25519);
    return p;
}

# Returns the enforcement mode (TrustEnforcement) of policy `p`.
fn policy_enforcement(p): i64 { return load64(p); }
# Returns the minimum acceptable trust level (TrustLevel) of policy `p`.
fn policy_min_trust(p): i64 { return load64(p + 8); }
# Returns 1 if policy `p` permits unsigned artifacts, else 0.
fn policy_allow_unsigned(p): i64 { return load64(p + 16); }
# Returns 1 if policy `p` requires verification at boot, else 0.
fn policy_verify_on_boot(p): i64 { return load64(p + 24); }
# Returns 1 if policy `p` requires verification at install, else 0.
fn policy_verify_on_install(p): i64 { return load64(p + 32); }
# Returns 1 if policy `p` requires verification at execute, else 0.
fn policy_verify_on_execute(p): i64 { return load64(p + 40); }
# Returns 1 if policy `p` enables revocation-list checking, else 0.
fn policy_revocation_check(p): i64 { return load64(p + 48); }
# Returns the hash algorithm (HashAlgorithm) configured on policy `p`.
fn policy_hash_alg(p): i64 { return load64(p + 56); }
# Returns the required signature algorithm (SignatureAlgorithm) of `p`.
fn policy_required_sig_alg(p): i64 { return load64(p + 64); }

# Sets the enforcement mode of policy `p` to `v`; returns `p`.
fn policy_set_enforcement(p, v): i64 { store64(p, v); return p; }
# Sets the minimum acceptable trust level of policy `p` to `v`; returns `p`.
fn policy_set_min_trust(p, v): i64 { store64(p + 8, v); return p; }
# Sets the allow-unsigned flag of policy `p` to `v`; returns `p`.
fn policy_set_allow_unsigned(p, v): i64 { store64(p + 16, v); return p; }
# Sets the verify-on-boot flag of policy `p` to `v`; returns `p`.
fn policy_set_verify_on_boot(p, v): i64 { store64(p + 24, v); return p; }
# Sets the verify-on-install flag of policy `p` to `v`; returns `p`.
fn policy_set_verify_on_install(p, v): i64 { store64(p + 32, v); return p; }
# Sets the verify-on-execute flag of policy `p` to `v`; returns `p`.
fn policy_set_verify_on_execute(p, v): i64 { store64(p + 40, v); return p; }
# Sets the revocation-check flag of policy `p` to `v`; returns `p`.
fn policy_set_revocation_check(p, v): i64 { store64(p + 48, v); return p; }
# Sets the hash algorithm of policy `p` to `v`; returns `p`.
fn policy_set_hash_alg(p, v): i64 { store64(p + 56, v); return p; }
# Sets the required signature algorithm of policy `p` to `v`; returns `p`.
fn policy_set_required_sig_alg(p, v): i64 { store64(p + 64, v); return p; }

